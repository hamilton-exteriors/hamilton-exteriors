---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { heroBg } from '../lib/images';
import { getGoogleReviews, getDisplayReviews } from '../lib/google-reviews';
import { CURATED_REVIEWS } from '../data/curated-reviews';
import { OpenPanelComponent } from '@openpanel/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  includeMapbox?: boolean;
  noindex?: boolean;
  geoPlacename?: string;
  geoPosition?: string;
  preloadHero?: boolean;
  heroImage?: ImageMetadata;
  /** When true, emits the full Organization schema (ratings, reviews, catalog).
   *  When false, emits a lean @id-only reference.
   *  Defaults to true only for homepage and top-level service pages. */
  fullOrgSchema?: boolean;
  /** Override the auto-derived canonical URL (e.g. for blog tag routes) */
  canonical?: string;
}

// IPs to exclude from analytics (dev + owner — avoid polluting OpenPanel/GTM data)
const EXCLUDED_IPS = new Set([
  '172.59.128.225',  // dev machine
]);
const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim()
  || Astro.request.headers.get('cf-connecting-ip')
  || '';
const isExcludedIp = EXCLUDED_IPS.has(clientIp);

const metaPixelId = import.meta.env.META_PIXEL_ID || '';

const heroSrc = Astro.props.heroImage || heroBg;
// Only process hero preload images when actually needed — avoids wasted SSR work
const heroMobilePreload = Astro.props.preloadHero ? await getImage({ src: heroSrc, width: 768, height: 960, format: 'webp', quality: 82 }) : null;
const heroDesktopPreload = Astro.props.preloadHero ? await getImage({ src: heroSrc, width: 1440, height: 810, format: 'webp', quality: 82 }) : null;

// Auto-generate page-specific OG image from heroImage when no explicit image prop is set.
// Produces a 1200x630 JPEG (maximum social-media compatibility) at build time.
const heroOgImage = !Astro.props.image && Astro.props.heroImage
  ? await getImage({ src: heroSrc, width: 1200, height: 630, format: 'jpg', quality: 80 })
  : null;

const DEFAULT_DESCRIPTION = 'Bay Area roofing, siding, windows, ADUs & custom homes. Architect-led, CSLB #1082377. 50-year warranty. Free estimate: (650) 977-3351.';
const DEFAULT_GEO_PLACENAME = 'Bay Area, California';

// Pages that should carry the full Organization schema (ratings, reviews, catalog)
const FULL_ORG_PATHS = new Set(['/', '/roofing', '/siding', '/windows', '/adu', '/custom-homes', '/additions', '/service-areas']);

const {
  title = "Bay Area Custom Home & Exteriors Contractor | Hamilton Exteriors",
  description: rawDescription,
  image,
  type = 'website',
  jsonLd,
  includeMapbox = false,
  noindex = false,
  geoPlacename = DEFAULT_GEO_PLACENAME,
  geoPosition,
  preloadHero = false,
  fullOrgSchema = FULL_ORG_PATHS.has(Astro.url.pathname),
} = Astro.props;

// Fetch live Google reviews for schema markup (cached 1hr, falls back to hardcoded)
const _reviewData = fullOrgSchema ? await getGoogleReviews() : null;
const _displayReviews = _reviewData ? getDisplayReviews(_reviewData, 5) : null;

// When no description is provided, generate a city-specific one for location pages
// (geoPlacename is passed as "CityName, CA" or "County Name, CA" by city/service routes).
// Falls back to the generic site-wide description for non-location pages.
function buildDescription(raw: string | undefined, geo: string): string {
  const trimmed = raw?.trim();
  if (trimmed) return trimmed;

  if (geo !== DEFAULT_GEO_PLACENAME) {
    // Normalise: strip trailing ", California" to keep it at ", CA"
    const place = geo.replace(/, California$/, ', CA');
    return `Hamilton Exteriors serves ${place} — roofing, siding, windows & more. 50-year warranty. CSLB #1082377. Free estimate: (650) 977-3351.`;
  }

  return DEFAULT_DESCRIPTION;
}

const description = buildDescription(rawDescription, geoPlacename);

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
// Canonical must match sitemap URLs — trailingSlash: 'never' means no trailing slashes
const canonicalUrl = Astro.props.canonical || (siteUrl + Astro.url.pathname).replace(/\/$/, '') || siteUrl;

// Resolve OG image: explicit prop > page-specific hero > stable default
// Homepage uses /og-default.jpg (hash-stable) instead of a build-hashed hero artifact
const ogImageUrl = image || (heroOgImage && Astro.props.heroImage ? siteUrl + heroOgImage.src : siteUrl + '/og-default.jpg');
const ogImageType = image ? 'image/jpeg' : (heroOgImage ? 'image/jpeg' : 'image/jpeg');

// ── Build structured data objects in frontmatter so Astro evaluates all expressions ──

const fullOrgSchemaObj = fullOrgSchema ? {
  "@type": ["GeneralContractor", "RoofingContractor"],
  "@id": "https://hamilton-exteriors.com/#business",
  "name": "Hamilton Exteriors",
  "url": "https://hamilton-exteriors.com",
  "telephone": "+16509773351",
  "email": "support@hamilton-exteriors.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "21634 Redwood Rd Unit F",
    "addressLocality": "Castro Valley",
    "addressRegion": "CA",
    "postalCode": "94546",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 37.69427,
    "longitude": -122.07887
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "14:00" }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+16509773351",
    "contactType": "customer service",
    "areaServed": "CA",
    "availableLanguage": "English"
  },
  "hasMap": "https://maps.google.com/?cid=3578771346418026097",
  "sameAs": [
    "https://www.facebook.com/hamiltonexteriors",
    "https://www.instagram.com/hamiltonexteriors",
    "https://www.linkedin.com/company/hamilton-exteriors/",
    "https://www.yelp.com/biz/hamilton-exteriors-castro-valley",
    "https://www.youtube.com/@HamiltonExteriors",
    "https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377",
    "https://www.wikidata.org/wiki/Q139044457",
    "https://www.homeadvisor.com/rated.abrqualityresources.150372023.html",
    "https://www.angi.com/companylist/us/ca/castro-valley/abr-quality-resources-reviews-10768498.htm",
    "https://www.bbb.org/us/ca/castro-valley/profile/general-contractor/hamilton-exteriors-inc-1116-977094"
  ],
  "alternateName": "ABR Quality Resources Inc",
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Alameda County", "sameAs": "https://en.wikipedia.org/wiki/Alameda_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
    { "@type": "AdministrativeArea", "name": "Contra Costa County", "sameAs": "https://en.wikipedia.org/wiki/Contra_Costa_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
    { "@type": "AdministrativeArea", "name": "Marin County", "sameAs": "https://en.wikipedia.org/wiki/Marin_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
    { "@type": "AdministrativeArea", "name": "Napa County", "sameAs": "https://en.wikipedia.org/wiki/Napa_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
    { "@type": "AdministrativeArea", "name": "Santa Clara County", "sameAs": "https://en.wikipedia.org/wiki/Santa_Clara_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
    { "@type": "AdministrativeArea", "name": "San Mateo County", "sameAs": "https://en.wikipedia.org/wiki/San_Mateo_County,_California", "containedInPlace": { "@type": "State", "name": "California" } }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": _displayReviews?.rating ?? 4.8,
    "reviewCount": (_displayReviews?.reviewCount ?? 26) + CURATED_REVIEWS.length,
    "ratingCount": (_displayReviews?.reviewCount ?? 26) + CURATED_REVIEWS.length,
    "bestRating": 5,
    "worstRating": 1
  },
  "priceRange": "$$",
  "image": {
    "@type": "ImageObject",
    "url": "https://hamilton-exteriors.com/og-default.jpg",
    "width": 1200,
    "height": 630,
    "caption": "Hamilton Exteriors — Bay Area Custom Home & Exteriors Contractor"
  },
  "logo": {
    "@type": "ImageObject",
    "url": "https://hamilton-exteriors.com/logo-schema.png",
    "width": 271,
    "height": 112
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Hamilton Exteriors Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/roofing#service", "name": "Roofing", "url": "https://hamilton-exteriors.com/roofing" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/siding#service", "name": "Siding", "url": "https://hamilton-exteriors.com/siding" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/windows#service", "name": "Windows", "url": "https://hamilton-exteriors.com/windows" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/adu#service", "name": "ADUs", "url": "https://hamilton-exteriors.com/adu" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/custom-homes#service", "name": "Custom Homes", "url": "https://hamilton-exteriors.com/custom-homes" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/additions#service", "name": "Additions", "url": "https://hamilton-exteriors.com/additions" } }
    ]
  },
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "CSLB Contractor License #1082377", "recognizedBy": { "@type": "Organization", "name": "Contractors State License Board", "url": "https://www.cslb.ca.gov" } },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "Tesla Powerwall Certified Installer" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "GAF Master Elite Contractor" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "Owens Corning Preferred Contractor" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "James Hardie Elite Preferred Installer" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "CertainTeed ShingleMaster" }
  ],
  "knowsAbout": [
    { "@type": "Thing", "name": "Roof replacement", "sameAs": "https://en.wikipedia.org/wiki/Domestic_roof_construction" },
    { "@type": "Thing", "name": "Asphalt shingle roofing", "sameAs": "https://en.wikipedia.org/wiki/Asphalt_shingle" },
    { "@type": "Thing", "name": "Metal roofing", "sameAs": "https://en.wikipedia.org/wiki/Metal_roof" },
    { "@type": "Thing", "name": "Fiber cement siding", "sameAs": "https://en.wikipedia.org/wiki/Fibre_cement" },
    { "@type": "Thing", "name": "James Hardie fiber cement siding", "sameAs": "https://en.wikipedia.org/wiki/James_Hardie_Industries" },
    { "@type": "Thing", "name": "Energy-efficient windows", "sameAs": "https://en.wikipedia.org/wiki/Energy-efficient_window" },
    { "@type": "Thing", "name": "Accessory dwelling unit", "sameAs": "https://en.wikipedia.org/wiki/Accessory_dwelling_unit" },
    { "@type": "Thing", "name": "Custom home building", "sameAs": "https://en.wikipedia.org/wiki/Custom_home" },
    { "@type": "Thing", "name": "Bay Area building codes" },
    { "@type": "Thing", "name": "California contractor licensing", "sameAs": "https://en.wikipedia.org/wiki/Contractors_State_License_Board" }
  ],
  "founder": {
    "@type": "Person",
    "@id": "https://hamilton-exteriors.com/#founder",
    "name": "Alexander Hamilton Li",
    "jobTitle": "Architect & General Contractor",
    "sameAs": [
      "https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377",
      "https://www.linkedin.com/in/alexanderhamiltonli",
      "https://www.wikidata.org/wiki/Q139044457",
      "https://www.yelp.com/biz/hamilton-exteriors-castro-valley"
    ]
  },
  "paymentAccepted": ["Cash", "Check", "ACH Transfer", "Credit Card"],
  "description": "Bay Area exterior remodeling - roofing, siding, windows, and waterproofing. Licensed, bonded, insured. 50-year warranty. In-house architect and engineering.",
  "review": [
    ...(_displayReviews?.reviews ?? []).map((r: any) => ({
      "@type": "Review",
      "datePublished": new Date(r.time * 1000).toISOString().split('T')[0],
      "author": { "@type": "Person", "name": r.author_name },
      "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": 5, "worstRating": 1 },
      "reviewBody": r.text,
      "publisher": { "@type": "Organization", "name": "Google" },
      "itemReviewed": { "@type": ["GeneralContractor", "RoofingContractor"], "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
    })),
    ...CURATED_REVIEWS.map((r) => ({
      "@type": "Review",
      "datePublished": r.date,
      "author": { "@type": "Person", "name": r.author_name },
      "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": 5, "worstRating": 1 },
      "reviewBody": r.text,
      "publisher": { "@type": "Organization", "name": r.platform === 'yelp' ? 'Yelp' : r.platform === 'angi' ? 'Angi' : r.platform === 'nextdoor' ? 'Nextdoor' : r.platform === 'bbb' ? 'BBB' : r.platform },
      "itemReviewed": { "@type": ["GeneralContractor", "RoofingContractor"], "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
    })),
  ]
} : null;

const leanOrgSchemaObj = !fullOrgSchema ? {
  "@type": ["GeneralContractor", "RoofingContractor"],
  "@id": "https://hamilton-exteriors.com/#business"
} : null;

const webSiteSchemaObj = Astro.url.pathname === '/' ? {
  "@type": "WebSite",
  "@id": "https://hamilton-exteriors.com/#website",
  "url": "https://hamilton-exteriors.com",
  "name": "Hamilton Exteriors",
  "inLanguage": "en-US",
  "publisher": { "@id": "https://hamilton-exteriors.com/#business" },
  "description": "Bay Area roofing, siding, windows, ADUs & custom homes by Hamilton Exteriors.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://hamilton-exteriors.com/blog?search={search_term_string}",
    "query-input": "required name=search_term_string"
  }
} : null;

const webPageSchemaObj = Astro.url.pathname === '/' ? {
  "@type": "WebPage",
  "@id": "https://hamilton-exteriors.com/#webpage",
  "url": "https://hamilton-exteriors.com",
  "name": "Bay Area Custom Home & Exteriors Contractor | Hamilton Exteriors",
  "isPartOf": { "@id": "https://hamilton-exteriors.com/#website" },
  "about": { "@id": "https://hamilton-exteriors.com/#business" },
  "inLanguage": "en-US"
} : null;

// ── Assemble single @graph from all schema objects ──
const graphItems: Record<string, unknown>[] = [];

// Layout-level schemas (org, website, webpage)
if (fullOrgSchemaObj) graphItems.push(fullOrgSchemaObj);
if (leanOrgSchemaObj) graphItems.push(leanOrgSchemaObj);
if (webSiteSchemaObj) graphItems.push(webSiteSchemaObj);
if (webPageSchemaObj) graphItems.push(webPageSchemaObj);

// Page-level schemas passed via jsonLd prop
if (jsonLd) {
  const items = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
  for (const item of items) {
    const { '@context': _ctx, ...rest } = item;
    graphItems.push(rest);
  }
}

const graphJsonLd = graphItems.length > 0 ? {
  "@context": "https://schema.org",
  "@graph": graphItems,
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ── Resource hints — must be first in <head> for maximum effectiveness ── -->
    <!-- OpenPanel Analytics (cookie-free, session replay, funnels, retention) -->
    <link rel="dns-prefetch" href="https://openpanel.dev" />
    <!-- GTM: deferred until interaction, so dns-prefetch is sufficient (preconnect wastes a TCP/TLS slot) -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <!-- Google Tag Manager secondary domain (loads analytics.js etc.) -->
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <!-- Meta Pixel (Facebook) -->
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <!-- BackOffice portfolio widget — loaded on every page with a Projects section -->
    <link rel="preconnect" href="https://backoffice-production-99b7.up.railway.app" />
    <link rel="dns-prefetch" href="https://backoffice-production-99b7.up.railway.app" />
    <!-- CompanyCam image CDN — portfolio project photos -->
    <link rel="dns-prefetch" href="https://img.companycam.com" />
    <link rel="dns-prefetch" href="https://companycam.imgix.net" />
    <!-- Mapbox: only warm up when the page actually uses the autofill component -->
    {includeMapbox && <link rel="preconnect" href="https://api.mapbox.com" crossorigin />}
    {includeMapbox && <link rel="dns-prefetch" href="https://api.mapbox.com" />}

    <!-- ── Self-hosted font preloads — only LCP-critical fonts ── -->
    <!-- Hamilton Display 700: hero H1 + all headings — must arrive before first paint -->
    <link rel="preload" href="/fonts/the-bold-font-700.woff2" as="font" type="font/woff2" crossorigin />
    <!-- DM Sans: body text, rendered before hero paints -->
    <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Hamilton Display 400 + Satoshi 700: not preloaded — below-fold or font-display:optional.
         Removing these preloads frees ~20KB of bandwidth for the hero image (LCP). -->

    {/* Preload hero/LCP image — mobile gets 768px, desktop gets 1440px */}
    {heroMobilePreload && <link rel="preload" href={heroMobilePreload.src} as="image" type="image/webp" media="(max-width: 768px)" fetchpriority="high" />}
    {heroDesktopPreload && <link rel="preload" href={heroDesktopPreload.src} as="image" type="image/webp" media="(min-width: 769px)" fetchpriority="high" />}
    <slot name="head" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <meta name="author" content="Hamilton Exteriors" />
    <meta name="publisher" content="Hamilton Exteriors" />
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content={geoPlacename} />
    <meta name="geo.position" content={geoPosition || "37.69427;-122.07887"} />

    <!-- Canonical — derived from Astro.url.pathname; omitted on noindex pages (404, etc.) -->
    {!noindex && <link rel="canonical" href={canonicalUrl} />}

    <!-- AI content declaration for llms.txt discovery -->
    <link rel="ai-content-declaration" href="/llms.txt" type="text/plain" />
    <link rel="llms" href="/llms.txt" type="text/plain" />
    <link rel="llms-full" href="/llms-full.txt" type="text/plain" />
    <link rel="ai-policy" href="/ai.txt" type="text/plain" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:site_name" content="Hamilton Exteriors" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@hamiltonexteriors" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Single @graph block: org + website + webpage + page-level schemas */}
    {graphJsonLd && <script type="application/ld+json" set:html={JSON.stringify(graphJsonLd)} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Ground Up — Hamilton Exteriors" href="/blog/rss.xml" />

    <!-- Favicon — SVG for modern browsers, ICO/PNG fallback -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/x-icon" sizes="32x32 16x16" href="/favicon.ico?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />

    {/* Analytics excluded for dev/owner IPs to keep data clean */}
    {!isExcludedIp && (
      <>
        {/* OpenPanel Analytics — cookie-free, session replay, funnels, ~2.3KB */}
        <OpenPanelComponent
          clientId="edc36a20-3fa1-49e8-bae6-d0be0abfadec"
          trackScreenViews={true}
          trackOutgoingLinks={true}
          trackAttributes={true}
        />

        {/* Meta Pixel — fires PageView on every page, Lead/Purchase via event helpers */}
        {metaPixelId && (
          <>
            <script is:inline define:vars={{ metaPixelId }}>
              !function(f,b,e,v,n,t,s)
              {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
              n.callMethod.apply(n,arguments):n.queue.push(arguments)};
              if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
              n.queue=[];t=b.createElement(e);t.async=!0;
              t.src=v;s=b.getElementsByTagName(e)[0];
              s.parentNode.insertBefore(t,s)}(window, document,'script',
              'https://connect.facebook.net/en_US/fbevents.js');
              fbq('init', metaPixelId);
              fbq('track', 'PageView');
            </script>
            <noscript><img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`} /></noscript>
          </>
        )}

        {/* Google Tag Manager — deferred until first user interaction to keep LCP/TBT clean */}
        <script is:inline>
          (function(){
            var loaded=false;
            function loadGTM(){
              if(loaded)return;loaded=true;
              (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
              new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
              j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
              'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
              })(window,document,'script','dataLayer','GTM-MTRC8MMK');
            }
            ['scroll','click','touchstart','keydown'].forEach(function(e){
              window.addEventListener(e,loadGTM,{once:true,passive:true});
            });
            setTimeout(loadGTM,5000);
          })();
        </script>
      </>
    )}

    <!-- Mapbox Address Autofill — lazy-loaded on first interaction to avoid 1.5MB initial JS -->
    {includeMapbox && (
      <script is:inline>
        (function(){
          var loaded=false;
          function loadMapbox(){
            if(loaded)return;loaded=true;
            var s=document.createElement('script');s.src='https://api.mapbox.com/search-js/v1.5.0/web.js';s.id='search-js';document.head.appendChild(s);
          }
          var addr=document.getElementById('hero-address');
          if(addr){addr.addEventListener('focus',loadMapbox,{once:true});addr.addEventListener('click',loadMapbox,{once:true});}
          else{document.addEventListener('DOMContentLoaded',function(){
            var a=document.getElementById('hero-address');
            if(a){a.addEventListener('focus',loadMapbox,{once:true});a.addEventListener('click',loadMapbox,{once:true});}
          });}
        })();
      </script>
    )}

  </head>
  <body class="overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-99999 focus:rounded focus:bg-primary focus:px-4 focus:py-2 focus:text-white">Skip to main content</a>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MTRC8MMK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />


    <script>
      // Navbar scroll shadow
      const navbar = document.querySelector('.navbar');
      if (navbar) {
        const onScroll = () => {
          navbar.classList.toggle('scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }


      // Scroll #quote links to center the form on screen
      document.querySelectorAll('a[href="#quote"], a[href="/#quote"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const form = document.getElementById('hero-form');
          if (form) {
            e.preventDefault();
            const rect = form.getBoundingClientRect();
            const formCenter = rect.top + window.scrollY + (rect.height / 2);
            const screenCenter = window.innerHeight / 2;
            window.scrollTo({ top: formCenter - screenCenter, behavior: 'smooth' });
            // Focus first input after scroll
            setTimeout(() => {
              const firstInput = form.querySelector('input:not([type="hidden"])') as HTMLInputElement;
              firstInput?.focus();
            }, 600);
          }
        });
      });
    </script>

    <!-- Global event tracking: phone clicks + CTA clicks -->
    <script>
      // Meta Pixel — ViewContent on service pages, InitiateCheckout on /buy/scan
      if (typeof fbq === 'function') {
        const path = window.location.pathname;
        if (['/roofing', '/siding', '/windows', '/adu', '/custom-homes', '/additions'].some(p => path.startsWith(p))) {
          fbq('track', 'ViewContent', { content_name: path });
        }
        if (path === '/buy/scan') {
          fbq('track', 'InitiateCheckout');
        }
      }

      // ── Persist ad click IDs + UTMs in sessionStorage ──
      // Survives page navigation within the session. Ensures:
      // - fbclid persists beyond Safari ITP's 24h cookie expiry
      // - gclid is captured for Google Ads attribution
      // - All 5 UTMs are available to form handlers even after URL changes
      (function() {
        const params = new URLSearchParams(window.location.search);
        const fbclid = params.get('fbclid');
        if (fbclid) {
          sessionStorage.setItem('he_fbclid', fbclid);
          sessionStorage.setItem('he_fbc', 'fb.1.' + Date.now() + '.' + fbclid);
        }
        const gclid = params.get('gclid');
        if (gclid) sessionStorage.setItem('he_gclid', gclid);
        // Persist UTMs — only overwrite if present (preserves first-touch from landing)
        ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(function(k) {
          const v = params.get(k);
          if (v) sessionStorage.setItem('he_' + k, v);
        });
      })();

      // Track all tel: link clicks
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a[href^="tel:"]') as HTMLAnchorElement;
        if (link) {
          window.op?.('track', 'phone_click', {
            page: window.location.pathname,
            text: link.textContent?.trim() || '',
          });
          window.dataLayer?.push({ event: 'phone_click', page: window.location.pathname });
          // Meta Pixel — Contact event on phone calls
          if (typeof fbq === 'function') {
            fbq('track', 'Contact', { content_name: 'phone_call', content_category: window.location.pathname });
          }
        }
      });

      // Track CTA button clicks (Get Free Quote, Get a Quote, etc.)
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('a[href="#quote"], a[href="/#quote"], a[href="/buy"], a[href="/buy/scan"]') as HTMLAnchorElement;
        if (el) {
          window.op?.('track', 'cta_click', {
            page: window.location.pathname,
            href: el.getAttribute('href') || '',
            text: el.textContent?.trim() || '',
          });
          window.dataLayer?.push({ event: 'cta_click', page: window.location.pathname });
        }
      });

      // Track any element with a data-track attribute (generic catch-all)
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('[data-track]') as HTMLElement;
        if (!el) return;
        // Skip elements already handled by tel: or CTA selectors
        const a = el.closest('a') as HTMLAnchorElement | null;
        if (a?.href?.startsWith('tel:')) return;
        if (a && ['#quote', '/#quote', '/buy', '/buy/scan'].includes(a.getAttribute('href') || '')) return;
        const trackValue = el.getAttribute('data-track')!;
        const page = window.location.pathname;
        const text = el.textContent?.trim() || '';
        window.op?.('track', trackValue, { page, text });
        window.dataLayer?.push({ event: trackValue, page, text });
      });

      // ── Scroll depth tracking (25/50/75/100%) ──
      const scrollMilestones = new Set<number>();
      const scrollPages = ['/', '/roofing', '/siding', '/windows', '/adu', '/custom-homes', '/additions', '/buy'];
      if (scrollPages.some(p => window.location.pathname === p || window.location.pathname.startsWith('/service-areas/'))) {
        window.addEventListener('scroll', () => {
          const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
          [25, 50, 75, 100].forEach(milestone => {
            if (pct >= milestone && !scrollMilestones.has(milestone)) {
              scrollMilestones.add(milestone);
              window.op?.('track', 'scroll_depth', { page: window.location.pathname, depth: milestone });
              window.dataLayer?.push({ event: 'scroll_depth', page: window.location.pathname, depth: milestone });
            }
          });
        }, { passive: true });
      }

      // ── Outbound link tracking ──
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a[href^="http"]') as HTMLAnchorElement;
        if (!link || new URL(link.href).hostname.includes('hamilton-exteriors.com')) return;
        const detail = { url: link.href, text: link.textContent?.trim() || '', page: window.location.pathname };
        window.op?.('track', 'outbound_click', detail);
        window.dataLayer?.push({ event: 'outbound_click', ...detail });
      });

      // ── Blog article read completion ──
      const articleContent = document.getElementById('article-content');
      if (articleContent) {
        let articleRead = false;
        const articleObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !articleRead) {
              articleRead = true;
              window.op?.('track', 'article_read', {
                page: window.location.pathname,
                title: document.title,
              });
              window.dataLayer?.push({ event: 'article_read', page: window.location.pathname });
              articleObserver.disconnect();
            }
          });
        }, { threshold: 0.1 });
        // Observe the last child to detect reaching end of article
        const lastChild = articleContent.lastElementChild;
        if (lastChild) articleObserver.observe(lastChild);
      }

      // ── Service area engagement tracking ──
      if (window.location.pathname.startsWith('/service-areas/')) {
        const serviceSlugs = ['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions'];
        document.addEventListener('click', (e) => {
          const link = (e.target as HTMLElement).closest('a[href]') as HTMLAnchorElement | null;
          if (!link) return;
          const href = link.getAttribute('href') || '';
          const parts = href.replace(/\/$/, '').split('/').filter(Boolean);
          // Only match /service-areas/... links
          if (parts[0] !== 'service-areas' || parts.length < 2) return;
          const page = window.location.pathname;
          const lastSegment = parts[parts.length - 1];

          // Service card click: href ends with a service slug
          if (serviceSlugs.includes(lastSegment)) {
            const cityOrCounty = parts.length >= 3 ? parts[1] : '';
            const props = { service: lastSegment, city_or_county: cityOrCounty, page };
            window.op?.('track', 'service_area_click', props);
            window.dataLayer?.push({ event: 'service_area_click', ...props });
            return;
          }

          // City card click: /service-areas/{county}/{city} (3 segments)
          if (parts.length === 3 && !serviceSlugs.includes(parts[2])) {
            const props = { city: parts[2], page };
            window.op?.('track', 'city_card_click', props);
            window.dataLayer?.push({ event: 'city_card_click', ...props });
          }
        });
      }
    </script>

  </body>
