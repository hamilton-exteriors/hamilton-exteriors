---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown>;
  includeMapbox?: boolean;
}

const {
  title = 'Top Rated Exterior Company in Castro Valley, CA | Hamilton Exteriors',
  description = 'Hamilton Exteriors is top rated Exterior Company in Castro Valley, CA. Our skilled team delivers high-value construction solutions. Call Now!',
  image,
  type = 'website',
  jsonLd,
  includeMapbox = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Preconnect to font origins (before CSS @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={image || '/images/og-image.jpg'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image || '/images/og-image.jpg'} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": "Hamilton Exteriors",
      "url": "https://hamilton-exteriors.com",
      "telephone": "+1-650-977-3351",
      "email": "support@hamilton-exteriors.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "21634 Redwood Rd Unit F",
        "addressLocality": "Castro Valley",
        "addressRegion": "CA",
        "postalCode": "94546",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 37.6941,
        "longitude": -122.0828
      },
      "areaServed": [
        "Castro Valley, CA", "Hayward, CA", "Fremont, CA", "Berkeley, CA",
        "San Ramon, CA", "Walnut Creek, CA", "Concord, CA", "Richmond, CA",
        "San Rafael, CA", "Novato, CA", "Mill Valley, CA"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "50"
      },
      "priceRange": "$$",
      "image": "https://hamilton-exteriors.com/favicon.png",
      "description": "Bay Area exterior remodeling — roofing, siding, windows, and waterproofing. Licensed, bonded, insured. 50-year warranty. 3-5 day installs."
    }
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-MTRC8MMK');
    </script>

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QN4P5K8YWD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QN4P5K8YWD');
    </script>
    {/* Mapbox Address Autofill — only loaded on pages with address form */}
    {includeMapbox && (
      <script id="search-js" defer src="https://api.mapbox.com/search-js/v1.5.0/web.js"></script>
    )}
  </head>
  <body class="overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[99999] focus:bg-[#256346] focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MTRC8MMK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <main id="main-content">
      <slot />
    </main>

    <script>
      // Navbar scroll shadow
      const navbar = document.querySelector('.navbar');
      if (navbar) {
        const onScroll = () => {
          navbar.classList.toggle('scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Scroll #quote links to center the form on screen
      document.querySelectorAll('a[href="#quote"], a[href="/#quote"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const form = document.getElementById('hero-form');
          if (form) {
            e.preventDefault();
            const rect = form.getBoundingClientRect();
            const formCenter = rect.top + window.scrollY + (rect.height / 2);
            const screenCenter = window.innerHeight / 2;
            window.scrollTo({ top: formCenter - screenCenter, behavior: 'smooth' });
            // Focus first input after scroll
            setTimeout(() => {
              const firstInput = form.querySelector('input:not([type="hidden"])') as HTMLInputElement;
              firstInput?.focus();
            }, 600);
          }
        });
      });
    </script>
  </body>
</html>
