---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  includeMapbox?: boolean;
  noindex?: boolean;
}

const DEFAULT_DESCRIPTION = 'Bay Area roofing, siding, windows, ADUs, and custom homes. Licensed, bonded, insured. 50-year warranty. $0 down financing. Free estimate — (650) 977-3351.';

const {
  title = 'Bay Area Roofing, Siding, ADUs & Custom Homes | Hamilton Exteriors',
  description: rawDescription,
  image,
  type = 'website',
  jsonLd,
  includeMapbox = false,
  noindex = false,
} = Astro.props;

// Guard against empty-string descriptions that would blank out the meta tag
const description = rawDescription?.trim() || DEFAULT_DESCRIPTION;

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Self-hosted font preloads — critical fonts only to avoid LCP delay -->
    <link rel="preload" href="/fonts/the-bold-font.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="author" content="Hamilton Exteriors" />
    <meta name="publisher" content="Hamilton Exteriors" />
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content="Castro Valley" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image || `${siteUrl}/og-default.svg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Hamilton Exteriors" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image || `${siteUrl}/og-default.svg`} />

    {jsonLd && !Array.isArray(jsonLd) && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {jsonLd && Array.isArray(jsonLd) && jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Hamilton Exteriors Blog" href="/blog/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": "Hamilton Exteriors",
      "url": "https://hamilton-exteriors.com",
      "telephone": "+1-650-977-3351",
      "email": "support@hamilton-exteriors.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "21634 Redwood Rd Unit F",
        "addressLocality": "Castro Valley",
        "addressRegion": "CA",
        "postalCode": "94546",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 37.6941,
        "longitude": -122.0828
      },
      "areaServed": [
        "Castro Valley, CA", "Oakland, CA", "Berkeley, CA", "Fremont, CA", "Hayward, CA", "San Leandro, CA",
        "Walnut Creek, CA", "Concord, CA", "Richmond, CA", "San Ramon, CA", "Antioch, CA",
        "San Rafael, CA", "Novato, CA", "Mill Valley, CA", "Larkspur, CA",
        "Napa, CA", "American Canyon, CA", "St. Helena, CA", "Calistoga, CA", "Yountville, CA",
        "San Jose, CA", "Palo Alto, CA", "Mountain View, CA", "Sunnyvale, CA", "Cupertino, CA",
        "Santa Clara, CA", "Saratoga, CA", "Los Gatos, CA", "Campbell, CA", "Milpitas, CA"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "50"
      },
      "priceRange": "$$",
      "image": "https://hamilton-exteriors.com/favicon.png",
      "description": "Bay Area exterior remodeling — roofing, siding, windows, and waterproofing. Licensed, bonded, insured. 50-year warranty. 3-5 day installs."
    }
    </script>

    <!-- Google Tag Manager (delayed 2s for better LCP) -->
    <script is:inline>
      setTimeout(function(){
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-MTRC8MMK');
      }, 2000);
    </script>

    <!-- Mapbox Address Autofill — lazy-loaded on first interaction to avoid 1.5MB initial JS -->
    {includeMapbox && (
      <script is:inline>
        (function(){
          var loaded=false;
          function loadMapbox(){
            if(loaded)return;loaded=true;
            var s=document.createElement('script');s.src='https://api.mapbox.com/search-js/v1.5.0/web.js';s.id='search-js';document.head.appendChild(s);
          }
          var addr=document.getElementById('hero-address');
          if(addr){addr.addEventListener('focus',loadMapbox,{once:true});addr.addEventListener('click',loadMapbox,{once:true});}
          else{document.addEventListener('DOMContentLoaded',function(){
            var a=document.getElementById('hero-address');
            if(a){a.addEventListener('focus',loadMapbox,{once:true});a.addEventListener('click',loadMapbox,{once:true});}
          });}
        })();
      </script>
    )}

    <!-- dns-prefetch for third-party domains -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://api.mapbox.com" />

    <!-- Page-specific head content -->
    <slot name="head" />
  </head>
  <body class="overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[99999] focus:bg-[#256346] focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MTRC8MMK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <main id="main-content">
      <slot />
    </main>

    <script>
      // Navbar scroll shadow
      const navbar = document.querySelector('.navbar');
      if (navbar) {
        const onScroll = () => {
          navbar.classList.toggle('scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Scroll #quote links to center the form on screen
      document.querySelectorAll('a[href="#quote"], a[href="/#quote"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const form = document.getElementById('hero-form');
          if (form) {
            e.preventDefault();
            const rect = form.getBoundingClientRect();
            const formCenter = rect.top + window.scrollY + (rect.height / 2);
            const screenCenter = window.innerHeight / 2;
            window.scrollTo({ top: formCenter - screenCenter, behavior: 'smooth' });
            // Focus first input after scroll
            setTimeout(() => {
              const firstInput = form.querySelector('input:not([type="hidden"])') as HTMLInputElement;
              firstInput?.focus();
            }, 600);
          }
        });
      });
    </script>
  </body>
</html>
