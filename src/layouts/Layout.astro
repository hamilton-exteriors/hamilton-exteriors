        "ratingValue": _displayReviews?.rating ?? 4.8,
        "reviewCount": _displayReviews?.reviewCount ?? 26,
        "bestRating": 5,
        "worstRating": 1
      },
      "priceRange": "$$",
      "image": {
        "@type": "ImageObject",
        "url": "https://hamilton-exteriors.com/og-default.jpg",
        "width": 1200,
        "height": 630,
        "caption": "Hamilton Exteriors — Bay Area Design-Build & Exteriors Contractor"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://hamilton-exteriors.com/logo-schema.png",
        "width": 600,
        "height": 120
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Hamilton Exteriors Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/roofing#service", "name": "Roofing", "url": "https://hamilton-exteriors.com/roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/siding#service", "name": "Siding", "url": "https://hamilton-exteriors.com/siding" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/windows#service", "name": "Windows", "url": "https://hamilton-exteriors.com/windows" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/adu#service", "name": "ADUs", "url": "https://hamilton-exteriors.com/adu" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/custom-homes#service", "name": "Custom Homes", "url": "https://hamilton-exteriors.com/custom-homes" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "@id": "https://hamilton-exteriors.com/additions#service", "name": "Additions", "url": "https://hamilton-exteriors.com/additions" } }
        ]
      },
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "license",
          "name": "CSLB Contractor License #1082377",
          "recognizedBy": { "@type": "Organization", "name": "Contractors State License Board", "url": "https://www.cslb.ca.gov" }
        },
        {
          "@type": "EducationalOccupationalCredential",
