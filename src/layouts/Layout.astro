---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { heroBg } from '../lib/images';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  includeMapbox?: boolean;
  noindex?: boolean;
  geoPlacename?: string;
  preloadHero?: boolean;
  heroImage?: ImageMetadata;
  /** When true, emits the full Organization schema (ratings, reviews, catalog).
   *  When false, emits a lean @id-only reference.
   *  Defaults to true only for homepage and top-level service pages. */
  fullOrgSchema?: boolean;
}

const heroSrc = Astro.props.heroImage || heroBg;
// Only process hero preload images when actually needed — avoids wasted SSR work
const heroMobilePreload = Astro.props.preloadHero ? await getImage({ src: heroSrc, width: 768, height: 432, format: 'webp', quality: 60 }) : null;
const heroDesktopPreload = Astro.props.preloadHero ? await getImage({ src: heroSrc, width: 1440, height: 810, format: 'webp', quality: 60 }) : null;

// Auto-generate page-specific OG image from heroImage when no explicit image prop is set.
// Produces a 1200x630 JPEG (maximum social-media compatibility) at build time.
const heroOgImage = !Astro.props.image && Astro.props.heroImage
  ? await getImage({ src: heroSrc, width: 1200, height: 630, format: 'jpg', quality: 80 })
  : null;

const DEFAULT_DESCRIPTION = 'Bay Area roofing, siding, windows, ADUs & custom homes. Licensed, bonded, insured. 50-year warranty. $0 down financing. Call (650) 977-3351.';
const DEFAULT_GEO_PLACENAME = 'Bay Area, California';

// Pages that should carry the full Organization schema (ratings, reviews, catalog)
const FULL_ORG_PATHS = new Set(['/', '/roofing', '/siding', '/windows', '/adu', '/custom-homes', '/additions', '/service-areas']);

const {
  title = "Bay Area Design-Build & Exteriors Contractor | Hamilton Exteriors",
  description: rawDescription,
  image,
  type = 'website',
  jsonLd,
  includeMapbox = false,
  noindex = false,
  geoPlacename = DEFAULT_GEO_PLACENAME,
  preloadHero = false,
  fullOrgSchema = FULL_ORG_PATHS.has(Astro.url.pathname),
} = Astro.props;

// When no description is provided, generate a city-specific one for location pages
// (geoPlacename is passed as "CityName, CA" or "County Name, CA" by city/service routes).
// Falls back to the generic site-wide description for non-location pages.
function buildDescription(raw: string | undefined, geo: string): string {
  const trimmed = raw?.trim();
  if (trimmed) return trimmed;

  if (geo !== DEFAULT_GEO_PLACENAME) {
    // Normalise: strip trailing ", California" to keep it at ", CA"
    const place = geo.replace(/, California$/, ', CA');
    return `Hamilton Exteriors serves ${place} — roofing, siding, windows & more. 50-year warranty. CSLB #1082377. Free estimate: (650) 977-3351.`;
  }

  return DEFAULT_DESCRIPTION;
}

const description = buildDescription(rawDescription, geoPlacename);

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
// Canonical must match sitemap URLs — trailingSlash: 'never' means no trailing slashes
const canonicalUrl = (siteUrl + Astro.url.pathname).replace(/\/$/, '') || siteUrl;

// Resolve OG image: explicit prop > auto-generated from hero > default fallback
const ogImageUrl = image || (heroOgImage ? siteUrl + heroOgImage.src : siteUrl + '/og-default.jpg');
const ogImageType = image ? 'image/jpeg' : (heroOgImage ? 'image/jpeg' : 'image/jpeg');
