---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import { heroBg } from '../lib/images';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  includeMapbox?: boolean;
  noindex?: boolean;
  geoPlacename?: string;
  preloadHero?: boolean;
}

const heroMobilePreload = await getImage({ src: heroBg, width: 768, height: 432, format: 'webp' });
const heroDesktopPreload = await getImage({ src: heroBg, width: 1920, height: 1080, format: 'webp' });

const DEFAULT_DESCRIPTION = 'Bay Area roofing, siding, windows, ADUs & custom homes. Licensed, bonded, insured. 50-year warranty. $0 down financing. Call (650) 977-3351.';
const DEFAULT_GEO_PLACENAME = 'Bay Area, California';

const {
  title = "Bay Area's Top Design-Build & Exteriors Contractor | Hamilton Exteriors",
  description: rawDescription,
  image,
  type = 'website',
  jsonLd,
  includeMapbox = false,
  noindex = false,
  geoPlacename = DEFAULT_GEO_PLACENAME,
  preloadHero = false,
} = Astro.props;

// When no description is provided, generate a city-specific one for location pages
// (geoPlacename is passed as "CityName, CA" or "County Name, CA" by city/service routes).
// Falls back to the generic site-wide description for non-location pages.
function buildDescription(raw: string | undefined, geo: string): string {
  const trimmed = raw?.trim();
  if (trimmed) return trimmed;

  if (geo !== DEFAULT_GEO_PLACENAME) {
    // Normalise: strip trailing ", California" to keep it at ", CA"
    const place = geo.replace(/, California$/, ', CA');
    return `Hamilton Exteriors serves ${place} — roofing, siding, windows & more. 50-year warranty. CSLB #1082377. Free estimate: (650) 977-3351.`;
  }

  return DEFAULT_DESCRIPTION;
}

const description = buildDescription(rawDescription, geoPlacename);

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Self-hosted font preloads — body fonts only; display font loads via font-display:swap -->
    <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/satoshi-700.woff2" as="font" type="font/woff2" crossorigin />

    {/* Preload hero/LCP image — mobile gets 768px, desktop gets 1920px */}
    {preloadHero && <link rel="preload" href={heroMobilePreload.src} as="image" type="image/webp" media="(max-width: 768px)" fetchpriority="high" />}
    {preloadHero && <link rel="preload" href={heroDesktopPreload.src} as="image" type="image/webp" media="(min-width: 769px)" fetchpriority="high" />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="author" content="Hamilton Exteriors" />
    <meta name="publisher" content="Hamilton Exteriors" />
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content={geoPlacename} />

    <!-- Canonical — derived from Astro.url.pathname; no prop override needed -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- AI content declaration for llms.txt discovery -->
    <link rel="ai-content-declaration" href="/llms.txt" type="text/plain" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image || `${siteUrl}/og-default.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content="Hamilton Exteriors" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image || `${siteUrl}/og-default.jpg`} />

    {jsonLd && !Array.isArray(jsonLd) && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {jsonLd && Array.isArray(jsonLd) && jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Ground Up — Hamilton Exteriors" href="/blog/rss.xml" />

    <!-- Favicon — SVG for modern browsers, PNG fallback -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "RoofingContractor",
      "@id": "https://hamilton-exteriors.com/#business",
      "name": "Hamilton Exteriors",
      "url": "https://hamilton-exteriors.com",
      "telephone": "+1-650-977-3351",
      "email": "support@hamilton-exteriors.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "21634 Redwood Rd Unit F",
        "addressLocality": "Castro Valley",
        "addressRegion": "CA",
        "postalCode": "94546",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 37.69412,
        "longitude": -122.08276
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "14:00" }
      ],
      "sameAs": [
        "https://www.yelp.com/biz/hamilton-exteriors-castro-valley",
        "https://www.facebook.com/hamiltonexteriors",
        "https://www.instagram.com/hamiltonexteriors",
        "https://www.linkedin.com/company/hamilton-exteriors/",
        "https://www.google.com/maps/place/Hamilton+Exteriors"
      ],
      "areaServed": [
        { "@type": "County", "name": "Alameda County", "sameAs": "https://en.wikipedia.org/wiki/Alameda_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
        { "@type": "County", "name": "Contra Costa County", "sameAs": "https://en.wikipedia.org/wiki/Contra_Costa_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
        { "@type": "County", "name": "Marin County", "sameAs": "https://en.wikipedia.org/wiki/Marin_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
        { "@type": "County", "name": "Napa County", "sameAs": "https://en.wikipedia.org/wiki/Napa_County,_California", "containedInPlace": { "@type": "State", "name": "California" } },
        { "@type": "County", "name": "Santa Clara County", "sameAs": "https://en.wikipedia.org/wiki/Santa_Clara_County,_California", "containedInPlace": { "@type": "State", "name": "California" } }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": 4.8,
        "reviewCount": 50
      },
      "priceRange": "$$",
      "image": "https://hamilton-exteriors.com/og-default.jpg",
      "logo": {
        "@type": "ImageObject",
        "url": "https://hamilton-exteriors.com/logo-schema.png",
        "width": 600,
        "height": 120
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Hamilton Exteriors Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roofing", "url": "https://hamilton-exteriors.com/roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Siding", "url": "https://hamilton-exteriors.com/siding" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Windows", "url": "https://hamilton-exteriors.com/windows" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ADUs", "url": "https://hamilton-exteriors.com/adu" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom Homes", "url": "https://hamilton-exteriors.com/custom-homes" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Additions", "url": "https://hamilton-exteriors.com/additions" } }
        ]
      },
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "license",
        "name": "CSLB Contractor License #1082377",
        "recognizedBy": { "@type": "Organization", "name": "Contractors State License Board", "url": "https://www.cslb.ca.gov" }
      },
      "additionalType": [
        "https://en.wikipedia.org/wiki/Roofing",
        "https://en.wikipedia.org/wiki/Siding",
        "https://en.wikipedia.org/wiki/General_contractor"
      ],
      "knowsAbout": [
        "Roof replacement",
        "Asphalt shingle roofing",
        "Metal roofing",
        "Tile roofing",
        "James Hardie siding",
        "Fiber cement siding",
        "Energy-efficient windows",
        "ADU construction",
        "Custom home building",
        "Bay Area building codes",
        "California contractor licensing"
      ],
      "description": "Bay Area exterior remodeling - roofing, siding, windows, and waterproofing. Licensed, bonded, insured. 50-year warranty. 3-5 day installs.",
      "review": [
        {
          "@type": "Review",
          "datePublished": "2026-01-15",
          "author": { "@type": "Person", "name": "Eric W" },
          "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5, "worstRating": 1 },
          "reviewBody": "Hamilton Exteriors did an amazing job on my roof. The team was professional, and the quality of work was top-notch. Highly recommend!",
          "itemReviewed": { "@type": "RoofingContractor", "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
        },
        {
          "@type": "Review",
          "datePublished": "2026-01-22",
          "author": { "@type": "Person", "name": "Sarah M" },
          "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5, "worstRating": 1 },
          "reviewBody": "The team at Hamilton Exteriors was respectful, on time, and did excellent work. They made sure to communicate with us throughout the entire process, ensuring we were informed every step of the way. Our new siding looks beautiful, and the quality of the materials they used is top-notch. The crew worked efficiently and left our property clean and tidy. We couldn't be happier with the final result and would highly recommend Hamilton Exteriors for any home improvement needs!",
          "itemReviewed": { "@type": "RoofingContractor", "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
        },
        {
          "@type": "Review",
          "datePublished": "2025-11-08",
          "author": { "@type": "Person", "name": "Robert Holt" },
          "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5, "worstRating": 1 },
          "reviewBody": "We'd been putting off replacing the windows in our home for years, but we finally decided it was time. From the very first consultation with Hamilton Exteriors, we knew we'd made the right choice. The team was not only knowledgeable but genuinely listened to our concerns about energy efficiency and design. When the windows were installed, we were amazed at how much brighter and more comfortable our home felt. It's been a few months now, and we've already noticed a drop in our energy bills. It's like we're living in a new house, and we couldn't be happier with the transformation!",
          "itemReviewed": { "@type": "RoofingContractor", "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
        },
        {
          "@type": "Review",
          "datePublished": "2025-12-03",
          "author": { "@type": "Person", "name": "Laura Gaubin" },
          "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5, "worstRating": 1 },
          "reviewBody": "Hamilton Exteriors repaired extensive dry rot damage on our home's exterior. Their attention to detail and commitment to quality were evident throughout the project. The crew was polite, professional, and ensured the site was clean before leaving each day. Our home looks better than ever, and we have peace of mind knowing the repairs were done correctly. We highly recommend their services.",
          "itemReviewed": { "@type": "RoofingContractor", "@id": "https://hamilton-exteriors.com/#business", "name": "Hamilton Exteriors" }
        }
      ]
    }
    </script>

    <!-- WebSite Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://hamilton-exteriors.com/#website",
      "url": "https://hamilton-exteriors.com",
      "name": "Hamilton Exteriors",
      "publisher": { "@id": "https://hamilton-exteriors.com/#business" }
    }
    </script>

    <!-- Google Tag Manager — deferred until first user interaction to keep LCP/TBT clean -->
    <script is:inline>
      (function(){
        var loaded=false;
        function loadGTM(){
          if(loaded)return;loaded=true;
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-MTRC8MMK');
        }
        ['scroll','click','touchstart','keydown'].forEach(function(e){
          window.addEventListener(e,loadGTM,{once:true,passive:true});
        });
        setTimeout(loadGTM,5000);
      })();
    </script>

    <!-- Mapbox Address Autofill — lazy-loaded on first interaction to avoid 1.5MB initial JS -->
    {includeMapbox && (
      <script is:inline>
        (function(){
          var loaded=false;
          function loadMapbox(){
            if(loaded)return;loaded=true;
            var s=document.createElement('script');s.src='https://api.mapbox.com/search-js/v1.5.0/web.js';s.id='search-js';document.head.appendChild(s);
          }
          var addr=document.getElementById('hero-address');
          if(addr){addr.addEventListener('focus',loadMapbox,{once:true});addr.addEventListener('click',loadMapbox,{once:true});}
          else{document.addEventListener('DOMContentLoaded',function(){
            var a=document.getElementById('hero-address');
            if(a){a.addEventListener('focus',loadMapbox,{once:true});a.addEventListener('click',loadMapbox,{once:true});}
          });}
        })();
      </script>
    )}

    <!-- preconnect for third-party domains -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.mapbox.com" crossorigin />

    <!-- Page-specific head content -->
    <slot name="head" />
  </head>
  <body class="overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[99999] focus:bg-[#256346] focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MTRC8MMK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <main id="main-content">
      <slot />
    </main>

    <!-- Sticky mobile CTA — only shows on pages with a hero form, hidden once form is in view -->
    <div id="mobile-sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 xl:hidden translate-y-full transition-transform duration-300" style="padding: 12px 16px; padding-bottom: max(12px, env(safe-area-inset-bottom)); background: var(--color-primary); box-shadow: 0 -2px 12px rgba(0,0,0,0.15);">
      <a href="#quote" class="flex items-center justify-center gap-2 w-full rounded-lg text-white no-underline" style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 600; height: 48px; background: var(--color-yellow); color: var(--color-charcoal); border-radius: 8px;">
        Get Your Free Inspection
      </a>
    </div>

    <script>
      // Navbar scroll shadow
      const navbar = document.querySelector('.navbar');
      if (navbar) {
        const onScroll = () => {
          navbar.classList.toggle('scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Sticky mobile CTA — show after scrolling 400px, hide when hero form is visible
      const stickyCta = document.getElementById('mobile-sticky-cta');
      const heroForm = document.getElementById('hero-form');
      if (stickyCta && heroForm) {
        const observer = new IntersectionObserver(([entry]) => {
          stickyCta.classList.toggle('translate-y-full', entry.isIntersecting);
          stickyCta.classList.toggle('translate-y-0', !entry.isIntersecting);
        }, { threshold: 0.3 });
        observer.observe(heroForm);
        // Also hide on pages without a hero form (like /buy which has its own CTA)
      } else if (stickyCta) {
        stickyCta.remove();
      }

      // Scroll #quote links to center the form on screen
      document.querySelectorAll('a[href="#quote"], a[href="/#quote"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const form = document.getElementById('hero-form');
          if (form) {
            e.preventDefault();
            const rect = form.getBoundingClientRect();
            const formCenter = rect.top + window.scrollY + (rect.height / 2);
            const screenCenter = window.innerHeight / 2;
            window.scrollTo({ top: formCenter - screenCenter, behavior: 'smooth' });
            // Focus first input after scroll
            setTimeout(() => {
              const firstInput = form.querySelector('input:not([type="hidden"])') as HTMLInputElement;
              firstInput?.focus();
            }, 600);
          }
        });
      });
    </script>
  </body>
</html>
