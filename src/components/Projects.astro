  @media (max-width: 768px) {
    .cc-grid {
      grid-template-columns: 1fr !important;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .cc-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  /* Card focus for keyboard nav */
  .cc-project-card:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }

  /* Card hover effects */
  .cc-project-card:hover .cc-photo-overlay {
    opacity: 1 !important;
  }

  /* Filter button hover */
  .cc-filter-btn:hover {
    border-color: rgba(37,99,70,0.3) !important;
    color: var(--color-heading) !important;
  }
  /* Filter button active/selected */
  .cc-filter-btn[data-active="true"] {
    background: var(--color-primary) !important;
    color: var(--color-white) !important;
    border-color: var(--color-primary) !important;
  }

  /* Lightbox button hover */
  #cc-lb-close:hover,
  #cc-lb-prev:hover,
  #cc-lb-next:hover {
    background: rgba(0,0,0,0.7) !important;
  }

  /* Hide scrollbar on filter tabs */
  .cc-filter-tabs::-webkit-scrollbar {
    display: none;
  }

  /* Lightbox mobile adjustments */
  @media (max-width: 768px) {
    #cc-lb-stage {
      inset: 60px 44px 90px !important;
    }
    #cc-lb-prev,
    #cc-lb-next {
      width: 36px !important;
      height: 36px !important;
    }
    #cc-lb-prev { left: 4px !important; }
    #cc-lb-next { right: 4px !important; }
    #cc-lb-info {
      max-width: calc(100% - 60px) !important;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cc-project-card,
    .cc-project-card .cc-card-photo,
    .cc-project-card .cc-photo-overlay,
    .cc-filter-btn {
      transition: none !important;
    }
  }
</style>
