---
/**
 * Projects section — SSR-renders portfolio data from BackOffice API,
 * then the widget JS hydrates over it for filtering, pagination & lightbox.
 *
 * Crawlers get real HTML with images, alt text, and structured data.
 * Users get the full interactive experience once JS loads.
 */
interface Props {
  showFilters?: boolean;
}

const widgetUrl = 'https://backoffice-production-99b7.up.railway.app/widget/portfolio.js';
const widgetKey = import.meta.env.BACKOFFICE_API_KEY || 'boak_43d1199812d9465422105ff4ad589e3f';
const apiUrl = `https://backoffice-production-99b7.up.railway.app/public/portfolio?key=${encodeURIComponent(widgetKey)}`;

interface ProjectPhoto {
  id: string;
  url: string;
  thumbnail_url?: string;
}

interface Project {
  id: string;
  title: string;
  city?: string;
  service_type?: string;
  products_used?: string;
  completed_at?: string;
  featured_photo_url?: string;
  photos: ProjectPhoto[];
}

let projects: Project[] = [];
try {
  const res = await fetch(apiUrl, { signal: AbortSignal.timeout(5000) });
  if (res.ok) {
    const data = await res.json();
    projects = data.projects || [];
  }
} catch { /* SSR fallback: widget JS will load data client-side */ }

function formatDate(d: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [y, m, day] = d.split('-');
  return `${months[parseInt(m, 10) - 1]} ${parseInt(day, 10)}, ${y}`;
}

function imgSrcset(url: string): string {
  if (!url.includes('?d=')) return '';
  return [300, 600, 900].map(w => `${url.replace(/\?d=\d+x\d+/, `?d=${w}x${w}`)} ${w}w`).join(', ');
}

function imgAlt(project: Project, index: number): string {
  const parts = [project.title];
  if (project.city) parts.push(`in ${project.city}`);
  if (index > 0) parts.push(`— photo ${index + 1}`);
  return parts.join(' ');
}
---

<section class="cv-auto w-full py-10 lg:py-16" style="background-color: var(--color-cream);">
  <div class="mx-auto max-w-[1170px] px-5" style="font-family: var(--font-dm-sans);">

    <!-- Header -->
    <div class="mb-6 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 36px); font-weight: 400; color: var(--color-charcoal); margin: 0; text-transform: uppercase; line-height: 1.1;">Our Latest Projects</h2>
      <a href="https://www.backofficeautomations.com/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5" style="text-decoration: none;">
        <span style="font-size: 11px; font-weight: 400; letter-spacing: 0.3px; color: var(--color-muted);">Powered by</span>
        <span style="font-family: var(--font-dm-sans); font-size: 11px; font-weight: 600; color: var(--color-charcoal);">BackOffice</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 1h6v6M9 1L1 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <!-- BackOffice Portfolio Widget — SSR content is replaced by widget JS on hydration -->
    <div id="bo-portfolio">
      {projects.length > 0 && (
        <div class="bop-ssr">
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;" class="bop-ssr-grid">
            {projects.map((project, i) => {
              const featuredUrl = project.featured_photo_url || project.photos[0]?.url || '';
              const photoCount = project.photos.length;
              return (
                <article style="border: 1px solid rgba(37,99,70,.12); border-radius: 6px; overflow: hidden; background: #fff;">
                  {featuredUrl && (
                    <div style="position: relative; width: 100%; padding-top: 62%; overflow: hidden; background: #e8e5df;">
                      <img
                        src={featuredUrl.replace(/\?d=\d+x\d+/, '?d=600x600')}
                        srcset={imgSrcset(featuredUrl)}
                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        alt={imgAlt(project, 0)}
                        width="600"
                        height="600"
                        loading="lazy"
                        decoding="async"
                        style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
                      />
                      {project.service_type && (
                        <span style="position: absolute; bottom: 8px; left: 8px; background: rgba(0,0,0,.65); color: #fff; font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 3px; letter-spacing: .5px; text-transform: uppercase;">
                          {project.service_type}
                        </span>
                      )}
                      {photoCount > 1 && (
                        <span style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,.65); color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 3px; letter-spacing: .3px; display: flex; align-items: center; gap: 4px;">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                          {photoCount}
                        </span>
                      )}
                    </div>
                  )}
                  <div style="padding: 14px 16px;">
                    <h3 style="font-size: 1rem; font-weight: 700; color: #1A1A1A; margin: 0 0 12px; line-height: 1.3;">
                      {project.title}
                    </h3>
                    {project.city && (
                      <>
                        <p style="font-size: 10px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: .8px; margin: 0 0 2px;">Location</p>
                        <p style="font-size: .875rem; color: #1A1A1A; margin: 0 0 8px;">{project.city}</p>
                      </>
                    )}
                    {project.products_used && (
                      <>
                        <p style="font-size: 10px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: .8px; margin: 0 0 2px;">Products</p>
                        <p style="font-size: .875rem; color: #1A1A1A; margin: 0 0 8px;">{project.products_used}</p>
                      </>
                    )}
                    {project.completed_at && (
                      <>
                        <p style="font-size: 10px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: .8px; margin: 0 0 2px;">Completed</p>
                        <p style="font-size: .875rem; color: #1A1A1A; margin: 0;">{formatDate(project.completed_at)}</p>
                      </>
                    )}
                  </div>
                  {project.photos.length > 1 && (
                    <div style="display: flex; gap: 5px; padding: 0 16px 14px; align-items: center;">
                      {project.photos.slice(1, 5).map((photo, j) => (
                        <img
                          src={(photo.thumbnail_url || photo.url).replace(/\?d=\d+x\d+/, '?d=250x250')}
                          alt={imgAlt(project, j + 1)}
                          width="48"
                          height="48"
                          loading="lazy"
                          decoding="async"
                          style="width: 48px; height: 48px; border-radius: 4px; object-fit: cover; flex-shrink: 0; background: #F4F1EB;"
                        />
                      ))}
                      {project.photos.length > 5 && (
                        <span style="width: 48px; height: 48px; border-radius: 4px; background: #F4F1EB; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: #999; flex-shrink: 0;">
                          +{project.photos.length - 5}
                        </span>
                      )}
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </div>
      )}
    </div>

  </div>
</section>

{/* ImageGallery schema removed — not a Google-supported rich result type (April 2026).
   Project photos are still visible in CompanyCam image URLs in the page HTML. */}

<style>
  /* SSR grid responsive — matches widget layout */
  @media (max-width: 1024px) {
    .bop-ssr-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 640px) {
    .bop-ssr-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script is:inline define:vars={{ widgetUrl, widgetKey }}>
  // Load the BackOffice portfolio widget — replaces SSR content with interactive version
  (function() {
    var s = document.createElement('script');
    s.src = widgetUrl;
    s.setAttribute('data-key', widgetKey);
    s.setAttribute('data-target', 'bo-portfolio');
    s.defer = true;
    document.body.appendChild(s);
  })();
</script>
