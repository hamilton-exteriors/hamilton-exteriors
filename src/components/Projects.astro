import { Image } from 'astro:assets';
---

<section class="w-full py-10 lg:py-16" style="background-color: var(--color-cream);">
  <div class="cc-showcase-wrapper mx-auto max-w-[1170px] px-5" style="font-family: var(--font-dm-sans);">

    <!-- Header -->
    <div class="mb-6 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 36px); font-weight: 400; color: var(--color-charcoal); margin: 0; text-transform: uppercase; line-height: 1.1;">Our Latest Projects</h2>
      <div class="flex items-center gap-1.5" style="opacity: 0.45;">
        <span style="font-size: 11px; color: var(--color-charcoal); font-weight: 400; letter-spacing: 0.3px;">Powered by</span>
        <span style="font-family: var(--font-dm-sans); font-size: 11px; font-weight: 600; color: var(--color-charcoal);">BackOffice</span>
      </div>
    </div>

    <!-- Category Filter Tabs -->
    {showFilters && (
      <div class="cc-filter-tabs mb-6 flex gap-2.5 overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
        {categories.map((cat) => (
          <button
            data-filter={cat.id}
            class="cc-filter-btn"
            style={`
              font-family: var(--font-satoshi);
              font-size: 11px;
              font-weight: 600;
              text-transform: uppercase;
              letter-spacing: 0.6px;
              padding: 6px 14px;
              border-radius: 100px;
              border: 1px solid rgba(37,99,70,0.15);
              background: var(--color-white);
              color: var(--color-muted);
              cursor: pointer;
              white-space: nowrap;
              transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
            `}
          >
            {cat.label}
          </button>
        ))}
      </div>
    )}

    <!-- Cards Grid -->
    <div class="cc-grid gap-4" style="display: grid; grid-template-columns: repeat(3, 1fr);">
      {projects.map((project, idx) => (
        <div
          class={`cc-project-card ${idx > 0 ? 'cc-card-extra' : ''}`}
          role="button"
          tabindex="0"
          data-category={project.category}
          data-images={JSON.stringify([project.featuredPhoto, ...project.thumbnails.map(t => t.replace('d=250x250', 'd=900x900'))])}
          data-title={project.title}
          data-city={project.city}
          data-date={project.date}
          data-type={project.projectType}
          data-products={project.productsUsed}
          style="border: 1px solid rgba(37,99,70,0.12); border-radius: 6px; overflow: hidden; background: var(--color-white); cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;"
        >

          <!-- Featured Photo with badges -->
          <div style="display: block; position: relative; width: 100%; padding-top: 62%; overflow: hidden; background: var(--color-border);">
            <Image
              class="cc-card-photo"
              src={project.featuredPhoto}
              alt={project.title}
              width={900}
              height={558}
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
            <!-- Location + date badge (bottom-left) -->
            <div style="position: absolute; bottom: 8px; left: 8px; background: rgba(0,0,0,0.65); color: white; font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 3px; letter-spacing: 0.5px; text-transform: uppercase;">
              {project.city.toUpperCase()} &middot; {project.date}
            </div>
            <!-- Photo count badge (bottom-right, always visible) -->
            <div style="position: absolute; bottom: 8px; right: 8px; background: var(--color-primary); color: var(--color-white); font-family: var(--font-satoshi); font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 3px; letter-spacing: 0.3px; display: flex; align-items: center; gap: 4px;">
              <IconImage size={12} class="text-white" />
              {project.mediaCount}
            </div>
            <!-- View Photos overlay -->
            <div class="cc-photo-overlay" style="position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.25s ease;">
              <span style="color: var(--color-white); font-family: var(--font-satoshi); font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 6px;">
                <IconSearchPlus size={18} class="text-white" />
                View {project.mediaCount} Photos
              </span>
            </div>
          </div>

          <!-- Card Content -->
          <div style="padding: 14px 16px;">
            <!-- Title -->
            <p style="font-size: 1rem; font-weight: 700; color: var(--color-charcoal); margin: 0 0 12px; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
              {project.title}
            </p>

            <!-- Project Type -->
            <div style="margin-bottom: 8px;">
              <p style="font-family: var(--font-satoshi); font-size: 10px; font-weight: 700; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.8px; margin: 0 0 2px;">PROJECT TYPE</p>
              <p style="font-size: 0.875rem; color: var(--color-charcoal); margin: 0;">{project.projectType}</p>
            </div>

            <!-- Products Used -->
            <div style="margin-bottom: 12px;">
              <p style="font-family: var(--font-satoshi); font-size: 10px; font-weight: 700; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.8px; margin: 0 0 2px;">PRODUCTS USED</p>
              <p style="font-size: 0.875rem; color: var(--color-charcoal); margin: 0;">{project.productsUsed}</p>
            </div>

            <!-- Thumbnails strip -->
            <div style="display: flex; gap: 5px; align-items: center;">
              {project.thumbnails.map(thumb => (
                <div style="width: 48px; height: 48px; border-radius: 4px; overflow: hidden; flex-shrink: 0; background: var(--color-cream);">
                  <Image
                    src={thumb}
                    alt=""
                    width={250}
                    height={250}
                    style="width: 100%; height: 100%; object-fit: cover;"
                    loading="lazy"
                  />
                </div>
              ))}
              {project.extraCount > 0 && (
                <div style="width: 48px; height: 48px; border-radius: 4px; background: var(--color-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-size: 0.875rem; font-weight: 700; color: var(--color-white);">+{project.extraCount}</span>
                </div>
              )}
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Pagination -->
    <div id="cc-pagination" style="display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 20px;">
      <button data-action="first" aria-label="First page" style="display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border: 1px solid var(--color-border); background: var(--color-white); border-radius: 4px; cursor: pointer; color: var(--color-muted);">
        <IconChevronDoubleLeft size={14} />
      </button>
      <button data-action="prev" aria-label="Previous page" style="display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border: 1px solid var(--color-border); background: var(--color-white); border-radius: 4px; cursor: pointer; color: var(--color-muted);">
        <IconChevronLeft size={14} />
      </button>
      <span id="cc-page-label" style="font-size: 0.8125rem; color: var(--color-muted); padding: 0 8px;">1 of 1</span>
      <button data-action="next" aria-label="Next page" style="display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border: 1px solid var(--color-border); background: var(--color-white); border-radius: 4px; cursor: pointer; color: var(--color-muted);">
        <IconChevronRight size={14} />
      </button>
      <button data-action="last" aria-label="Last page" style="display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border: 1px solid var(--color-border); background: var(--color-white); border-radius: 4px; cursor: pointer; color: var(--color-muted);">
        <IconChevronDoubleRight size={14} />
      </button>
    </div>

  </div>
</section>

<!-- Lightbox Modal -->
<div id="cc-lightbox" style="display: none; position: fixed; inset: 0; z-index: 99999; background: #000; isolation: isolate; font-family: var(--font-dm-sans);" role="dialog" aria-modal="true" aria-label="Project photo gallery">
  <!-- Close button -->
  <button id="cc-lb-close" style="position: absolute; top: 16px; right: 16px; z-index: 10; width: 44px; height: 44px; border: none; background: rgba(255,255,255,0.15); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s;" aria-label="Close gallery">
    <IconClose size={20} class="text-white" />
  </button>

  <!-- Project info bar -->
  <div id="cc-lb-info" style="position: absolute; top: 16px; left: 16px; z-index: 10; color: white; max-width: calc(100% - 80px);">
    <p id="cc-lb-title" style="font-size: 1rem; font-weight: 700; margin: 0 0 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></p>
    <p id="cc-lb-meta" style="font-size: 0.75rem; color: rgba(255,255,255,0.6); margin: 0;">
      <span id="cc-lb-type"></span> &middot; <span id="cc-lb-city"></span> &middot; <span id="cc-lb-products"></span>
    </p>
  </div>

  <!-- Main image area -->
  <div id="cc-lb-stage" style="position: absolute; inset: 70px 60px 80px; display: flex; align-items: center; justify-content: center; touch-action: pan-y;">
    <img id="cc-lb-img" src="" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 4px; user-select: none; -webkit-user-drag: none;" />
  </div>

  <!-- Prev / Next arrows -->
  <button id="cc-lb-prev" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); z-index: 10; width: 48px; height: 48px; border: none; background: rgba(0,0,0,0.5); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; backdrop-filter: blur(4px);" aria-label="Previous photo">
    <IconChevronLeft size={22} class="text-white" />
  </button>
  <button id="cc-lb-next" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); z-index: 10; width: 48px; height: 48px; border: none; background: rgba(0,0,0,0.5); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; backdrop-filter: blur(4px);" aria-label="Next photo">
    <IconChevronRight size={22} class="text-white" />
  </button>

  <!-- Thumbnail strip + counter -->
  <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 12px 16px; display: flex; flex-direction: column; align-items: center; gap: 8px;">
    <div id="cc-lb-thumbs" style="display: flex; gap: 6px; overflow-x: auto; max-width: 100%; scrollbar-width: none; -ms-overflow-style: none; padding: 0 4px;"></div>
    <span id="cc-lb-counter" style="font-size: 12px; color: rgba(255,255,255,0.5); font-weight: 600; letter-spacing: 0.5px;"></span>
  </div>
</div>

<script>
  // === SHARED STATE ===
  let currentPage = 1;
  let activeFilter = 'all';

  // === DOM ELEMENTS ===
  const filterBtns = document.querySelectorAll('.cc-filter-btn');
  const allCards = Array.from(document.querySelectorAll('.cc-project-card'));
  const grid = document.querySelector('.cc-grid');
  const label = document.getElementById('cc-page-label');
  const pagination = document.getElementById('cc-pagination');

  // === PAGINATION ===
  function getPerPage() {
    return window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;
  }

  function getFilteredCards() {
    return allCards.filter(card => {
      const cat = card.getAttribute('data-category');
      return activeFilter === 'all' || cat === activeFilter;
    });
  }

  function renderPagination() {
    const filtered = getFilteredCards();
    const perPage = getPerPage();
    const totalPages = Math.max(1, Math.ceil(filtered.length / perPage));
    if (currentPage > totalPages) currentPage = totalPages;

    // Hide all cards first
    allCards.forEach(card => {
      (card as HTMLElement).style.display = 'none';
    });

    // Show only current page of filtered cards
    filtered.forEach((card, i) => {
      const pageOfCard = Math.floor(i / perPage) + 1;
      (card as HTMLElement).style.display = pageOfCard === currentPage ? '' : 'none';
    });

    if (label) label.textContent = `${currentPage} of ${totalPages}`;

    if (pagination) {
      pagination.querySelectorAll('button').forEach(btn => {
        (btn as HTMLButtonElement).disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
        btn.style.display = 'flex';
      });
    }
  }

  // Re-render on resize so perPage stays in sync with CSS grid
  if (typeof window !== 'undefined') {
    let resizeTimer = 0;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => renderPagination(), 150);
    });
  }

  // === CATEGORY FILTERS ===
  function applyFilter(category: string) {
    activeFilter = category;
    filterBtns.forEach(btn => {
      const isActive = btn.getAttribute('data-filter') === category;
      (btn as HTMLElement).setAttribute('data-active', String(isActive));
    });

    allCards.forEach(card => {
      const cardCat = card.getAttribute('data-category');
      const show = category === 'all' || cardCat === category;
      (card as HTMLElement).style.display = show ? '' : 'none';
    });

    currentPage = 1;
    renderPagination();
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      applyFilter(btn.getAttribute('data-filter') || 'all');
    });
  });

  // Initialize
  applyFilter('all');

  if (pagination) {
    pagination.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;
      const action = btn.getAttribute('data-action');
      const filteredCards = allCards.filter(card => {
        const cardCat = card.getAttribute('data-category');
        return activeFilter === 'all' || cardCat === activeFilter;
      });
      const perPage = getPerPage();
      const totalPages = Math.max(1, Math.ceil(filteredCards.length / perPage));

      if (action === 'first') currentPage = 1;
      else if (action === 'prev') currentPage = currentPage <= 1 ? totalPages : currentPage - 1;
      else if (action === 'next') currentPage = currentPage >= totalPages ? 1 : currentPage + 1;
      else if (action === 'last') currentPage = totalPages;
      renderPagination();
    });
  }

  // Re-render on resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => renderPagination(), 150);
  });

  // === LIGHTBOX ===
  const lightbox = document.getElementById('cc-lightbox')!;
  const lbImg = document.getElementById('cc-lb-img') as HTMLImageElement;
  const lbTitle = document.getElementById('cc-lb-title')!;
  const lbType = document.getElementById('cc-lb-type')!;
  const lbCity = document.getElementById('cc-lb-city')!;
  const lbProducts = document.getElementById('cc-lb-products')!;
  const lbCounter = document.getElementById('cc-lb-counter')!;
  const lbThumbs = document.getElementById('cc-lb-thumbs')!;
  const lbClose = document.getElementById('cc-lb-close')!;
  const lbPrev = document.getElementById('cc-lb-prev')!;
  const lbNext = document.getElementById('cc-lb-next')!;

  let lbImages: string[] = [];
  let lbIndex = 0;

  function openLightbox(card: HTMLElement) {
    lbImages = JSON.parse(card.getAttribute('data-images') || '[]');
    if (!lbImages.length) return;

    lbTitle.textContent = card.getAttribute('data-title') || '';
    lbType.textContent = card.getAttribute('data-type') || '';
    lbCity.textContent = card.getAttribute('data-city') || '';
    lbProducts.textContent = card.getAttribute('data-products') || '';

    lbIndex = 0;
    thumbsBuilt = false;
    renderLightbox();
    lightbox.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  let thumbsBuilt = false;

  function buildThumbs() {
    lbThumbs.innerHTML = '';
    lbImages.forEach((src, i) => {
      const thumb = document.createElement('div');
      thumb.style.cssText = 'width: 48px; height: 48px; border-radius: 4px; overflow: hidden; flex-shrink: 0; cursor: pointer; border: 2px solid transparent; transition: border-color 0.15s;';
      thumb.innerHTML = `<img src="${src.replace('d=900x900', 'd=250x250')}" alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />`;
      thumb.addEventListener('click', () => { lbIndex = i; updateLightbox(); });
      lbThumbs.appendChild(thumb);
    });
    thumbsBuilt = true;
  }

  function updateLightbox() {
    lbImg.src = lbImages[lbIndex];
    lbImg.alt = `Photo ${lbIndex + 1} of ${lbImages.length}`;
    lbCounter.textContent = `${lbIndex + 1} / ${lbImages.length}`;

    // Update thumb highlights only
    Array.from(lbThumbs.children).forEach((thumb, i) => {
      (thumb as HTMLElement).style.borderColor = i === lbIndex ? '#FFDE21' : 'transparent';
    });

    const activeTh = lbThumbs.children[lbIndex] as HTMLElement;
    if (activeTh) activeTh.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  function renderLightbox() {
    if (!thumbsBuilt) buildThumbs();
    updateLightbox();
  }

  function lbGo(dir: number) {
    lbIndex = (lbIndex + dir + lbImages.length) % lbImages.length;
    updateLightbox();
  }

  // Card click → open lightbox
  allCards.forEach(card => {
    card.addEventListener('click', () => openLightbox(card as HTMLElement));
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        openLightbox(card as HTMLElement);
      }
    });
  });

  // Lightbox controls
  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => lbGo(-1));
  lbNext.addEventListener('click', () => lbGo(1));

  // Keyboard nav
  document.addEventListener('keydown', (e) => {
    if (lightbox.style.display === 'none') return;
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowLeft') lbGo(-1);
    else if (e.key === 'ArrowRight') lbGo(1);
  });

  // Click backdrop to close
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || (e.target as HTMLElement).id === 'cc-lb-stage') closeLightbox();
  });

  // === TOUCH SWIPE in Lightbox ===
  let touchStartX = 0;
  let touchStartY = 0;
  const lbStage = document.getElementById('cc-lb-stage')!;

  lbStage.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  lbStage.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    // Only swipe if horizontal movement > vertical and > 50px
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
      lbGo(dx < 0 ? 1 : -1);
    }
  }, { passive: true });
</script>

