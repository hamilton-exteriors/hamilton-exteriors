---

<section class="w-full py-8 lg:py-12" style="background-color: rgb(255,255,255);">
  <div class="cc-showcase-wrapper mx-auto max-w-[1170px] px-5" style="font-family: 'DM Sans', sans-serif;">

    <!-- Header -->
    <div class="mb-5 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(24px, 4vw, 30px); font-weight: 400; color: rgb(17,17,17); margin: 0; text-transform: uppercase;">Our Latest Projects</h2>
      <div class="flex items-center gap-1.5">
        <span style="font-size: 0.8125rem; color: rgb(120,120,120); font-weight: 400;">Powered By</span>
        <Image
          src="https://companycam.imgix.net/icons-logos/CompanyCam-Logos/All_Black_CompanyCam_Logo.png?auto=format%2Ccompress&w=350"
          alt="CompanyCam"
          width={350}
          height={50}
          style="height: 14px; width: auto;"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="cc-grid gap-4" style="display: grid;">
      {projects.map((project, idx) => (
        <div class={idx > 0 ? 'cc-card-extra' : ''} style="border: 1px solid rgb(230,230,230); border-radius: 6px; overflow: hidden; background: rgb(255,255,255); cursor: pointer;">

          <!-- Featured Photo with badges -->
          <div style="position: relative; width: 100%; padding-top: 62%; overflow: hidden; background: rgb(220,220,220);">
            <Image
              src={project.featuredPhoto}
              alt={project.title}
              width={900}
              height={558}
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;"
              loading="lazy"
            />
            <!-- Date badge (bottom-left) -->
            <div style="position: absolute; bottom: 8px; left: 8px; background: rgba(0,0,0,0.65); color: white; font-size: 10px; font-weight: 600; padding: 2px 6px; border-radius: 3px; letter-spacing: 0.5px; text-transform: uppercase;">
              {project.date}
            </div>
            <!-- City badge (bottom-right) -->
            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.65); color: white; font-size: 10px; font-weight: 600; padding: 2px 6px; border-radius: 3px; letter-spacing: 0.5px; text-transform: uppercase;">
              {project.city.toUpperCase()}
            </div>
          </div>

          <!-- Card Content -->
          <div style="padding: 12px 14px;">
            <!-- Title -->
            <p style="font-size: 0.875rem; font-weight: 700; color: rgb(17,17,17); margin: 0 0 10px; line-height: 1.35;">
              {project.title}
            </p>

            <!-- Project Type -->
            <div style="margin-bottom: 8px;">
              <p style="font-size: 10px; font-weight: 600; color: rgb(120,120,120); text-transform: uppercase; letter-spacing: 0.8px; margin: 0 0 2px;">PROJECT TYPE</p>
              <p style="font-size: 0.8125rem; color: rgb(40,40,40); margin: 0;">{project.projectType}</p>
            </div>

            <!-- Products Used -->
            <div style="margin-bottom: 10px;">
              <p style="font-size: 10px; font-weight: 600; color: rgb(120,120,120); text-transform: uppercase; letter-spacing: 0.8px; margin: 0 0 2px;">PRODUCTS USED</p>
              <p style="font-size: 0.8125rem; color: rgb(40,40,40); margin: 0;">{project.productsUsed}</p>
            </div>

            <!-- Thumbnails strip -->
            <div style="display: flex; gap: 4px; align-items: center;">
              {project.thumbnails.map(thumb => (
                <div style="width: 40px; height: 40px; border-radius: 3px; overflow: hidden; flex-shrink: 0; background: rgb(220,220,220);">
                  <Image
                    src={thumb}
                    alt=""
                    width={250}
                    height={250}
                    style="width: 100%; height: 100%; object-fit: cover;"
                    loading="lazy"
                  />
                </div>
              ))}
              {project.extraCount > 0 && (
                <div style="width: 40px; height: 40px; border-radius: 3px; background: rgb(240,240,240); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-size: 0.8125rem; font-weight: 600; color: rgb(80,80,80);">+{project.extraCount}</span>
                </div>
              )}
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Pagination -->
    <div id="cc-pagination" style="display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 20px;">
      <button data-action="first" style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border: 1px solid rgb(210,210,210); background: white; border-radius: 4px; cursor: pointer; color: rgb(60,60,60);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M11 18L5 12l6-6M19 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button data-action="prev" style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border: 1px solid rgb(210,210,210); background: white; border-radius: 4px; cursor: pointer; color: rgb(60,60,60);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span id="cc-page-label" style="font-size: 0.8125rem; color: rgb(60,60,60); padding: 0 8px;">1 of 1</span>
      <button data-action="next" style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border: 1px solid rgb(210,210,210); background: white; border-radius: 4px; cursor: pointer; color: rgb(60,60,60);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button data-action="last" style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border: 1px solid rgb(210,210,210); background: white; border-radius: 4px; cursor: pointer; color: rgb(60,60,60);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 18l6-6-6-6M13 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

  </div>
</section>

<script>
  const grid = document.querySelector('.cc-grid');
  const cards = grid ? Array.from(grid.children) : [];
  const label = document.getElementById('cc-page-label');
  const pagination = document.getElementById('cc-pagination');

  if (cards.length > 0 && pagination) {
    const perPage = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;
    const totalPages = Math.ceil(cards.length / perPage);
    let currentPage = 1;

    function render() {
      cards.forEach((card, i) => {
        const pageOfCard = Math.floor(i / perPage) + 1;
        (card as HTMLElement).style.display = pageOfCard === currentPage ? '' : 'none';
      });
      if (label) label.textContent = `${currentPage} of ${totalPages}`;

      pagination.querySelectorAll('button').forEach(btn => {
        const action = btn.getAttribute('data-action');
        const disabled = (action === 'first' || action === 'prev') ? currentPage <= 1 :
                         (action === 'next' || action === 'last') ? currentPage >= totalPages : false;
        (btn as HTMLButtonElement).disabled = disabled;
        btn.style.opacity = disabled ? '0.4' : '1';
        btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
      });
    }

    pagination.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn || (btn as HTMLButtonElement).disabled) return;
      const action = btn.getAttribute('data-action');
      if (action === 'first') currentPage = 1;
      else if (action === 'prev') currentPage = Math.max(1, currentPage - 1);
      else if (action === 'next') currentPage = Math.min(totalPages, currentPage + 1);
      else if (action === 'last') currentPage = totalPages;
      render();
    });

    render();
  }
</script>

<style>
  @media (max-width: 768px) {
    .cc-grid {
      grid-template-columns: 1fr !important;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .cc-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
