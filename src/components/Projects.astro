---
/**
 * Projects section — SSR-renders portfolio data from BackOffice API,
 * then the widget JS hydrates over it for filtering, pagination & lightbox.
 *
 * Crawlers get real HTML with images, alt text, and structured data.
 * Users get the full interactive experience once JS loads.
 */
interface Props {
  showFilters?: boolean;
}

const widgetUrl = 'https://backoffice-production-99b7.up.railway.app/widget/portfolio.js';
const widgetKey = import.meta.env.BACKOFFICE_API_KEY || 'boak_43d1199812d9465422105ff4ad589e3f';
const apiUrl = `https://backoffice-production-99b7.up.railway.app/public/portfolio?key=${encodeURIComponent(widgetKey)}`;

interface ProjectPhoto {
  id: string;
  url: string;
  thumbnail_url?: string;
}

interface Project {
  id: string;
  title: string;
  city?: string;
  service_type?: string;
  products_used?: string;
  completed_at?: string;
  featured_photo_url?: string;
  photos: ProjectPhoto[];
}

let projects: Project[] = [];
try {
  const res = await fetch(apiUrl, { signal: AbortSignal.timeout(5000) });
  if (res.ok) {
    const data = await res.json();
    projects = data.projects || [];
  }
} catch { /* SSR fallback: widget JS will load data client-side */ }

function formatDate(d: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [y, m, day] = d.split('-');
  return `${months[parseInt(m, 10) - 1]} ${parseInt(day, 10)}, ${y}`;
}

function imgSrcset(url: string): string {
  if (!url.includes('?d=')) return '';
  return [300, 600, 900].map(w => `${url.replace(/\?d=\d+x\d+/, `?d=${w}x${w}`)} ${w}w`).join(', ');
}

function imgAlt(project: Project, index: number): string {
  const parts = [project.title];
  if (project.city) parts.push(`in ${project.city}`);
  if (index > 0) parts.push(`— photo ${index + 1}`);
  return parts.join(' ');
}
---

<section class="cv-auto w-full bg-cream py-10 lg:py-16">
  <div class="mx-auto max-w-[1170px] px-5">

    <!-- Header -->
    <div class="mb-6 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="m-0 text-[clamp(1.75rem,5vw,2.25rem)] leading-[1.1] text-charcoal">Our Latest Projects</h2>
      <a href="https://www.backofficeautomations.com/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 no-underline">
        <span class="text-[0.6875rem] font-normal tracking-[0.3px] text-muted">Powered by</span>
        <span class="text-[0.6875rem] font-semibold text-charcoal">BackOffice</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 1h6v6M9 1L1 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <!-- BackOffice Portfolio Widget — SSR content is replaced by widget JS on hydration -->
    <div id="bo-portfolio">
      {projects.length > 0 && (
        <div class="bop-ssr">
          <div class="bop-ssr-grid grid grid-cols-3 gap-4">
            {projects.map((project, i) => {
              const featuredUrl = project.featured_photo_url || project.photos[0]?.url || '';
              const photoCount = project.photos.length;
              return (
                <article class="overflow-hidden rounded-[6px] border border-primary/12 bg-white">
                  {featuredUrl && (
                    <div class="relative w-full overflow-hidden bg-cream pt-[62%]">
                      <img
                        src={featuredUrl.replace(/\?d=\d+x\d+/, '?d=600x600')}
                        srcset={imgSrcset(featuredUrl)}
                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        alt={imgAlt(project, 0)}
                        width="600"
                        height="600"
                        loading="lazy"
                        decoding="async"
                        class="absolute inset-0 size-full object-cover"
                      />
                      {project.service_type && (
                        <span class="absolute bottom-2 left-2 rounded-[3px] bg-charcoal/65 px-2 py-[3px] text-[0.625rem] font-semibold tracking-[0.5px] text-white uppercase">
                          {project.service_type}
                        </span>
                      )}
                      {photoCount > 1 && (
                        <span class="absolute right-2 bottom-2 flex items-center gap-1 rounded-[3px] bg-charcoal/65 px-2 py-[3px] text-[0.6875rem] font-bold tracking-[0.3px] text-white">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                          {photoCount}
                        </span>
                      )}
                    </div>
                  )}
                  <div class="px-4 py-3.5">
                    <h3 class="m-0 mb-3 text-base leading-[1.3] font-normal text-charcoal">
                      {project.title}
                    </h3>
                    {project.city && (
                      <>
                        <p class="m-0 mb-0.5 text-[0.625rem] font-bold tracking-[0.8px] text-muted uppercase">Location</p>
                        <p class="m-0 mb-2 text-sm text-charcoal">{project.city}</p>
                      </>
                    )}
                    {project.products_used && (
                      <>
                        <p class="m-0 mb-0.5 text-[0.625rem] font-bold tracking-[0.8px] text-muted uppercase">Products</p>
                        <p class="m-0 mb-2 text-sm text-charcoal">{project.products_used}</p>
                      </>
                    )}
                    {project.completed_at && (
                      <>
                        <p class="m-0 mb-0.5 text-[0.625rem] font-bold tracking-[0.8px] text-muted uppercase">Completed</p>
                        <p class="m-0 text-sm text-charcoal">{formatDate(project.completed_at)}</p>
                      </>
                    )}
                  </div>
                  {project.photos.length > 1 && (
                    <div class="flex items-center gap-[5px] px-4 pb-3.5">
                      {project.photos.slice(1, 5).map((photo, j) => (
                        <img
                          src={(photo.thumbnail_url || photo.url).replace(/\?d=\d+x\d+/, '?d=250x250')}
                          alt={imgAlt(project, j + 1)}
                          width="48"
                          height="48"
                          loading="lazy"
                          decoding="async"
                          class="size-12 shrink-0 rounded-[4px] bg-cream object-cover"
                        />
                      ))}
                      {project.photos.length > 5 && (
                        <span class="flex size-12 shrink-0 items-center justify-center rounded-[4px] bg-cream text-xs font-bold text-muted">
                          +{project.photos.length - 5}
                        </span>
                      )}
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </div>
      )}
    </div>

  </div>
</section>

{/* ImageGallery schema removed — not a Google-supported rich result type (April 2026).
   Project photos are still visible in CompanyCam image URLs in the page HTML. */}

<style>
  /* SSR grid responsive — matches widget layout */
  @media (max-width: 1024px) {
    .bop-ssr-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 640px) {
    .bop-ssr-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- Lightbox mobile UX overrides (widget CSS/JS patches) -->
<style is:global>
  /* Force lightbox overlay above sticky nav */
  .bop-lightbox,
  [class*="lightbox-overlay"],
  #bo-portfolio ~ div[style*="position: fixed"] {
    z-index: 9999 !important;
  }
  /* Close button: enlarge to 44x44px touch target */
  .bop-lightbox-close,
  [class*="lightbox"] button[aria-label*="close" i],
  [class*="lightbox"] button[aria-label*="Close" i] {
    min-width: 44px !important;
    min-height: 44px !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
  }
</style>

<script is:inline define:vars={{ widgetUrl, widgetKey }}>
  // Load the BackOffice portfolio widget — replaces SSR content with interactive version
  (function() {
    var s = document.createElement('script');
    s.src = widgetUrl;
    s.setAttribute('data-key', widgetKey);
    s.setAttribute('data-target', 'bo-portfolio');
    s.defer = true;
    document.body.appendChild(s);

    // Patch lightbox after widget hydrates: swipe gestures + focus trapping
    s.addEventListener('load', function() {
      var observer = new MutationObserver(function(mutations) {
        for (var i = 0; i < mutations.length; i++) {
          var nodes = mutations[i].addedNodes;
          for (var j = 0; j < nodes.length; j++) {
            var node = nodes[j];
            if (node.nodeType !== 1) continue;
            var overlay = node.matches && node.matches('[style*="position: fixed"]') ? node : null;
            if (!overlay && node.querySelector) overlay = node.querySelector('[style*="position: fixed"]');
            if (overlay && !overlay._boPatched) patchLightbox(overlay);
          }
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });

    function patchLightbox(overlay) {
      overlay._boPatched = true;
      overlay.style.zIndex = '9999';

      // Find nav buttons
      var buttons = overlay.querySelectorAll('button');
      var prevBtn = null, nextBtn = null, closeBtn = null;
      buttons.forEach(function(btn) {
        var label = (btn.getAttribute('aria-label') || '').toLowerCase();
        var text = btn.textContent || '';
        if (label.includes('prev') || text.includes('‹') || text.includes('←')) prevBtn = btn;
        else if (label.includes('next') || text.includes('›') || text.includes('→')) nextBtn = btn;
        else if (label.includes('close') || text.includes('×') || text.includes('✕')) closeBtn = btn;
      });

      // Enlarge close button touch target
      if (closeBtn) {
        closeBtn.style.minWidth = '44px';
        closeBtn.style.minHeight = '44px';
      }

      // Swipe gesture support
      var startX = 0, startY = 0, tracking = false;
      overlay.addEventListener('touchstart', function(e) {
        if (e.touches.length !== 1) return;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        tracking = true;
      }, { passive: true });

      overlay.addEventListener('touchend', function(e) {
        if (!tracking) return;
        tracking = false;
        var dx = e.changedTouches[0].clientX - startX;
        var dy = e.changedTouches[0].clientY - startY;
        var absDx = Math.abs(dx), absDy = Math.abs(dy);

        // Horizontal swipe (>60px, dominant axis)
        if (absDx > 60 && absDx > absDy * 1.5) {
          if (dx < 0 && nextBtn) nextBtn.click();
          else if (dx > 0 && prevBtn) prevBtn.click();
        }
        // Vertical swipe down to dismiss (>100px)
        if (dy > 100 && absDy > absDx * 1.5 && closeBtn) {
          closeBtn.click();
        }
      }, { passive: true });

      // Focus trapping
      function getFocusable() {
        return overlay.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      }
      overlay.addEventListener('keydown', function(e) {
        if (e.key !== 'Tab') return;
        var focusable = getFocusable();
        if (focusable.length === 0) return;
        var first = focusable[0], last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });

      // Auto-focus first button
      if (closeBtn) closeBtn.focus();
    }
  })();
</script>
