---
import IconGoogle from './icons/IconGoogle.astro';
import IconYelp from './icons/IconYelp.astro';
import StarRating from './StarRating.astro';
import SectionLabel from './SectionLabel.astro';
import CTAButton from './CTAButton.astro';
import { getGoogleReviews, getDisplayReviews, GOOGLE_REVIEW_LINK } from '../lib/google-reviews';
import { getCuratedReviews } from '../data/curated-reviews';

interface Props {
  /** Service context for review selection (e.g. 'roofing', 'siding'). Default: 'general' */
  service?: 'roofing' | 'siding' | 'windows' | 'adu' | 'custom-homes' | 'additions' | 'general';
}
const { service = 'general' } = Astro.props;

const rawData = await getGoogleReviews();
const { rating, reviewCount, reviews: googleReviews } = getDisplayReviews(rawData, 2);

// Blend: 2 live Google reviews (with profile photos) + 2 curated from other platforms
const curated = getCuratedReviews(service, 2);
const reviews = [
  ...googleReviews.map(r => ({ ...r, platform: 'google' as const })),
  ...curated.map(r => ({
    author_name: r.author_name,
    rating: r.rating,
    text: r.text,
    time: Math.floor(new Date(r.date).getTime() / 1000),
    relative_time_description: r.platform === 'yelp' ? 'via Yelp' : r.platform === 'angi' ? 'via Angi' : r.platform === 'nextdoor' ? 'via Nextdoor' : `via ${r.platform}`,
    profile_photo_url: '',
    author_url: '',
    platform: r.platform,
  })),
];

const YELP_LINK = 'https://www.yelp.com/biz/hamilton-exteriors-castro-valley';
---

<section id="review" class="px-0 py-12 lg:py-20">
  <div class="mx-auto max-w-[1294px] px-[15px]">
    <!-- Section Title -->
    <div class="mb-6 lg:mb-8">
      <SectionLabel align="center">Rated {rating} ★ from {reviewCount} Verified Bay Area Homeowners</SectionLabel>
      <h2
        class="text-center font-oswald text-[clamp(30px,6vw,48px)] leading-[1.1] font-normal tracking-[-0.02em] text-heading uppercase"
      >
        What Homeowners Say About Our Work
      </h2>
      <p
        class="mt-2 text-center font-dm-sans text-[clamp(15px,2.5vw,20px)] tracking-[-0.02em] text-body lg:mt-4"
      >
        We do what we say, on time and on budget.
      </p>
    </div>

    <!-- Review Cards Grid -->
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:gap-[15px]">
      {reviews.map((review) => (
        <div
          class="flex flex-col rounded-[4px] border border-[rgb(226,226,226)] bg-white p-[20px]"
        >
          <!-- User + Google Logo Row -->
          <div class="mb-[12px] flex items-center justify-between">
            <div class="flex items-center gap-[10px]">
              {review.profile_photo_url ? (
                <img
                  src={review.profile_photo_url}
                  alt={`${review.author_name}, Hamilton Exteriors customer`}
                  width="36"
                  height="36"
                  class="size-[36px] rounded-full object-cover"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <div class="flex size-[36px] items-center justify-center rounded-full bg-(--color-primary) text-sm font-medium text-white">
                  {review.author_name.charAt(0).toUpperCase()}
                </div>
              )}
              <div>
                <p class="font-dm-sans text-[0.875rem] leading-[1.3] font-medium tracking-[-0.02em] text-body">
                  {review.author_name}
                </p>
                <p class="font-dm-sans text-[0.8125rem] leading-[1.4] font-normal tracking-[-0.02em] text-muted">
                  {review.relative_time_description}
                </p>
              </div>
            </div>
            <!-- Platform Logo -->
            {review.platform === 'yelp' ? (
              <a href={YELP_LINK} target="_blank" rel="noopener noreferrer" aria-label="View on Yelp">
                <IconYelp size={26} class="shrink-0" />
              </a>
            ) : (
              <a href={review.author_url || GOOGLE_REVIEW_LINK} target="_blank" rel="noopener noreferrer" aria-label="View on Google">
                <IconGoogle size={26} class="shrink-0" />
              </a>
            )}
          </div>

          <!-- Star Rating -->
          <StarRating size={20} class="mb-[10px]" />

          <!-- Review Text -->
          <p class="mb-[10px] line-clamp-4 font-dm-sans text-sm/normal font-normal tracking-[-0.02em] text-body">
            {review.text}
          </p>

        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <div class="mt-6 flex justify-center lg:mt-10">
      <CTAButton href="#quote" class="rounded-full! px-[30px]">Get Your Free Quote</CTAButton>
    </div>
  </div>
</section>

<!-- Review schema merged into main RoofingContractor block in Layout.astro to avoid duplicate @id -->
