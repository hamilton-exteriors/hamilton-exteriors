---
import { Image } from 'astro:assets';
import { reviewer1, reviewer2, reviewer3, reviewer4 } from '../lib/images';
import IconGoogle from './icons/IconGoogle.astro';
import StarRating from './StarRating.astro';
import CTAButton from './CTAButton.astro';

const reviews = [
  {
    photo: reviewer1,
    name: "Eric W",
    time: "2 months ago",
    date: "2026-01-15",
    text: "Hamilton Exteriors did an amazing job on my roof. The team was professional, and the quality of work was top-notch. Highly recommend!",
  },
  {
    photo: reviewer2,
    name: "Sarah M",
    time: "2 months ago",
    date: "2026-01-22",
    text: "The team at Hamilton Exteriors was respectful, on time, and did excellent work. They made sure to communicate with us throughout the entire process, ensuring we were informed every step of the way. Our new siding looks beautiful, and the quality of the materials they used is top-notch. The crew worked efficiently and left our property clean and tidy. We couldn't be happier with the final result and would highly recommend Hamilton Exteriors for any home improvement needs!",
  },
  {
    photo: reviewer3,
    name: "Robert Holt",
    time: "4 months ago",
    date: "2025-11-08",
    text: "We'd been putting off replacing the windows in our home for years, but we finally decided it was time. From the very first consultation with Hamilton Exteriors, we knew we'd made the right choice. The team was not only knowledgeable but genuinely listened to our concerns about energy efficiency and design. When the windows were installed, we were amazed at how much brighter and more comfortable our home felt. It's been a few months now, and we\u2019ve already noticed a drop in our energy bills. It's like we\u2019re living in a new house, and we couldn't be happier with the transformation!",
  },
  {
    photo: reviewer4,
    name: "Laura Gaubin",
    time: "4 months ago",
    date: "2025-12-03",
    text: "Hamilton Exteriors repaired extensive dry rot damage on our home's exterior. Their attention to detail and commitment to quality were evident throughout the project. The crew was polite, professional, and ensured the site was clean before leaving each day. Our home looks better than ever, and we have peace of mind knowing the repairs were done correctly. We highly recommend their services.",
  },
];
---

<section id="review" class="py-12 lg:py-20 px-0">
  <div class="mx-auto max-w-[1294px] px-[15px]">
    <!-- Section Title -->
    <div class="mb-6 lg:mb-8">
      <p style="font-family: var(--font-satoshi); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); text-align: center; margin-bottom: 12px;">
        Rated 4.8 ★ from 50+ Bay Area Homeowners
      </p>
      <h2
        class="text-center font-oswald font-normal uppercase leading-[1.1] tracking-[-0.02em]"
        style="font-size: clamp(30px, 6vw, 48px); color: var(--color-heading);"
      >
        What Homeowners Say About Our Work
      </h2>
      <p
        class="mt-2 text-center font-dm-sans tracking-[-0.02em] lg:mt-4"
        style="font-size: clamp(15px, 2.5vw, 20px); color: var(--color-body);"
      >
        We do what we say, on time and on budget.
      </p>
    </div>

    <!-- Review Cards Grid -->
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:gap-[15px]">
      {reviews.map((review) => (
        <div
          class="flex flex-col rounded-[4px] bg-white p-[20px]"
          style="border: 1px solid rgb(226, 226, 226);"
        >
          <!-- User + Google Logo Row -->
          <div class="mb-[12px] flex items-center justify-between">
            <div class="flex items-center gap-[10px]">
              <Image
                src={review.photo}
                alt={review.name}
                width={36}
                height={36}
                class="h-[36px] w-[36px] rounded-full object-cover"
                loading="lazy"
              />
              <div>
                <p
                  class="font-dm-sans text-[0.875rem] font-medium leading-[1.3] tracking-[-0.02em]"
                  style="color: var(--color-body);"
                >
                  {review.name}
                </p>
                <p
                  class="font-dm-sans text-[0.8125rem] font-normal leading-[1.4] tracking-[-0.02em]"
                  style="color: var(--color-muted);"
                >
                  {review.time}
                </p>
              </div>
            </div>
            <!-- Google Logo -->
            <IconGoogle size={26} class="flex-shrink-0" />
          </div>

          <!-- Star Rating -->
          <StarRating size={20} class="mb-[10px]" />

          <!-- Review Text -->
          <p
            class="mb-[10px] line-clamp-4 font-dm-sans text-[0.875rem] font-normal leading-[1.5] tracking-[-0.02em]"
            style="color: var(--color-body);"
          >
            {review.text}
          </p>

        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <div class="mt-6 flex justify-center lg:mt-10">
      <CTAButton href="#quote" class="rounded-full! px-[30px]">Get Your Free Quote</CTAButton>
    </div>
  </div>
</section>

<!-- Review schema merged into main RoofingContractor block in Layout.astro to avoid duplicate @id -->
