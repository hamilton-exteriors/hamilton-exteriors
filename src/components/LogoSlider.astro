---
import { Image } from 'astro:assets';
import { logoCert1, logoPartner1, logoGaf, logoCert2, logoPartner2 } from '../lib/images';

const logos = [
  { src: logoCert1, alt: "Owens Corning Preferred Contractor", w: 120, h: 120 },
  { src: logoPartner1, alt: "CertainTeed ShingleMaster", w: 120, h: 45 },
  { src: logoGaf, alt: "GAF Master Elite Contractor", w: 120, h: 99 },
  { src: logoCert2, alt: "Tesla Powerwall Certified", w: 120, h: 35 },
  { src: logoPartner2, alt: "James Hardie Elite Preferred", w: 120, h: 76 },
];
---

<section class="overflow-x-hidden bg-white px-5 py-8 lg:py-10">
  <div class="mx-auto max-w-[1200px]">
    <p
      class="text-center text-sm/normal text-heading"
    >
      Factory-certified by the industry's top manufacturers
    </p>

    <!-- Logos -->
    <div class="mt-5 flex flex-wrap items-center justify-center gap-6 lg:mt-8 lg:gap-12">
      {logos.map((logo) => (
        <div class="flex h-[48px] w-[90px] shrink-0 items-center justify-center lg:h-[72px] lg:w-[140px]">
          <Image
            src={logo.src}
            alt={logo.alt}
            width={logo.w}
            height={logo.h}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>
