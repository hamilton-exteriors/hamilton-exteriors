---
import { Image } from 'astro:assets';
import { logoCert1, logoPartner1, logoGaf, logoCert2, logoPartner2 } from '../lib/images';

const logos = [
  { src: logoCert1, alt: "Owens Corning Preferred Contractor", w: 280, h: 280 },
  { src: logoPartner1, alt: "CertainTeed ShingleMaster", w: 280, h: 106 },
  { src: logoGaf, alt: "GAF Certified Installer", w: 280, h: 230 },
  { src: logoCert2, alt: "Tesla Powerwall Certified", w: 147, h: 43 },
  { src: logoPartner2, alt: "James Hardie Elite Preferred", w: 280, h: 178 },
];
---

<section class="overflow-x-hidden px-5 py-8 lg:py-10" style="background-color: var(--color-white);">
  <div class="mx-auto" style="max-width: 1200px;">
    <p
      class="text-center"
      style="font-family: var(--font-dm-sans); font-size: 0.875rem; line-height: 1.5; color: var(--color-heading);"
    >
      Certified, highly trained installers delivering top-quality service.
    </p>

    <!-- Logos -->
    <div class="mt-5 flex flex-wrap items-center justify-center gap-6 lg:mt-8 lg:gap-12">
      {logos.map((logo) => (
        <div class="flex h-[48px] w-[90px] shrink-0 items-center justify-center lg:h-[72px] lg:w-[140px]">
          <Image
            src={logo.src}
            alt={logo.alt}
            width={logo.w}
            height={logo.h}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
