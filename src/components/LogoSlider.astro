---
import { Image } from 'astro:assets';
import { logoCert1, logoPartner1, logoGaf, logoCert2, logoPartner2 } from '../lib/images';

const logos = [
  { src: logoCert1, alt: "Certification Logo", w: 340, h: 364 },
  { src: logoPartner1, alt: "Partner Logo", w: 740, h: 279 },
  { src: logoGaf, alt: "GAF Logo", w: 380, h: 312 },
  { src: logoCert2, alt: "Certification Logo", w: 147, h: 43 },
  { src: logoPartner2, alt: "Partner Logo", w: 6600, h: 4200 },
];
---

<section class="overflow-x-hidden px-5 py-6 lg:py-12" style="background-color: rgb(255, 255, 255);">
  <div class="mx-auto" style="max-width: 1200px;">
    <p
      class="text-center"
      style="font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.5; color: rgb(13, 43, 29);"
    >
      Certified, highly trained installers delivering top-quality service.
    </p>

    <!-- Logos -->
    <div class="mt-5 flex flex-wrap items-center justify-center gap-6 lg:mt-8 lg:gap-12">
      {logos.map((logo) => (
        <div class="flex h-[48px] w-[90px] shrink-0 items-center justify-center lg:h-[72px] lg:w-[140px]">
          <Image
            src={logo.src}
            alt={logo.alt}
            width={logo.w}
            height={logo.h}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
