---
interface Props {
  text?: string;
}

const { text = 'Now Booking Summer 2026 — Schedule Your Consultation' } = Astro.props;
---

<div class="w-full bg-heading">
  <p
    class="px-[15px] py-2 text-center font-hamilton-display text-xs leading-[1.4] font-bold tracking-[0.06em] text-pretty text-white uppercase"
  >
    {text}
  </p>
</div>
