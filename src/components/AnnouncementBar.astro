---
interface Props {
  text?: string;
}

const { text = 'Limited Time Get up to $2000 off your Project*' } = Astro.props;
---

<div class="w-full" style="background-color: var(--color-heading);">
  <p
    class="text-pretty text-center font-oswald font-bold uppercase text-white"
    style="padding: 8px 15px; font-size: 0.75rem; line-height: 1.4; letter-spacing: 0.06em;"
  >
    {text}
  </p>
</div>
