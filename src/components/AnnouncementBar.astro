---
interface Props {
  text?: string;
}

const { text = 'Limited Time — Get up to $2000 off Your Project*' } = Astro.props;
---

<div class="w-full bg-heading">
  <p
    class="px-[15px] py-2 text-center font-oswald text-xs leading-[1.4] font-bold tracking-[0.06em] text-pretty text-white uppercase"
  >
    {text}
  </p>
</div>
