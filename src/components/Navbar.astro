---
import { Image } from 'astro:assets';
import { logoNav } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
---

<nav class="navbar sticky top-0 z-50 w-full border-b border-black/6 bg-white" aria-label="Main navigation">
  <div
    class="navbar-inner mx-auto flex max-w-[1329px] items-center justify-between gap-4 px-4 py-3"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Hamilton Exteriors — home">
      <Image
        src={logoNav}
        alt="Hamilton Exteriors"
        width={469}
        height={194}
        loading="eager"
        class="h-auto w-[143px] object-contain lg:w-[168px]"
      />
    </a>

    <!-- Nav links (flex-1, centered within available space) -->
    <div class="hidden flex-1 items-center justify-center pl-[78px] xl:flex">
      <ul class="m-0 flex list-none items-center gap-7 p-0 text-sm font-medium text-heading">
        <li><a href="/#about" class="whitespace-nowrap text-inherit no-underline">About Us</a></li>
        <li><a href="/#financing" class="whitespace-nowrap text-inherit no-underline">Financing</a></li>
        <li><a href={PHONE_HREF} class="whitespace-nowrap text-inherit no-underline">Call Us</a></li>
        <li><a href="/#service" class="whitespace-nowrap text-inherit no-underline">Services</a></li>
        <li><a href="/service-areas" class="whitespace-nowrap text-inherit no-underline">Service Areas</a></li>
        <li><a href="/#review" class="whitespace-nowrap text-inherit no-underline">Reviews</a></li>
        <li><a href="/blog" class="whitespace-nowrap text-inherit no-underline">Ground Up</a></li>
      </ul>
    </div>

    <!-- Phone -->
    <a
      href={PHONE_HREF}
      class="hidden shrink-0 text-base font-bold whitespace-nowrap text-heading transition-opacity hover:opacity-70 xl:flex"
    >
      {PHONE_DISPLAY}
    </a>

    <!-- CTA -->
    <a
      href="/#quote"
      class="hidden shrink-0 rounded-full bg-primary px-7 py-3 text-center text-[13px] leading-normal font-semibold tracking-[0.02em] whitespace-nowrap text-white transition-opacity hover:opacity-90 xl:flex"
    >
      Get Your Free Inspection
    </a>

    <!-- Mobile/Tablet -->
    <div class="ml-auto flex items-center gap-3 xl:hidden">
      <a href={PHONE_HREF} class="flex min-h-[44px] items-center text-[13px] font-bold whitespace-nowrap text-heading">{PHONE_DISPLAY}</a>
      <a
        href="/#quote"
        class="hidden shrink-0 rounded-full bg-primary px-5 py-2.5 text-center text-xs font-semibold whitespace-nowrap text-white transition-opacity hover:opacity-90 md:flex"
      >
        Free Quote
      </a>
    </div>
    <button id="menu-toggle" class="z-50 flex size-10 flex-col items-center justify-center gap-[5px] xl:hidden" aria-label="Toggle navigation menu" aria-expanded="false">
      <span class="hamburger-line block h-[2px] w-6 rounded bg-heading transition-all duration-300"></span>
      <span class="hamburger-line block h-[2px] w-6 rounded bg-heading transition-all duration-300"></span>
      <span class="hamburger-line block h-[2px] w-6 rounded bg-heading transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu absolute top-full left-0 z-40 hidden w-full bg-white shadow-lg xl:hidden" role="navigation" aria-label="Mobile navigation">
    <div class="flex flex-col items-center gap-1 px-5 py-4 font-dm-sans">
      <a href="/#about" class="flex min-h-[44px] items-center text-sm font-medium text-heading">About Us</a>
      <a href="/#financing" class="flex min-h-[44px] items-center text-sm font-medium text-heading">Financing</a>
      <a href={PHONE_HREF} class="flex min-h-[44px] items-center text-sm font-medium text-heading">Call Us</a>
      <a href="/#service" class="flex min-h-[44px] items-center text-sm font-medium text-heading">Services</a>
      <a href="/service-areas" class="flex min-h-[44px] items-center text-sm font-medium text-heading">Service Areas</a>
      <a href="/#review" class="flex min-h-[44px] items-center text-sm font-medium text-heading">Reviews</a>
      <a href="/blog" class="flex min-h-[44px] items-center text-sm font-medium text-heading">Ground Up</a>
      <hr class="w-full border-border" />
      <a href={PHONE_HREF} class="flex min-h-[44px] items-center text-base font-bold text-heading">{PHONE_DISPLAY}</a>
      <a href="/#quote" class="flex min-h-[48px] w-full max-w-xs items-center justify-center rounded-full bg-primary text-center text-sm font-semibold text-white">Get Your Free Inspection</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    const focusableSelector = 'a[href], button, input, textarea, select, [tabindex]:not([tabindex="-1"])';

    function openMenu() {
      menu.classList.remove('hidden');
      toggle.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
      document.addEventListener('keydown', trapFocus);
    }

    function closeMenu() {
      menu.classList.add('hidden');
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      document.removeEventListener('keydown', trapFocus);
      toggle.focus();
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key === 'Escape') { closeMenu(); return; }
      if (e.key !== 'Tab') return;
      const focusable = [toggle, ...menu.querySelectorAll(focusableSelector)] as HTMLElement[];
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }

    toggle.addEventListener('click', () => {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });
  }
</script>

<style>
  #menu-toggle.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #menu-toggle.open .hamburger-line:nth-child(2) { opacity: 0; }
  #menu-toggle.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
</style>
