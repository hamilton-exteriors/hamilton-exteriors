---
import { Image } from 'astro:assets';
import { logoNav } from '../lib/images';
---

<nav class="navbar w-full bg-white sticky top-0 z-50">
  <div
    class="navbar-inner mx-auto flex items-center"
    style="max-width: 1329px; padding: 14px 15px 15px; gap: 20px;"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <Image
        src={logoNav}
        alt="Hamilton Exteriors"
        width={469}
        height={194}
        loading="eager"
        class="object-contain h-auto"
        style="width: clamp(120px, 20vw, 168px);"
      />
    </a>

    <!-- Nav links (flex-1, centered within available space) -->
    <div class="hidden lg:flex items-center justify-center" style="flex: 1 0 0px; padding-left: 78px;">
      <ul style="display: flex; align-items: center; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; color: rgb(13, 43, 29); list-style: none; margin: 0; padding: 0; gap: 28px;">
        <li><a href="/#about" style="text-decoration: none; color: inherit; white-space: nowrap;">About Us</a></li>
        <li><a href="/#financing" style="text-decoration: none; color: inherit; white-space: nowrap;">Financing</a></li>
        <li><a href="/#contact" style="text-decoration: none; color: inherit; white-space: nowrap;">Contact Us</a></li>
        <li><a href="/#service" style="text-decoration: none; color: inherit; white-space: nowrap;">Services</a></li>
        <li><a href="/service-areas" style="text-decoration: none; color: inherit; white-space: nowrap;">Service Areas</a></li>
        <li><a href="/#review" style="text-decoration: none; color: inherit; white-space: nowrap;">Reviews</a></li>
      </ul>
    </div>

    <!-- Phone -->
    <a
      href="tel:6509773351"
      class="hidden lg:flex shrink-0 hover:opacity-70 transition-opacity whitespace-nowrap"
      style="font-family: 'DM Sans', sans-serif; font-size: 17px; font-weight: 700; color: rgb(13, 43, 29);"
    >
      (650) 977 - 3351
    </a>

    <!-- CTA -->
    <a
      href="/#quote"
      class="hidden lg:flex shrink-0 text-center text-white transition-opacity hover:opacity-90 whitespace-nowrap"
      style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.02em; line-height: 24px; background-color: rgb(37, 99, 70); border-radius: 8px; padding: 12px 28px;"
    >
      Schedule a FREE Inspection
    </a>

    <!-- Mobile -->
    <div class="flex lg:hidden items-center gap-3">
      <a href="tel:6509773351" class="whitespace-nowrap" style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 700; color: rgb(13, 43, 29);">(650) 977 - 3351</a>
    </div>
    <button id="menu-toggle" class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-[5px] z-50" aria-label="Toggle navigation menu" aria-expanded="false">
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu lg:hidden hidden absolute top-full left-0 w-full bg-white shadow-lg z-40">
    <div class="flex flex-col items-center gap-4 px-5 py-6" style="font-family: 'DM Sans', sans-serif;">
      <a href="/#about" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">About Us</a>
      <a href="/#financing" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">Financing</a>
      <a href="/#contact" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">Contact Us</a>
      <a href="/#service" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">Services</a>
      <a href="/service-areas" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">Service Areas</a>
      <a href="/#review" class="text-[14px] font-medium" style="color: rgb(13, 43, 29);">Reviews</a>
      <hr class="w-full border-gray-200" />
      <a href="tel:6509773351" class="text-[17px] font-bold" style="color: rgb(13, 43, 29);">(650) 977 - 3351</a>
      <a href="/#quote" class="w-full max-w-xs text-center text-white" style="font-size: 13px; font-weight: 600; background-color: rgb(37, 99, 70); border-radius: 8px; padding: 10px 24px;">Schedule a FREE Inspection</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      toggle.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!menu.classList.contains('hidden')));
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('open');
      });
    });
  }
</script>

<style>
  #menu-toggle.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #menu-toggle.open .hamburger-line:nth-child(2) { opacity: 0; }
  #menu-toggle.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
</style>
