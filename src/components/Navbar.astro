---
import { Image } from 'astro:assets';
import { logoNav } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
---

<nav class="navbar w-full bg-white sticky top-0 z-50" aria-label="Main navigation" style="border-bottom: 1px solid rgba(0,0,0,0.06);">
  <div
    class="navbar-inner mx-auto flex items-center justify-between"
    style="max-width: 1329px; padding: 12px 16px; gap: 16px;"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <Image
        src={logoNav}
        alt="Hamilton Exteriors"
        width={469}
        height={194}
        loading="eager"
        class="h-auto object-contain w-[143px] lg:w-[168px]"
      />
    </a>

    <!-- Nav links (flex-1, centered within available space) -->
    <div class="hidden xl:flex items-center justify-center" style="flex: 1 0 0px; padding-left: 78px;">
      <ul style="display: flex; align-items: center; font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 500; color: var(--color-heading); list-style: none; margin: 0; padding: 0; gap: 28px;">
        <li><a href="/#about" style="text-decoration: none; color: inherit; white-space: nowrap;">About Us</a></li>
        <li><a href="/#financing" style="text-decoration: none; color: inherit; white-space: nowrap;">Financing</a></li>
        <li><a href={PHONE_HREF} style="text-decoration: none; color: inherit; white-space: nowrap;">Call Us</a></li>
        <li><a href="/#service" style="text-decoration: none; color: inherit; white-space: nowrap;">Services</a></li>
        <li><a href="/service-areas" style="text-decoration: none; color: inherit; white-space: nowrap;">Service Areas</a></li>
        <li><a href="/#review" style="text-decoration: none; color: inherit; white-space: nowrap;">Reviews</a></li>
        <li><a href="/blog" style="text-decoration: none; color: inherit; white-space: nowrap;">Ground Up</a></li>
      </ul>
    </div>

    <!-- Phone -->
    <a
      href={PHONE_HREF}
      class="hidden xl:flex shrink-0 hover:opacity-70 transition-opacity whitespace-nowrap"
      style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 700; color: var(--color-heading);"
    >
      {PHONE_DISPLAY}
    </a>

    <!-- CTA -->
    <a
      href="/#quote"
      class="hidden xl:flex shrink-0 text-center text-white transition-opacity hover:opacity-90 whitespace-nowrap"
      style="font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.02em; line-height: 1.5; background-color: var(--color-primary); border-radius: 8px; padding: 12px 28px;"
    >
      Get Your Free Inspection
    </a>

    <!-- Mobile/Tablet -->
    <div class="flex xl:hidden items-center gap-3 ml-auto">
      <a href={PHONE_HREF} class="whitespace-nowrap min-h-[44px] flex items-center" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 700; color: var(--color-heading);">{PHONE_DISPLAY}</a>
      <a
        href="/#quote"
        class="hidden md:flex shrink-0 text-center text-white transition-opacity hover:opacity-90 whitespace-nowrap"
        style="font-family: var(--font-dm-sans); font-size: 0.75rem; font-weight: 600; background-color: var(--color-primary); border-radius: 6px; padding: 10px 20px;"
      >
        Free Quote
      </a>
    </div>
    <button id="menu-toggle" class="xl:hidden flex flex-col justify-center items-center w-10 h-10 gap-[5px] z-50" aria-label="Toggle navigation menu" aria-expanded="false">
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: var(--color-heading);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: var(--color-heading);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: var(--color-heading);"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu xl:hidden hidden absolute top-full left-0 w-full bg-white shadow-lg z-40" role="navigation" aria-label="Mobile navigation">
    <div class="flex flex-col items-center gap-1 px-5 py-4" style="font-family: var(--font-dm-sans);">
      <a href="/#about" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">About Us</a>
      <a href="/#financing" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Financing</a>
      <a href={PHONE_HREF} class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Call Us</a>
      <a href="/#service" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Services</a>
      <a href="/service-areas" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Service Areas</a>
      <a href="/#review" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Reviews</a>
      <a href="/blog" class="min-h-[44px] flex items-center text-[0.875rem] font-medium" style="color: var(--color-heading);">Ground Up</a>
      <hr class="w-full" style="border-color: var(--color-border);" />
      <a href={PHONE_HREF} class="min-h-[44px] flex items-center text-[1rem] font-bold" style="color: var(--color-heading);">{PHONE_DISPLAY}</a>
      <a href="/#quote" class="w-full max-w-xs min-h-[48px] flex items-center justify-center text-center text-white" style="font-size: 0.875rem; font-weight: 600; background-color: var(--color-primary); border-radius: 8px;">Get Your Free Inspection</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    const focusableSelector = 'a[href], button, input, textarea, select, [tabindex]:not([tabindex="-1"])';

    function openMenu() {
      menu.classList.remove('hidden');
      toggle.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
      document.addEventListener('keydown', trapFocus);
    }

    function closeMenu() {
      menu.classList.add('hidden');
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      document.removeEventListener('keydown', trapFocus);
      toggle.focus();
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key === 'Escape') { closeMenu(); return; }
      if (e.key !== 'Tab') return;
      const focusable = [toggle, ...menu.querySelectorAll(focusableSelector)] as HTMLElement[];
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }

    toggle.addEventListener('click', () => {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });
  }
</script>

<style>
  #menu-toggle.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #menu-toggle.open .hamburger-line:nth-child(2) { opacity: 0; }
  #menu-toggle.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
</style>
