---
---

<nav class="navbar w-full bg-white sticky top-0 z-50">
  <div
    class="navbar-inner mx-auto flex items-center justify-between"
    style="max-width: 1329px; padding: 14px 20px 15px;"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img
        src="https://framerusercontent.com/images/3o6dMG6rHB3zLq01KSQtoInJw.png?width=469&height=194"
        alt="Hamilton Exteriors"
        width="469"
        height="194"
        loading="eager"
        style="object-fit: contain; width: 168px; height: auto;"
      />
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links hidden lg:flex items-center gap-6" style="font-family: 'Inter', 'Inter Placeholder', sans-serif; font-size: 14px; font-weight: 500; color: rgb(13, 43, 29);">
      <li><a href="/#about" class="hover:opacity-70 transition-opacity">About Us</a></li>
      <li><a href="/#financing" class="hover:opacity-70 transition-opacity">Financing</a></li>
      <li><a href="/#contact" class="hover:opacity-70 transition-opacity">Contact Us</a></li>
      <li><a href="/#service" class="hover:opacity-70 transition-opacity">Services</a></li>
      <li><a href="/service-areas" class="hover:opacity-70 transition-opacity">Service Areas</a></li>
      <li><a href="/#review" class="hover:opacity-70 transition-opacity">Reviews</a></li>
    </ul>

    <!-- Phone + CTA (desktop) -->
    <div class="hidden lg:flex items-center gap-4">
      <a
        href="tel:6509773351"
        class="hover:opacity-70 transition-opacity whitespace-nowrap"
        style="font-family: 'Inter', 'Inter Placeholder', sans-serif; font-size: 17px; font-weight: 700; color: rgb(13, 43, 29); text-align: center;"
      >
        (650) 977 - 3351
      </a>
      <a
        href="/#quote"
        class="text-center text-white transition-opacity hover:opacity-90 whitespace-nowrap"
        style="font-family: 'Inter', 'Inter Placeholder', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.02em; line-height: 24px; background-color: rgb(37, 99, 70); border-radius: 8px; padding: 10px 24px; border: 1px solid rgb(37, 99, 70);"
      >
        Schedule a FREE Inspection
      </a>
    </div>

    <!-- Mobile phone + hamburger -->
    <div class="flex lg:hidden items-center gap-3">
      <a
        href="tel:6509773351"
        class="whitespace-nowrap"
        style="font-family: 'Inter', 'Inter Placeholder', sans-serif; font-size: 13px; font-weight: 700; color: rgb(13, 43, 29);"
      >
        (650) 977 - 3351
      </a>
    </div>
    <button
      id="menu-toggle"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-[5px] z-50"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
      <span class="hamburger-line block w-6 h-[2px] rounded transition-all duration-300" style="background-color: rgb(13, 43, 29);"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu lg:hidden hidden absolute top-full left-0 w-full bg-white shadow-lg z-40">
    <div class="flex flex-col items-center gap-4 px-5 py-6" style="font-family: 'Inter', 'Inter Placeholder', sans-serif;">
      <a href="/#about" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">About Us</a>
      <a href="/#financing" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">Financing</a>
      <a href="/#contact" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">Contact Us</a>
      <a href="/#service" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">Services</a>
      <a href="/service-areas" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">Service Areas</a>
      <a href="/#review" class="text-[14px] font-medium hover:opacity-70" style="color: rgb(13, 43, 29);">Reviews</a>
      <hr class="w-full border-gray-200" />
      <a
        href="tel:6509773351"
        class="text-[17px] font-bold"
        style="color: rgb(13, 43, 29);"
      >
        (650) 977 - 3351
      </a>
      <a
        href="/#quote"
        class="w-full max-w-xs text-center text-white transition-opacity hover:opacity-90"
        style="font-family: 'Inter', 'Inter Placeholder', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.02em; line-height: 24px; background-color: rgb(37, 99, 70); border-radius: 8px; padding: 10px 24px; border: 1px solid rgb(37, 99, 70);"
      >
        Schedule a FREE Inspection
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.classList.toggle('open');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('open');
      });
    });
  }
</script>

<style>
  /* Hamburger animation */
  #menu-toggle.open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #menu-toggle.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle.open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
