<section id="about" class="w-full py-10 lg:py-16">
  <div class="mx-auto max-w-[1200px] px-5">
    <div class="flex flex-col items-center gap-4 text-center">
      <!-- Title -->
      <h2
        style="font-family: var(--font-oswald); font-size: clamp(32px, 5vw, 40px); line-height: 1.2; font-weight: 400; color: var(--color-heading); text-transform: uppercase;"
      >
        Our Mission
      </h2>
      <!-- Body -->
      <p
