---
import { Image } from 'astro:assets';
import { hamiltonSilhouette } from '../lib/images';
---

<section id="about" class="mission-section w-full">
  <div class="mx-auto max-w-[1200px] px-5">
    <div class="flex flex-col items-center text-center">

      <!-- Hamilton silhouette (historical paper-cut portrait) -->
      <div class="mission-silhouette" aria-hidden="true">
        <Image
          src={hamiltonSilhouette}
          alt="Alexander Hamilton, the inspiration behind Hamilton Exteriors"
          width={200}
          height={240}
          class="mission-silhouette-img"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Title -->
      <h2 class="mission-title">Our Mission</h2>

      <!-- Decorative rule -->
      <div class="mission-rule" aria-hidden="true"></div>

      <!-- Body -->
      <p class="mission-body max-w-[65ch]">
        Named for the man who built our nation's foundation, Hamilton Exteriors carries that same conviction: build it right, build it to last. 50+ years of combined team experience, architect-level standards on every build, and one promise &mdash; every detail right the first time.
      </p>
    </div>
  </div>
</section>

<style>
  .mission-section {
    padding: 20px 0 48px;
  }
  @media (min-width: 1024px) {
    .mission-section {
      padding: 32px 0 64px;
    }
  }

  .mission-silhouette {
    width: 160px;
    height: 192px;
    margin-bottom: 20px;
    opacity: 0.18;
    mix-blend-mode: multiply;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .mission-silhouette {
      width: 170px;
      height: 204px;
      margin-bottom: 22px;
    }
  }
  @media (min-width: 1024px) {
    .mission-silhouette {
      width: 180px;
      height: 216px;
      margin-bottom: 24px;
    }
  }

  .mission-silhouette-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.8) brightness(0.9);
  }

  .mission-title {
    font-family: var(--font-oswald);
    font-size: clamp(2rem, 5vw, 2.5rem);
    line-height: 1.2;
    font-weight: 400;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .mission-rule {
    width: 64px;
    height: 3px;
    background: var(--color-primary);
    margin-bottom: 20px;
  }

  .mission-body {
    font-family: var(--font-dm-sans);
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 400;
    color: var(--color-body);
    margin: 0;
  }
</style>
