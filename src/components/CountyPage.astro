---
import { Image } from 'astro:assets';
import type { CountyPageData } from '../lib/county-page-types';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Reviews from './Reviews.astro';
import Difference from './Difference.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { serviceRoofing, serviceSiding, serviceWindows, serviceAdu, serviceCustomHomes, serviceAdditions } from '../lib/images';
import Breadcrumb from './Breadcrumb.astro';
import Section from './Section.astro';
import SectionLabel from './SectionLabel.astro';
import ServiceCard from './ServiceCard.astro';

interface Props {
  data: CountyPageData;
}

const { data } = Astro.props;

const services = [
  { title: 'Roofing', description: 'Full roof replacements and repairs with GAF-certified shingles and a 50-year warranty. Most jobs done in 3\u20135 days.', image: serviceRoofing, href: `/service-areas/${data.countySlug}/roofing` },
  { title: 'Siding', description: 'James Hardie fiber cement siding that protects your home and looks great for decades. We handle dry rot repair and full replacements.', image: serviceSiding, href: `/service-areas/${data.countySlug}/siding` },
  { title: 'Windows', description: 'Energy-efficient window replacements that transform comfort and curb appeal. Double-hung, casement, bay, and more.', image: serviceWindows, href: `/service-areas/${data.countySlug}/windows` },
  { title: 'ADUs', description: 'Detached ADUs, garage conversions, and junior ADUs. Design, permits, and construction from start to finish.', image: serviceAdu, href: `/service-areas/${data.countySlug}/adu` },
  { title: 'Custom Homes', description: 'Ground-up custom home construction tailored to your vision. From foundation to finishing touches.', image: serviceCustomHomes, href: `/service-areas/${data.countySlug}/custom-homes` },
  { title: 'Additions', description: 'Seamless room additions that match your home\u2019s existing style. We handle permits, design, and construction.', image: serviceAdditions, href: `/service-areas/${data.countySlug}/additions` },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': `${data.county}, ${data.state}`, 'item': `https://hamilton-exteriors.com/service-areas/${data.countySlug}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `https://hamilton-exteriors.com/service-areas/${data.countySlug}#service`,
  'name': `Custom Home & Exterior Contracting in ${data.county}, ${data.state}`,
  'description': `Hamilton Exteriors provides roofing, siding, windows, ADUs, custom homes, and additions in ${data.county}, California. Licensed general contractor (CSLB #1082377) with 50-year warranty.`,
  'url': `https://hamilton-exteriors.com/service-areas/${data.countySlug}`,
  'provider': { '@type': 'GeneralContractor', '@id': 'https://hamilton-exteriors.com/#business', 'name': 'Hamilton Exteriors' },
  'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
  'dateModified': new Date().toISOString().split('T')[0],
  'areaServed': {
    '@type': 'AdministrativeArea',
    'name': data.county,
    'sameAs': `https://en.wikipedia.org/wiki/${data.county.replace(/ County$/, '').replace(/ /g, '_')}_County,_California`,
    'containedInPlace': { '@type': 'State', 'name': 'California' },
    ...(data.proximity && {
      'geo': {
        '@type': 'GeoCoordinates',
        'longitude': parseFloat(data.proximity.split(',')[0]),
        'latitude': parseFloat(data.proximity.split(',')[1]),
      },
    }),
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<AnnouncementBar slot="header" />
<Navbar slot="header" />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: `${data.county}, ${data.state}` },
]} />

<Hero
  formTitle={data.heroFormTitle}
  headline={data.heroHeadline}
  proximity={data.proximity}
/>
<LogoSlider />

<!-- Services Grid -->
<Section bg="white" padding="lg">
  <SectionLabel class="mb-3">What We Build</SectionLabel>
  <h2
    class="mb-12 text-[clamp(28px,5vw,40px)] leading-tight"
  >
    Custom Home & Exterior Services in {data.county}
  </h2>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {services.map((service) => (
      <ServiceCard
        title={service.title}
        description={service.description}
        image={service.image}
        href={service.href}
        city={data.county}
      />
    ))}
  </div>
</Section>

<!-- County Editorial Content -->
{data.editorial && (
  <Section bg="cream" padding="md" width="narrow">
    <h2
      class="mb-6 text-[clamp(24px,4vw,32px)] leading-[1.3]"
    >
      {data.editorial.heading}
    </h2>
    {data.editorial.paragraphs.map((p) => (
      <p
        class="mb-4 text-base leading-[1.75] text-body"
        set:html={p}
      />
    ))}
  </Section>
)}

<!-- Cities Grid -->
{data.cities && data.citySectionStyle === 'label' && (
  <section class="cc-locations-section">
    <div class="cc-locations-container">
      <p class="cc-locations-label">LOCATIONS</p>
      <div class="cc-locations-grid">
        {data.cities.map((city) => (
          <a href={city.slug} class="cc-city-card">
            <div class="cc-city-card-image-wrap">
              <Image
                src={city.image}
                alt={`Hamilton Exteriors services in ${city.name}, California`}
                width={540}
                height={312}
                class="cc-city-card-image"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="cc-city-card-content">
              <h3 class="cc-city-card-name">{city.name}, CA</h3>
              <span class="cc-city-card-link">Explore Service Area &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{data.cities && data.citySectionStyle === 'heading' && (
  <section class="w-full bg-white py-20">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 class="mb-10 text-[clamp(28px,4vw,40px)] leading-[1.2]">
        Service Locations in {data.county}
      </h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {data.cities.map((city) => (
          <a href={city.slug} class="group flex flex-col overflow-hidden">
            <div class="aspect-540/312 w-full overflow-hidden">
              <Image
                src={city.image}
                alt={`Hamilton Exteriors services in ${city.name}, California`}
                width={540}
                height={312}
                class="size-full object-cover transition-opacity group-hover:opacity-90"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="px-5 pt-4 pb-5">
              <h3 class="m-0 mb-2 text-lg">
                {city.name}, CA
              </h3>
              <span class="text-sm font-medium text-primary group-hover:underline">
                Explore Service Area &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<Reviews />
<Difference />
<FAQ />
<ContactUs />
<Footer slot="footer" />

<style>
  /* ========== CONTRA COSTA LOCATIONS ========== */
  .cc-locations-section {
    width: 100%;
    background-color: var(--color-white);
    padding: 80px 0;
  }
  .cc-locations-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 15px;
  }
  .cc-locations-label {
    font-family: var(--font-satoshi);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-heading);
    margin: 0 0 32px 0;
  }
  .cc-locations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 1023px) {
    .cc-locations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    .cc-locations-grid {
      grid-template-columns: 1fr;
    }
  }
  .cc-city-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
  }
  .cc-city-card-image-wrap {
    width: 100%;
    aspect-ratio: 540 / 312;
    overflow: hidden;
  }
  .cc-city-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .cc-city-card:hover .cc-city-card-image {
    opacity: 0.9;
  }
  .cc-city-card-content {
    padding: 16px 20px 20px;
  }
  .cc-city-card-name {
    font-family: var(--font-oswald);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 0 0 8px 0;
  }
  .cc-city-card-link {
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }
  .cc-city-card:hover .cc-city-card-link {
    text-decoration: underline;
  }
</style>
