---
import { Image } from 'astro:assets';
import type { CountyPageData } from '../lib/county-page-types';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Reviews from './Reviews.astro';
import Difference from './Difference.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { serviceRoofing, serviceSiding, serviceWindows, serviceAdu, serviceCustomHomes, serviceAdditions } from '../lib/images';
import Breadcrumb from './Breadcrumb.astro';
import SectionLabel from './SectionLabel.astro';
import ServiceCard from './ServiceCard.astro';

interface Props {
  data: CountyPageData;
}

const { data } = Astro.props;

const services = [
  { title: 'Roofing', description: 'Full roof replacements and repairs with GAF-certified shingles and a 50-year warranty. Most jobs done in 3\u20135 days.', image: serviceRoofing, href: `/service-areas/${data.countySlug}/roofing` },
  { title: 'Siding', description: 'James Hardie fiber cement siding that protects your home and looks great for decades. We handle dry rot repair and full replacements.', image: serviceSiding, href: `/service-areas/${data.countySlug}/siding` },
  { title: 'Windows', description: 'Energy-efficient window replacements that transform comfort and curb appeal. Double-hung, casement, bay, and more.', image: serviceWindows, href: `/service-areas/${data.countySlug}/windows` },
  { title: 'ADUs', description: 'Detached ADUs, garage conversions, and junior ADUs. Design, permits, and construction from start to finish.', image: serviceAdu, href: `/service-areas/${data.countySlug}/adu` },
  { title: 'Custom Homes', description: 'Ground-up custom home construction tailored to your vision. From foundation to finishing touches.', image: serviceCustomHomes, href: `/service-areas/${data.countySlug}/custom-homes` },
  { title: 'Additions', description: 'Seamless room additions that match your home\u2019s existing style. We handle permits, design, and construction.', image: serviceAdditions, href: `/service-areas/${data.countySlug}/additions` },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': `${data.county}, ${data.state}`, 'item': `https://hamilton-exteriors.com/service-areas/${data.countySlug}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  'name': `Roofing and Exterior Services in ${data.county}, ${data.state}`,
  'url': `https://hamilton-exteriors.com/service-areas/${data.countySlug}`,
  'provider': { '@type': 'RoofingContractor', '@id': 'https://hamilton-exteriors.com/#business', 'name': 'Hamilton Exteriors' },
  'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
  'areaServed': {
    '@type': 'County',
    'name': data.county,
    'sameAs': `https://en.wikipedia.org/wiki/${data.county.replace(/ County$/, '').replace(/ /g, '_')}_County,_California`,
    'containedInPlace': { '@type': 'State', 'name': 'California' },
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<AnnouncementBar />
<Navbar />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: `${data.county}, ${data.state}` },
]} />

<Hero
  formTitle={data.heroFormTitle}
  headline={data.heroHeadline}
  proximity={data.proximity}
/>
<LogoSlider />

<!-- Services Grid -->
<section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
  <div class="mx-auto max-w-[1200px] px-5">
    <SectionLabel class="mb-3">Our Services</SectionLabel>
    <h2
      style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); line-height: 1.25; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 48px;"
    >
      Design-Build Services in {data.county}
    </h2>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          image={service.image}
          href={service.href}
          city={data.county}
        />
      ))}
    </div>
  </div>
</section>

<!-- Cities Grid -->
{data.cities && data.citySectionStyle === 'label' && (
  <section class="cc-locations-section">
    <div class="cc-locations-container">
      <p class="cc-locations-label">LOCATIONS</p>
      <div class="cc-locations-grid">
        {data.cities.map((city) => (
          <a href={city.slug} class="cc-city-card">
            <div class="cc-city-card-image-wrap">
              <Image
                src={city.image}
                alt={`Hamilton Exteriors services in ${city.name}, California`}
                width={540}
                height={312}
                class="cc-city-card-image"
                loading="lazy"
              />
            </div>
            <div class="cc-city-card-content">
              <h3 class="cc-city-card-name">{city.name}, CA</h3>
              <span class="cc-city-card-link">Explore Service Area &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{data.cities && data.citySectionStyle === 'heading' && (
  <section class="w-full bg-white" style="padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 40px;">
        Service Locations in {data.county}
      </h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {data.cities.map((city) => (
          <a href={city.slug} class="group flex flex-col overflow-hidden">
            <div class="w-full overflow-hidden" style="aspect-ratio: 540/312;">
              <Image
                src={city.image}
                alt={`Hamilton Exteriors services in ${city.name}, California`}
                width={540}
                height={312}
                class="h-full w-full object-cover transition-opacity group-hover:opacity-90"
                loading="lazy"
              />
            </div>
            <div style="padding: 16px 20px 20px;">
              <h3 style="font-size: 1.125rem; margin: 0 0 8px;">
                {city.name}, CA
              </h3>
              <span style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 500; color: var(--color-primary);" class="group-hover:underline">
                Explore Service Area &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<Reviews />
<Difference />
<FAQ />
<ContactUs />
<Footer />

<style>
  /* ========== CONTRA COSTA LOCATIONS ========== */
  .cc-locations-section {
    width: 100%;
    background-color: var(--color-white);
    padding: 80px 0;
  }
  .cc-locations-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 15px;
  }
  .cc-locations-label {
    font-family: var(--font-satoshi);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-heading);
    margin: 0 0 32px 0;
  }
  .cc-locations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 1023px) {
    .cc-locations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    .cc-locations-grid {
      grid-template-columns: 1fr;
    }
  }
  .cc-city-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
  }
  .cc-city-card-image-wrap {
    width: 100%;
    aspect-ratio: 540 / 312;
    overflow: hidden;
  }
  .cc-city-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .cc-city-card:hover .cc-city-card-image {
    opacity: 0.9;
  }
  .cc-city-card-content {
    padding: 16px 20px 20px;
  }
  .cc-city-card-name {
    font-family: var(--font-oswald);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 0 0 8px 0;
  }
  .cc-city-card-link {
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }
  .cc-city-card:hover .cc-city-card-link {
    text-decoration: underline;
  }
</style>
