          <a href="/service-areas/santa-clara-county-ca/san-jose-ca" class="footer-area-city">San Jose</a>
          <a href="/service-areas/santa-clara-county-ca/palo-alto-ca" class="footer-area-city">Palo Alto</a>
          <a href="/service-areas/santa-clara-county-ca/sunnyvale-ca" class="footer-area-city">Sunnyvale</a>
          <a href="/service-areas/santa-clara-county-ca/mountain-view-ca" class="footer-area-city">Mountain View</a>
          <a href="/service-areas/santa-clara-county-ca/cupertino-ca" class="footer-area-city">Cupertino</a>
          <a href="/service-areas/santa-clara-county-ca/santa-clara-ca" class="footer-area-city">Santa Clara</a>
          <a href="/service-areas/santa-clara-county-ca/saratoga-ca" class="footer-area-city">Saratoga</a>
          <a href="/service-areas/santa-clara-county-ca/los-gatos-ca" class="footer-area-city">Los Gatos</a>
          <a href="/service-areas/santa-clara-county-ca/campbell-ca" class="footer-area-city">Campbell</a>
          <a href="/service-areas/santa-clara-county-ca/milpitas-ca" class="footer-area-city">Milpitas</a>
        </div>
        <div>
          <a href="/service-areas/marin-county-ca" class="footer-area-county">Marin County</a>
          <a href="/service-areas/marin-county-ca/san-rafael-ca" class="footer-area-city">San Rafael</a>
          <a href="/service-areas/marin-county-ca/mill-valley-ca" class="footer-area-city">Mill Valley</a>
