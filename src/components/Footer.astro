          <a href="/service-areas/napa-county-ca/american-canyon-ca" class="footer-area-city">American Canyon</a>
          <a href="/service-areas/napa-county-ca/st-helena-ca" class="footer-area-city">St. Helena</a>
          <a href="/service-areas/napa-county-ca/calistoga-ca" class="footer-area-city">Calistoga</a>
          <a href="/service-areas/napa-county-ca/yountville-ca" class="footer-area-city">Yountville</a>
        </div>
        <div>
          <a href="/service-areas/san-mateo-county-ca" class="footer-area-county">San Mateo County</a>
          <a href="/service-areas/san-mateo-county-ca/redwood-city-ca" class="footer-area-city">Redwood City</a>
          <a href="/service-areas/san-mateo-county-ca/san-mateo-ca" class="footer-area-city">San Mateo</a>
          <a href="/service-areas/san-mateo-county-ca/burlingame-ca" class="footer-area-city">Burlingame</a>
          <a href="/service-areas/san-mateo-county-ca/daly-city-ca" class="footer-area-city">Daly City</a>
          <a href="/service-areas/san-mateo-county-ca/south-san-francisco-ca" class="footer-area-city">South San Francisco</a>
        </div>
      </div>
      <a href="/service-areas" class="mt-4 inline-flex min-h-[44px] items-center text-xs text-white-65 underline underline-offset-2">View all service areas &rarr;</a>
    </div>
  </div>

  <!-- Entity description — citable by AI search, visible to crawlers -->
  <div class="mx-auto max-w-[1170px] px-4 lg:px-5">
    <p class="border-t border-white/10 pt-6 pb-2 text-center text-xs/relaxed text-white/80 lg:text-left">
      Hamilton Exteriors (DBA of ABR Quality Resources Inc) is a licensed California general contractor (CSLB #1082377), serving the Bay Area since 2018. Roofing, siding, windows, ADUs, and custom homes. One of fewer than 2% of Bay Area contractors to hold GAF Master Elite, Owens Corning Preferred, and CertainTeed ShingleMaster certifications.
    </p>
  </div>

  <!-- Bottom Row -->
  <div class="mx-auto max-w-[1170px] px-4 md:px-5">
    <div class="flex flex-col items-center gap-4 border-t border-white/20 py-6 md:flex-row md:justify-between">
      <!-- Social Icons -->
      <div class="flex items-center gap-1">
        <a href="https://www.facebook.com/hamiltonexteriors" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
          <IconFacebook size={15} />
        </a>
        <a href="https://www.instagram.com/hamiltonexteriors" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
          <IconInstagram size={20} />
        </a>
        <a href="https://www.linkedin.com/company/hamilton-exteriors/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
          <IconLinkedIn size={20} />
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-center text-xs text-white md:text-right">
        &copy;{new Date().getFullYear()} Hamilton Exteriors. All rights reserved.
      </p>
    </div>
