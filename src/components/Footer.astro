---
---

<footer class="w-full" style="background-color: rgb(36, 99, 69);">
  <div class="mx-auto" style="max-width: 1170px; padding: 40px 15px;">
    <div class="flex flex-col lg:flex-row lg:justify-between" style="gap: 40px;">

      <!-- Column 1: Logo + Info -->
      <div class="flex flex-col items-center lg:items-start" style="max-width: 395px; gap: 16px;">
        <div class="relative" style="width: 395px; max-width: 100%;">
          <img
            src="https://framerusercontent.com/images/0aDBLFP1ZZRBrQhrlh2Hk7vABw0.png?scale-down-to=512&width=804&height=804"
            alt="Hamilton Exteriors"
            width="395"
            height="162"
            style="display: block; width: 100%; height: auto; object-fit: contain;"
            loading="lazy"
          />
        </div>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 600; line-height: 24px; color: rgb(255, 255, 255); text-align: center; margin: 0;" class="lg:!text-left">
          Hamilton Exteriors collects certain categories of personal information. See links for more information.
        </p>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 600; line-height: 24px; color: rgb(255, 255, 255); text-align: center; margin: 0;" class="lg:!text-left">
          Get in Touch: <a href="tel:6509773351" style="color: rgb(255, 255, 255); text-decoration: underline;">(650) 977-3351</a>
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="flex flex-col items-center lg:items-start" style="gap: 16px;">
        <h3 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 30px; font-weight: 400; color: rgb(255, 255, 255); text-transform: uppercase; margin: 0; line-height: 1.2;">
          QUICK LINKS
        </h3>
        <nav class="flex flex-col items-center lg:items-start" style="gap: 6px;">
          <a href="/terms" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; line-height: 21.98px; color: rgb(255, 255, 255); text-decoration: underline;">Terms</a>
          <a href="/privacy-policy" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; line-height: 21.98px; color: rgb(255, 255, 255); text-decoration: underline;">Privacy Policy</a>
          <a href="/privacy-notice-ca" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; line-height: 21.98px; color: rgb(255, 255, 255); text-decoration: underline;">Privacy Notice for CA Residents</a>
          <a href="/eeo-policy" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; line-height: 21.98px; color: rgb(255, 255, 255); text-decoration: underline;">EEO Policy</a>
          <a href="/opt-out" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; line-height: 21.98px; color: rgb(255, 255, 255); text-decoration: underline;">Opt Out of Sale or Sharing of Personal Information</a>
        </nav>
      </div>

      <!-- Column 3: Newsletter + Reviews -->
      <div class="flex flex-col items-center lg:items-start" style="max-width: 410px; gap: 20px;">
        <p style="font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 600; line-height: 24px; color: rgb(255, 255, 255); text-align: center; margin: 0;" class="lg:!text-left">
          Stay updated with offers and new offerings by subscribing to our newsletter.
        </p>

        <form class="flex w-full flex-col" style="gap: 12px; max-width: 380px;">
          <input
            type="text"
            name="footerName"
            placeholder="Name"
            style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'Inter', sans-serif; font-size: 14px; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
          />
          <input
            type="email"
            name="footerEmail"
            placeholder="Email"
            required
            style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'Inter', sans-serif; font-size: 14px; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
          />
          <button
            type="submit"
            style="width: 100%; border-radius: 10px; background-color: rgb(51, 51, 51); border: none; padding: 10px 16px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: rgb(255, 255, 255); cursor: pointer;"
          >
            Submit
          </button>
        </form>

        <!-- Review Logos -->
        <p style="font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 600; line-height: 24px; color: rgb(255, 255, 255); text-align: center; margin: 0;">
          Drop Us A Review:
        </p>
        <div class="flex flex-wrap items-center justify-center lg:justify-start" style="gap: 12px;">
          <a href="https://g.page/r/review" target="_blank" rel="noopener noreferrer">
            <img
              src="https://framerusercontent.com/images/mwg7oWLIjDpZD9neoc91Eozu2Xg.webp?width=239&height=80"
              alt="Review us on Google"
              width="239"
              height="80"
              style="display: block; height: 60px; width: auto;"
              loading="lazy"
            />
          </a>
          <a href="https://facebook.com/review" target="_blank" rel="noopener noreferrer">
            <img
              src="https://framerusercontent.com/images/L5mdjaOkshmej3y5gGT4JoIxKQ.webp?width=239&height=80"
              alt="Review us on Facebook"
              width="239"
              height="80"
              style="display: block; height: 60px; width: auto;"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="mx-auto" style="max-width: 1170px; padding: 0 15px;">
    <div data-border="true" style="border-top: 1px solid rgb(196, 191, 182); padding: 30px 0 40px;">
      <div class="flex flex-col items-center gap-5 md:flex-row md:justify-between md:items-center">
        <!-- Social Icons -->
        <div class="flex items-center" style="gap: 16px;">
