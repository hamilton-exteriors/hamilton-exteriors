---
import { Image } from 'astro:assets';
import { logoFooter, badgeGoogle, badgeYelp } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF, CSLB_URL } from '../lib/constants';
import IconFacebook from './icons/IconFacebook.astro';
import IconInstagram from './icons/IconInstagram.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
---

<footer class="w-full bg-footer">
  <div class="mx-auto max-w-[1170px] px-4 py-12 lg:px-5 lg:py-16">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-16">

      <!-- Column 1: Logo + Info -->
      <div class="flex flex-col items-center gap-5 lg:max-w-[320px] lg:items-start">
        <Image
          src={logoFooter}
          alt="Hamilton Exteriors"
          width={395}
          height={162}
          class="w-full max-w-[250px]"
          loading="lazy"
          decoding="async"
        />
        <p class="text-center text-sm/relaxed text-white/80 lg:text-left">
          500+ roofing, siding, and construction projects across the Bay Area. Licensed, bonded, and insured.
        </p>
        <p class="text-center text-xs/relaxed text-white/80 lg:text-left">
          <a href={CSLB_URL} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 transition-colors hover:text-white/90">CSLB License #1082377</a> &middot; <a href="https://maps.google.com/?cid=3578771346418026097" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 transition-colors hover:text-white/90">Google Business Profile</a>
        </p>
        <a href={PHONE_HREF} class="font-oswald text-2xl font-bold tracking-wide text-white underline underline-offset-4 lg:text-3xl">
          {PHONE_DISPLAY}
        </a>
        <address class="text-center text-xs/relaxed text-white/80 not-italic lg:text-left">
          21634 Redwood Rd Unit F, Castro Valley, CA 94546
        </address>
      </div>

      <!-- Column 2: Services -->
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <h3 class="font-oswald text-xl font-bold tracking-[0.06em] text-white uppercase">
          Services
        </h3>
        <nav class="flex flex-col items-center gap-1.5 lg:items-start lg:gap-2">
          <a href="/roofing" class="footer-link flex min-h-[44px] items-center">Roofing</a>
          <a href="/siding" class="footer-link flex min-h-[44px] items-center">Siding</a>
          <a href="/windows" class="footer-link flex min-h-[44px] items-center">Windows</a>
          <a href="/adu" class="footer-link flex min-h-[44px] items-center">ADUs</a>
          <a href="/custom-homes" class="footer-link flex min-h-[44px] items-center">Custom Homes</a>
          <a href="/additions" class="footer-link flex min-h-[44px] items-center">Additions</a>
        </nav>
      </div>

      <!-- Column 3: Quick Links -->
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <h3 class="font-oswald text-xl font-bold tracking-[0.06em] text-white uppercase">
          Quick Links
        </h3>
        <nav class="flex flex-col items-center gap-1.5 lg:items-start lg:gap-2">
          <a href="/terms" class="footer-link flex min-h-[44px] items-center">Terms</a>
          <a href="/privacy-policy" class="footer-link flex min-h-[44px] items-center">Privacy Policy</a>
          <a href="/privacy-notice-ca" class="footer-link flex min-h-[44px] items-center">Privacy Notice for CA Residents</a>
          <a href="/eeo-policy" class="footer-link flex min-h-[44px] items-center">EEO Policy</a>
          <a href="/opt-out" class="footer-link flex min-h-[44px] items-center">Opt Out</a>
          <a href="/blog" class="footer-link flex min-h-[44px] items-center">Ground Up</a>
          <a href="/service-areas" class="footer-link flex min-h-[44px] items-center">Service Areas</a>
        </nav>
      </div>

      <!-- Column 4: Newsletter + Reviews -->
      <div class="flex w-full flex-col items-center gap-5 lg:w-auto lg:max-w-[320px] lg:items-start">
        <h3 class="font-oswald text-xl font-bold tracking-[0.06em] text-white uppercase">
          Newsletter
        </h3>
        <p class="text-center text-sm/relaxed text-white/80 lg:text-left">
          Seasonal maintenance tips, project spotlights, and Bay Area building insights.
        </p>

        <form id="newsletter-form" class="flex w-full flex-col gap-3 lg:max-w-[320px]">
          <label for="footerName" class="sr-only">Name</label>
          <input
            type="text"
            id="footerName"
            name="footerName"
            placeholder="Your name"
            maxlength="100"
            class="footer-input"
          />
          <label for="footerEmail" class="sr-only">Email</label>
          <input
            type="email"
            id="footerEmail"
            name="footerEmail"
            placeholder="Your email"
            required
            maxlength="254"
            class="footer-input"
          />
          <button
            type="submit"
            class="footer-btn"
            data-track="newsletter_submit"
          >
            Subscribe
          </button>
          <p id="newsletter-msg" class="text-center text-sm" style="display: none;" aria-live="polite"></p>
        </form>

        <!-- Review Badges -->
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2 lg:justify-start">
          <a href="https://maps.google.com/?cid=3578771346418026097" target="_blank" rel="noopener noreferrer" aria-label="Google reviews">
            <Image
              src={badgeGoogle}
              alt="Hamilton Exteriors on Google — 4.8 stars"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
              decoding="async"
            />
          </a>
          <a href="https://www.yelp.com/biz/hamilton-exteriors-castro-valley" target="_blank" rel="noopener noreferrer" aria-label="Yelp reviews">
            <Image
              src={badgeYelp}
              alt="Hamilton Exteriors on Yelp"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
        <a
          href="https://maps.google.com/?cid=3578771346418026097"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-sm font-medium text-white/70 underline underline-offset-2 transition-colors hover:text-white/90"
        >
          Leave us a review on Google
        </a>
      </div>
    </div>
  </div>

  <!-- Service Areas -->
  <div class="mx-auto max-w-[1170px] px-4 lg:px-5">
    <div class="border-t border-white/10 pt-8 pb-4">
