</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement;
  let submitting = false;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitting) return;
    submitting = true;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const original = btn.textContent || '';
    btn.disabled = true;
    btn.textContent = 'Sending...';
    msg.style.display = 'none';
    try {
      const res = await fetch('/api/newsletter', { method: 'POST', body: new FormData(form) });
      const data = await res.json();
      if (res.ok) {
        const nlEmail = (new FormData(form).get('footerEmail') as string) || '';
        const nlName = (new FormData(form).get('footerName') as string) || '';
        if (nlEmail) {
          window.op?.('identify', {
            profileId: nlEmail,
            email: nlEmail,
            firstName: nlName.split(' ')[0] || '',
            lastName: nlName.split(' ').slice(1).join(' ') || '',
          });
        }
        window.op?.('track', 'newsletter_subscribed', { source: 'footer' });
        window.dataLayer?.push({ event: 'newsletter_subscribed', source: 'footer' });
        msg.textContent = 'You\'re in! Watch your inbox.';
        msg.style.color = 'var(--color-green-light)';
        form.reset();
      } else {
        msg.textContent = data.error || 'We couldn\'t sign you up. Please try again.';
        msg.style.color = 'var(--color-yellow)';
      }
    } catch {
      msg.textContent = 'Network error. Please try again.';
      msg.style.color = 'var(--color-yellow)';
    }
    msg.style.display = 'block';
    btn.disabled = false;
    btn.textContent = original;
    submitting = false;
  });

  // Collapse footer service areas on mobile by default
  if (window.innerWidth < 768) {
    const details = document.querySelector('.footer-areas-details');
    if (details) details.removeAttribute('open');
  }
</script>

<style>
  .bg-footer {
    background-color: var(--color-footer);
  }
  .bg-primary {
    background-color: var(--color-primary);
  }
  .footer-link {
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--color-white-80);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }
  .footer-link:hover {
    color: var(--color-white);
  }
  .footer-input {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    color: var(--color-white);
    outline: none;
    transition: border-color 0.2s ease-out;
  }
  .footer-input::placeholder {
    color: var(--color-white-45);
  }
  .footer-input:focus {
    border-color: var(--color-yellow);
    box-shadow: 0 0 0 2px rgba(255, 222, 33, 0.15);
  }
  footer {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white-70);
    width: 44px;
    height: 44px;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease-out;
  }
  .social-icon:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .footer-area-county {
    display: flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--font-dm-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-white-70);
    text-decoration: none;
    margin-bottom: 0;
    transition: color 0.2s ease-out;
  }
  .footer-area-county:hover {
    color: var(--color-white);
  }
  .footer-area-city {
    display: flex;
    align-items: center;
    font-family: var(--font-dm-sans);
    font-size: 0.75rem;
    line-height: 1.9;
    color: var(--color-white-65);
    text-decoration: none;
    transition: color 0.2s ease-out;
    min-height: 44px;
    padding-block: 2px;
  }
  .footer-area-city:hover {
    color: var(--color-white-80);
  }
  .footer-btn {
    width: 100%;
    border-radius: 0.5rem;
    background-color: var(--color-yellow);
    border: none;
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: var(--font-oswald);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-heading);
    cursor: pointer;
    transition: background-color 0.2s ease-out;
  }
  .footer-btn:hover {
    filter: brightness(0.92);
  }
  footer a:focus-visible,
  footer button:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
