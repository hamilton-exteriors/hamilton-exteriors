---
import { Image } from 'astro:assets';
import { logoFooter, badgeGoogle, badgeYelp } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconFacebook from './icons/IconFacebook.astro';
import IconInstagram from './icons/IconInstagram.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
---

<footer class="w-full bg-footer">
  <div class="mx-auto max-w-[1170px] px-4 py-12 lg:px-5 lg:py-16">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-16">

      <!-- Column 1: Logo + Info -->
      <div class="flex flex-col items-center gap-5 lg:items-start lg:max-w-[320px]">
        <Image
          src={logoFooter}
          alt="Hamilton Exteriors"
          width={395}
          height={162}
          class="w-full max-w-[250px]"
          loading="lazy"
        />
        <p class="text-center text-sm leading-relaxed text-white/70 lg:text-left">
          500+ roofing, siding, and construction projects across the Bay Area. Licensed, bonded, and insured.
        </p>
        <p class="text-center text-xs leading-relaxed text-white/50 lg:text-left">
          CSLB License #1082377 &middot; <a href="https://www.google.com/maps/place/Hamilton+Exteriors" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-white/70 transition-colors">Google Business Profile</a>
        </p>
        <a href={PHONE_HREF} class="font-oswald text-xl font-bold tracking-wide text-white underline underline-offset-4">
          {PHONE_DISPLAY}
        </a>
      </div>

      <!-- Column 2: Services -->
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <h3 class="font-oswald text-xl font-bold uppercase tracking-[0.06em] text-white">
          Services
        </h3>
        <nav class="flex flex-col items-center gap-1.5 lg:items-start lg:gap-2">
          <a href="/roofing" class="footer-link min-h-[44px] flex items-center">Roofing</a>
          <a href="/siding" class="footer-link min-h-[44px] flex items-center">Siding</a>
          <a href="/windows" class="footer-link min-h-[44px] flex items-center">Windows</a>
          <a href="/adu" class="footer-link min-h-[44px] flex items-center">ADUs</a>
          <a href="/custom-homes" class="footer-link min-h-[44px] flex items-center">Custom Homes</a>
          <a href="/additions" class="footer-link min-h-[44px] flex items-center">Additions</a>
        </nav>
      </div>

      <!-- Column 3: Quick Links -->
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <h3 class="font-oswald text-xl font-bold uppercase tracking-[0.06em] text-white">
          Quick Links
        </h3>
        <nav class="flex flex-col items-center gap-1.5 lg:items-start lg:gap-2">
          <a href="/terms" class="footer-link min-h-[44px] flex items-center">Terms</a>
          <a href="/privacy-policy" class="footer-link min-h-[44px] flex items-center">Privacy Policy</a>
          <a href="/privacy-notice-ca" class="footer-link min-h-[44px] flex items-center">Privacy Notice for CA Residents</a>
          <a href="/eeo-policy" class="footer-link min-h-[44px] flex items-center">EEO Policy</a>
          <a href="/opt-out" class="footer-link min-h-[44px] flex items-center">Opt Out</a>
          <a href="/blog" class="footer-link min-h-[44px] flex items-center">Blog</a>
          <a href="/service-areas" class="footer-link min-h-[44px] flex items-center">Service Areas</a>
        </nav>
      </div>

      <!-- Column 4: Newsletter + Reviews -->
      <div class="flex w-full flex-col items-center gap-5 lg:w-auto lg:items-start lg:max-w-[320px]">
        <h3 class="font-oswald text-xl font-bold uppercase tracking-[0.06em] text-white">
          Newsletter
        </h3>
        <p class="text-center text-sm leading-relaxed text-white/70 lg:text-left">
          Seasonal tips, project updates, and exclusive financing offers.
        </p>

        <form id="newsletter-form" class="flex w-full flex-col gap-3 lg:max-w-[320px]" action="/api/newsletter" method="POST">
          <label for="footerName" class="sr-only">Name</label>
          <input
            type="text"
            id="footerName"
            name="footerName"
            placeholder="Name"
            maxlength="100"
            class="footer-input"
          />
          <label for="footerEmail" class="sr-only">Email</label>
          <input
            type="email"
            id="footerEmail"
            name="footerEmail"
            placeholder="Email"
            required
            maxlength="254"
            class="footer-input"
          />
          <button
            type="submit"
            class="footer-btn"
          >
            SIGN ME UP
          </button>
          <p id="newsletter-msg" class="text-center text-sm" style="display: none;" aria-live="polite"></p>
        </form>

        <!-- Review Badges -->
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2 lg:justify-start">
          <a href="https://www.google.com/maps/place/Hamilton+Exteriors" target="_blank" rel="noopener noreferrer" aria-label="Google reviews">
            <Image
              src={badgeGoogle}
              alt="Hamilton Exteriors on Google — 4.8 stars"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
            />
          </a>
          <a href="https://www.yelp.com/biz/hamilton-exteriors-castro-valley" target="_blank" rel="noopener noreferrer" aria-label="Yelp reviews">
            <Image
              src={badgeYelp}
              alt="Hamilton Exteriors on Yelp"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
            />
          </a>
        </div>
        <a
          href="https://www.google.com/maps/place/Hamilton+Exteriors"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-2 text-sm font-medium text-white/60 underline underline-offset-2 transition-colors hover:text-white/80"
          style="font-family: var(--font-dm-sans);"
        >
          Leave us a review on Google
        </a>
      </div>
    </div>
  </div>

  <!-- Service Areas -->
  <div class="mx-auto max-w-[1170px] px-4 lg:px-5">
    <div class="border-t border-white/10 pt-8 pb-4">
      <h3 class="font-oswald text-sm font-bold uppercase tracking-[0.1em] text-white/60 mb-4">Service Areas</h3>
      <div class="grid grid-cols-2 gap-x-6 gap-y-3 sm:grid-cols-3 md:grid-cols-5">
        <div>
          <a href="/service-areas/alameda-county-ca" class="footer-area-county">Alameda County</a>
          <a href="/service-areas/alameda-county-ca/oakland-ca" class="footer-area-city">Oakland</a>
          <a href="/service-areas/alameda-county-ca/berkeley-ca" class="footer-area-city">Berkeley</a>
          <a href="/service-areas/alameda-county-ca/fremont-ca" class="footer-area-city">Fremont</a>
          <a href="/service-areas/alameda-county-ca/hayward-ca" class="footer-area-city">Hayward</a>
          <a href="/service-areas/alameda-county-ca/san-leandro-ca" class="footer-area-city">San Leandro</a>
        </div>
        <div>
          <a href="/service-areas/contra-costa-county-ca" class="footer-area-county">Contra Costa County</a>
          <a href="/service-areas/contra-costa-county-ca/walnut-creek-ca" class="footer-area-city">Walnut Creek</a>
          <a href="/service-areas/contra-costa-county-ca/concord-ca" class="footer-area-city">Concord</a>
          <a href="/service-areas/contra-costa-county-ca/san-ramon-ca" class="footer-area-city">San Ramon</a>
          <a href="/service-areas/contra-costa-county-ca/richmond-ca" class="footer-area-city">Richmond</a>
          <a href="/service-areas/contra-costa-county-ca/antioch-ca" class="footer-area-city">Antioch</a>
        </div>
        <div>
          <a href="/service-areas/santa-clara-county-ca" class="footer-area-county">Santa Clara County</a>
          <a href="/service-areas/santa-clara-county-ca/san-jose-ca" class="footer-area-city">San Jose</a>
          <a href="/service-areas/santa-clara-county-ca/palo-alto-ca" class="footer-area-city">Palo Alto</a>
          <a href="/service-areas/santa-clara-county-ca/sunnyvale-ca" class="footer-area-city">Sunnyvale</a>
          <a href="/service-areas/santa-clara-county-ca/mountain-view-ca" class="footer-area-city">Mountain View</a>
          <a href="/service-areas/santa-clara-county-ca/cupertino-ca" class="footer-area-city">Cupertino</a>
        </div>
        <div>
          <a href="/service-areas/marin-county-ca" class="footer-area-county">Marin County</a>
          <a href="/service-areas/marin-county-ca/san-rafael-ca" class="footer-area-city">San Rafael</a>
          <a href="/service-areas/marin-county-ca/mill-valley-ca" class="footer-area-city">Mill Valley</a>
          <a href="/service-areas/marin-county-ca/novato-ca" class="footer-area-city">Novato</a>
          <a href="/service-areas/marin-county-ca/larkspur-ca" class="footer-area-city">Larkspur</a>
        </div>
        <div>
          <a href="/service-areas/napa-county-ca" class="footer-area-county">Napa County</a>
          <a href="/service-areas/napa-county-ca/napa-ca" class="footer-area-city">Napa</a>
          <a href="/service-areas/napa-county-ca/american-canyon-ca" class="footer-area-city">American Canyon</a>
          <a href="/service-areas/napa-county-ca/st-helena-ca" class="footer-area-city">St. Helena</a>
          <a href="/service-areas/napa-county-ca/calistoga-ca" class="footer-area-city">Calistoga</a>
          <a href="/service-areas/napa-county-ca/yountville-ca" class="footer-area-city">Yountville</a>
        </div>
      </div>
      <a href="/service-areas" class="inline-block mt-4" style="font-family: var(--font-dm-sans); font-size: 0.75rem; color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">View all service areas &rarr;</a>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="mx-auto max-w-[1170px] px-4 md:px-5">
    <div class="flex flex-col items-center gap-4 border-t border-white/20 py-6 md:flex-row md:justify-between">
      <!-- Social Icons -->
      <div class="flex items-center gap-1">
        <a href="https://www.facebook.com/hamiltonexteriors" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
          <IconFacebook size={15} />
        </a>
        <a href="https://www.instagram.com/hamiltonexteriors" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
          <IconInstagram size={20} />
        </a>
        <a href="https://www.linkedin.com/company/hamilton-exteriors/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
          <IconLinkedIn size={20} />
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-center text-xs text-white/60 md:text-right">
        &copy;{new Date().getFullYear()} Hamilton Exteriors, Inc. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement;
  let submitting = false;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitting) return;
    submitting = true;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const original = btn.textContent || '';
    btn.disabled = true;
    btn.textContent = 'Sending...';
    msg.style.display = 'none';
    try {
      const res = await fetch('/api/newsletter', { method: 'POST', body: new FormData(form) });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = 'You\'re in! Watch your inbox.';
        msg.style.color = 'var(--color-green-light)';
        form.reset();
      } else {
        msg.textContent = data.error || 'Something went wrong. Try again.';
        msg.style.color = 'var(--color-yellow)';
      }
    } catch {
      msg.textContent = 'Network error. Please try again.';
      msg.style.color = 'var(--color-yellow)';
    }
    msg.style.display = 'block';
    btn.disabled = false;
    btn.textContent = original;
    submitting = false;
  });

  // Collapse footer service areas on mobile by default
  if (window.innerWidth < 768) {
    const details = document.querySelector('.footer-areas-details');
    if (details) details.removeAttribute('open');
  }
</script>

<style>
  .bg-footer {
    background-color: var(--color-footer);
  }
  .bg-primary {
    background-color: var(--color-primary);
  }
  .footer-link {
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }
  .footer-link:hover {
    color: var(--color-white);
  }
  .footer-input {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: var(--font-dm-sans);
    font-size: 0.875rem;
    color: var(--color-white);
    outline: none;
    transition: border-color 0.2s ease-out;
  }
  .footer-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }
  .footer-input:focus {
    border-color: var(--color-yellow);
    box-shadow: 0 0 0 2px rgba(255, 222, 33, 0.15);
  }
  footer {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    width: 44px;
    height: 44px;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease-out;
  }
  .social-icon:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .footer-area-county {
    display: block;
    font-family: var(--font-dm-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    margin-bottom: 6px;
    transition: color 0.2s ease-out;
  }
  .footer-area-county:hover {
    color: var(--color-white);
  }
  .footer-area-city {
    display: flex;
    align-items: center;
    font-family: var(--font-dm-sans);
    font-size: 0.75rem;
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s ease-out;
    min-height: 44px;
    padding-block: 2px;
  }
  .footer-area-city:hover {
    color: rgba(255, 255, 255, 0.8);
  }
  .footer-btn {
    width: 100%;
    border-radius: 0.5rem;
    background-color: var(--color-yellow);
    border: none;
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: var(--font-oswald);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-heading);
    cursor: pointer;
    transition: transform 0.2s ease-out, background-color 0.2s ease-out;
  }
  .footer-btn:hover {
    background-color: rgb(240, 208, 20);
  }
  footer a:focus-visible,
  footer button:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
