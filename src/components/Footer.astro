          <a href="/service-areas/alameda-county-ca/oakland-ca" class="footer-area-city">Oakland</a>
          <a href="/service-areas/alameda-county-ca/berkeley-ca" class="footer-area-city">Berkeley</a>
          <a href="/service-areas/alameda-county-ca/fremont-ca" class="footer-area-city">Fremont</a>
          <a href="/service-areas/alameda-county-ca/hayward-ca" class="footer-area-city">Hayward</a>
          <a href="/service-areas/alameda-county-ca/san-leandro-ca" class="footer-area-city">San Leandro</a>
          <a href="/service-areas/alameda-county-ca/dublin-ca" class="footer-area-city">Dublin</a>
          <a href="/service-areas/alameda-county-ca/pleasanton-ca" class="footer-area-city">Pleasanton</a>
          <a href="/service-areas/alameda-county-ca/livermore-ca" class="footer-area-city">Livermore</a>
          <a href="/service-areas/alameda-county-ca/union-city-ca" class="footer-area-city">Union City</a>
          <a href="/service-areas/alameda-county-ca/alameda-ca" class="footer-area-city">Alameda</a>
        </div>
        <div>
          <a href="/service-areas/contra-costa-county-ca" class="footer-area-county">Contra Costa County</a>
          <a href="/service-areas/contra-costa-county-ca/walnut-creek-ca" class="footer-area-city">Walnut Creek</a>
          <a href="/service-areas/contra-costa-county-ca/concord-ca" class="footer-area-city">Concord</a>
          <a href="/service-areas/contra-costa-county-ca/san-ramon-ca" class="footer-area-city">San Ramon</a>
          <a href="/service-areas/contra-costa-county-ca/richmond-ca" class="footer-area-city">Richmond</a>
          <a href="/service-areas/contra-costa-county-ca/antioch-ca" class="footer-area-city">Antioch</a>
          <a href="/service-areas/contra-costa-county-ca/lafayette-ca" class="footer-area-city">Lafayette</a>
          <a href="/service-areas/contra-costa-county-ca/orinda-ca" class="footer-area-city">Orinda</a>
          <a href="/service-areas/contra-costa-county-ca/danville-ca" class="footer-area-city">Danville</a>
          <a href="/service-areas/contra-costa-county-ca/brentwood-ca" class="footer-area-city">Brentwood</a>
          <a href="/service-areas/contra-costa-county-ca/pittsburg-ca" class="footer-area-city">Pittsburg</a>
