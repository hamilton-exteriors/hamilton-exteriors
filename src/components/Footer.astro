---
import { Image } from 'astro:assets';
import { logoFooter, badgeGoogle, badgeYelp } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconFacebook from './icons/IconFacebook.astro';
import IconTwitter from './icons/IconTwitter.astro';
import IconInstagram from './icons/IconInstagram.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
import IconYouTube from './icons/IconYouTube.astro';
---

<footer class="w-full bg-footer">
  <div class="mx-auto max-w-[1170px] px-4 py-12 lg:px-5 lg:py-16">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-16">

      <!-- Column 1: Logo + Info -->
      <div class="flex flex-col items-center gap-5 lg:items-start lg:max-w-[320px]">
        <Image
          src={logoFooter}
          alt="Hamilton Exteriors"
          width={395}
          height={162}
          class="w-full max-w-[250px]"
          loading="lazy"
        />
        <p class="text-center text-sm leading-relaxed text-white/70 lg:text-left">
          Serving the Bay Area with roofing, siding, and window installations since 2020. Licensed, bonded, and insured.
        </p>
        <a href={PHONE_HREF} class="font-oswald text-xl font-bold tracking-wide text-white underline underline-offset-4">
          {PHONE_DISPLAY}
        </a>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <h3 class="font-oswald text-xl font-bold uppercase tracking-[0.06em] text-white">
          Quick Links
        </h3>
        <nav class="flex flex-col items-center gap-1.5 lg:items-start lg:gap-2">
          <a href="/terms" class="footer-link min-h-[44px] flex items-center">Terms</a>
          <a href="/privacy-policy" class="footer-link min-h-[44px] flex items-center">Privacy Policy</a>
          <a href="/privacy-notice-ca" class="footer-link min-h-[44px] flex items-center">Privacy Notice for CA Residents</a>
          <a href="/eeo-policy" class="footer-link min-h-[44px] flex items-center">EEO Policy</a>
          <a href="/opt-out" class="footer-link min-h-[44px] flex items-center">Opt Out</a>
          <a href="/blog" class="footer-link min-h-[44px] flex items-center">Blog</a>
        </nav>
      </div>

      <!-- Column 3: Newsletter + Reviews -->
      <div class="flex w-full flex-col items-center gap-5 lg:w-auto lg:items-start lg:max-w-[320px]">
        <h3 class="font-oswald text-xl font-bold uppercase tracking-[0.06em] text-white">
          Newsletter
        </h3>
        <p class="text-center text-sm leading-relaxed text-white/80 lg:text-left">
          Stay updated with offers and new services.
        </p>

        <form class="flex w-full flex-col gap-3 lg:max-w-[320px]" action="/api/newsletter" method="POST">
          <label for="footerName" class="sr-only">Name</label>
          <input
            type="text"
            id="footerName"
            name="footerName"
            placeholder="Name"
            class="footer-input"
          />
          <label for="footerEmail" class="sr-only">Email</label>
          <input
            type="email"
            id="footerEmail"
            name="footerEmail"
            placeholder="Email"
            required
            class="footer-input"
          />
          <button
            type="submit"
            class="footer-btn"
          >
            GET UPDATES
          </button>
        </form>

        <!-- Review Badges -->
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2 lg:justify-start">
          <a href="https://g.page/r/review" target="_blank" rel="noopener noreferrer" aria-label="Review us on Google">
            <Image
              src={badgeGoogle}
              alt="Review us on Google"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
            />
          </a>
          <a href="https://yelp.com/review" target="_blank" rel="noopener noreferrer" aria-label="Review us on Yelp">
            <Image
              src={badgeYelp}
              alt="Review us on Yelp"
              width={239}
              height={80}
              class="h-10 w-auto"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="mx-auto max-w-[1170px] px-5">
    <div class="flex flex-col items-center gap-4 border-t border-white/20 py-6 md:flex-row md:justify-between">
      <!-- Social Icons -->
      <div class="flex items-center gap-1">
        <!-- TODO: Replace with actual company social URLs -->
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
          <IconFacebook size={15} />
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="social-icon">
          <IconTwitter size={20} />
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
          <IconInstagram size={20} />
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
          <IconLinkedIn size={20} />
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-icon">
          <IconYouTube size={20} />
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-center text-xs text-white/60 md:text-right">
        &copy;{new Date().getFullYear()} Hamilton Exteriors, Inc. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .bg-footer {
    background-color: var(--color-primary-dark);
  }
  .bg-primary {
    background-color: var(--color-primary);
  }
  .footer-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }
  .footer-link:hover {
    color: var(--color-white);
  }
  .footer-input {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid rgba(196, 191, 182, 0.8);
    background-color: var(--color-white);
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: var(--color-charcoal);
    outline: none;
    transition: border-color 0.2s ease-out;
  }
  .footer-input::placeholder {
    color: rgb(140, 140, 140);
  }
  .footer-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(37, 99, 70, 0.2);
  }
  footer {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease-out;
  }
  .social-icon:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .footer-btn {
    width: 100%;
    border-radius: 0.5rem;
    background-color: var(--color-yellow);
    border: none;
    padding: 0.75rem 1rem;
    min-height: 44px;
    font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-primary-dark);
    cursor: pointer;
    transition: transform 0.2s ease-out, background-color 0.2s ease-out;
  }
  .footer-btn:hover {
    background-color: rgb(240, 208, 20);
    transform: scale(1.02);
  }
  footer a:focus-visible,
  footer button:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
