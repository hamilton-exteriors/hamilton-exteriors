---
/**
 * SubServicePage — focused landing page for individual service types.
 * e.g., /roofing/asphalt-shingles, /siding/fiber-cement, /windows/casement
 *
 * Simpler than ServicePage — content-focused with clear CTA path.
 */
import type { SubServiceData } from '../data/sub-services';
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import LogoSlider from './LogoSlider.astro';
import Section from './Section.astro';
import SectionLabel from './SectionLabel.astro';
import Reviews from './Reviews.astro';
import CTA from './CTA.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import Breadcrumb from './Breadcrumb.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getSubServicesForParent } from '../data/sub-services';

interface Props {
  data: SubServiceData;
}

const { data } = Astro.props;

const siteUrl = 'https://hamilton-exteriors.com';
const pageUrl = `${siteUrl}/${data.parentService}/${data.typeSlug}`;

// Sibling sub-services for cross-linking
const siblings = getSubServicesForParent(data.parentService)
  .filter(s => s.typeSlug !== data.typeSlug);

// Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: data.parentName, item: `${siteUrl}/${data.parentService}` },
    { '@type': 'ListItem', position: 3, name: data.headline.replace('\n', ' '), item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}#service`,
  name: data.title.split('|')[0].trim(),
  url: pageUrl,
  description: data.description,
  provider: { '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'San Mateo County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
};

// Product schema for material/product sub-service pages (roofing materials, siding, windows)
// Maps parentService/typeSlug → Product schema data
const PRODUCT_SCHEMA_MAP: Record<string, { name: string; brand?: string; category: string; lowPrice: number; highPrice: number; unit: string; description: string }> = {
  'roofing/asphalt-shingles': { name: 'Asphalt Shingle Roofing', brand: 'GAF, CertainTeed, Owens Corning', category: 'Roofing Materials', lowPrice: 950, highPrice: 1400, unit: 'per roofing square (100 sq ft)', description: 'Architectural asphalt composite shingle roof installation with Class A fire rating and 50-year system warranty.' },
  'roofing/metal': { name: 'Standing Seam Metal Roofing', category: 'Roofing Materials', lowPrice: 1200, highPrice: 1800, unit: 'per roofing square (100 sq ft)', description: 'Standing seam metal roof installation in steel or aluminum with 40–70 year lifespan and 70% solar heat reflection.' },
  'roofing/tile': { name: 'Clay & Concrete Tile Roofing', category: 'Roofing Materials', lowPrice: 1400, highPrice: 2500, unit: 'per roofing square (100 sq ft)', description: 'Clay and concrete tile roof installation with 75–100 year lifespan and Class A fire resistance.' },
  'roofing/energy': { name: 'GAF Energy Roof System', brand: 'GAF', category: 'Solar Roofing', lowPrice: 1800, highPrice: 2800, unit: 'per roofing square (100 sq ft)', description: 'Integrated solar shingle roofing system with 30% federal tax credit and 80–95% energy offset.' },
  'siding/vinyl': { name: 'Vinyl Siding', brand: 'CertainTeed, Ply Gem', category: 'Siding Materials', lowPrice: 450, highPrice: 600, unit: 'per square (100 sq ft)', description: 'Premium insulated vinyl siding with 60+ color options and lifetime owner warranty.' },
  'siding/fiber-cement': { name: 'James Hardie Fiber Cement Siding', brand: 'James Hardie', category: 'Siding Materials', lowPrice: 800, highPrice: 1200, unit: 'per square (100 sq ft)', description: 'HZ5 fiber cement siding with ColorPlus factory finish, Class A fire resistance, and 86% resale ROI.' },
  'siding/stucco': { name: 'Three-Coat Stucco Siding', category: 'Siding Materials', lowPrice: 800, highPrice: 1100, unit: 'per square (100 sq ft)', description: 'Traditional three-coat stucco exterior with one-hour fire rating and 50–80 year lifespan.' },
  'windows/single-hung': { name: 'Single Hung Windows', brand: 'Milgard, Andersen', category: 'Replacement Windows', lowPrice: 600, highPrice: 1200, unit: 'per window installed', description: 'Single hung replacement windows with dual-pane Low-E glass, U-factor 0.25, and tilt-in cleaning.' },
  'windows/single-slider': { name: 'Single Slider Windows', brand: 'Milgard, Andersen', category: 'Replacement Windows', lowPrice: 600, highPrice: 1100, unit: 'per window installed', description: 'Horizontal single slider windows with Low-E glass, no exterior clearance required.' },
  'windows/sliding-glass-doors': { name: 'Sliding Glass Doors', brand: 'Milgard, Andersen, Marvin', category: 'Patio Doors', lowPrice: 1500, highPrice: 12000, unit: 'per door installed', description: 'Multi-pane sliding glass doors from 5–16 ft wide with multi-point locking and ADA-compliant options.' },
  'windows/picture': { name: 'Picture Windows', category: 'Replacement Windows', lowPrice: 800, highPrice: 2500, unit: 'per window installed', description: 'Large fixed-pane picture windows with U-factor 0.20 (triple-pane) and sizes up to 8×6 ft.' },
  'windows/double-hung': { name: 'Double Hung Windows', brand: 'Andersen, Marvin, Pella', category: 'Replacement Windows', lowPrice: 700, highPrice: 1500, unit: 'per window installed', description: 'Classic double hung windows with two operable sashes, tilt-in cleaning, and period-accurate profiles.' },
  'windows/casement': { name: 'Casement Windows', brand: 'Andersen, Marvin, Milgard', category: 'Replacement Windows', lowPrice: 800, highPrice: 1500, unit: 'per window installed', description: 'Crank-open casement windows with 50–90% more airflow, U-factor 0.22, and tightest seal of any operable window.' },
};

const productKey = `${data.parentService}/${data.typeSlug}`;
const productData = PRODUCT_SCHEMA_MAP[productKey];

const productSchema = productData ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${pageUrl}#product`,
  'name': productData.name,
  'description': productData.description,
  'url': pageUrl,
  'category': productData.category,
  ...(productData.brand && {
    'brand': productData.brand.includes(',')
      ? productData.brand.split(', ').map(b => ({ '@type': 'Brand', 'name': b }))
      : { '@type': 'Brand', 'name': productData.brand },
  }),
  'manufacturer': productData.brand && !productData.brand.includes(',')
    ? { '@type': 'Organization', 'name': productData.brand }
    : undefined,
  'offers': {
    '@type': 'AggregateOffer',
    'lowPrice': productData.lowPrice,
    'highPrice': productData.highPrice,
    'priceCurrency': 'USD',
    'unitText': productData.unit,
    'availability': 'https://schema.org/InStock',
    'seller': { '@id': `${siteUrl}/#business` },
    'areaServed': { '@type': 'State', 'name': 'California' },
    'priceValidUntil': `${new Date().getFullYear()}-12-31`,
  },
} : null;
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
{productSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
)}

<AnnouncementBar slot="header" />
<Navbar slot="header" />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: data.parentName, href: `/${data.parentService}` },
  { label: data.headline.replace('\n', ' ') },
]} />

<!-- Hero — image with overlay text -->
<section class="relative min-h-[420px] w-full" aria-label={`${data.headline.replace('\n', ' ')} hero`}>
  <Image
    src={data.heroImage}
    alt={data.heroAlt}
    width={1440}
    height={600}
    class="block h-[420px] w-full object-cover"
    loading="eager"
    decoding="async"
  />
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(26,26,26,0.85) 0%, rgba(26,26,26,0.4) 100%);">
    <div class="mx-auto flex h-full max-w-[1200px] flex-col justify-center px-5">
      <a
        href={`/${data.parentService}`}
        class="mb-4 inline-block font-satoshi text-xs font-semibold tracking-[0.12em] text-yellow uppercase no-underline transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-charcoal focus-visible:outline-none rounded-sm"
      >
        &larr; All {data.parentName}
      </a>
      <h1 class="max-w-[600px] text-[clamp(36px,6vw,56px)] leading-[1.15] whitespace-pre-line text-white">
        {data.headline}
      </h1>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="#quote"
          class="inline-block rounded-full bg-yellow px-8 py-3.5 font-oswald text-base font-bold tracking-[0.04em] text-heading uppercase no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-charcoal focus-visible:outline-none"
        >
          Get a Free Estimate
        </a>
        <a
          href={PHONE_HREF}
          class="inline-block rounded-full border-2 border-white/40 px-7 py-3 text-sm font-semibold text-white no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-charcoal focus-visible:outline-none"
        >
          {PHONE_DISPLAY}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Logo Slider -->
<LogoSlider />

<!-- Author/date line -->
<div class="mx-auto max-w-[800px] px-5 pt-6 pb-2">
  <p class="text-[13px] text-muted">
    Reviewed by <a href="/about/alex-hamilton-li" class="text-muted underline underline-offset-2 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none rounded-sm">Alexander Hamilton Li</a>, Architect &amp; General Contractor · <a href="https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377" target="_blank" rel="noopener noreferrer" class="text-muted underline underline-offset-2 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none rounded-sm">CSLB #1082377</a> · Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
  </p>
</div>

<!-- Main Content -->
<Section bg="white" padding="lg" width="narrow">
  <div class="service-intro flex flex-col gap-6">
    {data.content.map((paragraph) => (
      <p class="text-[1.0625rem] leading-[1.8] text-charcoal">
        {paragraph}
      </p>
    ))}
  </div>
</Section>

<!-- Key Facts -->
<Section bg="cream" padding="md" width="narrow">
  <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
    {data.keyFacts.map((fact) => (
      <div class="flex flex-col">
        <span class="font-oswald text-[clamp(1.5rem,3.5vw,2rem)] leading-[1.2] font-normal text-primary">
          {fact.value}
        </span>
        <span class="mt-1 text-[0.8125rem] text-muted">
          {fact.label}
        </span>
      </div>
    ))}
  </div>
</Section>

<!-- Reviews -->
<Reviews />

<!-- FAQ -->
<FAQ extraFaqs={data.faqs} />

<!-- Inline CTA -->
<Section bg="cream" padding="md">
  <div class="text-center" aria-label="Get a quote">
    <h2 class="mb-4">Get Your {data.headline.replace('\n', ' ')} Estimate</h2>
    <p class="mx-auto mb-7 max-w-[480px] text-base text-muted">
      Free estimate for your {data.headline.replace('\n', ' ').toLowerCase()} project. We respond in minutes, not days.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a
        href="#quote"
        class="inline-block rounded-full bg-yellow px-9 py-3.5 font-oswald text-base font-bold tracking-[0.04em] text-heading uppercase no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-yellow focus-visible:ring-offset-2 focus-visible:outline-none"
      >
        Get Your Free Estimate
      </a>
      <a
        href={PHONE_HREF}
        class="inline-block rounded-full border-2 border-primary px-8 py-3 text-sm font-semibold text-primary no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none"
      >
        Call {PHONE_DISPLAY}
      </a>
    </div>
  </div>
</Section>

<!-- Cross-links to sibling sub-services -->
{siblings.length > 0 && (
  <Section bg="white" padding="md" borderTop>
    <SectionLabel>Other {data.parentName} Options</SectionLabel>
    <div class="mt-4 flex flex-wrap gap-3">
      {siblings.map((s) => (
        <a
          href={`/${s.parentService}/${s.typeSlug}`}
          class="rounded-full border border-border px-5 py-2.5 text-sm font-medium text-primary no-underline transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          {s.headline.replace('\n', ' ')}
        </a>
      ))}
    </div>
  </Section>
)}

<!-- Contact -->
<div id="quote" class="scroll-mt-16"></div>
<ContactUs />

<!-- Footer -->
<Footer slot="footer" />
