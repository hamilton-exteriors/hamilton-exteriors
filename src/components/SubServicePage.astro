---
/**
 * SubServicePage — focused landing page for individual service types.
 * e.g., /roofing/asphalt-shingles, /siding/fiber-cement, /windows/casement
 *
 * Simpler than ServicePage — content-focused with clear CTA path.
 */
import type { SubServiceData } from '../data/sub-services';
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import LogoSlider from './LogoSlider.astro';
import Section from './Section.astro';
import SectionLabel from './SectionLabel.astro';
import Reviews from './Reviews.astro';
import CTA from './CTA.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import Breadcrumb from './Breadcrumb.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getSubServicesForParent } from '../lib/ghost';

interface Props {
  data: SubServiceData;
}

const { data } = Astro.props;

const siteUrl = 'https://hamilton-exteriors.com';
const pageUrl = `${siteUrl}/${data.parentService}/${data.typeSlug}`;

// Sibling sub-services for cross-linking
const siblings = (await getSubServicesForParent(data.parentService))
  .filter(s => s.typeSlug !== data.typeSlug);

// Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: data.parentName, item: `${siteUrl}/${data.parentService}` },
    { '@type': 'ListItem', position: 3, name: data.headline.replace('\n', ' '), item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}#service`,
  name: data.title.split('|')[0].trim(),
  url: pageUrl,
  description: data.description,
  provider: { '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'San Mateo County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
};

