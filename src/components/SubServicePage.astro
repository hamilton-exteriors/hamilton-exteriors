    <div class="overflow-x-auto mb-12 -mx-5 px-5 md:mx-0 md:px-0">
      <table class="w-full min-w-[540px] text-[0.9375rem] leading-[1.6] border-collapse">
        <thead>
          <tr>
            {geoData.comparisonColumns.map((col) => (
              <th
                class="bg-primary px-4 py-3 text-left font-satoshi text-xs font-semibold tracking-[0.08em] text-white uppercase first:rounded-tl-md last:rounded-tr-md"
              >
                {col}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {geoData.comparisonRows.map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-cream/50' : 'bg-white'}>
              {geoData.comparisonColumns.map((col, j) => (
                <td class={`px-4 py-3 text-charcoal ${j === 0 ? 'font-medium' : ''}`}>
                  {row[col]}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
