---
const features = [
  {
    title: 'Best Price Guarantee',
    description:
      "We'll beat any written estimate on the same scope of work. That's our guarantee.",
  },
  {
    title: 'Factory Trained Installers',
    description:
      'Every crew member is licensed, bonded, insured, and passes background and business screening before they step on your property.',
  },
  {
    title: '50-Year Warranty',
    description:
      '50-year shingle warranty plus 35-year labor warranty. If anything fails, we fix it free.',
  },
  {
    title: 'Your Own Project Manager',
    description:
      'One person manages your project start to finish — you get one call, not ten.',
  },
];
