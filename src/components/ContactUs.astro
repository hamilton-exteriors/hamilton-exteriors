---
import { Image } from 'astro:assets';
import { iconContactMap, iconContactPhone, iconContactEmail, iconContactClock } from '../lib/images';

interface Props {
  formAction?: string;
}

const { formAction = '/success' } = Astro.props;
---

<section id="contact" class="w-full py-10 lg:py-16" style="background-color: rgb(255, 255, 255);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px; padding: 0 15px; gap: 42px;">

    <!-- Left Column — Contact Info + Map Image -->
    <div class="flex w-full flex-col lg:w-1/2">
      <!-- Map/Illustration -->
      <div class="relative w-full" style="aspect-ratio: auto;">
        <Image
          src={iconContactMap}
          alt="Service area map"
          width={566}
          height={501}
          class="w-full"
          style="object-fit: cover; object-position: center top;"
          loading="lazy"
        />
      </div>

      <!-- Contact details -->
      <div class="flex flex-col gap-4 mt-6">
        <!-- Phone -->
        <div class="flex items-center gap-2.5">
          <div class="shrink-0" style="width: 17px; height: 17px; position: relative;">
            <Image
              src={iconContactPhone}
              alt=""
              width={17}
              height={17}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <a
            href="tel:6509773351"
            style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading); text-decoration: none;"
          >
            (650) 977-3351
          </a>
        </div>

        <!-- Email -->
        <div class="flex items-center gap-2.5">
          <div class="shrink-0" style="width: 16px; height: 13px; position: relative;">
            <Image
              src={iconContactEmail}
              alt=""
              width={16}
              height={13}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <a
            href="mailto:support@hamilton-exteriors.com"
            style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading); text-decoration: none;"
          >
            support@hamilton-exteriors.com
          </a>
        </div>

        <!-- Address -->
        <div class="flex items-start gap-2.5">
          <div class="shrink-0" style="width: 12px; height: 18px; position: relative; margin-top: 3px;">
            <Image
              src={iconContactClock}
              alt=""
              width={12}
              height={18}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <span style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading);">
            21634 Redwood Rd Unit F Castro Valley CA 94546
          </span>
        </div>
      </div>
    </div>

    <!-- Right Column — CTA -->
    <div class="flex w-full flex-col items-center justify-center lg:w-1/2 py-10 lg:py-16">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(28px, 5vw, 40px); font-weight: 400; line-height: 1.25; color: var(--color-heading); text-transform: uppercase; margin: 0; text-align: center;">
        Ready to Start?
      </h2>
      <p class="mt-2 text-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; line-height: 1.5; color: var(--color-muted); max-width: 30ch;">
        Fill out the form above and we'll call you within 5 minutes to schedule your free inspection.
      </p>
      <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row">
        <a
          href="#quote"
          class="inline-flex items-center justify-center rounded-full px-8 py-4 transition-all hover:scale-[1.02]"
          style="background-color: var(--color-yellow); color: var(--color-primary); font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 0.875rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; text-decoration: none;"
        >
          Get Your Free Quote
        </a>
        <a
          href="tel:6509773351"
          class="inline-flex items-center justify-center gap-2 rounded-full border px-6 py-3 transition-opacity hover:opacity-80"
          style="border-color: var(--color-border); color: var(--color-heading); font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 600; text-decoration: none;"
        >
          Or Call (650) 977-3351
        </a>
      </div>
    </div>
  </div>
</section>
