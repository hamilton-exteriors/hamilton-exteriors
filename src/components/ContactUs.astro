---
import { Image } from 'astro:assets';
import { iconContactMap, iconContactPhone, iconContactEmail, iconContactClock } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF, EMAIL, ADDRESS } from '../lib/constants';
---

<section id="contact" class="w-full" style="background-color: var(--color-heading);">
  <div class="mx-auto max-w-[1170px] px-5 py-16 md:py-20">

    <!-- Two-column layout -->
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:justify-between md:gap-16">

      <!-- Left: Heading + CTA -->
      <div class="flex flex-col items-start md:max-w-[520px]">
        <h2
          style="font-family: var(--font-oswald); font-size: clamp(32px, 5vw, 48px); font-weight: 400; line-height: 1.1; text-transform: uppercase; margin: 0;"
        >
          <span style="color: var(--color-white);">Let's Get Your</span><br/>
          <span style="color: var(--color-green-light);">Project Moving</span>
        </h2>
        <p class="mt-4" style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.7; color: rgba(255,255,255,0.7); max-width: 42ch;">
          Call us or fill out the form above. We'll get back to you within 5 minutes to schedule your free inspection.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:flex-wrap">
          <a
            href="#quote"
            class="inline-flex items-center justify-center w-full sm:w-auto px-12 py-4 transition-all hover:opacity-90"
            style="background-color: var(--color-yellow); color: var(--color-heading); font-family: var(--font-oswald); font-size: 0.875rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; text-decoration: none; border-radius: 6px; min-width: 220px;"
          >
            Get Your Free Quote
          </a>
          <a
            href={PHONE_HREF}
            class="inline-flex items-center justify-center w-full sm:w-auto px-12 py-4 transition-all hover:opacity-90"
            style="border: 1px solid rgba(255,255,255,0.25); color: var(--color-white); font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 6px; min-width: 220px;"
          >
            Call {PHONE_DISPLAY}
          </a>
        </div>
      </div>

      <!-- Right: Map + Address -->
      <div class="w-full md:max-w-[480px]">
        <div style="border-radius: 12px; overflow: hidden;">
          <Image
            src={iconContactMap}
            alt="Hamilton Exteriors service area map"
            width={566}
            height={501}
            class="w-full"
            style="object-fit: cover; display: block;"
            loading="lazy"
          />
        </div>
        <p class="mt-4" style="font-family: var(--font-dm-sans); font-size: 0.875rem; line-height: 1.5; color: rgba(255,255,255,0.6);">
          {ADDRESS}
        </p>
      </div>

    </div>
  </div>
</section>
