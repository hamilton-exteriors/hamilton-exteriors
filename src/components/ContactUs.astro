---
import { Image } from 'astro:assets';
import { iconContactMap, iconContactPhone, iconContactEmail, iconContactClock } from '../lib/images';

interface Props {
  formAction?: string;
}

const { formAction = '/success' } = Astro.props;
---

<section id="contact" class="w-full py-10 lg:py-16" style="background-color: rgb(255, 255, 255);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px; padding: 0 15px; gap: 42px;">

    <!-- Left Column — Contact Info + Map Image -->
    <div class="flex w-full flex-col lg:w-1/2">
      <!-- Map/Illustration -->
      <div class="relative w-full" style="aspect-ratio: auto;">
        <Image
          src={iconContactMap}
          alt="Service area map"
          width={566}
          height={501}
          class="w-full"
          style="object-fit: cover; object-position: center top;"
          loading="lazy"
        />
      </div>

      <!-- Contact details -->
      <div class="flex flex-col gap-4 mt-6">
        <!-- Phone -->
        <div class="flex items-center gap-2.5">
          <div class="shrink-0" style="width: 17px; height: 17px; position: relative;">
            <Image
              src={iconContactPhone}
              alt=""
              width={17}
              height={17}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <a
            href="tel:6509773351"
            style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: rgb(13, 43, 29); text-decoration: none;"
          >
            (650) 977-3351
          </a>
        </div>

        <!-- Email -->
        <div class="flex items-center gap-2.5">
          <div class="shrink-0" style="width: 16px; height: 13px; position: relative;">
            <Image
              src={iconContactEmail}
              alt=""
              width={16}
              height={13}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <a
            href="mailto:support@hamilton-exteriors.com"
            style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: rgb(13, 43, 29); text-decoration: none;"
          >
            support@hamilton-exteriors.com
          </a>
        </div>

        <!-- Address -->
        <div class="flex items-start gap-2.5">
          <div class="shrink-0" style="width: 12px; height: 18px; position: relative; margin-top: 3px;">
            <Image
              src={iconContactClock}
              alt=""
              width={12}
              height={18}
              style="display: block; width: 100%; height: 100%; object-fit: contain;"
            />
          </div>
          <span style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: rgb(13, 43, 29);">
            21634 Redwood Rd Unit F Castro Valley CA 94546
          </span>
        </div>
      </div>
    </div>

    <!-- Right Column — Form -->
    <div class="flex w-full flex-col lg:w-1/2 py-8 lg:py-10">
      <!-- Title wrap -->
      <div>
        <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(28px, 5vw, 40px); font-weight: 400; line-height: 1.25; color: rgb(13, 43, 29); text-transform: uppercase; margin: 0;">
          Contact Us
        </h2>
        <p class="mt-2" style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: rgb(136, 136, 136);">
          Quick Response, Expert Assessment
        </p>
      </div>

      <form action={formAction} method="POST" class="flex flex-col mt-6 gap-3">
        <!-- Full Name -->
        <label for="fullName" class="sr-only">Full Name</label>
        <input
          type="text"
          id="fullName"
          name="fullName"
          placeholder="Full Name"
          required
          style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
        />

        <!-- Address -->
        <label for="address" class="sr-only">Address</label>
        <input
          type="text"
          id="address"
          name="address"
          placeholder="Address"
          required
          style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
        />

        <!-- Email -->
        <label for="email" class="sr-only">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="Email"
          required
          style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
        />

        <!-- Phone -->
        <label for="phone" class="sr-only">Phone Number</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="Phone Number"
          required
          style="width: 100%; border-radius: 10px; border: 1px solid rgb(196, 191, 182); padding: 10px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(104, 104, 105); outline: none; background-color: rgb(255, 255, 255);"
        />

        <!-- Consultation type -->
        <fieldset style="border: none; padding: 0; margin: 8px 0 0 0;">
          <legend class="mb-2" style="font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; font-weight: 500; color: rgb(136, 136, 136);">
            Which type of consultation would you prefer?
          </legend>
          <div class="flex gap-6">
            <label class="flex cursor-pointer items-center gap-2" style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(13, 43, 29);">
              <input
                type="radio"
                name="consultationType"
                value="In-Home"
                checked
                style="width: 16px; height: 16px; accent-color: rgb(37, 99, 70);"
              />
              In-Home
            </label>
            <label class="flex cursor-pointer items-center gap-2" style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(13, 43, 29);">
              <input
                type="radio"
                name="consultationType"
                value="Virtual"
                style="width: 16px; height: 16px; accent-color: rgb(37, 99, 70);"
              />
              Virtual
            </label>
          </div>
        </fieldset>

        <!-- Submit -->
        <button
          type="submit"
          style="width: 100%; border-radius: 8px; background-color: rgb(37, 99, 70); border: none; padding: 14px 24px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 600; line-height: 1.5; color: rgb(246, 253, 252); cursor: pointer; margin-top: 4px;"
        >
          Schedule a FREE Inspection
        </button>
      </form>

      <!-- Disclaimer -->
      <p style="font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 400; line-height: 1.5; color: rgb(136, 136, 136); margin-top: 12px;">
        By submitting, you agree to our <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Privacy Policy</a> and <a href="/terms" class="underline" target="_blank" rel="noopener">Terms</a>. We'll contact you at the number provided. Msg & data rates may apply.
      </p>
    </div>
  </div>
</section>
