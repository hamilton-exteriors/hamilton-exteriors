---
import { PHONE_DISPLAY, PHONE_HREF, EMAIL, ADDRESS } from '../lib/constants';
import CTAButton from './CTAButton.astro';
---

<section id="contact" class="w-full" style="background-color: var(--color-heading);">
  <div class="mx-auto max-w-[1170px] px-5 py-16 md:py-20">

    <!-- Two-column layout -->
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between lg:gap-16">

      <!-- Left: Phone CTA -->
      <div class="flex flex-col items-start lg:max-w-[560px]">
        <p style="font-family: var(--font-satoshi); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-yellow); margin: 0 0 16px;">
          Ready to start?
        </p>
        <a
          href={PHONE_HREF}
          style="font-family: var(--font-oswald); font-size: clamp(48px, 8vw, 72px); font-weight: 400; line-height: 1; text-transform: uppercase; color: var(--color-white); text-decoration: none; margin: 0;"
          class="transition-opacity hover:opacity-80"
        >
          {PHONE_DISPLAY}
        </a>
        <p class="mt-4" style="font-family: var(--font-dm-sans); font-size: 1.125rem; line-height: 1.6; color: rgba(255,255,255,0.8); max-width: 38ch;">
          Call now — we answer in 3 minutes. Or <a href="#quote" style="color: var(--color-yellow); text-decoration: underline; text-underline-offset: 3px;">fill out the form above</a> and we'll call you.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:flex-wrap">
          <CTAButton href="#quote" size="lg" class="w-full sm:w-auto min-w-[220px]">Get Your Free Quote</CTAButton>
          <CTAButton href={PHONE_HREF} variant="outline" size="lg" class="w-full sm:w-auto min-w-[220px]">Call {PHONE_DISPLAY}</CTAButton>
        </div>
      </div>

      <!-- Right: Map + Address -->
      <div class="w-full lg:max-w-[480px]">
        <div style="border-radius: 12px; overflow: hidden;">
          <iframe
            src="https://www.google.com/maps?q=21634+Redwood+Rd+Unit+F,+Castro+Valley,+CA+94546&output=embed"
            width="100%"
            height="280"
            style="border: 0; display: block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Hamilton Exteriors location — 21634 Redwood Rd Unit F, Castro Valley, CA 94546"
            allowfullscreen
          ></iframe>
        </div>
        <p class="mt-4" style="font-family: var(--font-dm-sans); font-size: 0.875rem; line-height: 1.5; color: rgba(255,255,255,0.6);">
          {ADDRESS}
        </p>
        <p class="mt-2" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; line-height: 1.8; color: rgba(255,255,255,0.65);">
          Serving
          <a href="/service-areas/alameda-county-ca/oakland-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Oakland</a>,
          <a href="/service-areas/alameda-county-ca/berkeley-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Berkeley</a>,
          <a href="/service-areas/alameda-county-ca/fremont-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Fremont</a>,
          <a href="/service-areas/santa-clara-county-ca/san-jose-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">San Jose</a>,
          <a href="/service-areas/santa-clara-county-ca/palo-alto-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Palo Alto</a>,
          <a href="/service-areas/contra-costa-county-ca/walnut-creek-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Walnut Creek</a>,
          <a href="/service-areas/marin-county-ca/san-rafael-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">San Rafael</a>,
          <a href="/service-areas/napa-county-ca/napa-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Napa</a>
          &amp; more across
          <a href="/service-areas/alameda-county-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Alameda</a>,
          <a href="/service-areas/contra-costa-county-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Contra Costa</a>,
          <a href="/service-areas/marin-county-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Marin</a>,
          <a href="/service-areas/napa-county-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Napa</a> &amp;
          <a href="/service-areas/santa-clara-county-ca" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">Santa Clara</a> counties.
          <a href="/service-areas" style="color: rgba(255,255,255,0.65); text-decoration: underline; text-underline-offset: 2px;">All 29 cities &rarr;</a>
        </p>
      </div>

    </div>
  </div>
</section>
