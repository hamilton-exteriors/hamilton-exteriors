---
import { PHONE_DISPLAY, PHONE_HREF, EMAIL, ADDRESS } from '../lib/constants';
import CTAButton from './CTAButton.astro';
import SectionLabel from './SectionLabel.astro';
---

<section id="contact" class="cv-auto w-full bg-heading">
  <div class="mx-auto max-w-[1170px] px-5 py-16 md:py-20">

    <!-- Two-column layout -->
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between lg:gap-16">

      <!-- Left: Phone CTA -->
      <div class="flex flex-col items-start lg:max-w-[560px]">
        <SectionLabel color="yellow">Ready to start?</SectionLabel>
        <a
          href={PHONE_HREF}
          class="m-0 font-hamilton-display text-[clamp(3rem,8vw,4.5rem)] leading-none font-normal text-white uppercase no-underline transition-opacity hover:opacity-80"
          data-track="contactus_phone_click"
        >
          {PHONE_DISPLAY}
        </a>
        <p class="mt-4 max-w-[38ch] text-lg leading-[1.6] text-white-80">
          Call now — we pick up in minutes. Or <a href="#quote" class="text-yellow underline underline-offset-[3px]">fill out the form above</a> and we'll call you.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <CTAButton href="#quote" size="lg" class="w-full min-w-[220px] sm:w-auto">Get Your Quote</CTAButton>
          <CTAButton href={PHONE_HREF} variant="outline" size="lg" class="w-full min-w-[220px] sm:w-auto">Call {PHONE_DISPLAY}</CTAButton>
        </div>
      </div>

      <!-- Right: Map + Address -->
      <div class="w-full lg:max-w-[480px]">
        <div class="overflow-hidden rounded-[4px]">
          <iframe
            src="https://www.google.com/maps?cid=3578771346418026097&output=embed"
            width="100%"
            height="280"
            class="block border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Hamilton Exteriors location — 21634 Redwood Rd Unit F, Castro Valley, CA 94546"
            allowfullscreen
          ></iframe>
        </div>
        <p class="mt-4 text-sm/normal text-white-70">
          {ADDRESS}
        </p>
        <p class="mt-2 text-[0.8125rem] leading-[1.8] text-white-70">
          Serving
          <a href="/service-areas/alameda-county-ca/oakland-ca" class="text-white-85 underline underline-offset-2">Oakland</a>,
          <a href="/service-areas/alameda-county-ca/berkeley-ca" class="text-white-85 underline underline-offset-2">Berkeley</a>,
          <a href="/service-areas/alameda-county-ca/fremont-ca" class="text-white-85 underline underline-offset-2">Fremont</a>,
          <a href="/service-areas/santa-clara-county-ca/san-jose-ca" class="text-white-85 underline underline-offset-2">San Jose</a>,
          <a href="/service-areas/santa-clara-county-ca/palo-alto-ca" class="text-white-85 underline underline-offset-2">Palo Alto</a>,
          <a href="/service-areas/contra-costa-county-ca/walnut-creek-ca" class="text-white-85 underline underline-offset-2">Walnut Creek</a>,
          <a href="/service-areas/marin-county-ca/san-rafael-ca" class="text-white-85 underline underline-offset-2">San Rafael</a>,
          <a href="/service-areas/napa-county-ca/napa-ca" class="text-white-85 underline underline-offset-2">Napa</a>,
          <a href="/service-areas/san-mateo-county-ca/redwood-city-ca" class="text-white-85 underline underline-offset-2">Redwood City</a>
          &amp; more across
          <a href="/service-areas/alameda-county-ca" class="text-white-85 underline underline-offset-2">Alameda</a>,
          <a href="/service-areas/contra-costa-county-ca" class="text-white-85 underline underline-offset-2">Contra Costa</a>,
          <a href="/service-areas/marin-county-ca" class="text-white-85 underline underline-offset-2">Marin</a>,
          <a href="/service-areas/napa-county-ca" class="text-white-85 underline underline-offset-2">Napa</a>,
          <a href="/service-areas/san-mateo-county-ca" class="text-white-85 underline underline-offset-2">San Mateo</a> &amp;
          <a href="/service-areas/santa-clara-county-ca" class="text-white-85 underline underline-offset-2">Santa Clara</a> counties.
          <a href="/service-areas" class="text-white-85 underline underline-offset-2">All 47 cities &rarr;</a>
        </p>
      </div>

    </div>
  </div>
</section>
