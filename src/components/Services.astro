---
import { Image } from 'astro:assets';
import { serviceRoofing, serviceSiding, serviceAdu, serviceWindows } from '../lib/images';

const services = [
  {
    title: 'Roofing',
    description:
      'Full roof replacements and repairs with GAF-certified shingles and a 50-year warranty. We handle everything from tear-off to final inspection — most jobs done in 3-5 days.',
    image: serviceRoofing,
    href: './roofing',
  },
  {
    title: 'Siding',
    description:
      'James Hardie fiber cement siding that protects your home and looks great for decades. We handle dry rot repair, full replacements, and fresh paint — transforming your curb appeal.',
    image: serviceSiding,
    href: './siding',
  },
  {
    title: 'Windows',
    description:
      'Energy-efficient Anlin windows that cut your heating and cooling bills. Double-pane, low-E glass installed by factory-trained crews. Most homes done in one day.',
    image: serviceAdu,
    href: './windows',
  },
  {
    title: 'Waterproofing',
    description:
      'Protect your foundation and basement from water damage. We install drainage systems, apply waterproof coatings, and fix grading issues before they become costly problems.',
    image: serviceWindows,
    href: './waterproofing',
  },
];
---

<section id="service" class="w-full py-10 lg:py-16">
  <div class="mx-auto max-w-[1200px] px-5">
    <!-- Section heading -->
    <h2
      class="mb-6"
      style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(28px, 5vw, 40px); line-height: 1.25; font-weight: 400; color: rgb(13, 43, 29); text-transform: uppercase;"
    >
      Exterior Services Offered in Castro Valley, CA
    </h2>

    <!-- Service cards grid — 2x2 -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      {
        services.map((service) => (
          <a href={service.href} class="service-card">
            {/* Service image */}
            <div class="w-full overflow-hidden" style="border-radius: 10px;">
              <Image
                src={service.image}
                alt={service.title}
                width={566}
                height={292}
                style="width: 100%; height: auto; aspect-ratio: 566 / 292; object-fit: cover; display: block; border-radius: 10px;"
                loading="lazy"
              />
            </div>

            {/* Card content */}
            <div style="padding-top: 16px;">
              <h3
                style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 1.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 6px; color: rgb(13, 43, 29); text-transform: uppercase;"
              >
                {service.title}
              </h3>
              <p
                style="font-size: 0.875rem; line-height: 1.5; color: rgb(104, 104, 105);"
              >
                {service.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .service-card:hover img {
    transform: scale(1.02);
    transition: transform 0.3s ease;
  }
</style>
