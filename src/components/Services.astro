---
import { Image } from 'astro:assets';
import { serviceRoofing, serviceSiding, serviceWindows, serviceCustomHomes, serviceAdditions, serviceAdu } from '../lib/images';

interface Props {
  city?: string;
}

const { city = 'the Bay Area' } = Astro.props;

const services = [
  {
    title: 'Custom Homes',
    description:
      'Ground-up custom home construction tailored to your vision. From foundation to finishing touches, our team manages every detail to deliver the home you\'ve always wanted.',
    image: serviceCustomHomes,
    href: '/custom-homes',
  },
  {
    title: 'Additions',
    description:
      'Expand your living space with seamless room additions that match your home\'s existing style. We handle permits, design, and construction — adding value and square footage.',
    image: serviceAdditions,
    href: './additions',
  },
  {
    title: 'ADUs',
    description:
      'Detached ADUs, garage conversions, and junior ADUs that add living space and rental income. We handle design, permits, and construction from start to finish.',
    image: serviceAdu,
    href: './adu',
  },
  {
    title: 'Windows',
    description:
      'Energy-efficient window replacements that transform your home\'s comfort and curb appeal. Double-hung, casement, bay, and more — professionally installed with a full warranty.',
    image: serviceWindows,
    href: '/windows',
    mobileHidden: true,
  },
  {
    title: 'Roofing',
    description:
      'Full roof replacements and repairs with GAF-certified shingles and a 50-year warranty. We handle everything from tear-off to final inspection — most jobs done in 3-5 days.',
    image: serviceRoofing,
    href: './roofing',
  },
  {
    title: 'Siding',
    description:
      'James Hardie fiber cement siding that protects your home and looks great for decades. We handle dry rot repair, full replacements, and fresh paint — transforming your curb appeal.',
    image: serviceSiding,
    href: './siding',
  },
];
---

<section id="service" class="w-full py-12 lg:py-20">
  <div class="mx-auto max-w-[1200px] px-5">
    <!-- Section heading -->
    <h2
      class="mb-6"
      style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); line-height: 1.25; font-weight: 400; color: var(--color-heading); text-transform: uppercase;"
    >
      Design-Build Services in {city}
    </h2>

    <!-- Service cards grid — 2x2 -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      {
        services.map((service) => (
          <a href={service.href} class={`service-card${service.mobileHidden ? ' hidden sm:flex' : ''}`}>
            {/* Service image */}
            <div class="w-full overflow-hidden">
              <Image
                src={service.image}
                alt={service.title}
                width={566}
                height={292}
                style="width: 100%; height: auto; aspect-ratio: 566 / 292; object-fit: cover; display: block;"
                loading="lazy"
              />
            </div>

            {/* Card content */}
            <div style="padding-top: 16px;">
              <h3
                style="font-family: var(--font-oswald); font-size: 1.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 6px; color: var(--color-heading); text-transform: uppercase;"
              >
                {service.title}
              </h3>
              <p
                style="font-size: 0.875rem; line-height: 1.5; color: var(--color-muted);"
              >
                {service.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

</style>
