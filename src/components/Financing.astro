---
import { Image } from 'astro:assets';
import { financingHouse, financingWorker, iconCheckmarkCircle } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import SectionLabel from './SectionLabel.astro';

interface Props {
  scheduleHref?: string;
}

const { scheduleHref } = Astro.props;
---

<section id="financing" class="w-full px-0 py-10 lg:py-16">
  <div class="mx-auto flex max-w-[1294px] flex-col overflow-hidden lg:flex-row">
    <!-- Left Column: Photo -->
    <div class="relative h-[280px] w-full md:h-[420px] lg:h-auto lg:min-h-[600px] lg:w-1/2">
      <Image
        src={financingHouse}
        alt="Bay Area home with financing options available through Hamilton Exteriors"
        widths={[420, 700]}
        sizes="(max-width: 1023px) 420px, 700px"
        class="absolute inset-0 size-full object-cover object-center"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Right Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-[50px] lg:py-[80px]">
      <!-- Title -->
      <div class="mb-[20px]">
        <SectionLabel>Financing Options</SectionLabel>
        <h2
          class="m-0 font-oswald text-[clamp(1.875rem,5vw,2.875rem)] leading-[1.15] font-normal tracking-normal uppercase"
        >
          <span class="text-heading">Financing Options </span><span class="text-primary-dark">Available For Everyone</span>
        </h2>
      </div>

      <!-- Body Text -->
      <p
        class="font-dm-sans text-base/normal text-heading"
      >
        Most Bay Area exterior projects range from $15,000 for a standard roof replacement to $600,000 for a custom ADU — and paying out of pocket isn't the only option. Hamilton Exteriors partners with multiple lending providers to offer $0-down financing with approved credit, 12-month same-as-cash plans, and extended terms up to 15 years for larger projects. You only pay for completed, inspected work — we never ask for full payment before the job is done. Whether you're replacing a roof, upgrading siding, or building an ADU, your project manager will walk you through every payment option during your free estimate so you can choose what fits your budget.
      </p>

      <!-- Trust line -->
      <p class="mt-6 text-base font-semibold text-heading">
        Ask about same-as-cash plans during your estimate.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <!-- Call Now Button -->
        <a
          href={PHONE_HREF}
          class="flex min-h-[52px] items-center justify-center gap-2.5 rounded-full bg-yellow px-7 py-4 font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-heading uppercase no-underline transition-opacity hover:opacity-90"
        >
          <Image
            src={iconCheckmarkCircle}
            alt=""
            width={18}
            height={18}
            class="size-[18px]"
          />
          Call Now {PHONE_DISPLAY}
        </a>

        <!-- Schedule Button -->
        <a
          href={scheduleHref || '#quote'}
          class="flex min-h-[52px] items-center justify-center rounded-full bg-primary px-7 py-4 text-center font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-white uppercase no-underline transition-opacity hover:opacity-90"
        >
          Get Your Quote
        </a>
      </div>
    </div>
  </div>
</section>
