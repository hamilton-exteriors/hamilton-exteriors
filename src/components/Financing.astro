---
import { Image } from 'astro:assets';
import { financingHouse, financingWorker, iconCheckmarkCircle } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import SectionLabel from './SectionLabel.astro';

interface Props {
  scheduleHref?: string;
}

const { scheduleHref } = Astro.props;
---

<section id="financing" class="w-full px-0 py-10 lg:py-16">
  <div class="mx-auto flex max-w-[1294px] flex-col overflow-hidden lg:flex-row">
    <!-- Left Column: Photo -->
    <div class="relative h-[280px] w-full md:h-[420px] lg:h-auto lg:min-h-[600px] lg:w-1/2">
      <Image
        src={financingHouse}
        alt="Bay Area home with financing options available through Hamilton Exteriors"
        width={700}
        height={600}
        class="absolute inset-0 size-full object-cover object-center"
        loading="lazy"
      />
    </div>

    <!-- Right Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-[50px] lg:py-[80px]">
      <!-- Title -->
      <div class="mb-[20px]">
        <SectionLabel>$0 Down Available</SectionLabel>
        <h2
          class="m-0 font-oswald text-[clamp(30px,5vw,46px)] leading-[1.15] font-normal tracking-normal uppercase"
        >
          <span class="text-heading">Financing Options </span><span class="text-primary-dark">Available For Everyone</span>
        </h2>
      </div>

      <!-- Body Text -->
      <p
        class="font-dm-sans text-sm/normal text-heading"
      >
        Flexible financing for every homeowner — high credit or low. We partner with multiple lenders to get you competitive rates. Don't let cost delay your project.
      </p>

      <!-- Trust line -->
      <p class="mt-6 text-sm font-semibold text-heading">
        We respond within 5 minutes. No obligation.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <!-- Call Now Button -->
        <a
          href={PHONE_HREF}
          class="flex min-h-[52px] items-center justify-center gap-2.5 rounded-full bg-yellow px-7 py-4 font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-heading uppercase no-underline transition-opacity hover:opacity-90"
        >
          <Image
            src={iconCheckmarkCircle}
            alt=""
            width={18}
            height={18}
            class="size-[18px]"
          />
          Call Now {PHONE_DISPLAY}
        </a>

        <!-- Schedule Button -->
        <a
          href={scheduleHref || '#quote'}
          class="flex min-h-[52px] items-center justify-center rounded-full bg-primary px-7 py-4 text-center font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-white uppercase no-underline transition-opacity hover:opacity-90"
        >
          Get Your Free Quote
        </a>
      </div>
    </div>
  </div>
</section>
