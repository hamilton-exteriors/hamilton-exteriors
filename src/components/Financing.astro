---
import { Image } from 'astro:assets';
import { financingHouse, financingWorker, iconCheckmarkCircle } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';

interface Props {
  scheduleHref?: string;
}

const { scheduleHref } = Astro.props;
---

<section id="financing" class="w-full py-10 lg:py-16 px-0">
  <div class="mx-auto flex max-w-[1294px] flex-col overflow-hidden lg:flex-row">
    <!-- Left Column: Photo -->
    <div class="relative h-[280px] w-full lg:h-auto lg:min-h-[600px] lg:w-1/2">
      <Image
        src={financingHouse}
        alt="Bay Area home with financing options available through Hamilton Exteriors"
        width={700}
        height={600}
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="lazy"
      />
    </div>

    <!-- Right Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-[50px] lg:py-[80px]">
      <!-- Title -->
      <div class="mb-[20px]">
        <p style="font-family: var(--font-satoshi); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); margin-bottom: 12px;">
          $0 Down Available
        </p>
        <h2
          class="font-oswald font-normal uppercase"
          style="font-size: clamp(30px, 5vw, 46px); line-height: 1.15; letter-spacing: 0; margin: 0;"
        >
          <span style="color: var(--color-heading);">Financing Options </span><span style="color: var(--color-primary-dark);">Available For Everyone</span>
        </h2>
      </div>

      <!-- Body Text -->
      <p
        class="font-dm-sans text-[0.875rem] leading-[1.5]"
        style="color: var(--color-heading);"
      >
        Flexible financing for every homeowner — high credit or low. We partner with multiple lenders to get you competitive rates. Don't let cost delay your project.
      </p>

      <!-- Trust line -->
      <p class="mt-6" style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: var(--color-heading);">
        We respond within 5 minutes. No obligation.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <!-- Call Now Button -->
        <a
          href={PHONE_HREF}
          class="flex items-center justify-center gap-2.5 rounded-full px-7 py-4 min-h-[52px] transition-opacity hover:opacity-90 whitespace-nowrap"
          style="background-color: var(--color-yellow); font-family: var(--font-oswald); font-size: 1rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-primary); text-decoration: none;"
        >
          <Image
            src={iconCheckmarkCircle}
            alt=""
            width={18}
            height={18}
            class="h-[18px] w-[18px]"
          />
          Call Now {PHONE_DISPLAY}
        </a>

        <!-- Schedule Button -->
        <a
          href={scheduleHref || '#quote'}
          class="flex items-center justify-center rounded-full px-7 py-4 min-h-[52px] text-center transition-opacity hover:opacity-90 whitespace-nowrap"
          style="background-color: var(--color-primary); color: var(--color-white); text-decoration: none; font-family: var(--font-oswald); font-size: 1rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;"
        >
          Get Your Free Quote
        </a>
      </div>
    </div>
  </div>
</section>
