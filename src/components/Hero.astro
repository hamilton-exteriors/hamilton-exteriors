---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { heroBg, iconStar } from '../lib/images';

interface Props {
  formTitle?: string;
  formAction?: string;
  formSubtitle?: string;
  headline?: string;
  badges?: string[];
  ctaText?: string;
  ctaHref?: string;
  heroImage?: ImageMetadata;
}

const {
  formTitle = 'Get a FREE QUOTE',
  formAction = '/success',
  formSubtitle = "We'll contact you in 3-5 minutes to schedule a FREE roof inspection.",
  headline = 'Bay Areas Favorite Construction  Company',
  badges = [
    'Licensed Bonded & Insured',
    'Start with $0 Down',
    '50 year Warranty',
    '3-5 day install',
  ],
  ctaText = 'Call Us - We Answer Fast',
  ctaHref = 'tel:6509773351',
  heroImage = heroBg,
} = Astro.props;
---

<section id="quote" class="relative w-full overflow-hidden" style="padding-top: 24px; padding-bottom: 32px;">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      width={1920}
      height={1080}
      class="h-full w-full object-cover"
      loading="eager"
    />
  </div>

  <div
    class="relative mx-auto flex flex-col gap-6 px-4 lg:flex-row lg:items-start lg:gap-12 lg:px-5"
    style="max-width: 1294px;"
  >

    <!-- Left Column -->
    <div class="flex flex-col items-start lg:w-[45%] lg:py-6">

      <!-- Rating badge -->
      <div class="mb-4 inline-flex items-center gap-2 lg:mb-0">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <div class="relative h-[16px] w-[16px] shrink-0 lg:h-[20px] lg:w-[20px]">
              <Image
                src={iconStar}
                alt=""
                width={20}
                height={21}
                loading="eager"
                class="h-full w-full object-contain"
              />
            </div>
          ))}
        </div>
        <span
          class="text-white/80"
          style="font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; font-weight: 400; letter-spacing: 0;"
        >
          rated 5/5 based on 50 reviews.
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="hero-headline text-white"
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-weight: 400; text-transform: uppercase;"
      >
        {headline}
      </h1>

      <!-- Trust badges -->
      <div class="mt-3 flex flex-col gap-1.5 lg:mt-5 lg:gap-3">
        {badges.map((badge) => (
          <div class="flex items-center gap-2.5">
            <div class="relative h-[18px] w-[18px] shrink-0 lg:h-[20px] lg:w-[20px]">
              <svg viewBox="0 0 20 20" class="h-full w-full" style="fill: rgba(0,0,0,1); color: rgba(0,0,0,1);">
                <path d="M16.667 5L7.5 14.167L3.333 10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>
            <span class="text-white" style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; line-height: 1.5;">{badge}</span>
          </div>
        ))}
      </div>

      <!-- CTA button -->
      <a
        href={ctaHref}
        class="mt-4 inline-block w-full text-center transition-all hover:scale-[1.02] sm:w-auto lg:mt-6"
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 0.875rem; font-weight: 700; letter-spacing: 0.05em; line-height: 1.5; background-color: rgb(255, 222, 33); color: rgb(37, 99, 70); border-radius: 8px; padding: 14px 32px;"
      >
        {ctaText}
      </a>
    </div>

    <!-- Right Column — Lead Form -->
    <div class="w-full lg:w-[45%]">
      <!-- Outer gradient wrapper -->
      <div
        class="w-full"
        style="background: linear-gradient(rgb(255, 255, 255) 0%, rgb(153, 153, 153) 107%); border-radius: 12px;"
        class="lg:!rounded-[30px]"
      >
        <!-- Inner white content -->
        <div
          class="lg:!rounded-[30px] lg:!p-[30px_28px_28px]"
          style="background-color: rgb(255, 255, 255); border-radius: 16px; padding: 20px 16px 16px;"
        >
          <!-- Form title -->
          <h2
            class="mb-1 text-center"
            style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-size: 1.5rem; line-height: 1.2; font-weight: 400; color: rgb(13, 43, 29);"
          >
            {formTitle}
          </h2>

          <!-- Subtitle -->
          <p
            class="mb-5 text-center"
            style="font-family: 'DM Sans', sans-serif; line-height: 1.6; color: rgb(134, 134, 134);"
          >
            {formSubtitle}
          </p>

          <!-- Form -->
          <form action={formAction} method="POST">
            <div class="flex flex-col gap-3">
              <!-- Name -->
              <input
                type="text"
                name="fullName"
                placeholder="Name"
                required
                class="hero-input w-full"
              />

              <!-- Phone + Email -->
              <div class="flex flex-col gap-3 sm:flex-row">
                <div class="relative w-full sm:w-1/2">
                  <div class="flex overflow-hidden" style="border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 10px;">
                    <div class="flex items-center shrink-0" style="padding: 12px 0 12px 12px; width: 52px;">
                      <span
                        style="font-family: 'DM Sans', sans-serif; font-size: 1rem; line-height: 1.6; color: rgb(32, 26, 22);"
                      >+1</span>
                    </div>
                    <div style="width: 1px; margin-top: 8px; margin-bottom: 8px; background-color: rgba(0, 0, 0, 0.2);"></div>
                    <input
                      type="tel"
                      name="phone"
                      placeholder="Phone Number"
                      required
                      class="flex-1 border-none bg-transparent outline-none"
                      style="font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 400; line-height: 1.6; color: rgb(32, 26, 22); padding: 12px;"
                    />
                  </div>
                </div>
                <input
                  type="email"
                  name="email"
                  placeholder="Email"
                  required
                  class="hero-input w-full sm:w-1/2"
                />
              </div>

              <!-- Project Address -->
              <input
                type="text"
                name="address"
                placeholder="Project Address"
                required
                class="hero-input w-full"
              />

              <!-- Textarea -->
              <textarea
                name="message"
                rows="4"
                placeholder="Tell us about your project – any issues or services you're interested in? We're here to help!"
                class="hero-input w-full resize-none"
              ></textarea>

              <!-- Consent checkbox -->
              <label class="flex items-start gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  name="consent"
                  required
                  class="mt-0.5 h-4 w-4 shrink-0"
                  style="border-radius: 4px; border: 1px solid rgba(136, 136, 136, 0.2); background: rgba(187, 187, 187, 0.2);"
                />
                <span
                  class="italic"
                  style="font-family: 'Satoshi', sans-serif; font-size: 10px; font-weight: 500; line-height: 1.4; color: rgb(136, 136, 136);"
                >
                  <strong>I agree to receive promotional messages sent via an autodialer, and this agreement isn't a condition of any purchase. I agree to receive promotional messages sent via an autodialer, and this agreement isn't a condition of any purchase.</strong>
                  <br /><br />
                  <strong>I also agree to the <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Terms of Service</a> and <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Privacy Policy</a> 4 Msgs/Month. Msg &amp; Data rates may apply. Text HELP for help or STOP to stop.</strong>
                </span>
              </label>

              <!-- Submit -->
              <button
                type="submit"
                class="mt-1 w-full"
                style="border-radius: 10px;"
              >
                <div
                  class="w-full py-4"
                  style="background-color: rgb(36, 99, 69); border-radius: 40px;"
                >
                  <p
                    class="text-center text-white uppercase"
                    style="font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 700; line-height: 1.4;"
                  >
                    Request a Quote
                  </p>
                </div>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    font-size: 15vw;
    line-height: 0.95;
    letter-spacing: 0.01em;
  }

  @media (min-width: 1024px) {
    .hero-headline {
      font-size: clamp(48px, 4vw, 56px);
      line-height: 1.1;
      letter-spacing: normal;
    }
  }

  .hero-input {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0em;
    color: rgb(32, 26, 22);
    background-color: rgb(255, 255, 255);
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    padding: 12px;
    outline: none;
    transition: border-color 0.2s;
  }
  .hero-input::placeholder {
    color: rgb(134, 134, 134);
  }
  .hero-input:focus {
    border-color: rgb(37, 99, 70);
  }

  /* Responsive headline scaling */
  @media (max-width: 1023px) {
    h1 {
      font-size: 42px !important;
      line-height: 1.2 !important;
    }
  }
  @media (max-width: 767px) {
    h1 {
      font-size: 36px !important;
      line-height: 1.2 !important;
    }
  }
</style>
