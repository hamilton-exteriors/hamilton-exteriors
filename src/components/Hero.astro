---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { actions } from 'astro:actions';
import { heroBg } from '../lib/images';
import IconCheck from './icons/IconCheck.astro';
import IconCheckmark from './icons/IconCheckmark.astro';
import IconArrowLeft from './icons/IconArrowLeft.astro';
import StarRating from './StarRating.astro';
import { getGoogleReviews, getDisplayReviews } from '../lib/google-reviews';

const _heroReviews = getDisplayReviews(await getGoogleReviews());

interface Props {
  formTitle?: string;
  formAction?: string;
  formSubtitle?: string;
  headline?: string;
  badges?: string[];
  ctaText?: string;
  ctaHref?: string;
  heroImage?: ImageMetadata;
  heroAlt?: string;
  serviceType?: string;
  serviceOptions?: string[];
  proximity?: string; // "lng,lat" for Mapbox city bias
}

const {
  formTitle = 'Get Your Free Quote',
  formAction = '/success',
  formSubtitle = "We'll call you within 3\u20135 minutes to schedule your inspection.",
  headline = "Bay Area's Architect-Led Custom Home & Exteriors Contractor",
  badges = [
    'In-House Architect & Engineering',
    'Flexible Financing Available',
    '50-Year Warranty',
    'Licensed Bonded & Insured',
  ],
  ctaText = 'Call Us - We Answer Fast',
  ctaHref = 'tel:+16509773351',
  heroImage = heroBg,
  heroAlt = 'Hamilton Exteriors — Bay Area roofing, siding, and exterior remodeling',
  serviceType,
  serviceOptions,
  proximity,
} = Astro.props;

const hasPresetService = !!serviceType;
const step2Options = serviceOptions || ['Roofing', 'Siding', 'Windows', 'Other'];
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

// Generate responsive hero image variants from dynamic heroImage prop
// Quality values MUST match Layout.astro preload (72 mobile, 78 desktop) — mismatch = wasted preload
const [heroMobile, heroTablet, heroDesktop] = await Promise.all([
  getImage({ src: heroImage, width: 768, height: 432, format: 'webp', quality: 72 }),
  getImage({ src: heroImage, width: 1280, height: 720, format: 'webp', quality: 75 }),
  getImage({ src: heroImage, width: 1440, height: 810, format: 'webp', quality: 78 }),
]);
---

<section id="quote" class="relative w-full overflow-hidden py-10">
  <!-- Background image — zoomed out on mobile -->
  <div class="absolute inset-0">
    <picture>
      <source srcset={heroMobile.src} media="(max-width: 768px)" type="image/webp" width="768" height="432" />
      <source srcset={heroTablet.src} media="(max-width: 1280px)" type="image/webp" width="1280" height="720" />
      <source srcset={heroDesktop.src} type="image/webp" width="1440" height="810" />
      <img
        src={heroDesktop.src}
        alt={heroAlt}
        width="1440"
        height="810"
        sizes="100vw"
        class="hero-bg-img size-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
      />
    </picture>
  </div>
  <!-- Dark gradient scrim for text readability -->
  <div class="pointer-events-none absolute inset-0 z-1" aria-hidden="true">
    <div class="hero-scrim absolute inset-0"></div>
  </div>
  <!-- Film grain: CSS noise (lightweight, no SVG filter paint cost) -->
  <div class="hero-grain pointer-events-none absolute inset-0 z-2" aria-hidden="true"></div>

  <div
    class="relative z-3 mx-auto flex max-w-[1294px] flex-col gap-6 px-4 lg:flex-row lg:items-start lg:gap-8 lg:px-5"
  >

    <!-- Left Column -->
    <div class="flex flex-col items-start lg:w-[55%] lg:py-6">

      <!-- Rating badge -->
      <div class="mb-4 inline-flex items-center gap-2 lg:mb-3">
        <StarRating size={20} class="hero-stars" />
        <span
          class="text-[clamp(1rem,4vw,1.0625rem)] font-medium tracking-[0.01em] text-white/80"
        >
          {_heroReviews.rating}-star rated by {_heroReviews.reviewCount} verified Bay Area homeowners
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="hero-h1 w-full leading-[1.05] tracking-[0.01em] text-white"
      >
        {headline}
      </h1>

      <!-- Trust badges -->
      <div class="mt-3 flex flex-col gap-1.5 lg:mt-5 lg:gap-3">
        {badges.map((badge) => (
          <div class="flex items-center gap-2.5">
            <div class="relative size-[clamp(16px,4.5vw,20px)] shrink-0">
              <IconCheck stroke="white" class="size-full" />
            </div>
            <span class="hero-badge-text text-[clamp(1.125rem,4.5vw,1.25rem)] leading-[1.4] font-medium text-white">{badge}</span>
          </div>
        ))}
      </div>

    </div>

    <!-- Right Column — Lead Form -->
    <div class="w-full lg:w-[40%]">
      <!-- Form card -->
      <div class="overflow-hidden rounded-[8px] shadow-[0_8px_32px_rgba(0,0,0,0.12)]">
        <div class="bg-white px-4 pt-5 pb-4 lg:p-6">
          <!-- Form title -->
          <h2
            class="mb-1 text-center font-dm-sans text-[1.25rem] leading-[1.3] font-bold tracking-[0.02em] text-heading uppercase"
          >
            {formTitle}
          </h2>
          <p
            class="mb-5 text-center text-[0.8125rem] leading-normal text-muted"
          >
            {formSubtitle}
          </p>

          <!-- 3-Step Form -->
          <form method="POST" action={formAction} id="hero-form" aria-label="Get a free quote" data-preset-service={serviceType || ''} data-has-options={serviceOptions ? 'true' : 'false'}>
            <!-- Step 1: Contact Info -->
            <div id="step-1" class="form-step">
              <div class="mb-3 flex items-center gap-2">
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full bg-border">
                    <div class="h-full rounded-full bg-primary" style={`width: ${hasPresetService && !serviceOptions ? '50' : '33'}%;`}></div>
                  </div>
                </div>
                <span class="text-xs text-muted">{hasPresetService && !serviceOptions ? '1/2' : '1/3'}</span>
              </div>
              <div class="flex flex-col gap-2.5">
                <div>
                  <label for="hero-name" class="hero-label">Full Name</label>
                  <input type="text" id="hero-name" name="fullName" placeholder="Your full name" required autocomplete="name" maxlength="100" class="hero-input w-full" />
                </div>
                <div>
                  <label for="hero-phone" class="hero-label">Phone Number</label>
                  <input type="tel" id="hero-phone" name="phone" placeholder="(650) 977-3351" required autocomplete="tel" inputmode="tel" maxlength="16" class="hero-input w-full" />
                  <p class="mt-1 text-[0.6875rem] leading-tight text-muted">We'll only call to schedule your inspection</p>
                </div>
                <div>
                  <label for="hero-email" class="hero-label">Email</label>
                  <input type="email" id="hero-email" name="email" placeholder="name@example.com" required autocomplete="email" inputmode="email" maxlength="254" class="hero-input w-full" />
                </div>
                <div>
                  <label for="hero-address" class="hero-label">Project Address</label>
                  <mapbox-address-autofill access-token={mapboxToken} country="us" data-proximity={proximity || ''} data-bbox="-123.1,36.9,-121.2,38.9" theme={JSON.stringify({ variables: { fontFamily: "'DM Sans', sans-serif", colorText: "#1A1A1A", colorPrimary: "#256346", borderRadius: "10px", unit: "14px" }})}>
                    <input type="text" id="hero-address" name="address" placeholder="123 Main St, Oakland, CA" required autocomplete="address-line1" maxlength="200" class="hero-input w-full" />
                  </mapbox-address-autofill>
                </div>
              </div>
              <button
                type="button"
                id="next-btn-1"
                class="mt-4 w-full rounded-full bg-yellow py-3.5 text-center font-oswald text-sm font-bold tracking-[0.05em] text-primary uppercase"
              >
                {hasPresetService && serviceOptions ? `Next: Choose Your ${serviceType}` : hasPresetService ? 'Next: Tell Us About Your Project' : 'Next: Choose Your Service'}
              </button>
            </div>

            <!-- Step 2: Service Selection -->
            <div id="step-2" class="form-step hidden">
              <div class="mb-3 flex items-center gap-2">
                <button type="button" id="back-btn-1" class="shrink-0 text-primary flex items-center justify-center min-h-[44px] min-w-[44px]" aria-label="Go back">
                  <IconArrowLeft size={20} />
                </button>
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full bg-border">
                    <div class="h-full w-[66%] rounded-full bg-primary"></div>
                  </div>
                </div>
                <span class="text-xs text-muted">2/3</span>
              </div>
              <p class="mb-1 text-center text-base font-semibold text-heading">
                {hasPresetService ? `What type of ${serviceType?.toLowerCase()}?` : 'What do you need help with?'}
              </p>
              <p class="mb-3 text-center text-xs text-muted">Select one to continue</p>
              <input type="hidden" name="service" id="service-input" value={serviceType || ''} />
              <input type="hidden" name="serviceDetail" id="service-detail-input" />
              <input type="hidden" name="fbclid" id="fbclid-input" />
              <input type="hidden" name="fbc" id="fbc-input" />
              <input type="hidden" name="gclid" id="gclid-input" />
              <input type="hidden" name="utm_source" id="utm-source-input" />
              <input type="hidden" name="utm_medium" id="utm-medium-input" />
              <input type="hidden" name="utm_campaign" id="utm-campaign-input" />
              <input type="hidden" name="utm_content" id="utm-content-input" />
              <input type="hidden" name="utm_term" id="utm-term-input" />
              <div class="grid grid-cols-2 gap-2">
                {step2Options.map((option) => (
                  <button
                    type="button"
                    class="service-btn"
                    data-service={option}
                  >
                    {option}
                  </button>
                ))}
              </div>
            </div>

            <!-- Step 3: Details + Submit -->
            <div id="step-3" class="form-step hidden">
              <div class="mb-3 flex items-center gap-2">
                <button type="button" id="back-btn-2" class="shrink-0 text-primary flex items-center justify-center min-h-[44px] min-w-[44px]" aria-label="Go back">
                  <IconArrowLeft size={20} />
                </button>
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full bg-border">
                    <div class="size-full rounded-full bg-primary"></div>
                  </div>
                </div>
                <span class="text-xs text-muted">{hasPresetService && !serviceOptions ? '2/2' : '3/3'}</span>
              </div>
              <label for="hero-message" class="sr-only">Project details</label>
              <textarea
                id="hero-message"
                name="message"
                rows="3"
                placeholder="Tell us about your project (optional)"
                class="hero-input w-full resize-none"
              ></textarea>
              <div class="mt-3 flex items-start gap-2">
                <input
                  type="checkbox"
                  id="consent-checkbox"
                  name="consent"
                  required
                  class="mt-0.5 size-5 min-h-[20px] min-w-[20px] shrink-0 rounded-[4px]"
                  style="accent-color: var(--color-primary);"
                />
                <label for="consent-checkbox" class="cursor-pointer text-[13px] leading-normal text-muted">
                  I agree to the <a href="/terms" class="underline" target="_blank" rel="noopener">Terms</a> & <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Privacy Policy</a>. Msg & data rates may apply.
                </label>
              </div>
              <button
                type="submit"
                class="mt-4 w-full rounded-full bg-yellow py-3.5 text-center font-oswald text-sm font-bold tracking-[0.05em] text-primary uppercase"
              >
                Get Your Free Quote
              </button>
            </div>
          </form>
          <!-- Trust micro-copy -->
          <p class="mt-3 text-center text-[11px] text-muted">
            Your information is private and secure
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { actions } from 'astro:actions';

  // Configure Mapbox proximity bias after web component loads
  const autofillEl = document.querySelector('mapbox-address-autofill');
  if (autofillEl) {
    const proximityAttr = autofillEl.getAttribute('data-proximity');
    const bboxAttr = autofillEl.getAttribute('data-bbox');
    const configure = () => {
      try {
        const opts: Record<string, unknown> = {};
        if (bboxAttr) opts.bbox = bboxAttr.split(',').map(Number);
        if (proximityAttr) opts.proximity = proximityAttr.split(',').map(Number);
        if (Object.keys(opts).length > 0) {
          (autofillEl as any).searchOptions = opts;
        }
      } catch { /* Mapbox API may differ — fail silently */ }
    };
    if (customElements.get('mapbox-address-autofill')) {
      configure();
    } else {
      customElements.whenDefined('mapbox-address-autofill').then(configure);
    }
  }

  const serviceBtns = document.querySelectorAll('.service-btn');
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const step3 = document.getElementById('step-3');
  const serviceInput = document.getElementById('service-input') as HTMLInputElement;
  const serviceDetailInput = document.getElementById('service-detail-input') as HTMLInputElement;
  const heroForm = document.getElementById('hero-form') as HTMLFormElement;

  const presetService = heroForm?.dataset.presetService || '';
  const hasOptions = heroForm?.dataset.hasOptions === 'true';
  // Skip Step 2 entirely when service is preset and no sub-options
  const skipStep2 = !!presetService && !hasOptions;

  // Populate hidden fields from sessionStorage (persisted on landing in Layout.astro)
  const hiddenFieldMap: Record<string, string> = {
    'fbclid-input': 'he_fbclid',
    'fbc-input': 'he_fbc',
    'gclid-input': 'he_gclid',
    'utm-source-input': 'he_utm_source',
    'utm-medium-input': 'he_utm_medium',
    'utm-campaign-input': 'he_utm_campaign',
    'utm-content-input': 'he_utm_content',
    'utm-term-input': 'he_utm_term',
  };
  Object.entries(hiddenFieldMap).forEach(([elId, storageKey]) => {
    const el = document.getElementById(elId) as HTMLInputElement;
    if (el) el.value = sessionStorage.getItem(storageKey) || '';
  });

  function showStep(step: HTMLElement | null) {
    // Analytics: track form step views for abandonment analysis
    const stepNum = step === step1 ? 1 : step === step2 ? 2 : step === step3 ? 3 : 0;
    const stepNames: Record<number, string> = { 1: 'contact_info', 2: 'service_selection', 3: 'consent_submit' };
    if (stepNum && stepNames[stepNum]) {
      window.op?.('track', 'hero_form_step', { step: stepNum, step_name: stepNames[stepNum] });
      window.dataLayer?.push({ event: 'hero_form_step', step: stepNum, step_name: stepNames[stepNum] });
    }
    [step1, step2, step3].forEach(s => {
      if (s) { s.style.display = 'none'; s.style.opacity = '0'; }
    });
    if (step) {
      step.style.display = 'block';
      requestAnimationFrame(() => { step.style.opacity = '1'; });
    }
  }

  // ── Phone auto-format ────────────────────────────────────
  const phoneInput = document.getElementById('hero-phone') as HTMLInputElement;
  function formatPhone(value: string): string {
    let raw = value.replace(/\D/g, '');
    // Strip leading country code (1) if 11 digits
    if (raw.length === 11 && raw.startsWith('1')) raw = raw.slice(1);
    raw = raw.slice(0, 10);
    if (raw.length === 0) return '';
    if (raw.length <= 3) return `(${raw}`;
    if (raw.length <= 6) return `(${raw.slice(0, 3)}) ${raw.slice(3)}`;
    return `(${raw.slice(0, 3)}) ${raw.slice(3, 6)}-${raw.slice(6)}`;
  }
  phoneInput?.addEventListener('input', () => { phoneInput.value = formatPhone(phoneInput.value); });

  // ── Inline validation on blur ──────────────────────────────
  function clearFieldError(el: HTMLElement) {
    el.style.borderColor = '';
    el.parentElement?.querySelector('.field-error')?.remove();
  }
  function showFieldError(el: HTMLElement, msg: string) {
    el.style.borderColor = 'var(--color-error)';
    let errEl = el.parentElement?.querySelector('.field-error') as HTMLElement;
    if (!errEl) {
      errEl = document.createElement('p');
      errEl.className = 'field-error';
      errEl.style.cssText = "font-family: var(--font-dm-sans); font-size: 0.75rem; color: var(--color-error); margin: 4px 0 0;";
      el.insertAdjacentElement('afterend', errEl);
    }
    errEl.textContent = msg;
  }

  const blurValidations: Record<string, (el: HTMLInputElement) => string | null> = {
    fullName: (el) => el.value.trim().length < 2 ? 'Name is required' : null,
    phone: (el) => {
      const digits = el.value.replace(/\D/g, '');
      return digits.length > 0 && digits.length < 10 ? 'Enter a 10-digit phone number' : null;
    },
    email: (el) => {
      if (!el.value.trim()) return null; // don't nag on empty — "Next" button catches required
      return !el.value.includes('@') || !el.value.includes('.') ? 'Enter a valid email address' : null;
    },
  };

  heroForm?.querySelectorAll('input, textarea').forEach(input => {
    const el = input as HTMLInputElement;
    // Clear errors on input
    el.addEventListener('input', () => clearFieldError(el));
    // Validate on blur
    const validate = blurValidations[el.name];
    if (validate) {
      el.addEventListener('blur', () => {
        const err = validate(el);
        if (err) showFieldError(el, err);
      });
    }
  });

  // ── Progressive lead capture ──────────────────────────────
  // Fire-and-forget: send partial lead data to BackOffice on each step
  // so we capture the contact even if they abandon the form.
  function savePartialLead(step: number) {
    const fd = new FormData(heroForm);
    const body: Record<string, unknown> = {
      name: fd.get('fullName') || '',
      phone: fd.get('phone') || '',
      email: fd.get('email') || '',
      address: fd.get('address') || '',
      service: fd.get('service') || presetService || '',
      serviceDetail: fd.get('serviceDetail') || '',
      step,
      page_url: window.location.pathname,
    };
    // Capture all 5 UTMs + click IDs from sessionStorage (persisted on landing in Layout.astro)
    // sessionStorage is more reliable than URL params — UTMs survive page navigation
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(k => {
      const v = sessionStorage.getItem('he_' + k);
      if (v) body[k] = v;
    });
    // Ad platform click IDs for conversion attribution
    const storedFbclid = sessionStorage.getItem('he_fbclid');
    const storedFbc = sessionStorage.getItem('he_fbc');
    const storedGclid = sessionStorage.getItem('he_gclid');
    if (storedFbclid) body.fbclid = storedFbclid;
    if (storedFbc) body.fbc = storedFbc;
    if (storedGclid) body.gclid = storedGclid;

    fetch('/api/leads/partial', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    }).catch(() => {}); // fire-and-forget — never block the UI
  }

  // Step 1 → Step 2 (or Step 3 if skipping): validate
  document.getElementById('next-btn-1')?.addEventListener('click', () => {
    const fields = ['fullName', 'phone', 'email', 'address'].map(n =>
      heroForm.querySelector(`input[name="${n}"]`) as HTMLInputElement
    );
    let valid = true;
    const missingFields: string[] = [];
    const labelMap: Record<string, string> = { fullName: 'Full Name', phone: 'Phone Number', email: 'Email', address: 'Project Address' };
    fields.forEach(f => {
      if (!f?.value?.trim()) {
        showFieldError(f, `${labelMap[f.name] || f.name} is required`);
        valid = false;
        missingFields.push(labelMap[f.name] || f.name);
      }
    });
    // Basic email check
    const email = heroForm.querySelector('input[name="email"]') as HTMLInputElement;
    if (email?.value && !email.value.includes('@')) {
      showFieldError(email, 'Enter a valid email address');
      valid = false;
      missingFields.push('valid email');
    }
    // Phone digit check
    const phone = heroForm.querySelector('input[name="phone"]') as HTMLInputElement;
    if (phone?.value && phone.value.replace(/\D/g, '').length < 10) {
      showFieldError(phone, 'Enter a 10-digit phone number');
      valid = false;
      if (!missingFields.includes('Phone Number')) missingFields.push('valid phone number');
    }
    if (!valid) {
      // Announce validation errors to screen readers
      let liveEl = heroForm.querySelector('.sr-form-errors') as HTMLElement;
      if (!liveEl) {
        liveEl = document.createElement('div');
        liveEl.className = 'sr-form-errors sr-only';
        liveEl.setAttribute('aria-live', 'assertive');
        liveEl.setAttribute('role', 'alert');
        heroForm.prepend(liveEl);
      }
      liveEl.textContent = 'Please fill in: ' + missingFields.join(', ');
      // Focus the first invalid field
      const firstInvalid = fields.find(f => !f?.value?.trim());
      if (firstInvalid) firstInvalid.focus();
    }
    if (valid) {
      savePartialLead(1);
      showStep(skipStep2 ? step3 : step2);
    }
  });

  // Step 2: service selection auto-advances
  serviceBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const service = (btn as HTMLElement).dataset.service || '';
      // If preset service exists, this is a sub-option (e.g., "Asphalt Shingles")
      if (presetService) {
        if (serviceDetailInput) serviceDetailInput.value = service;
      } else {
        if (serviceInput) serviceInput.value = service;
      }
      serviceBtns.forEach(b => b.classList.remove('service-btn--active'));
      btn.classList.add('service-btn--active');
      savePartialLead(2);
      setTimeout(() => showStep(step3), 250);
    });
  });

  // Back buttons — clear any lingering validation errors when navigating back
  function clearStepErrors(step: HTMLElement | null) {
    step?.querySelectorAll('input, textarea').forEach(el => clearFieldError(el as HTMLElement));
  }
  document.getElementById('back-btn-1')?.addEventListener('click', () => { clearStepErrors(step1); showStep(step1); });
  document.getElementById('back-btn-2')?.addEventListener('click', () => {
    const target = skipStep2 ? step1 : step2;
    clearStepErrors(target);
    showStep(target);
  });

  // Form submit — use Astro Action (with double-submit guard)
  let isSubmitting = false;
  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    const submitBtn = heroForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn?.textContent || '';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending your request...';
    }

    try {
      const formData = new FormData(heroForm);
      const { data, error } = await actions.submitLead(formData);

      if (error) {
        // Show field-level errors
        if ('fields' in error) {
          const fields = error.fields as Record<string, string[]>;
          for (const [fieldName, messages] of Object.entries(fields)) {
            const input = heroForm.querySelector(`[name="${fieldName}"]`) as HTMLElement;
            if (input) showFieldError(input, messages[0]);
          }
          // Go back to the step with the error
          if (fields.fullName || fields.phone || fields.email || fields.address) {
            showStep(step1);
          } else if (fields.consent) {
            showStep(step3);
          }
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
        isSubmitting = false;
        return;
      }

      // Success — identify user profile + track conversion
      const leadName = formData.get('fullName') as string || '';
      const leadEmail = formData.get('email') as string || '';
      const leadPhone = formData.get('phone') as string || '';
      // Build UTM props from sessionStorage for client-side attribution
      const utmProps: Record<string, string> = {};
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(k => {
        const v = sessionStorage.getItem('he_' + k);
        if (v) utmProps[k] = v;
      });

      if ((window as any).op) {
        (window as any).op('identify', {
          profileId: leadEmail,
          email: leadEmail,
          firstName: leadName.split(' ')[0] || '',
          lastName: leadName.split(' ').slice(1).join(' ') || '',
          phone: leadPhone,
          properties: {
            address: formData.get('address') as string || '',
            service: formData.get('service') as string || 'general',
            source: 'hero_form',
            ...utmProps,
          },
        });
        (window as any).op('track', 'lead_form_submitted', {
          service: formData.get('service') || 'general',
          source: 'hero_form',
          ...utmProps,
        });
      }
      if ((window as any).dataLayer) {
        (window as any).dataLayer.push({
          event: 'lead_form_submitted',
          service: formData.get('service') || 'general',
          source: 'hero_form',
          ...utmProps,
        });
      }

      // Meta Pixel — client-side Lead event (deduped with server CAPI via eventId)
      if (typeof fbq === 'function' && data?.eventId) {
        fbq('track', 'Lead', {
          content_name: formData.get('service') || 'general',
          currency: 'USD',
        }, { eventID: data.eventId });
      }

      // Success — show confirmation
      const formCard = heroForm.parentElement;
      if (formCard) {
        formCard.innerHTML = `
          <div style="text-align: center; padding: 40px 20px;">
            <div style="width: 48px; height: 48px; margin: 0 auto 12px; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <h3 style="font-family: var(--font-oswald); font-size: 1.5rem; color: var(--color-primary); text-transform: uppercase; margin-bottom: 8px;">Thank You — We're On It</h3>
            <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted); line-height: 1.5;">We'll call you within <strong>3–5 minutes</strong> to schedule your inspection.</p>
            <a href="tel:+16509773351" style="display: inline-block; margin-top: 16px; font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 700; color: var(--color-primary); text-decoration: underline;">Or call us now: (650) 977-3351</a>
          </div>
        `;
      }
    } catch (err) {
      // Network error fallback — styled inline, never browser alert()
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
      isSubmitting = false;
      let errBox = heroForm.querySelector('.form-error-inline');
      if (!errBox) {
        errBox = document.createElement('div');
        errBox.className = 'form-error-inline';
        errBox.style.cssText = 'margin-top:12px;padding:14px 16px;border-radius:4px;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);text-align:center;';
        heroForm.appendChild(errBox);
      }
      errBox.innerHTML = '<p style="font-family:var(--font-dm-sans);font-size:14px;color:var(--color-error);margin-bottom:6px;font-weight:500;">We couldn\'t submit your request. Please try again.</p><a href="tel:+16509773351" style="font-family:var(--font-dm-sans);font-size:14px;font-weight:700;color:var(--color-primary);text-decoration:underline;">Or call us: (650) 977-3351</a>';
    }
  });
</script>

