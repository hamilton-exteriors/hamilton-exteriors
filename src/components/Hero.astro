---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { heroBg, iconStar } from '../lib/images';

interface Props {
  formTitle?: string;
  formAction?: string;
  formSubtitle?: string;
  headline?: string;
  badges?: string[];
  ctaText?: string;
  ctaHref?: string;
  heroImage?: ImageMetadata;
}

const {
  formTitle = 'Get a FREE QUOTE',
  formAction = '/success',
  formSubtitle = "We'll contact you in 3-5 minutes to schedule a FREE roof inspection.",
  headline = 'Bay Areas  Favorite  Construction  Company',
  headlineLines = headline.trim().split(/\s{2,}|\n/),
  badges = [
    'Licensed Bonded & Insured',
    'Start with $0 Down',
    '50 year Warranty',
    '3-5 day install',
  ],
  ctaText = 'Call Us - We Answer Fast',
  ctaHref = 'tel:6509773351',
  heroImage = heroBg,
} = Astro.props;
---

<section id="quote" class="relative w-full overflow-hidden" style="padding-top: 24px; padding-bottom: 32px;">
  <!-- Background image — zoomed out on mobile -->
  <div class="absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      width={1920}
      height={1080}
      class="hero-bg-img h-full w-full object-cover"
      loading="eager"
    />
  </div>
  <!-- Dark gradient scrim for text readability -->
  <div class="pointer-events-none absolute inset-0" style="z-index: 1;" aria-hidden="true">
    <div class="hero-scrim absolute inset-0"></div>
  </div>
  <!-- Film grain overlay -->
  <div class="pointer-events-none absolute inset-0" style="opacity: 0.15; mix-blend-mode: overlay; z-index: 2;" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style="display: block;">
      <filter id="hero-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#hero-grain)" />
    </svg>
  </div>

  <div
    class="relative mx-auto flex flex-col gap-6 px-4 lg:flex-row lg:items-start lg:gap-12 lg:px-5"
    style="max-width: 1294px;"
  >

    <!-- Left Column -->
    <div class="flex flex-col items-start lg:w-[45%] lg:py-6">

      <!-- Rating badge -->
      <div class="mb-4 inline-flex items-center gap-2 lg:mb-0">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <div class="relative h-[16px] w-[16px] shrink-0 lg:h-[20px] lg:w-[20px]">
              <Image
                src={iconStar}
                alt=""
                width={20}
                height={21}
                loading="eager"
                class="h-full w-full object-contain"
              />
            </div>
          ))}
        </div>
        <span
          class="text-white/80"
          style="font-family: 'DM Sans', sans-serif; font-size: clamp(0.875rem, 4vw, 1rem); font-weight: 500; letter-spacing: 0;"
        >
          rated 5/5 based on 50 reviews.
        </span>
      </div>

      <!-- Headline — fluid fit-to-width per line -->
      <h1
        class="w-full text-white"
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-weight: 400; text-transform: uppercase; line-height: 0.75; display: flex; flex-direction: column; gap: 0;"
      >
        {headlineLines.map((line: string) => (
          <span class="text-fit">
            <span><span>{line}</span></span>
            <span aria-hidden="true">{line}</span>
          </span>
        ))}
      </h1>

      <!-- Trust badges -->
      <div class="mt-3 flex flex-col gap-1.5 lg:mt-5 lg:gap-3">
        {badges.map((badge) => (
          <div class="flex items-center gap-2.5">
            <div class="relative shrink-0" style="width: clamp(16px, 4.5vw, 20px); height: clamp(16px, 4.5vw, 20px);">
              <svg viewBox="0 0 20 20" class="h-full w-full" style="fill: rgba(0,0,0,1); color: rgba(0,0,0,1);">
                <path d="M16.667 5L7.5 14.167L3.333 10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>
            <span class="text-white" style="font-family: 'DM Sans', sans-serif; font-size: clamp(1rem, 4.5vw, 1.125rem); line-height: 1.4;">{badge}</span>
          </div>
        ))}
      </div>

    </div>

    <!-- Right Column — Lead Form -->
    <div class="w-full lg:w-[45%]">
      <!-- Form card -->
      <div class="overflow-hidden rounded-2xl lg:rounded-3xl" style="box-shadow: 0 8px 32px rgba(0,0,0,0.12);">
        <div class="bg-white px-4 pb-4 pt-5 lg:px-6 lg:pb-6 lg:pt-6">
          <!-- Form title -->
          <h2
            class="mb-1 text-center"
            style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 1.5rem; line-height: 1.2; font-weight: 400; color: var(--color-heading); text-transform: uppercase;"
          >
            {formTitle}
          </h2>
          <p
            class="mb-5 text-center"
            style="font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; line-height: 1.5; color: var(--color-light);"
          >
            {formSubtitle}
          </p>

          <!-- 3-Step Form -->
          <form action={formAction} method="POST" id="hero-form">
            <!-- Step 1: Contact Info -->
            <div id="step-1" class="form-step">
              <div class="mb-3 flex items-center gap-2">
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full" style="background: rgb(230,230,230);">
                    <div class="h-full rounded-full" style="width: 33%; background: var(--color-primary);"></div>
                  </div>
                </div>
                <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: rgb(150,150,150);">1/3</span>
              </div>
              <div class="flex flex-col gap-3">
                <label for="hero-name" class="sr-only">Full Name</label>
                <input type="text" id="hero-name" name="fullName" placeholder="Full Name" required class="hero-input w-full" />
                <label for="hero-phone" class="sr-only">Phone Number</label>
                <input type="tel" id="hero-phone" name="phone" placeholder="Phone Number" required class="hero-input w-full" />
                <label for="hero-email" class="sr-only">Email</label>
                <input type="email" id="hero-email" name="email" placeholder="Email" required class="hero-input w-full" />
                <label for="hero-address" class="sr-only">Project Address</label>
                <input type="text" id="hero-address" name="address" placeholder="Project Address" required class="hero-input w-full" />
              </div>
              <button
                type="button"
                id="next-btn-1"
                class="mt-4 w-full rounded-full py-3.5 text-center font-bold uppercase text-white"
                style="background-color: var(--color-yellow); color: var(--color-primary); font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 0.875rem; letter-spacing: 0.05em;"
              >
                Next: Choose Your Service
              </button>
            </div>

            <!-- Step 2: Service Selection -->
            <div id="step-2" class="form-step" style="display: none;">
              <div class="mb-3 flex items-center gap-2">
                <button type="button" id="back-btn-1" class="shrink-0" style="color: var(--color-primary);">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                </button>
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full" style="background: rgb(230,230,230);">
                    <div class="h-full rounded-full" style="width: 66%; background: var(--color-primary);"></div>
                  </div>
                </div>
                <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: rgb(150,150,150);">2/3</span>
              </div>
              <p class="mb-1 text-center" style="font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600; color: var(--color-heading);">What do you need help with?</p>
              <p class="mb-3 text-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: rgb(150,150,150);">Select one to continue</p>
              <input type="hidden" name="service" id="service-input" />
              <div class="grid grid-cols-2 gap-2">
                {['Roofing', 'Siding', 'Windows', 'Other'].map((service) => (
                  <button
                    type="button"
                    class="service-btn"
                    data-service={service}
                  >
                    {service}
                  </button>
                ))}
              </div>
            </div>

            <!-- Step 3: Details + Submit -->
            <div id="step-3" class="form-step" style="display: none;">
              <div class="mb-3 flex items-center gap-2">
                <button type="button" id="back-btn-2" class="shrink-0" style="color: var(--color-primary);">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                </button>
                <div class="flex-1">
                  <div class="h-1.5 w-full rounded-full" style="background: rgb(230,230,230);">
                    <div class="h-full rounded-full" style="width: 100%; background: var(--color-primary);"></div>
                  </div>
                </div>
                <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: rgb(150,150,150);">3/3</span>
              </div>
              <label for="hero-message" class="sr-only">Project details</label>
              <textarea
                id="hero-message"
                name="message"
                rows="3"
                placeholder="Tell us about your project (optional)"
                class="hero-input w-full resize-none"
              ></textarea>
              <label class="mt-3 flex items-start gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  name="consent"
                  required
                  class="mt-0.5 h-4 w-4 shrink-0"
                  style="border-radius: 4px; accent-color: var(--color-primary);"
                />
                <span style="font-family: 'DM Sans', sans-serif; font-size: 10px; line-height: 1.5; color: var(--color-light);">
                  I agree to the <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Terms</a> & <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Privacy Policy</a>. Msg & data rates may apply.
                </span>
              </label>
              <button
                type="submit"
                class="mt-4 w-full rounded-full py-3.5 text-center font-bold uppercase text-white"
                style="background-color: var(--color-yellow); color: var(--color-primary); font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 0.875rem; letter-spacing: 0.05em;"
              >
                Get My Free Quote
              </button>
            </div>
          </form>
          <!-- Trust micro-copy -->
          <p class="mt-3 text-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.6875rem; color: rgb(150,150,150);">
            Your info is safe &bull; 100% Free &bull; No obligation
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const serviceBtns = document.querySelectorAll('.service-btn');
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const step3 = document.getElementById('step-3');
  const serviceInput = document.getElementById('service-input') as HTMLInputElement;
  const heroForm = document.getElementById('hero-form') as HTMLFormElement;

  function showStep(step: HTMLElement | null) {
    [step1, step2, step3].forEach(s => {
      if (s) { s.style.display = 'none'; s.style.opacity = '0'; }
    });
    if (step) {
      step.style.display = 'block';
      requestAnimationFrame(() => { step.style.opacity = '1'; });
    }
  }

  // Clear red border on input
  heroForm?.querySelectorAll('input, textarea').forEach(input => {
    input.addEventListener('input', () => {
      (input as HTMLElement).style.borderColor = '';
    });
  });

  // Step 1 → Step 2: validate
  document.getElementById('next-btn-1')?.addEventListener('click', () => {
    const fields = ['fullName', 'phone', 'email', 'address'].map(n =>
      heroForm.querySelector(`input[name="${n}"]`) as HTMLInputElement
    );
    let valid = true;
    fields.forEach(f => {
      if (!f?.value?.trim()) {
        f.style.borderColor = 'var(--color-error)';
        valid = false;
      }
    });
    // Basic email check
    const email = heroForm.querySelector('input[name="email"]') as HTMLInputElement;
    if (email?.value && !email.value.includes('@')) {
      email.style.borderColor = 'var(--color-error)';
      valid = false;
    }
    if (valid) showStep(step2);
  });

  // Step 2: service selection auto-advances
  serviceBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const service = (btn as HTMLElement).dataset.service || '';
      if (serviceInput) serviceInput.value = service;
      serviceBtns.forEach(b => b.classList.remove('service-btn--active'));
      btn.classList.add('service-btn--active');
      setTimeout(() => showStep(step3), 250);
    });
  });

  // Back buttons
  document.getElementById('back-btn-1')?.addEventListener('click', () => showStep(step1));
  document.getElementById('back-btn-2')?.addEventListener('click', () => showStep(step2));

  // Form submit — show success state
  heroForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formCard = heroForm.closest('.lg\\:!rounded-\\[30px\\]') || heroForm.parentElement;
    if (formCard) {
      formCard.innerHTML = `
        <div style="text-align: center; padding: 40px 20px;">
          <div style="font-size: 48px; margin-bottom: 12px;">✓</div>
          <h3 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 1.5rem; color: var(--color-primary); text-transform: uppercase; margin-bottom: 8px;">We Got Your Request!</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: rgb(100,100,100); line-height: 1.5;">We'll call you within <strong>5 minutes</strong> to schedule your free inspection.</p>
          <a href="tel:6509773351" style="display: inline-block; margin-top: 16px; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--color-primary); text-decoration: underline;">Or call us now: (650) 977-3351</a>
        </div>
      `;
    }
  });
</script>

<style>
  /* Calibrated scrim: 25% uniform to boost contrast without killing image */
  .hero-scrim {
    background: rgba(0, 0, 0, 0.25);
  }

  .text-fit > :not([aria-hidden]) > * {
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.25), 0 0 2px rgba(0, 0, 0, 0.15);
  }

  #quote .text-white,
  #quote .text-white\/80,
  #quote .text-white\/90 {
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .hero-bg-img {
    object-position: center 20%;
  }

  @media (min-width: 1024px) {
    .hero-bg-img {
      object-position: center center;
    }
  }

  .form-step {
    transition: opacity 0.2s ease-out;
  }

  .service-btn {
    font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-green-bg);
    border: 2px solid rgb(37, 99, 70, 0.2);
    border-radius: 10px;
    padding: 18px 8px;
    cursor: pointer;
    transition: all 0.15s ease-out;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .service-btn:hover {
    border-color: var(--color-primary);
    background: var(--color-green-light);
    transform: scale(1.02);
  }
  .service-btn:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }
  .service-btn--active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
  }
  .text-fit {
    display: flex;
    container-type: inline-size;
    --fit-length: initial;
    --fit-sentinel: var(--fit-length, 9999px);
    --fit-max: 1.5em;
    margin-bottom: -0.28em;
  }

  .text-fit > [aria-hidden] {
    visibility: hidden;
    position: absolute;
    pointer-events: none;
  }

  .text-fit > :not([aria-hidden]) {
    flex-grow: 1;
    container-type: inline-size;
    --fit-length: 100cqi;
    --fit-space: var(--fit-length);
  }

  .text-fit > :not([aria-hidden]) > * {
    --fit-sentinel: inherit;
    --fit-length: 100cqi;
    --fit-ratio: tan(atan2(
      var(--fit-space),
      var(--fit-space) - var(--fit-length)
    ));
    --fit-size: clamp(
      1em,
      1em * var(--fit-ratio),
      var(--fit-max, infinity * 1px) - var(--fit-sentinel)
    );
    inline-size: var(--fit-space);
    display: block;
    font-size: calc(var(--fit-size) * 0.88);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  @media (min-width: 1024px) {
    .text-fit {
      display: inline;
      container-type: normal;
    }
    .text-fit > [aria-hidden] {
      display: none;
    }
    .text-fit > :not([aria-hidden]) {
      container-type: normal;
    }
    .text-fit > :not([aria-hidden]) > * {
      font-size: clamp(48px, 4vw, 56px);
      inline-size: auto;
      white-space: normal;
      display: inline;
    }
  }

  .hero-input {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0em;
    color: rgb(32, 26, 22);
    background-color: rgb(255, 255, 255);
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    padding: 12px;
    outline: none;
    transition: border-color 0.2s;
  }
  .hero-input::placeholder {
    color: var(--color-light);
  }
  .hero-input:focus {
    border-color: var(--color-primary);
  }

  /* Responsive headline scaling */
  @media (max-width: 1023px) {
    h1 {
      font-size: 42px !important;
      line-height: 1.2 !important;
    }
  }
  @media (max-width: 767px) {
    h1 {
      font-size: 36px !important;
      line-height: 1.2 !important;
    }
  }
</style>
