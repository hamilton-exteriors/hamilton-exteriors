---
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconPlus from './icons/IconPlus.astro';

interface Props {
  extraFaqs?: Array<{ question: string; answer: string }>;
}
const { extraFaqs } = Astro.props;

const faqs = [
  {
    question: 'How does pricing work — any hidden fees?',
    answer:
      'Every estimate is written and itemized before we start. The price we quote is the price you pay — no surprises, no add-ons.',
  },
  {
    question: 'Will you beat a competitor\'s quote?',
    answer:
      'Yes. Show us a written estimate from a licensed contractor for the same scope of work and we\'ll match or beat it.',
  },
  {
    question: 'How does billing and financing work?',
    answer:
      '$0 down financing available with approved credit. You only pay for completed, inspected work. We\'ll walk you through all your payment options during the estimate.',
  },
  {
    question: 'How long does a typical project take?',
    answer:
      'Most roofs are done in 3-5 days. Siding projects run 1-2 weeks depending on scope. We\'ll give you a specific timeline during your free inspection.',
  },
  {
    question: 'What warranties do you offer?',
    answer:
      'Up to a 50-year shingle warranty and 35-year labor warranty on roofing. Every project comes with a written warranty — we stand behind our work.',
  },
];
---

<section class="w-full" style="background-color: var(--color-white);">
  <div class="mx-auto px-5 py-12 lg:py-20" style="max-width: 1170px;">

    <!-- Heading row: title left, CTA right -->
    <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center" style="margin-bottom: 40px;">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); font-weight: 400; line-height: 1.25; color: var(--color-heading); text-transform: uppercase; margin: 0;">
        Frequently Asked Questions
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading); margin: 0;" class="text-left md:text-right md:whitespace-nowrap">
        Didn't find the answer to your question?{' '}
        <a
          href={PHONE_HREF}
          style="font-weight: 400; color: var(--color-heading); text-decoration: none;"
        >
          Call Now  {PHONE_DISPLAY}
        </a>
      </p>
    </div>

    <!-- Accordion -->
    <div class="mx-auto" style="max-width: 100%;">
      {
        faqs.map((faq, index) => (
          <details
            class="group"
            data-border="true"
            style={`border-bottom: 1px solid var(--color-border); background-color: var(--color-white);`}
          >
            <summary class="flex cursor-pointer items-center justify-between list-none [&::-webkit-details-marker]:hidden" style="padding: 20px 0;">
              <span style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; letter-spacing: 0px; color: var(--color-charcoal); padding-right: 16px;">
                {faq.question}
              </span>
              <span class="relative flex shrink-0 items-center justify-center" style="width: 24px; height: 24px; color: var(--color-charcoal);">
                <IconPlus />
              </span>
            </summary>
            <div style="padding-bottom: 20px; padding-right: 48px;">
              <p style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; color: var(--color-muted); margin: 0;">
                {faq.answer}
              </p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- FAQPage Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(faq => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
})} />

<style>
  summary svg {
    transition: transform 0.2s ease-out;
  }
  details[open] summary svg {
    transform: rotate(45deg);
  }
</style>
