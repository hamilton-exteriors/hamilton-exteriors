---
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconPlus from './icons/IconPlus.astro';

interface Props {
  extraFaqs?: Array<{ question: string; answer: string }>;
}
const { extraFaqs } = Astro.props;

const baseFaqs = [
  {
    question: 'What areas in the Bay Area do you serve?',
    answer:
      'Hamilton Exteriors serves six Bay Area counties: Alameda County (Oakland, Berkeley, Fremont, Hayward, San Leandro), Contra Costa County (Walnut Creek, Concord, San Ramon, Richmond, Antioch), Santa Clara County (San Jose, Palo Alto, Sunnyvale, Mountain View, Cupertino), Marin County (San Rafael, Mill Valley, Novato, Larkspur), Napa County (Napa, St. Helena, Calistoga, Yountville, American Canyon), and San Mateo County. We handle all local permits and know the building codes for each jurisdiction — permit requirements and fees vary significantly between cities, so local expertise matters. Our crews are based in Castro Valley in Alameda County, which puts us within 45 minutes of every city we serve. We completed over 500 residential projects across these six counties since 2020, and our project managers are familiar with the specific inspection requirements of each city building department.',
  },
  {
    question: 'How does billing and financing work?',
    answer:
      'Hamilton Exteriors offers $0 down financing with approved credit, so you can start your project without any upfront cost. We partner with multiple lending providers to offer flexible terms including 12 months same-as-cash, low monthly payment plans, and extended terms up to 15 years for larger projects like ADUs and custom homes. You only pay for completed, inspected work — we never ask for full payment before the job is done. During your free estimate appointment, your project manager will walk you through all available payment options and help you choose the plan that fits your budget. For homeowners who prefer to pay in full, we accept checks, ACH transfers, and all major credit cards.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      'Yes. Hamilton Exteriors holds California Contractors State License Board (CSLB) License #1082377, which you can verify directly on the CSLB website at cslb.ca.gov. We carry general liability insurance with a minimum $2 million policy and workers\' compensation coverage for every crew member on your property. We are also bonded as required by California law. Our manufacturer certifications include GAF Certified Installer, Owens Corning Preferred Contractor, CertainTeed ShingleMaster, James Hardie Elite Preferred, and Tesla Powerwall Certified Installer — each of these requires annual training and quality audits to maintain. Our founder, Alexander Hamilton Li, is a licensed architect and general contractor who personally oversees project quality. We are happy to provide proof of insurance and licensing before any work begins, and we encourage homeowners to verify any contractor\'s license status on the CSLB website before signing a contract.',
  },
  {
    question: 'Do I need a permit for my exterior project?',
    answer:
      'Most roof replacements, siding installations, and window replacements in the Bay Area require a building permit. Permit requirements and fees vary by city and county — for example, Oakland permits cost $200 to $600, while Palo Alto and other Peninsula cities may charge more. Hamilton Exteriors handles the entire permit process for you, including application, plan submission, and scheduling inspections. Permit fees are included as a separate line item in your estimate so there are no surprises. For homes in Wildland-Urban Interface (WUI) fire zones — common in the Berkeley Hills, Oakland Hills, and parts of Marin — additional fire-rated material requirements apply, and we ensure full compliance with local fire codes.',
  },
];

// Merge base FAQs with page-specific extra FAQs (city/service pages pass these in)
const faqs = [...baseFaqs, ...(extraFaqs || [])];
---

<section class="cv-auto w-full" style="background-color: var(--color-white);">
  <div class="mx-auto px-5 py-12 lg:py-20" style="max-width: 1170px;">

    <!-- Heading row: title left, CTA right -->
    <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center" style="margin-bottom: 40px;">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); font-weight: 400; line-height: 1.25; color: var(--color-heading); text-transform: uppercase; margin: 0;">
        Frequently Asked Questions
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading); margin: 0;" class="text-left md:text-right md:whitespace-nowrap">
        Didn't find the answer to your question?{' '}
        <a
          href={PHONE_HREF}
          style="font-weight: 400; color: var(--color-heading); text-decoration: none;"
        >
          Call Now  {PHONE_DISPLAY}
        </a>
      </p>
    </div>

    <!-- Accordion -->
    <div class="mx-auto" style="max-width: 100%;">
      {
        faqs.map((faq, index) => (
          <details
            class="group"
            data-border="true"
            style={`border-bottom: 1px solid var(--color-border); background-color: var(--color-white);`}
          >
            <summary class="flex cursor-pointer items-center justify-between list-none [&::-webkit-details-marker]:hidden" style="padding: 20px 0;">
              <span style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; letter-spacing: 0px; color: var(--color-charcoal); padding-right: 16px;">
                {faq.question}
              </span>
              <span class="relative flex shrink-0 items-center justify-center" style="width: 24px; height: 24px; color: var(--color-charcoal);">
                <IconPlus />
              </span>
            </summary>
            <div style="padding-bottom: 20px; padding-right: 48px;">
              <p style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; color: var(--color-muted); margin: 0;">
                {faq.answer}
              </p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- FAQPage Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(faq => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
})} />

<style>
  summary svg {
    transition: transform 0.2s ease-out;
  }
  details[open] summary svg {
    transform: rotate(45deg);
  }
</style>
