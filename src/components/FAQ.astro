---
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconPlus from './icons/IconPlus.astro';

interface Props {
  extraFaqs?: Array<{ question: string; answer: string }>;
}
const { extraFaqs } = Astro.props;

const baseFaqs = [
  {
    question: 'What areas in the Bay Area do you serve?',
    answer:
      'Hamilton Exteriors serves six Bay Area counties: Alameda County (Oakland, Berkeley, Fremont, Hayward, San Leandro), Contra Costa County (Walnut Creek, Concord, San Ramon, Richmond, Antioch), Santa Clara County (San Jose, Palo Alto, Sunnyvale, Mountain View, Cupertino), Marin County (San Rafael, Mill Valley, Novato, Larkspur), Napa County (Napa, St. Helena, Calistoga, Yountville, American Canyon), and San Mateo County. We handle all local permits and know the building codes for each jurisdiction — permit requirements and fees vary significantly between cities, so local expertise matters. Our crews are based in Castro Valley in Alameda County, which puts us within 45 minutes of every city we serve. We completed over 500 residential projects across these six counties since 2018, and our project managers are familiar with the specific inspection requirements of each city building department.',
  },
  {
    question: 'How does billing and financing work?',
    answer:
      'Hamilton Exteriors offers $0 down financing with approved credit, so you can start your project without any upfront cost. We partner with multiple lending providers to offer flexible terms including 12 months same-as-cash, low monthly payment plans, and extended terms up to 15 years for larger projects like ADUs and custom homes. You only pay for completed, inspected work — we never ask for full payment before the job is done. During your free estimate appointment, your project manager will walk you through all available payment options and help you choose the plan that fits your budget. For homeowners who prefer to pay in full, we accept checks, ACH transfers, and all major credit cards.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      'Yes. Hamilton Exteriors holds California Contractors State License Board (CSLB) License #1082377, which you can verify directly on the CSLB website at cslb.ca.gov. We carry general liability insurance with a minimum $2 million policy and workers\' compensation coverage for every crew member on your property. We are also bonded as required by California law. Our manufacturer certifications include GAF Master Elite Contractor, Owens Corning Preferred Contractor, CertainTeed ShingleMaster, James Hardie Elite Preferred, and Tesla Powerwall Certified Installer — each of these requires annual training and quality audits to maintain. Our founder, Alexander Hamilton Li, is a licensed architect and general contractor who personally oversees project quality. We are happy to provide proof of insurance and licensing before any work begins, and we encourage homeowners to verify any contractor\'s license status on the CSLB website before signing a contract.',
  },
  {
    question: 'Do I need a permit for my exterior project?',
    answer:
      'Most roof replacements, siding installations, and window replacements in the Bay Area require a building permit. Permit requirements and fees vary by city and county — for example, Oakland permits cost $200 to $600, while Palo Alto and other Peninsula cities may charge more. Hamilton Exteriors handles the entire permit process for you, including application, plan submission, and scheduling inspections. Permit fees are included as a separate line item in your estimate so there are no surprises. For homes in Wildland-Urban Interface (WUI) fire zones — common in the Berkeley Hills, Oakland Hills, and parts of Marin — additional fire-rated material requirements apply, and we ensure full compliance with local fire codes.',
  },
];

// Merge base FAQs with page-specific extra FAQs (city/service pages pass these in)
const faqs = [...baseFaqs, ...(extraFaqs || [])];
---

<section class="cv-auto w-full bg-white">
  <div class="mx-auto max-w-[1170px] px-5 py-12 lg:py-20">

    <!-- Heading row: title left, CTA right -->
    <div class="mb-10 flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
      <h2 class="m-0 text-[clamp(28px,5vw,40px)] leading-tight">
        Frequently Asked Questions
      </h2>
      <p class="m-0 text-left text-sm/normal font-normal text-heading md:text-right md:whitespace-nowrap">
        Didn't find the answer to your question?{' '}
        <a
          href={PHONE_HREF}
          class="font-normal text-heading no-underline"
        >
          Call Now  {PHONE_DISPLAY}
        </a>
      </p>
    </div>

    <!-- Accordion -->
    <div class="mx-auto max-w-full">
      {
        faqs.map((faq, index) => (
          <details
            class="group border-b border-border bg-white"
            data-border="true"
          >
            <summary class="flex cursor-pointer list-none items-center justify-between py-5 [&::-webkit-details-marker]:hidden">
              <span class="pr-4 text-base/normal font-normal text-charcoal">
                {faq.question}
              </span>
              <span class="relative flex size-6 shrink-0 items-center justify-center text-charcoal">
                <IconPlus />
              </span>
            </summary>
            <div class="pr-12 pb-5">
              <p class="m-0 text-base/normal font-normal text-muted">
                {faq.answer}
              </p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- FAQPage Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `https://hamilton-exteriors.com${Astro.url.pathname}#faq`,
  'mainEntity': faqs.map(faq => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
})} />

<style>
  summary svg {
    transition: transform 0.2s ease-out;
  }
  details[open] summary svg {
    transform: rotate(45deg);
  }
</style>
