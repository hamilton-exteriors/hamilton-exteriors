---
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import IconPlus from './icons/IconPlus.astro';

interface Props {
  extraFaqs?: Array<{ question: string; answer: string }>;
}
const { extraFaqs } = Astro.props;

const baseFaqs = [
  {
    question: 'How long does a typical project take?',
    answer:
      'Project timelines depend on the scope of work, but Hamilton Exteriors is known for fast, efficient installations across the Bay Area. A standard asphalt shingle roof replacement typically takes 3 to 5 days from start to completion, including tear-off, underlayment, installation, flashing, and cleanup. Metal and tile roofs may take 5 to 7 days due to additional preparation. James Hardie fiber cement siding projects generally run 1 to 2 weeks depending on the home\'s square footage. Window replacements average 1 to 2 days for a typical home. Every project gets a dedicated project manager who provides a specific timeline during your free inspection, keeps you updated daily, and ensures the crew meets the schedule.',
  },
  {
    question: 'What warranties do you offer?',
    answer:
      'Hamilton Exteriors provides industry-leading warranties on every project. For roofing, we offer up to a 50-year manufacturer shingle warranty combined with a 35-year labor warranty — one of the longest in the Bay Area. Our GAF and Owens Corning certifications qualify your roof for enhanced manufacturer warranties that cover both materials and workmanship. For James Hardie siding, you receive a 30-year non-prorated product warranty plus our 10-year labor warranty. Window installations carry the manufacturer\'s lifetime warranty on glass seals and frames. Every Hamilton Exteriors project comes with a written warranty document that clearly states what is covered, for how long, and how to file a claim. We stand behind our work — CSLB License #1082377.',
  },
  {
    question: 'How does billing and financing work?',
    answer:
      'Hamilton Exteriors offers $0 down financing with approved credit, so you can start your project without any upfront cost. We partner with multiple lending providers to offer flexible terms including 12 months same-as-cash, low monthly payment plans, and extended terms up to 15 years for larger projects like ADUs and custom homes. You only pay for completed, inspected work — we never ask for full payment before the job is done. During your free estimate appointment, your project manager will walk you through all available payment options and help you choose the plan that fits your budget. For homeowners who prefer to pay in full, we accept checks, ACH transfers, and all major credit cards.',
  },
  {
    question: 'What areas in the Bay Area do you serve?',
    answer:
      'Hamilton Exteriors serves five Bay Area counties: Alameda County (Oakland, Berkeley, Fremont, Hayward, San Leandro), Contra Costa County (Walnut Creek, Concord, San Ramon, Richmond, Antioch), Santa Clara County (San Jose, Palo Alto, Sunnyvale, Mountain View, Cupertino), Marin County (San Rafael, Mill Valley, Novato, Larkspur), and Napa County (Napa, St. Helena, Calistoga, Yountville, American Canyon). We handle all local permits and know the building codes for each jurisdiction. Our crews are based in Castro Valley, which puts us within 45 minutes of every city we serve.',
  },
  {
    question: 'How much does a roof replacement cost in the Bay Area?',
    answer:
      'Bay Area roof replacement costs range from $8,000 to $25,000 for most homes, depending on roof size, pitch, material, and access. Composite asphalt shingles run $940 to $1,125 per roofing square (100 sq ft) installed. Premium architectural shingles and designer options range from $1,075 to $1,525 per square. Metal roofing costs $1,200 to $1,800 per square but lasts 40 to 70 years. Every Hamilton Exteriors estimate is itemized with no hidden fees — tear-off, underlayment, flashing, materials, labor, cleanup, and permit costs are all listed separately so you can see exactly where your money goes.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      'Yes. Hamilton Exteriors holds California Contractors State License Board (CSLB) License #1082377, which you can verify directly on the CSLB website at cslb.ca.gov. We carry general liability insurance and workers\' compensation coverage for every crew member on your property. We are also bonded as required by California law. Our certifications include GAF Certified, Owens Corning Preferred, CertainTeed ShingleMaster, James Hardie Elite Preferred, and Tesla Powerwall Certified Installer. We are happy to provide proof of insurance and licensing before any work begins.',
  },
  {
    question: 'What is included in a free roof inspection?',
    answer:
      'Our free roof inspection covers a full assessment of your existing roof\'s condition. A Hamilton Exteriors project manager will examine shingle wear, granule loss, cracked or missing shingles, flashing around vents and chimneys, gutter condition, signs of water intrusion in the attic, and overall structural integrity. You\'ll receive a written report with photos documenting any issues found, along with a detailed estimate if work is recommended. The inspection typically takes 30 to 45 minutes and there is no obligation to proceed. We inspect over 200 Bay Area roofs per year and will give you an honest assessment of whether you need a repair, partial replacement, or full reroof.',
  },
  {
    question: 'Do I need a permit for my roofing or siding project?',
    answer:
      'Most roof replacements and siding installations in the Bay Area require a building permit. Permit requirements and fees vary by city and county — for example, Oakland permits cost $200 to $600, while Palo Alto and other Peninsula cities may charge more. Hamilton Exteriors handles the entire permit process for you, including application, plan submission, and scheduling inspections. Permit fees are included as a separate line item in your estimate so there are no surprises. For homes in Wildland-Urban Interface (WUI) fire zones — common in the Berkeley Hills, Oakland Hills, and parts of Marin — additional fire-rated material requirements apply, and we ensure full compliance with local fire codes.',
  },
];

// Merge base FAQs with page-specific extra FAQs (city/service pages pass these in)
const faqs = [...baseFaqs, ...(extraFaqs || [])];
---

<section class="w-full" style="background-color: var(--color-white);">
  <div class="mx-auto px-5 py-12 lg:py-20" style="max-width: 1170px;">

    <!-- Heading row: title left, CTA right -->
    <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center" style="margin-bottom: 40px;">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); font-weight: 400; line-height: 1.25; color: var(--color-heading); text-transform: uppercase; margin: 0;">
        Frequently Asked Questions
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 400; line-height: 1.5; color: var(--color-heading); margin: 0;" class="text-left md:text-right md:whitespace-nowrap">
        Didn't find the answer to your question?{' '}
        <a
          href={PHONE_HREF}
          style="font-weight: 400; color: var(--color-heading); text-decoration: none;"
        >
          Call Now  {PHONE_DISPLAY}
        </a>
      </p>
    </div>

    <!-- Accordion -->
    <div class="mx-auto" style="max-width: 100%;">
      {
        faqs.map((faq, index) => (
          <details
            class="group"
            data-border="true"
            style={`border-bottom: 1px solid var(--color-border); background-color: var(--color-white);`}
          >
            <summary class="flex cursor-pointer items-center justify-between list-none [&::-webkit-details-marker]:hidden" style="padding: 20px 0;">
              <span style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; letter-spacing: 0px; color: var(--color-charcoal); padding-right: 16px;">
                {faq.question}
              </span>
              <span class="relative flex shrink-0 items-center justify-center" style="width: 24px; height: 24px; color: var(--color-charcoal);">
                <IconPlus />
              </span>
            </summary>
            <div style="padding-bottom: 20px; padding-right: 48px;">
              <p style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 400; line-height: 1.5; color: var(--color-muted); margin: 0;">
                {faq.answer}
              </p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- FAQPage Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(faq => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
})} />

<style>
  summary svg {
    transition: transform 0.2s ease-out;
  }
  details[open] summary svg {
    transform: rotate(45deg);
  }
</style>
