---
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Reviews from './Reviews.astro';
import CTA from './CTA.astro';
import Difference from './Difference.astro';
import Financing from './Financing.astro';
import ReviewLogos from './ReviewLogos.astro';
import Projects from './Projects.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { hasImage } from '../lib/service-page-types';
import type { ServicePageData, SectionBlock, StylesSection } from '../lib/service-page-types';
import { resolveImage } from '../lib/image-map';
import { getCityWikipedia } from '../lib/city-wikipedia';
import { getCityLocalFacts } from '../lib/city-local-facts';

interface Props {
  data: ServicePageData;
}

const { data } = Astro.props;

// Resolve any string file paths in section images to Astro ImageMetadata
for (const section of data.sections) {
  if (section.type === 'styles' && section.data?.items) {
    for (const item of section.data.items) {
      if (typeof item.image === 'string') {
        item.image = resolveImage(item.image);
      }
    }
  }
  if (section.type === 'imageBanner' && section.data && typeof section.data.image === 'string') {
    section.data.image = resolveImage(section.data.image);
  }
}

// Build areaServed — use city if available (pSEO pages), otherwise counties
// Use AdministrativeArea for county-level entities (name contains "County")
const cityOrArea = (data as any).city;
const citySlug = (data as any).citySlug || '';
const isCountyArea = cityOrArea && /county/i.test(cityOrArea);
const cityWiki = !isCountyArea && citySlug ? getCityWikipedia(citySlug) : undefined;
const areaServed = cityOrArea
  ? isCountyArea
    ? { '@type': 'AdministrativeArea', 'name': cityOrArea, 'containedInPlace': { '@type': 'State', 'name': 'California' } }
    : { '@type': 'City', 'name': cityOrArea, ...(cityWiki && { 'sameAs': cityWiki }), 'containedInPlace': { '@type': 'State', 'name': 'California' } }
  : [
      { '@type': 'County', 'name': 'Alameda County', 'sameAs': 'https://en.wikipedia.org/wiki/Alameda_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Contra Costa County', 'sameAs': 'https://en.wikipedia.org/wiki/Contra_Costa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Marin County', 'sameAs': 'https://en.wikipedia.org/wiki/Marin_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Napa County', 'sameAs': 'https://en.wikipedia.org/wiki/Napa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Santa Clara County', 'sameAs': 'https://en.wikipedia.org/wiki/Santa_Clara_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
    ];

// Detect if this is a main service page (not city/county-specific) for cross-linking
const pathname = Astro.url.pathname.replace(/\/$/, '');
const SERVICE_SLUG_MAP: Record<string, string> = { roofing: 'Roofing', siding: 'Siding', windows: 'Windows', adu: 'ADUs', 'custom-homes': 'Custom Homes', additions: 'Additions' };
const isMainServicePage = !cityOrArea && Object.keys(SERVICE_SLUG_MAP).includes(pathname.replace('/', ''));
const currentServiceSlug = pathname.replace('/', '');
const localFacts = citySlug ? getCityLocalFacts(citySlug) : undefined;

// Build cross-service links for city+service pages
const pathParts = pathname.split('/').filter(Boolean); // e.g., ['service-areas', 'alameda-county-ca', 'oakland-ca', 'roofing']
const isCityServicePage = pathParts.length === 4 && pathParts[0] === 'service-areas';
const countySlugFromPath = isCityServicePage ? pathParts[1] : '';
const citySlugFromPath = isCityServicePage ? pathParts[2] : '';
const currentService = isCityServicePage ? pathParts[3] : '';
const otherServices = isCityServicePage
  ? Object.entries(SERVICE_SLUG_MAP).filter(([slug]) => slug !== currentService)
  : [];

const counties = [
  { name: 'Alameda County', slug: 'alameda-county-ca' },
  { name: 'Contra Costa County', slug: 'contra-costa-county-ca' },
  { name: 'Marin County', slug: 'marin-county-ca' },
  { name: 'Napa County', slug: 'napa-county-ca' },
  { name: 'Santa Clara County', slug: 'santa-clara-county-ca' },
];

// Derive serviceType from the page slug
const serviceSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop() || '';
const SERVICE_TYPE_MAP: Record<string, string> = {
  roofing: 'Roofing',
  siding: 'Siding',
  windows: 'Window Installation',
  adu: 'ADU Construction',
  'custom-homes': 'Custom Home Building',
  additions: 'Room Additions',
};
const serviceType = SERVICE_TYPE_MAP[serviceSlug] || data.title.split('|')[0].split('—')[0].trim();

// Pricing data for AggregateOffer — only on main service pages
const SERVICE_PRICING: Record<string, { low: number; high: number; unit: string; currency: string }> = {
  roofing: { low: 940, high: 1525, unit: 'per roofing square (100 sq ft)', currency: 'USD' },
  siding: { low: 400, high: 1250, unit: 'per 100 sq ft installed', currency: 'USD' },
  windows: { low: 600, high: 3200, unit: 'per window/unit installed', currency: 'USD' },
};
const pricing = SERVICE_PRICING[serviceSlug];

const serviceSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `https://hamilton-exteriors.com${Astro.url.pathname}#service`,
  'name': data.title.split('|')[0].trim(),
  'url': `https://hamilton-exteriors.com${Astro.url.pathname}`,
  'serviceType': serviceType,
  'provider': {
    '@id': 'https://hamilton-exteriors.com/#business',
  },
  'areaServed': areaServed,
  'description': data.description,
  'dateModified': new Date().toISOString().split('T')[0],
  ...(pricing && {
    'offers': {
      '@type': 'AggregateOffer',
      'lowPrice': pricing.low,
      'highPrice': pricing.high,
      'priceCurrency': pricing.currency,
      'unitText': pricing.unit,
      'availability': 'https://schema.org/InStock',
    },
  }),
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

{data.announcementText ? <AnnouncementBar text={data.announcementText} /> : <AnnouncementBar />}
<Navbar />
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  ctaText={data.hero.ctaText}
  ctaHref={data.hero.ctaHref}
  heroImage={data.hero.heroImage}
  badges={data.hero.badges}
  serviceType={data.hero.serviceType}
  serviceOptions={data.hero.serviceOptions}
/>

<div class="mx-auto max-w-7xl px-4 pt-3">
  <p class="text-xs text-gray-400 font-[Satoshi]">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
</div>

{data.sections.map((section) => {
  if (section.type === 'logoSlider') {
    return <LogoSlider />;
  }

  if (section.type === 'reviews') {
    return <Reviews />;
  }

  if (section.type === 'cta') {
    return <CTA />;
  }

  if (section.type === 'reviewLogos') {
    return <ReviewLogos />;
  }

  if (section.type === 'difference') {
    return <Difference />;
  }

  if (section.type === 'projects') {
    return <Projects showFilters={false} />;
  }

  if (section.type === 'financing') {
    return <Financing />;
  }

  if (section.type === 'pricing') {
    const { data: p } = section;
    return (
      <section class="w-full" style="background-color: var(--color-cream); padding: 80px 0;">
        <div class="mx-auto max-w-[1000px] px-5">
          <h2 style="margin-bottom: 8px;">{p.heading}</h2>
          <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted); margin-bottom: 40px;">All prices are per roofing square (100 sq ft), fully installed.</p>
          <div class="overflow-x-auto">
            <table style="width: 100%; border-collapse: collapse; font-family: var(--font-dm-sans); font-size: 0.9375rem;">
              <thead>
                <tr style="border-bottom: 2px solid var(--color-primary);">
                  <th style="text-align: left; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Product</th>
                  <th style="text-align: right; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Price / sq</th>
                  <th style="text-align: right; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Materials</th>
                </tr>
              </thead>
              <tbody>
                {p.tiers.map((tier) => (
                  <>
                    <tr style="background-color: rgba(37, 99, 70, 0.08);">
                      <td colspan="3" style="padding: 10px 16px; font-family: var(--font-oswald); font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary);">{tier.name}</td>
                    </tr>
                    {tier.rows.map((row) => (
                      <tr style="border-bottom: 1px solid var(--color-border);">
                        <td style="padding: 12px 16px; color: var(--color-charcoal);">{row.product}</td>
                        <td style="padding: 12px 16px; text-align: right; font-weight: 600; color: var(--color-heading);">{row.pricePerSq}</td>
                        <td style="padding: 12px 16px; text-align: right; color: var(--color-muted);">{row.materialCost}</td>
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
          <p style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted); margin-top: 16px;">{p.footnote}</p>
          <p style="font-family: var(--font-dm-sans); font-size: 0.75rem; color: var(--color-muted); margin-top: 8px; font-style: italic;">Prices reflect Hamilton Exteriors installed pricing as of Q1 2026, Castro Valley, CA. All prices include tear-off, materials, labor, and cleanup.</p>
        </div>
      </section>
    );
  }

  if (section.type === 'faq') {
    return <FAQ extraFaqs={(data as any).localFaqs} />;
  }

  if (section.type === 'contactUs') {
    return (
      <>
        {localFacts && (
          <section class="w-full" style="background-color: var(--color-cream); padding: 60px 0;">
            <div class="mx-auto max-w-[800px] px-5">
              <h2 style="margin-bottom: 24px;">
                {SERVICE_SLUG_MAP[currentServiceSlug] || 'Our Services'} in {cityOrArea}, California
              </h2>
              <div style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.75; color: var(--color-charcoal);" class="flex flex-col gap-4">
                <p>{localFacts.housingNote}</p>
                <p>{localFacts.permitNote}</p>
                {localFacts.weatherNote && <p>{localFacts.weatherNote}</p>}
              </div>
            </div>
          </section>
        )}
        <ContactUs />
      </>
    );
  }

  if (section.type === 'footer') {
    return (
      <>
        {isMainServicePage && (
          <section class="w-full" style="background-color: var(--color-cream); padding: 60px 0;">
            <div class="mx-auto max-w-[1200px] px-5">
              <h2 style="margin-bottom: 32px;">
                {SERVICE_SLUG_MAP[currentServiceSlug] || 'Our Services'} Across the Bay Area
              </h2>
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {counties.map(c => (
                  <a href={`/service-areas/${c.slug}/${currentServiceSlug}`} style="display: block; padding: 20px; background: var(--color-white); border: 1px solid var(--color-border); text-decoration: none; transition: opacity 0.2s;" class="hover:opacity-80">
                    <h3 style="font-size: 1rem; margin-bottom: 4px; color: var(--color-heading);">{c.name}</h3>
                    <p style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted);">
                      {SERVICE_SLUG_MAP[currentServiceSlug]} services in {c.name}
                    </p>
                  </a>
                ))}
                <a href="/service-areas" style="display: flex; align-items: center; justify-content: center; padding: 20px; background: var(--color-primary); text-decoration: none; transition: opacity 0.2s;" class="hover:opacity-90">
                  <span style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: white;">View All Service Areas &rarr;</span>
                </a>
              </div>
            </div>
          </section>
        )}
        <Footer />
      </>
    );
  }

  if (section.type === 'yellowBar') {
    return (
      <div class="w-full text-center" style="background-color: var(--color-yellow); padding: 14px 0;">
        <a href={section.href} style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: var(--color-heading); text-decoration: none;">{section.text} &rarr;</a>
      </div>
    );
  }

  if (section.type === 'imageBanner') {
    const { data: banner } = section;
    return (
      <section class="relative w-full" style={`height: ${banner.height || 400}px;`}>
        <Image
          src={banner.image}
          alt={banner.alt}
          width={1280}
          height={853}
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
          loading="lazy"
        />
      </section>
    );
  }

  if (section.type === 'stats') {
    const { data: stats } = section;
    const padding = stats.desktopOnly ? '60px 0' : '48px 0';
    const gridBreakpoint = stats.desktopOnly ? 'lg' : 'md';
    return (
      <section class={`w-full ${stats.desktopOnly ? 'hidden lg:block' : ''}`} style={`background-color: var(--color-cream); padding: ${padding};`}>
        <div class={`mx-auto max-w-[1200px] px-5 grid grid-cols-1 ${gridBreakpoint === 'lg' ? `lg:grid-cols-${stats.items.length}` : `md:grid-cols-${stats.items.length} md:gap-8`} gap-${gridBreakpoint === 'lg' ? '8' : '4'}`}>
          {stats.items.map((stat) => (
            <div class="text-center">
              <div style="font-family: var(--font-oswald); font-size: 3rem; font-weight: 400; color: var(--color-primary-dark); margin-bottom: 8px;">{stat.value}</div>
              <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted);">{stat.label}</p>
            </div>
          ))}
        </div>
      </section>
    );
  }

  if (section.type === 'styles') {
    const styles = section.data;
    const cols = styles.columns || 2;
    const gridClass = cols === 3
      ? 'grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3'
      : 'grid grid-cols-1 gap-5 sm:grid-cols-2';

    return (
      <section class="w-full" style="padding: 79px 0;">
        <div class="mx-auto" style="max-width: 1182px; padding: 0 15px;">
          <h2
            class="mb-6 text-center"
            style="margin-bottom: 0;"
          >
            {styles.heading}
          </h2>
          <div class={gridClass} style="margin-top: 20px;">
            {styles.items.map((item, i) => {
              const titleEl = (
                <h3 style="font-size: 1.125rem; margin-bottom: 6px;">
                  {item.title}
                </h3>
              );
              const descEl = (
                <p style="font-size: 0.875rem; line-height: 1.5; color: var(--color-muted);">
                  {item.description}
                </p>
              );

              const card = (
                <div class:list={[cols === 3 && i >= 3 && "hidden sm:block"]}>
                  {hasImage(item) && (
                    <div class="w-full overflow-hidden">
                      <Image
                        src={item.image}
                        alt={`${item.title} by Hamilton Exteriors in the Bay Area`}
                        width={566}
                        height={cols === 3 ? 362 : 292}
                        style={`width: 100%; height: auto; aspect-ratio: 566 / ${cols === 3 ? 362 : 292}; object-fit: cover; display: block;`}
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div style="padding-top: 16px;">
                    {titleEl}
                    {descEl}
                  </div>
                </div>
              );

              return !hasImage(item) && !('image' in item) && (item as any).href ? (
                <a href={(item as any).href} class="block">{card}</a>
              ) : card;
            })}
          </div>
        </div>
      </section>
    );
  }

  return null;
})}

{isCityServicePage && otherServices.length > 0 && (
  <section class="bg-[var(--color-cream)] py-10 px-4">
    <div class="mx-auto max-w-5xl">
      <p class="font-[Satoshi] text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">
        Also serving {cityOrArea || 'this area'}
      </p>
      <div class="flex flex-wrap gap-2">
        {otherServices.map(([slug, label]) => (
          <a
            href={`/service-areas/${countySlugFromPath}/${citySlugFromPath}/${slug}`}
            class="rounded-full border border-[var(--color-primary)] px-4 py-2 font-[DM_Sans] text-sm text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white transition-colors"
          >
            {label} in {cityOrArea}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{data.extraStyles && <style set:html={data.extraStyles} />}
