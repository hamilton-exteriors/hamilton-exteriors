---
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Reviews from './Reviews.astro';
import CTA from './CTA.astro';
import Difference from './Difference.astro';
import Financing from './Financing.astro';
import ReviewLogos from './ReviewLogos.astro';
import Projects from './Projects.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { hasImage } from '../lib/service-page-types';
import type { ServicePageData, SectionBlock, StylesSection } from '../lib/service-page-types';
import { resolveImage } from '../lib/image-map';
import { getCityWikipedia } from '../lib/city-wikipedia';
import { getCityLocalFacts } from '../lib/city-local-facts';
import { getCityProximity } from '../lib/city-coordinates';

interface Props {
  data: ServicePageData;
}

const { data } = Astro.props;

// Resolve any string file paths in section images to Astro ImageMetadata
for (const section of data.sections) {
  if (section.type === 'styles' && section.data?.items) {
    for (const item of section.data.items) {
      if (typeof item.image === 'string') {
        item.image = resolveImage(item.image);
      }
    }
  }
  if (section.type === 'imageBanner' && section.data && typeof section.data.image === 'string') {
    section.data.image = resolveImage(section.data.image);
  }
}

// Build areaServed — use city if available (pSEO pages), otherwise counties
// Use AdministrativeArea for county-level entities (name contains "County")
const cityOrArea = (data as any).city;
const citySlug = (data as any).citySlug || '';
const isCountyArea = cityOrArea && /county/i.test(cityOrArea);
const cityWiki = !isCountyArea && citySlug ? getCityWikipedia(citySlug) : undefined;
const cityProximity = !isCountyArea && citySlug ? getCityProximity(citySlug) : undefined;
const [cityLng, cityLat] = cityProximity ? cityProximity.split(',').map(Number) : [undefined, undefined];
const areaServed = cityOrArea
  ? isCountyArea
    ? { '@type': 'AdministrativeArea', 'name': cityOrArea, 'containedInPlace': { '@type': 'State', 'name': 'California' } }
    : { '@type': 'City', 'name': cityOrArea, ...(cityWiki && { 'sameAs': cityWiki }), 'containedInPlace': { '@type': 'State', 'name': 'California' }, ...(cityLat && cityLng && { 'geo': { '@type': 'GeoCoordinates', 'latitude': cityLat, 'longitude': cityLng } }) }
  : [
      { '@type': 'County', 'name': 'Alameda County', 'sameAs': 'https://en.wikipedia.org/wiki/Alameda_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Contra Costa County', 'sameAs': 'https://en.wikipedia.org/wiki/Contra_Costa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Marin County', 'sameAs': 'https://en.wikipedia.org/wiki/Marin_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Napa County', 'sameAs': 'https://en.wikipedia.org/wiki/Napa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'County', 'name': 'Santa Clara County', 'sameAs': 'https://en.wikipedia.org/wiki/Santa_Clara_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
    ];

// Detect if this is a main service page (not city/county-specific) for cross-linking
const pathname = Astro.url.pathname.replace(/\/$/, '');
const SERVICE_SLUG_MAP: Record<string, string> = { roofing: 'Roofing', siding: 'Siding', windows: 'Windows', adu: 'ADUs', 'custom-homes': 'Custom Homes', additions: 'Additions' };
const isMainServicePage = !cityOrArea && Object.keys(SERVICE_SLUG_MAP).includes(pathname.replace('/', ''));
const currentServiceSlug = pathname.replace('/', '');
const localFacts = citySlug ? getCityLocalFacts(citySlug) : undefined;

// Derive serviceSlug early — needed by RELATED_BLOG_POSTS below
const serviceSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop() || '';

// Related blog articles by service — strengthens topical clusters
const RELATED_BLOG_POSTS: Record<string, Array<{ href: string; title: string }>> = {
  roofing: [
    { href: '/blog/how-much-does-a-roof-replacement-cost-in-the-bay-area-in-2026', title: 'How Much Does a Roof Replacement Cost in the Bay Area in 2026?' },
    { href: '/blog/metal-roof-vs-asphalt-shingles-bay-area', title: 'Metal Roof vs. Asphalt Shingles: Which Is Right for Bay Area Homes?' },
    { href: '/blog/7-warning-signs-you-need-a-new-roof-before-it-is-too-late', title: '7 Warning Signs You Need a New Roof' },
    { href: '/blog/how-long-does-a-roof-replacement-take-bay-area-timeline', title: 'How Long Does a Roof Replacement Take? Bay Area Timeline' },
    { href: '/blog/when-is-the-best-time-to-replace-your-roof-in-the-bay-area', title: 'When Is the Best Time to Replace Your Roof in the Bay Area?' },
    { href: '/blog/what-does-roofing-warranty-cover', title: 'What Does a Roofing Warranty Cover?' },
    { href: '/blog/roof-maintenance-checklist-bay-area', title: 'Roof Maintenance Checklist for Bay Area Homeowners' },
    { href: '/blog/bay-area-fire-zone-roofing-requirements', title: 'Bay Area Fire Zone Roofing Requirements' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Roofing Contractor in the Bay Area' },
  ],
  siding: [
    { href: '/blog/james-hardie-siding-bay-area', title: 'James Hardie Siding: The Bay Area Homeowner\'s Guide' },
    { href: '/blog/bay-area-fire-zone-roofing-requirements', title: 'Bay Area Fire Zone Roofing Requirements' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose an Exterior Contractor in the Bay Area' },
  ],
  windows: [
    { href: '/blog/window-replacement-cost-bay-area-2026', title: 'Window Replacement Cost in the Bay Area (2026)' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose an Exterior Contractor in the Bay Area' },
  ],
  adu: [
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
  ],
  'custom-homes': [
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
    { href: '/blog/second-story-addition-cost-bay-area', title: 'Second Story Addition Cost in the Bay Area' },
  ],
  additions: [
    { href: '/blog/second-story-addition-cost-bay-area', title: 'Second Story Addition Cost in the Bay Area' },
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
  ],
};
const relatedPosts = RELATED_BLOG_POSTS[serviceSlug] || [];

// Build cross-service links for city+service pages
const pathParts = pathname.split('/').filter(Boolean); // e.g., ['service-areas', 'alameda-county-ca', 'oakland-ca', 'roofing']
const isCityServicePage = pathParts.length === 4 && pathParts[0] === 'service-areas';
const countySlugFromPath = isCityServicePage ? pathParts[1] : '';
const citySlugFromPath = isCityServicePage ? pathParts[2] : '';
const currentService = isCityServicePage ? pathParts[3] : '';
const otherServices = isCityServicePage
  ? Object.entries(SERVICE_SLUG_MAP).filter(([slug]) => slug !== currentService)
  : [];

const counties = [
  { name: 'Alameda County', slug: 'alameda-county-ca', cities: [
    { name: 'Oakland', slug: 'oakland-ca' },
    { name: 'Berkeley', slug: 'berkeley-ca' },
    { name: 'Fremont', slug: 'fremont-ca' },
    { name: 'Hayward', slug: 'hayward-ca' },
    { name: 'San Leandro', slug: 'san-leandro-ca' },
  ]},
  { name: 'Contra Costa County', slug: 'contra-costa-county-ca', cities: [
    { name: 'Walnut Creek', slug: 'walnut-creek-ca' },
    { name: 'Concord', slug: 'concord-ca' },
    { name: 'San Ramon', slug: 'san-ramon-ca' },
    { name: 'Antioch', slug: 'antioch-ca' },
    { name: 'Richmond', slug: 'richmond-ca' },
  ]},
  { name: 'Marin County', slug: 'marin-county-ca', cities: [
    { name: 'San Rafael', slug: 'san-rafael-ca' },
    { name: 'Mill Valley', slug: 'mill-valley-ca' },
    { name: 'Novato', slug: 'novato-ca' },
    { name: 'Larkspur', slug: 'larkspur-ca' },
  ]},
  { name: 'Napa County', slug: 'napa-county-ca', cities: [
    { name: 'Napa', slug: 'napa-ca' },
    { name: 'American Canyon', slug: 'american-canyon-ca' },
    { name: 'St. Helena', slug: 'st-helena-ca' },
    { name: 'Calistoga', slug: 'calistoga-ca' },
    { name: 'Yountville', slug: 'yountville-ca' },
  ]},
  { name: 'Santa Clara County', slug: 'santa-clara-county-ca', cities: [
    { name: 'San Jose', slug: 'san-jose-ca' },
    { name: 'Palo Alto', slug: 'palo-alto-ca' },
    { name: 'Mountain View', slug: 'mountain-view-ca' },
    { name: 'Sunnyvale', slug: 'sunnyvale-ca' },
    { name: 'Cupertino', slug: 'cupertino-ca' },
    { name: 'Santa Clara', slug: 'santa-clara-ca' },
    { name: 'Saratoga', slug: 'saratoga-ca' },
    { name: 'Los Gatos', slug: 'los-gatos-ca' },
    { name: 'Campbell', slug: 'campbell-ca' },
    { name: 'Milpitas', slug: 'milpitas-ca' },
  ]},
];

// For pSEO city+service pages: find sibling cities in the same county
const siblingCityLinks = isCityServicePage
  ? (counties.find(c => c.slug === countySlugFromPath)?.cities || [])
      .filter(city => city.slug !== citySlugFromPath)
      .slice(0, 3)
  : [];

// Derive serviceType from the page slug (serviceSlug declared above near RELATED_BLOG_POSTS)
const SERVICE_TYPE_MAP: Record<string, string> = {
  roofing: 'Roofing',
  siding: 'Siding',
  windows: 'Window Installation',
  adu: 'ADU Construction',
  'custom-homes': 'Custom Home Building',
  additions: 'Room Additions',
};
const serviceType = SERVICE_TYPE_MAP[serviceSlug] || data.title.split('|')[0].split('—')[0].trim();

// Pricing data for AggregateOffer — only on main service pages
const SERVICE_PRICING: Record<string, { low: number; high: number; unit: string; currency: string }> = {
  roofing: { low: 940, high: 1525, unit: 'per roofing square (100 sq ft)', currency: 'USD' },
  siding: { low: 400, high: 1250, unit: 'per 100 sq ft installed', currency: 'USD' },
  windows: { low: 600, high: 3200, unit: 'per window/unit installed', currency: 'USD' },
};
const pricing = SERVICE_PRICING[serviceSlug];

const serviceSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `https://hamilton-exteriors.com${Astro.url.pathname}#service`,
  'name': data.title.split('|')[0].trim(),
  'url': `https://hamilton-exteriors.com${Astro.url.pathname}`,
  'serviceType': serviceType,
  'provider': {
    '@id': 'https://hamilton-exteriors.com/#business',
  },
  'areaServed': areaServed,
  'description': data.description,
  'dateModified': new Date().toISOString().split('T')[0],
  ...(pricing && {
    'offers': {
      '@type': 'AggregateOffer',
      'offerCount': 6,
      'lowPrice': pricing.low,
      'highPrice': pricing.high,
      'priceCurrency': pricing.currency,
      'unitText': pricing.unit,
    },
  }),
  'aggregateRating': {
    '@type': 'AggregateRating',
    'ratingValue': 4.8,
    'reviewCount': 52,
    'bestRating': 5,
    'worstRating': 1,
  },
};

// HowTo schema for main service pages — helps AI snippet eligibility
const HOWTO_SCHEMAS: Record<string, Record<string, unknown>> = {
  roofing: {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to Get a Roof Replacement in the Bay Area',
    description: 'The complete process for replacing your roof with Hamilton Exteriors, from free inspection to final walkthrough.',
    totalTime: 'P7D',
    estimatedCost: { '@type': 'MonetaryAmount', currency: 'USD', value: '15000-35000' },
    step: [
      { '@type': 'HowToStep', position: 1, name: 'Schedule a Free Inspection', text: 'Call (650) 977-3351 or fill out our online form. A project manager visits your property to assess the roof condition, take measurements, and identify any structural issues.' },
      { '@type': 'HowToStep', position: 2, name: 'Receive Your Detailed Estimate', text: 'Within 48 hours, you receive a written estimate with material options, labor costs, permit fees, and financing terms — no hidden fees.' },
      { '@type': 'HowToStep', position: 3, name: 'Choose Materials and Sign Contract', text: 'Select from GAF, Owens Corning, or CertainTeed shingle lines. We walk you through warranty tiers and color options. Sign the contract with $0 down.' },
      { '@type': 'HowToStep', position: 4, name: 'Permit and Scheduling', text: 'Hamilton Exteriors pulls all required building permits and schedules your installation date. We coordinate directly with your city building department.' },
      { '@type': 'HowToStep', position: 5, name: 'Roof Installation', text: 'Our factory-trained crew completes the full tear-off, inspection, and new roof installation. Most residential roofs are completed in 1-3 days.' },
      { '@type': 'HowToStep', position: 6, name: 'Final Inspection and Warranty', text: 'We schedule the city building inspection, walk you through the completed work, and activate your manufacturer warranty — up to 50 years of coverage.' },
    ],
  },
  siding: {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to Get New Siding Installed in the Bay Area',
    description: 'The complete process for replacing your home siding with Hamilton Exteriors, from consultation to final inspection.',
    totalTime: 'P10D',
    estimatedCost: { '@type': 'MonetaryAmount', currency: 'USD', value: '15000-45000' },
    step: [
      { '@type': 'HowToStep', position: 1, name: 'Schedule a Free Consultation', text: 'Call (650) 977-3351 or request an estimate online. A project manager inspects your exterior, checks for dry rot or moisture damage, and takes measurements.' },
      { '@type': 'HowToStep', position: 2, name: 'Receive Your Estimate', text: 'Within 48 hours, you receive a detailed proposal with material options (James Hardie fiber cement, LP SmartSide, or vinyl), color selections, and total project cost.' },
      { '@type': 'HowToStep', position: 3, name: 'Material Selection and Contract', text: 'Choose your siding material, profile, and color. As a James Hardie Elite Preferred installer, we offer the full ColorPlus line. Sign with $0 down financing available.' },
      { '@type': 'HowToStep', position: 4, name: 'Permits and Prep', text: 'We pull all necessary permits and prep the jobsite. Any dry rot or sheathing damage is repaired before new siding goes up.' },
      { '@type': 'HowToStep', position: 5, name: 'Siding Installation', text: 'Our trained crew installs your new siding with proper flashing, trim, and weatherproofing. Most homes are completed in 5-10 days depending on size.' },
      { '@type': 'HowToStep', position: 6, name: 'Inspection and Warranty', text: 'Final city inspection, walkthrough with your project manager, and warranty activation. James Hardie products carry a 30-year non-prorated warranty.' },
    ],
  },
};
const howToSchema = HOWTO_SCHEMAS[serviceSlug];
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
{howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

{data.announcementText ? <AnnouncementBar text={data.announcementText} /> : <AnnouncementBar />}
<Navbar />
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  ctaText={data.hero.ctaText}
  ctaHref={data.hero.ctaHref}
  heroImage={data.hero.heroImage}
  heroAlt={data.hero.heroAlt}
  badges={data.hero.badges}
  serviceType={data.hero.serviceType}
  serviceOptions={data.hero.serviceOptions}
/>

<div class="mx-auto max-w-7xl px-4 pt-3">
  <p class="text-xs text-gray-600 font-[Satoshi]">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
</div>

{isCityServicePage && cityOrArea && (
  <div class="mx-auto max-w-3xl px-5 pt-6 pb-2">
    <p style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.75; color: var(--color-charcoal);">
      Hamilton Exteriors provides professional {(SERVICE_SLUG_MAP[currentService] || 'exterior').toLowerCase()} services in {cityOrArea}, California.{' '}
      {localFacts?.housingNote ? `${localFacts.housingNote} ` : ' '}
      Licensed under CSLB #1082377, we handle all {cityOrArea} building permits and inspections. Call <a href="tel:+16509773351" style="color: var(--color-primary); font-weight: 600;">(650) 977-3351</a> for a free estimate.
    </p>
  </div>
)}

{data.sections.map((section) => {
  if (section.type === 'logoSlider') {
    return (
      <>
        <LogoSlider />
        <div class="mx-auto max-w-7xl px-4 py-2 text-center">
          <p style="font-family: var(--font-dm-sans); font-size: 13px; color: var(--color-muted);">
            Reviewed by <a href="/about/alex-hamilton-li" style="color: var(--color-muted); text-decoration: underline; text-underline-offset: 2px;">Alexander Hamilton Li</a>, Architect &amp; General Contractor · <a href="https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377" target="_blank" rel="noopener noreferrer" style="color: var(--color-muted); text-decoration: underline; text-underline-offset: 2px;">CSLB #1082377</a> · Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
          </p>
        </div>
      </>
    );
  }

  if (section.type === 'reviews') {
    return <Reviews />;
  }

  if (section.type === 'cta') {
    return <CTA />;
  }

  if (section.type === 'reviewLogos') {
    return <ReviewLogos />;
  }

  if (section.type === 'difference') {
    return <Difference />;
  }

  if (section.type === 'projects') {
    return <Projects showFilters={false} />;
  }

  if (section.type === 'financing') {
    return <Financing />;
  }

  if (section.type === 'pricing') {
    const { data: p } = section;
    return (
      <section class="w-full" style="background-color: var(--color-cream); padding: 80px 0;">
        <div class="mx-auto max-w-[1000px] px-5">
          <h2 style="margin-bottom: 8px;">{p.heading}</h2>
          <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted); margin-bottom: 40px;">All prices are per roofing square (100 sq ft), fully installed.</p>
          <div class="overflow-x-auto">
            <table style="width: 100%; border-collapse: collapse; font-family: var(--font-dm-sans); font-size: 0.9375rem;">
              <thead>
                <tr style="border-bottom: 2px solid var(--color-primary);">
                  <th style="text-align: left; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Product</th>
                  <th style="text-align: right; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Price / sq</th>
                  <th style="text-align: right; padding: 12px 16px; font-weight: 600; color: var(--color-heading);">Materials</th>
                </tr>
              </thead>
              <tbody>
                {p.tiers.map((tier) => (
                  <>
                    <tr style="background-color: rgba(37, 99, 70, 0.08);">
                      <td colspan="3" style="padding: 10px 16px; font-family: var(--font-oswald); font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary);">{tier.name}</td>
                    </tr>
                    {tier.rows.map((row) => (
                      <tr style="border-bottom: 1px solid var(--color-border);">
                        <td style="padding: 12px 16px; color: var(--color-charcoal);">{row.product}</td>
                        <td style="padding: 12px 16px; text-align: right; font-weight: 600; color: var(--color-heading);">{row.pricePerSq}</td>
                        <td style="padding: 12px 16px; text-align: right; color: var(--color-muted);">{row.materialCost}</td>
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
          <p style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted); margin-top: 16px;">{p.footnote}</p>
          <p style="font-family: var(--font-dm-sans); font-size: 0.75rem; color: var(--color-muted); margin-top: 8px; font-style: italic;">Prices reflect Hamilton Exteriors installed pricing as of Q1 2026, Castro Valley, CA. All prices include tear-off, materials, labor, and cleanup.</p>
        </div>
      </section>
    );
  }

  if (section.type === 'faq') {
    return (
      <>
        <FAQ extraFaqs={data.localFaqs} />
        {relatedPosts.length > 0 && (
          <section class="w-full" style="padding: 48px 0 0;">
            <div class="mx-auto max-w-[800px] px-5">
              <h2 style="font-size: 1.25rem; margin-bottom: 20px;">Related Articles</h2>
              <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
                {relatedPosts.map((post) => (
                  <li>
                    <a href={post.href} style="font-family: var(--font-dm-sans); font-size: 1rem; color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px;">
                      {post.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </>
    );
  }

  if (section.type === 'contactUs') {
    return (
      <>
        {localFacts && (
          <section class="w-full" style="background-color: var(--color-cream); padding: 60px 0;">
            <div class="mx-auto max-w-[800px] px-5">
              <h2 style="margin-bottom: 24px;">
                {SERVICE_SLUG_MAP[currentServiceSlug] || 'Our Services'} in {cityOrArea}, California
              </h2>
              <div style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.75; color: var(--color-charcoal);" class="flex flex-col gap-4">
                <p>{localFacts.housingNote}</p>
                <p>{localFacts.permitNote}</p>
                {localFacts.weatherNote && <p>{localFacts.weatherNote}</p>}
              </div>
            </div>
          </section>
        )}
        <ContactUs />
      </>
    );
  }

  if (section.type === 'footer') {
    return (
      <>
        {isMainServicePage && (
          <section class="w-full" style="background-color: var(--color-cream); padding: 60px 0;">
            <div class="mx-auto max-w-[1200px] px-5">
              <h2 style="margin-bottom: 32px;">
                {SERVICE_SLUG_MAP[currentServiceSlug] || 'Our Services'} Across the Bay Area
              </h2>
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {counties.map(c => (
                  <div style="padding: 20px; background: var(--color-white); border: 1px solid var(--color-border);">
                    <a href={`/service-areas/${c.slug}/${currentServiceSlug}`} style="text-decoration: none;">
                      <h3 style="font-size: 1rem; margin-bottom: 4px; color: var(--color-heading);">{c.name}</h3>
                    </a>
                    <ul style="list-style: none; padding: 0; margin: 8px 0 0;">
                      {c.cities.map(city => (
                        <li style="margin-bottom: 4px;">
                          <a
                            href={`/service-areas/${c.slug}/${city.slug}/${currentServiceSlug}`}
                            style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-primary); text-decoration: none;"
                            class="hover:underline"
                          >
                            {SERVICE_SLUG_MAP[currentServiceSlug]} in {city.name}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
                <a href="/service-areas" style="display: flex; align-items: center; justify-content: center; padding: 20px; background: var(--color-primary); text-decoration: none; transition: opacity 0.2s;" class="hover:opacity-90">
                  <span style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: white;">View All Service Areas &rarr;</span>
                </a>
              </div>
            </div>
          </section>
        )}
        <Footer />
      </>
    );
  }

  if (section.type === 'yellowBar') {
    return (
      <div class="w-full text-center" style="background-color: var(--color-yellow); padding: 14px 0;">
        <a href={section.href} style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: var(--color-heading); text-decoration: none;">{section.text} &rarr;</a>
      </div>
    );
  }

  if (section.type === 'imageBanner') {
    const { data: banner } = section;
    return (
      <section class="relative w-full" style={`height: ${banner.height || 400}px;`}>
        <Image
          src={banner.image}
          alt={banner.alt}
          width={1280}
          height={853}
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
          loading="lazy"
        />
      </section>
    );
  }

  if (section.type === 'stats') {
    const { data: stats } = section;
    const padding = stats.desktopOnly ? '60px 0' : '48px 0';
    const gridBreakpoint = stats.desktopOnly ? 'lg' : 'md';
    return (
      <section class={`w-full ${stats.desktopOnly ? 'hidden lg:block' : ''}`} style={`background-color: var(--color-cream); padding: ${padding};`}>
        <div class={`mx-auto max-w-[1200px] px-5 grid grid-cols-1 ${gridBreakpoint === 'lg' ? `lg:grid-cols-${stats.items.length}` : `md:grid-cols-${stats.items.length} md:gap-8`} gap-${gridBreakpoint === 'lg' ? '8' : '4'}`}>
          {stats.items.map((stat) => (
            <div class="text-center">
              <div style="font-family: var(--font-oswald); font-size: 3rem; font-weight: 400; color: var(--color-primary-dark); margin-bottom: 8px;">{stat.value}</div>
              <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted);">{stat.label}</p>
            </div>
          ))}
        </div>
      </section>
    );
  }

  if (section.type === 'styles') {
    const styles = section.data;
    const cols = styles.columns || 2;
    const gridClass = cols === 3
      ? 'grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3'
      : 'grid grid-cols-1 gap-5 sm:grid-cols-2';

    return (
      <section class="w-full" style="padding: 79px 0;">
        <div class="mx-auto" style="max-width: 1182px; padding: 0 15px;">
          <h2
            class="mb-6 text-center"
            style="margin-bottom: 0;"
          >
            {styles.heading}
          </h2>
          <div class={gridClass} style="margin-top: 20px;">
            {styles.items.map((item, i) => {
              const titleEl = (
                <h3 style="font-size: 1.125rem; margin-bottom: 6px;">
                  {item.title}
                </h3>
              );
              const descEl = (
                <p style="font-size: 0.875rem; line-height: 1.5; color: var(--color-muted);">
                  {item.description}
                </p>
              );

              const card = (
                <div class:list={[cols === 3 && i >= 3 && "hidden sm:block"]}>
                  {hasImage(item) && (
                    <div class="w-full overflow-hidden">
                      <Image
                        src={item.image}
                        alt={`${item.title} by Hamilton Exteriors in the Bay Area`}
                        width={566}
                        height={cols === 3 ? 362 : 292}
                        style={`width: 100%; height: auto; aspect-ratio: 566 / ${cols === 3 ? 362 : 292}; object-fit: cover; display: block;`}
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div style="padding-top: 16px;">
                    {titleEl}
                    {descEl}
                  </div>
                </div>
              );

              return !hasImage(item) && !('image' in item) && (item as any).href ? (
                <a href={(item as any).href} class="block">{card}</a>
              ) : card;
            })}
          </div>
        </div>
      </section>
    );
  }

  return null;
})}

{isCityServicePage && otherServices.length > 0 && (
  <section class="bg-[var(--color-cream)] py-10 px-4">
    <div class="mx-auto max-w-5xl">
      <a
        href={`/service-areas/${countySlugFromPath}/${citySlugFromPath}`}
        class="inline-block mb-5 font-[DM_Sans] text-sm font-medium text-[var(--color-primary)] underline underline-offset-2 hover:opacity-80 transition-opacity"
      >
        &larr; All services in {cityOrArea}
      </a>
      <p class="font-[Satoshi] text-xs font-semibold uppercase tracking-wider text-gray-600 mb-4">
        Also serving {cityOrArea || 'this area'}
      </p>
      <div class="flex flex-wrap gap-2">
        {otherServices.map(([slug, label]) => (
          <a
            href={`/service-areas/${countySlugFromPath}/${citySlugFromPath}/${slug}`}
            class="rounded-full border border-[var(--color-primary)] px-4 py-2 font-[DM_Sans] text-sm text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white transition-colors"
          >
            {label} in {cityOrArea}
          </a>
        ))}
      </div>
      {siblingCityLinks.length > 0 && (
        <>
          <p class="font-[Satoshi] text-xs font-semibold uppercase tracking-wider text-gray-600 mb-4 mt-6">
            {SERVICE_SLUG_MAP[currentService] || 'Services'} in nearby cities
          </p>
          <div class="flex flex-wrap gap-2">
            {siblingCityLinks.map(city => (
              <a
                href={`/service-areas/${countySlugFromPath}/${city.slug}/${currentService}`}
                class="rounded-full border border-[var(--color-border)] px-4 py-2 font-[DM_Sans] text-sm text-[var(--color-charcoal)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
              >
                {city.name}
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
)}

{data.extraStyles && <style set:html={data.extraStyles} />}
