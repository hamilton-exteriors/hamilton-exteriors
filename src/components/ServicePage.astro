---
import { Image } from 'astro:assets';
import { PHONE_DISPLAY } from '../lib/constants';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Reviews from './Reviews.astro';
import Section from './Section.astro';
import SectionLabel from './SectionLabel.astro';
import SectionHeading from './SectionHeading.astro';
import CTA from './CTA.astro';
import Difference from './Difference.astro';
import Financing from './Financing.astro';
import ReviewLogos from './ReviewLogos.astro';
import Projects from './Projects.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { hasImage } from '../lib/service-page-types';
import type { ServicePageData, SectionBlock, StylesSection } from '../lib/service-page-types';
import { resolveImage } from '../lib/image-map';
import { getCityWikipedia } from '../lib/city-wikipedia';
import { getCityLocalFacts } from '../lib/city-local-facts';
import { getCityProximity } from '../lib/city-coordinates';

interface Props {
  data: ServicePageData;
}

const { data } = Astro.props;

// Resolve any string file paths in section images to Astro ImageMetadata
for (const section of data.sections) {
  if (section.type === 'styles' && section.data?.items) {
    for (const item of section.data.items) {
      if (typeof item.image === 'string') {
        item.image = resolveImage(item.image);
      }
    }
  }
  if (section.type === 'imageBanner' && section.data && typeof section.data.image === 'string') {
    section.data.image = resolveImage(section.data.image);
  }
}

// Build areaServed — use city if available (pSEO pages), otherwise counties
// Use County type for county-level entities (name contains "County")
const cityOrArea = (data as any).city;
const citySlug = (data as any).citySlug || '';
const isCountyArea = cityOrArea && /county/i.test(cityOrArea);
const cityWiki = !isCountyArea && citySlug ? getCityWikipedia(citySlug) : undefined;
const cityProximity = !isCountyArea && citySlug ? getCityProximity(citySlug) : undefined;
const [cityLng, cityLat] = cityProximity ? cityProximity.split(',').map(Number) : [undefined, undefined];
const areaServed = cityOrArea
  ? isCountyArea
    ? { '@type': 'AdministrativeArea', 'name': cityOrArea, 'containedInPlace': { '@type': 'State', 'name': 'California' } }
    : { '@type': 'City', 'name': cityOrArea, ...(cityWiki && { 'sameAs': cityWiki }), 'containedInPlace': { '@type': 'State', 'name': 'California' }, ...(cityLat && cityLng && { 'geo': { '@type': 'GeoCoordinates', 'latitude': cityLat, 'longitude': cityLng } }) }
  : [
      { '@type': 'AdministrativeArea', 'name': 'Alameda County', 'sameAs': 'https://en.wikipedia.org/wiki/Alameda_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'AdministrativeArea', 'name': 'Contra Costa County', 'sameAs': 'https://en.wikipedia.org/wiki/Contra_Costa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'AdministrativeArea', 'name': 'Marin County', 'sameAs': 'https://en.wikipedia.org/wiki/Marin_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'AdministrativeArea', 'name': 'Napa County', 'sameAs': 'https://en.wikipedia.org/wiki/Napa_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'AdministrativeArea', 'name': 'Santa Clara County', 'sameAs': 'https://en.wikipedia.org/wiki/Santa_Clara_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      { '@type': 'AdministrativeArea', 'name': 'San Mateo County', 'sameAs': 'https://en.wikipedia.org/wiki/San_Mateo_County,_California', 'containedInPlace': { '@type': 'State', 'name': 'California' } },
    ];

// Detect if this is a main service page (not city/county-specific) for cross-linking
const pathname = Astro.url.pathname.replace(/\/$/, '');
const SERVICE_SLUG_MAP: Record<string, string> = { roofing: 'Roofing', siding: 'Siding', windows: 'Windows', adu: 'ADUs', 'custom-homes': 'Custom Homes', additions: 'Additions' };
const isMainServicePage = !cityOrArea && Object.keys(SERVICE_SLUG_MAP).includes(pathname.replace('/', ''));
const currentServiceSlug = pathname.replace('/', '');
const localFacts = citySlug ? getCityLocalFacts(citySlug) : undefined;

// Derive serviceSlug early — needed by RELATED_BLOG_POSTS below
const serviceSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop() || '';

// Related blog articles by service — strengthens topical clusters
const RELATED_BLOG_POSTS: Record<string, Array<{ href: string; title: string }>> = {
  roofing: [
    { href: '/blog/how-much-does-a-roof-replacement-cost-in-the-bay-area-in-2026', title: 'How Much Does a Roof Replacement Cost in the Bay Area in 2026?' },
    { href: '/blog/metal-roof-vs-asphalt-shingles-bay-area', title: 'Metal Roof vs. Asphalt Shingles: Which Is Right for Bay Area Homes?' },
    { href: '/blog/7-warning-signs-you-need-a-new-roof-before-it-is-too-late', title: '7 Warning Signs You Need a New Roof' },
    { href: '/blog/how-long-does-a-roof-replacement-take-bay-area-timeline', title: 'How Long Does a Roof Replacement Take? Bay Area Timeline' },
    { href: '/blog/when-is-the-best-time-to-replace-your-roof-in-the-bay-area', title: 'When Is the Best Time to Replace Your Roof in the Bay Area?' },
    { href: '/blog/what-does-roofing-warranty-cover', title: 'What Does a Roofing Warranty Cover?' },
    { href: '/blog/roof-maintenance-checklist-bay-area', title: 'Roof Maintenance Checklist for Bay Area Homeowners' },
    { href: '/blog/bay-area-fire-zone-roofing-requirements', title: 'Bay Area Fire Zone Roofing Requirements' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Roofing Contractor in the Bay Area' },
  ],
  siding: [
    { href: '/blog/james-hardie-siding-bay-area', title: 'James Hardie Siding: The Bay Area Homeowner\'s Guide' },
    { href: '/blog/bay-area-fire-zone-roofing-requirements', title: 'Bay Area Fire Zone Roofing Requirements' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose an Exterior Contractor in the Bay Area' },
  ],
  windows: [
    { href: '/blog/window-replacement-cost-bay-area-2026', title: 'Window Replacement Cost in the Bay Area (2026)' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose an Exterior Contractor in the Bay Area' },
  ],
  adu: [
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
  ],
  'custom-homes': [
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
    { href: '/blog/second-story-addition-cost-bay-area', title: 'Second Story Addition Cost in the Bay Area' },
  ],
  additions: [
    { href: '/blog/second-story-addition-cost-bay-area', title: 'Second Story Addition Cost in the Bay Area' },
    { href: '/blog/adu-cost-bay-area-2026', title: 'ADU Cost in the Bay Area (2026): Complete Guide' },
    { href: '/blog/how-to-choose-roofing-contractor-bay-area', title: 'How to Choose a Contractor in the Bay Area' },
  ],
};
const relatedPosts = RELATED_BLOG_POSTS[serviceSlug] || [];

// Build cross-service links for city+service pages
const pathParts = pathname.split('/').filter(Boolean); // e.g., ['service-areas', 'alameda-county-ca', 'oakland-ca', 'roofing']
const isCityServicePage = pathParts.length === 4 && pathParts[0] === 'service-areas';
const countySlugFromPath = isCityServicePage ? pathParts[1] : '';
const citySlugFromPath = isCityServicePage ? pathParts[2] : '';
const currentService = isCityServicePage ? pathParts[3] : '';
const otherServices = isCityServicePage
  ? Object.entries(SERVICE_SLUG_MAP).filter(([slug]) => slug !== currentService)
  : [];

const counties = [
  { name: 'Alameda County', slug: 'alameda-county-ca', cities: [
    { name: 'Oakland', slug: 'oakland-ca' },
    { name: 'Berkeley', slug: 'berkeley-ca' },
    { name: 'Fremont', slug: 'fremont-ca' },
    { name: 'Hayward', slug: 'hayward-ca' },
    { name: 'San Leandro', slug: 'san-leandro-ca' },
  ]},
  { name: 'Contra Costa County', slug: 'contra-costa-county-ca', cities: [
    { name: 'Walnut Creek', slug: 'walnut-creek-ca' },
    { name: 'Concord', slug: 'concord-ca' },
    { name: 'San Ramon', slug: 'san-ramon-ca' },
    { name: 'Antioch', slug: 'antioch-ca' },
    { name: 'Richmond', slug: 'richmond-ca' },
  ]},
  { name: 'Marin County', slug: 'marin-county-ca', cities: [
    { name: 'San Rafael', slug: 'san-rafael-ca' },
    { name: 'Mill Valley', slug: 'mill-valley-ca' },
    { name: 'Novato', slug: 'novato-ca' },
    { name: 'Larkspur', slug: 'larkspur-ca' },
  ]},
  { name: 'Napa County', slug: 'napa-county-ca', cities: [
    { name: 'Napa', slug: 'napa-ca' },
    { name: 'American Canyon', slug: 'american-canyon-ca' },
    { name: 'St. Helena', slug: 'st-helena-ca' },
    { name: 'Calistoga', slug: 'calistoga-ca' },
    { name: 'Yountville', slug: 'yountville-ca' },
  ]},
  { name: 'Santa Clara County', slug: 'santa-clara-county-ca', cities: [
    { name: 'San Jose', slug: 'san-jose-ca' },
    { name: 'Palo Alto', slug: 'palo-alto-ca' },
    { name: 'Mountain View', slug: 'mountain-view-ca' },
    { name: 'Sunnyvale', slug: 'sunnyvale-ca' },
    { name: 'Cupertino', slug: 'cupertino-ca' },
    { name: 'Santa Clara', slug: 'santa-clara-ca' },
    { name: 'Saratoga', slug: 'saratoga-ca' },
    { name: 'Los Gatos', slug: 'los-gatos-ca' },
    { name: 'Campbell', slug: 'campbell-ca' },
    { name: 'Milpitas', slug: 'milpitas-ca' },
  ]},
  { name: 'San Mateo County', slug: 'san-mateo-county-ca', cities: [
    { name: 'Redwood City', slug: 'redwood-city-ca' },
    { name: 'San Mateo', slug: 'san-mateo-ca' },
    { name: 'Burlingame', slug: 'burlingame-ca' },
    { name: 'Daly City', slug: 'daly-city-ca' },
    { name: 'South San Francisco', slug: 'south-san-francisco-ca' },
  ]},
];

// For pSEO city+service pages: find sibling cities in the same county
const siblingCityLinks = isCityServicePage
  ? (counties.find(c => c.slug === countySlugFromPath)?.cities || [])
      .filter(city => city.slug !== citySlugFromPath)
      .slice(0, 3)
  : [];

// Derive serviceType from the page slug (serviceSlug declared above near RELATED_BLOG_POSTS)
const SERVICE_TYPE_MAP: Record<string, string> = {
  roofing: 'Roofing',
  siding: 'Siding',
  windows: 'Window Installation',
  adu: 'ADU Construction',
  'custom-homes': 'Custom Home Building',
  additions: 'Room Additions',
};
const serviceType = SERVICE_TYPE_MAP[serviceSlug] || data.title.split('|')[0].split('—')[0].trim();

// Pricing data for AggregateOffer — only on main service pages
const SERVICE_PRICING: Record<string, { low: number; high: number; unit: string; currency: string }> = {
  roofing: { low: 940, high: 1525, unit: 'per roofing square (100 sq ft)', currency: 'USD' },
  siding: { low: 400, high: 1250, unit: 'per 100 sq ft installed', currency: 'USD' },
  windows: { low: 600, high: 3200, unit: 'per window/unit installed', currency: 'USD' },
  adu: { low: 100000, high: 437500, unit: 'per project', currency: 'USD' },
  'custom-homes': { low: 437, high: 1000, unit: 'per square foot', currency: 'USD' },
  additions: { low: 200, high: 500, unit: 'per square foot', currency: 'USD' },
};
const pricing = SERVICE_PRICING[serviceSlug];

const serviceSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `https://hamilton-exteriors.com${Astro.url.pathname}#service`,
  'name': data.title.split('|')[0].trim(),
  'url': `https://hamilton-exteriors.com${Astro.url.pathname}`,
  'serviceType': serviceType,
  'provider': {
    '@id': 'https://hamilton-exteriors.com/#business',
  },
  'areaServed': areaServed,
  'description': data.description,
  'dateModified': new Date().toISOString().split('T')[0],
  'speakable': {
    '@type': 'SpeakableSpecification',
    'cssSelector': ['.local-context p:first-of-type', 'details:first-of-type p', 'h2 + p'],
  },
  ...(pricing && {
    'offers': {
      '@type': 'AggregateOffer',
      'lowPrice': pricing.low,
      'highPrice': pricing.high,
      'priceCurrency': pricing.currency,
      'unitText': pricing.unit,
      'seller': { '@id': 'https://hamilton-exteriors.com/#business' },
    },
  }),
};

// BreadcrumbList for service pages
const breadcrumbItems: Array<Record<string, unknown>> = [
  { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
];

if (isCityServicePage) {
  // City+service: Home → Service Areas → County → City → Service
  breadcrumbItems.push(
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': `${counties.find(c => c.slug === countySlugFromPath)?.name || countySlugFromPath}`, 'item': `https://hamilton-exteriors.com/service-areas/${countySlugFromPath}` },
    { '@type': 'ListItem', 'position': 4, 'name': cityOrArea, 'item': `https://hamilton-exteriors.com/service-areas/${countySlugFromPath}/${citySlugFromPath}` },
    { '@type': 'ListItem', 'position': 5, 'name': SERVICE_SLUG_MAP[currentService] || serviceType, 'item': `https://hamilton-exteriors.com${pathname}` },
  );
} else if (isMainServicePage) {
  // Main service: Home → Service
  breadcrumbItems.push(
    { '@type': 'ListItem', 'position': 2, 'name': SERVICE_SLUG_MAP[currentServiceSlug] || serviceType, 'item': `https://hamilton-exteriors.com${pathname}` },
  );
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': breadcrumbItems,
};

// HowTo rich results removed by Google Sept 2023 — schema omitted

// Jump-link nav — compute links based on which sections exist
const sectionTypes = new Set(data.sections.map(s => s.type));
const jumpLinks = [
  sectionTypes.has('styles') && { href: '#styles', label: 'Styles' },
  sectionTypes.has('pricing') && { href: '#pricing', label: 'Pricing' },
  sectionTypes.has('reviews') && { href: '#reviews', label: 'Reviews' },
  sectionTypes.has('projects') && { href: '#projects', label: 'Projects' },
  sectionTypes.has('faq') && { href: '#faq', label: 'FAQ' },
  { href: '#quote', label: 'Get a Quote' },
].filter(Boolean) as Array<{ href: string; label: string }>;
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

{data.announcementText ? <AnnouncementBar text={data.announcementText} slot="header" /> : <AnnouncementBar slot="header" />}
<Navbar slot="header" />
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  ctaText={data.hero.ctaText}
  ctaHref={data.hero.ctaHref}
  heroImage={data.hero.heroImage}
  heroAlt={data.hero.heroAlt}
  badges={data.hero.badges}
  serviceType={data.hero.serviceType}
  serviceOptions={data.hero.serviceOptions}
/>

<div class="mx-auto max-w-7xl px-4 pt-3">
  <p class="font-satoshi text-xs text-gray-600">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
</div>

{/* Jump-link nav — only shows links to sections that exist on this page */}
{jumpLinks.length > 2 && (
  <>
    <nav class="sticky top-0 z-40 w-full border-b border-border bg-white/95 backdrop-blur-sm" aria-label="Page sections">
      <div class="mx-auto flex max-w-7xl gap-1 overflow-x-auto px-4 py-0 no-scrollbar">
        {jumpLinks.map(link => (
          <a
            href={link.href}
            class="jump-link shrink-0 px-3 py-2.5 font-satoshi text-[0.8125rem] font-medium text-charcoal no-underline transition-all hover:text-primary"
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
    <script is:inline>
      // Highlight active jump-link as user scrolls
      document.addEventListener('DOMContentLoaded', () => {
        const links = document.querySelectorAll('.jump-link');
        const ids = Array.from(links).map(a => (a.getAttribute('href') || '').replace('#', '')).filter(Boolean);
        const targets = ids.map(id => document.getElementById(id)).filter(Boolean);
        if (!targets.length) return;
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            const id = entry.target.id || (entry.target.querySelector('[id]') || {}).id;
            if (!id) continue;
            const link = document.querySelector('.jump-link[href="#' + id + '"]');
            if (entry.isIntersecting) {
              links.forEach(l => { l.classList.remove('text-primary', 'border-b-2', 'border-primary'); });
              if (link) { link.classList.add('text-primary', 'border-b-2', 'border-primary'); }
            }
          }
        }, { rootMargin: '-60px 0px -70% 0px' });
        targets.forEach(t => io.observe(t));
      });
    </script>
  </>
)}

{isCityServicePage && cityOrArea && (
  <div class="mx-auto max-w-3xl px-5 pt-6 pb-2">
    <p class="text-base leading-[1.75] text-charcoal">
      Hamilton Exteriors provides professional {(SERVICE_SLUG_MAP[currentService] || 'exterior').toLowerCase()} services in {cityOrArea}, California.{' '}
      {localFacts?.housingNote ? `${localFacts.housingNote} ` : ' '}
      Licensed under CSLB #1082377, we handle all {cityOrArea} building permits and inspections. Call <a href="tel:+16509773351" class="font-semibold text-primary">(650) 977-3351</a> for an estimate.
    </p>
  </div>
)}

{/* Definition block — standalone 40-60 word answer optimized for AI snippet extraction */}
{data.definition && (
  <div class="mx-auto max-w-3xl px-5 pt-8 pb-4">
    <p class="text-[1.0625rem] leading-[1.8] text-charcoal">{data.definition}</p>
  </div>
)}

{data.sections.map((section) => {
  if (section.type === 'logoSlider') {
    return (
      <>
        <LogoSlider />
        <div class="mx-auto max-w-7xl px-4 py-2 text-center">
          <p class="text-[13px] text-muted">
            Reviewed by <a href="/about/alex-hamilton-li" class="text-muted underline underline-offset-2">Alexander Hamilton Li</a>, Architect &amp; General Contractor · <a href="https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377" target="_blank" rel="noopener noreferrer" class="text-muted underline underline-offset-2">CSLB #1082377</a> · Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
          </p>
        </div>
      </>
    );
  }

  if (section.type === 'reviews') {
    return <div id="reviews"><Reviews /></div>;
  }

  if (section.type === 'cta') {
    return <CTA />;
  }

  if (section.type === 'reviewLogos') {
    return <ReviewLogos />;
  }

  if (section.type === 'difference') {
    return <Difference />;
  }

  if (section.type === 'projects') {
    return <div id="projects"><Projects showFilters={false} /></div>;
  }

  if (section.type === 'financing') {
    return <Financing />;
  }

  if (section.type === 'pricing') {
    const { data: p } = section;
    return (
      <section id="pricing" class="w-full bg-cream py-20">
        <div class="mx-auto max-w-[1000px] px-5">
          <h2 class="mb-2">{p.heading}</h2>
          <p class="mb-10 text-sm text-muted">{
            ['roofing', 'siding'].includes(serviceSlug)
              ? 'All prices are per roofing square (100 sq ft), fully installed.'
              : serviceSlug === 'windows'
                ? 'All prices are per window, fully installed.'
                : ['adu', 'custom-homes', 'additions'].includes(serviceSlug)
                  ? 'Prices shown are estimated project ranges.'
                  : 'All prices are fully installed.'
          }</p>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-[0.9375rem]">
              <thead>
                <tr class="border-b-2 border-primary">
                  <th class="px-4 py-3 text-left font-semibold text-heading">Product</th>
                  <th class="px-4 py-3 text-right font-semibold text-heading">
                    {['roofing', 'siding'].includes(serviceSlug) ? 'Installed Price / sq' : serviceSlug === 'windows' ? 'Installed Price / unit' : 'Price Range'}
                    <span class="block text-[0.6875rem] font-normal text-muted">{['roofing', 'siding'].includes(serviceSlug) ? 'Total cost per 100 sq ft' : serviceSlug === 'windows' ? 'Per window, fully installed' : 'Estimated project cost'}</span>
                  </th>
                  <th class="px-4 py-3 text-right font-semibold text-heading">
                    Material Cost
                    <span class="block text-[0.6875rem] font-normal text-muted">Included in installed price</span>
                  </th>
                </tr>
              </thead>
              <tbody>
                {p.tiers.map((tier) => (
                  <>
                    <tr class="bg-[rgba(37,99,70,0.08)]">
                      <td colspan="3" class="px-4 py-2.5 font-oswald text-[0.8125rem] font-bold tracking-[0.08em] text-primary uppercase">{tier.name}</td>
                    </tr>
                    {tier.rows.map((row) => (
                      <tr class="border-b border-border">
                        <td class="px-4 py-3 text-charcoal">{row.product}</td>
                        <td class="px-4 py-3 text-right font-semibold text-heading">{row.pricePerSq}</td>
                        <td class="px-4 py-3 text-right text-muted">{row.materialCost}</td>
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-[0.8125rem] text-muted">{p.footnote}</p>
          <p class="mt-2 text-xs text-muted italic">Prices reflect Hamilton Exteriors installed pricing as of {`Q${Math.ceil((new Date().getMonth() + 1) / 3)} ${new Date().getFullYear()}`}, Castro Valley, CA. All prices include tear-off, materials, labor, and cleanup.</p>
        </div>
      </section>
    );
  }

  if (section.type === 'comparison') {
    const { data: cmp } = section;
    return (
      <section class="w-full bg-white py-16">
        <div class="mx-auto max-w-[1000px] px-5">
          <h2 class="mb-8">{cmp.heading}</h2>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-[0.9375rem]">
              <thead>
                <tr class="border-b-2 border-primary">
                  <th class="px-4 py-3 text-left font-semibold text-heading">Feature</th>
                  {cmp.columns.map(col => (
                    <th class="px-4 py-3 text-left font-semibold text-heading">{col}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {cmp.rows.map(row => (
                  <tr class="border-b border-border">
                    <td class="px-4 py-3 font-medium text-charcoal">{row.feature}</td>
                    {row.values.map(val => (
                      <td class="px-4 py-3 text-charcoal">{val}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {cmp.source && <p class="mt-3 text-xs text-muted italic">Sources: {cmp.source}</p>}
        </div>
      </section>
    );
  }

  if (section.type === 'localContext') {
    const { data: lc } = section;
    return (
      <section class="local-context w-full bg-cream pt-14 pb-12" aria-label="Local roofing expertise and market context">
        <div class="mx-auto max-w-3xl px-5">
          <SectionLabel>Local Expertise</SectionLabel>
          <h2 class="mb-6">{lc.heading}</h2>
          <div class="flex flex-col gap-5">
            {lc.paragraphs.map((p) => (
              <p class="text-[1.0625rem] leading-[1.8] text-charcoal">{p}</p>
            ))}
          </div>
          <div class="mt-8">
            <a href="#quote" class="inline-block rounded-full bg-yellow px-8 py-3.5 font-oswald text-base font-bold tracking-[0.04em] text-heading uppercase no-underline transition-opacity hover:opacity-90 focus:ring-2 focus:ring-yellow focus:ring-offset-2 focus:outline-none">
              Get Your Quote
            </a>
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'cityPricing') {
    const { data: cp } = section;
    const tierBadge = cp.priceTier === 'luxury' ? 'Premium Market' : `${cp.priceTier.charAt(0).toUpperCase() + cp.priceTier.slice(1)} Market`;
    return (
      <Section bg="dark" padding="md" width="narrow" class="text-center" aria-label={`${cp.heading} — pricing information`}>
        <span class="mb-4 inline-block rounded-full bg-yellow px-4 py-[5px] font-satoshi text-xs font-semibold tracking-[0.06em] text-heading uppercase">
          {tierBadge}
        </span>
        <h2 class="mb-4 text-white">{cp.heading}</h2>
        <p class="mb-2 font-oswald text-[clamp(2.5rem,6vw,3.5rem)] leading-[1.1] font-normal wrap-break-word text-yellow uppercase">
          {cp.priceRange}
        </p>
        <p class="mb-6 text-[0.9375rem] text-white-70">
          Median home value in {cp.city}: {cp.medianHomePrice}
        </p>
        <p class="mx-auto mb-7 max-w-[540px] text-[0.8125rem] leading-[1.6] text-white-50">
          {cp.footnote}
        </p>
        <a href="#quote" class="inline-block rounded-full bg-yellow px-9 py-4 font-oswald text-base font-bold tracking-[0.04em] text-heading uppercase no-underline transition-opacity hover:opacity-90 focus:ring-2 focus:ring-yellow focus:ring-offset-2 focus:ring-offset-(--color-heading) focus:outline-none">
          Get Your Estimate
        </a>
      </Section>
    );
  }

  if (section.type === 'neighborhoodService') {
    const { data: ns } = section;
    return (
      <Section bg="white" padding="md" aria-label={`${ns.heading} — neighborhoods served`}>
        <SectionLabel>Neighborhoods We Serve</SectionLabel>
        <h2 class="mb-10">{ns.heading}</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
          {ns.items.map((item) => (
            <div class="rounded-[4px] bg-cream p-7">
              <h3 class="mb-3 text-xl tracking-[0.02em] wrap-break-word">{item.neighborhood}</h3>
              <p class="text-[0.9375rem] leading-[1.7] text-charcoal">
                {item.description}
              </p>
            </div>
          ))}
        </div>
      </Section>
    );
  }

  if (section.type === 'faq') {
    return (
      <>
        {/* Expert quotes — attributed blockquotes for AI citation extraction */}
        {data.expertQuotes && data.expertQuotes.length > 0 && (
          <section class="w-full bg-cream py-12">
            <div class="mx-auto max-w-3xl px-5 flex flex-col gap-8">
              {data.expertQuotes.map(eq => (
                <blockquote class="pl-6 py-2 relative before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[2px] before:bg-primary/30 before:rounded-full">
                  <p class="text-[1.0625rem] leading-[1.8] text-charcoal italic">"{eq.quote}"</p>
                  <footer class="mt-2 text-sm text-muted">— <strong>{eq.author}</strong>, {eq.credentials}</footer>
                </blockquote>
              ))}
            </div>
          </section>
        )}
        <div id="faq"><FAQ extraFaqs={data.localFaqs} /></div>
        {relatedPosts.length > 0 && (
          <section class="w-full pt-14">
            <div class="mx-auto max-w-[1000px] px-5">
              <SectionLabel class="mb-3">Learn More</SectionLabel>
              <h2 class="mb-8">Related Articles</h2>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                {relatedPosts.slice(0, 4).map((post) => (
                  <a
                    href={post.href}
                    class="block rounded-[4px] bg-cream px-6 py-5 no-underline transition-opacity hover:opacity-85"
                  >
                    <span class="block text-[0.9375rem] leading-[1.4] font-semibold text-heading">
                      {post.title}
                    </span>
                    <span class="mt-2 block font-satoshi text-xs font-medium tracking-[0.06em] text-primary uppercase">
                      Read article &rarr;
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </section>
        )}
      </>
    );
  }

  if (section.type === 'contactUs') {
    return (
      <>
        {localFacts && (
          <section class="w-full bg-cream py-[60px]">
            <div class="mx-auto max-w-[800px] px-5">
              <h2 class="mb-6">
                {SERVICE_SLUG_MAP[currentServiceSlug] || 'Our Services'} in {cityOrArea}, California
              </h2>
              <div class="flex flex-col gap-4 text-base leading-[1.75] text-charcoal">
                <p>{localFacts.housingNote}</p>
                <p>{localFacts.permitNote}</p>
                {localFacts.weatherNote && <p>{localFacts.weatherNote}</p>}
              </div>
            </div>
          </section>
        )}
        <ContactUs />
      </>
    );
  }

  if (section.type === 'footer') {
    return <Footer slot="footer" />;
  }

  if (section.type === 'yellowBar') {
    return (
      <div class="w-full bg-yellow py-3.5 text-center">
        <a href={section.href} class="text-sm font-semibold text-heading no-underline">{section.text} &rarr;</a>
      </div>
    );
  }

  if (section.type === 'imageBanner') {
    const { data: banner } = section;
    return (
      <section class="relative w-full" style={`height: ${banner.height || 400}px;`}>
        <Image
          src={banner.image}
          alt={banner.alt}
          width={1280}
          height={853}
          class="block size-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </section>
    );
  }

  if (section.type === 'stats') {
    const { data: stats } = section;
    return (
      <section class={`w-full bg-cream ${stats.desktopOnly ? 'hidden lg:block' : ''}`} style="padding: 48px 0;">
        <div class={`mx-auto grid max-w-[1200px] grid-cols-2 gap-6 px-5 md:grid-cols-${stats.items.length}`}>
          {stats.items.map((stat) => (
            <div class="flex flex-col">
              <span class="font-oswald text-[clamp(1.5rem,3.5vw,2rem)] leading-[1.2] font-normal text-primary">{stat.value}</span>
              <span class="mt-1 text-sm text-muted">{stat.label}</span>
            </div>
          ))}
        </div>
      </section>
    );
  }

  if (section.type === 'styles') {
    const styles = section.data;
    const cols = styles.columns || 2;
    const gridClass = cols === 3
      ? 'grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3'
      : 'grid grid-cols-1 gap-5 sm:grid-cols-2';

    return (
      <section id="styles" class="w-full py-[79px]">
        <div class="mx-auto max-w-[1182px] px-[15px]">
          <h2
            class="mb-0 text-center"
          >
            {styles.heading}
          </h2>
          <div class={`${gridClass} mt-5`}>
            {styles.items.map((item, i) => {
              const titleEl = (
                <h3 class="mb-1.5 text-lg">
                  {item.title}
                </h3>
              );
              const descEl = (
                <p class="text-sm/normal text-muted">
                  {item.description}
                </p>
              );

              const card = (
                <div class:list={[cols === 3 && i >= 3 && "hidden sm:block"]}>
                  {hasImage(item) && (
                    <div class="w-full overflow-hidden">
                      <Image
                        src={item.image}
                        alt={`${item.title} by Hamilton Exteriors in the Bay Area`}
                        width={566}
                        height={cols === 3 ? 362 : 292}
                        class="block h-auto w-full object-cover"
                        style={`aspect-ratio: 566 / ${cols === 3 ? 362 : 292};`}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="pt-4">
                    {titleEl}
                    {descEl}
                  </div>
                </div>
              );

              return (item as any).href ? (
                <a href={(item as any).href} class="block text-inherit no-underline transition-opacity hover:opacity-85">{card}</a>
              ) : card;
            })}
          </div>
        </div>
      </section>
    );
  }

  return null;
})}

{isCityServicePage && otherServices.length > 0 && (
  <section class="bg-cream px-4 py-10">
    <div class="mx-auto max-w-5xl">
      <a
        href={`/service-areas/${countySlugFromPath}/${citySlugFromPath}`}
        class="mb-5 inline-block font-dm-sans text-sm font-medium text-primary underline underline-offset-2 transition-opacity hover:opacity-80"
      >
        &larr; All services in {cityOrArea}
      </a>
      <p class="mb-4 font-satoshi text-xs font-semibold tracking-wider text-gray-600 uppercase">
        Also serving {cityOrArea || 'this area'}
      </p>
      <div class="flex flex-wrap gap-2">
        {otherServices.map(([slug, label]) => (
          <a
            href={`/service-areas/${countySlugFromPath}/${citySlugFromPath}/${slug}`}
            class="rounded-full border border-primary px-4 py-2 font-dm-sans text-sm text-primary transition-colors hover:bg-primary hover:text-white"
          >
            {label} in {cityOrArea}
          </a>
        ))}
      </div>
      {siblingCityLinks.length > 0 && (
        <>
          <p class="mt-6 mb-4 font-satoshi text-xs font-semibold tracking-wider text-gray-600 uppercase">
            {SERVICE_SLUG_MAP[currentService] || 'Services'} in nearby cities
          </p>
          <div class="flex flex-wrap gap-2">
            {siblingCityLinks.map(city => (
              <a
                href={`/service-areas/${countySlugFromPath}/${city.slug}/${currentService}`}
                class="rounded-full border border-border px-4 py-2 font-dm-sans text-sm text-charcoal transition-colors hover:border-primary hover:text-primary"
              >
                {city.name}
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
)}

{data.extraStyles && <style set:html={data.extraStyles} />}

