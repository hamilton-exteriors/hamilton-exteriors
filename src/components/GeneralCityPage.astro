---
import type { GeneralCityPageData } from '../lib/general-city-types';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Difference from './Difference.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { resolveImage } from '../lib/image-map';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getCityProximity, getCityCoordinates } from '../lib/city-coordinates';
import { getCityLocalFacts } from '../lib/city-local-facts';
import Reviews from './Reviews.astro';
import Breadcrumb from './Breadcrumb.astro';
import { getGoogleReviews, getDisplayReviews } from '../lib/google-reviews';
import SectionLabel from './SectionLabel.astro';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';
import StarRating from './StarRating.astro';
import ServiceCard from './ServiceCard.astro';

interface Props {
  data: GeneralCityPageData;
  heroImage?: ImageMetadata;
}

const { data, heroImage } = Astro.props;
const proximity = getCityProximity(data.slug);
const cityCoords = getCityCoordinates(data.slug);
const mapLat = cityCoords ? cityCoords[1] : 37.7;
const mapLng = cityCoords ? cityCoords[0] : -122.2;
const localFacts = getCityLocalFacts(data.slug);

// Fetch live review data so city page schema matches Layout schema
const _rawReviews = await getGoogleReviews();
const _cityReviews = getDisplayReviews(_rawReviews);

// Seed data uses short county slugs ("alameda"), URLs use full slugs ("alameda-county-ca")
const countyUrlSlug = data.countySlug.endsWith('-county-ca') ? data.countySlug : `${data.countySlug}-county-ca`;
// Seed data uses short city slugs ("oakland"), URLs use full slugs ("oakland-ca")
const cityUrlSlug = data.slug.endsWith('-ca') ? data.slug : `${data.slug}-ca`;

const pageUrl = `https://hamilton-exteriors.com/service-areas/${countyUrlSlug}/${cityUrlSlug}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': `${data.county} County`, 'item': `https://hamilton-exteriors.com/service-areas/${countyUrlSlug}` },
    { '@type': 'ListItem', 'position': 4, 'name': `${data.city}, ${data.state}`, 'item': pageUrl },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': 'https://hamilton-exteriors.com/#website' },
  about: { '@id': 'https://hamilton-exteriors.com/#business' },
  inLanguage: 'en-US',
};

// Review schema for city-specific testimonials
const allReviews = [
  data.reviews.featured,
  ...data.reviews.side,
];
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  '@id': 'https://hamilton-exteriors.com/#business',
  name: 'Hamilton Exteriors',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: _cityReviews.rating,
    reviewCount: _cityReviews.reviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  review: allReviews.map((r, i) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5, worstRating: 1 },
    reviewBody: r.text,
    datePublished: (r as any).date || ['2025-11-15', '2025-12-08', '2026-01-03', '2026-01-22'][i] || '2025-12-01',
    publisher: { '@type': 'Organization', name: 'Google' },
  })),
};
---

<AnnouncementBar slot="header" />
<Navbar slot="header" />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: `${data.county} County`, href: `/service-areas/${countyUrlSlug}` },
  { label: `${data.city}, ${data.state}` },
]} />

<!-- BreadcrumbList JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<!-- WebPage JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
<!-- Review JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />

<!-- Hero -->
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  badges={data.hero.badges}
  proximity={proximity}
  heroImage={heroImage}
  heroAlt={`Hamilton Exteriors — roofing, siding, and exterior remodeling in ${data.city}, CA`}
/>

<!-- Logo Slider -->
<LogoSlider />

<!-- Stats Strip -->
{data.stats && data.stats.length > 0 && (
  <Section bg="dark" padding="sm">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {data.stats.map((stat) => (
        <div class="text-center">
          <div class="font-oswald text-[2.625rem] font-normal text-yellow">{stat.value}</div>
          <p class="text-sm text-white-65">{stat.label}</p>
        </div>
      ))}
    </div>
  </Section>
)}

<!-- Reviews Section — uses real reviews from Reviews.astro -->
<Reviews />

<!-- Local Facts — unique city data for content differentiation -->
{localFacts && (
  <Section bg="cream" padding="lg">
    <SectionLabel class="mb-3">Local Expertise</SectionLabel>
    <h2 class="mb-8">
      Exterior Projects in {data.city}, California
    </h2>
    <div class="mx-auto max-w-3xl flex flex-col gap-5 text-base leading-[1.75] text-charcoal">
      <p>{localFacts.housingNote}</p>
      <p>{localFacts.permitNote}</p>
      {localFacts.weatherNote && <p>{localFacts.weatherNote}</p>}
      {localFacts.fireZone && localFacts.fireZoneNote && (
        <p>{localFacts.fireZoneNote}</p>
      )}
    </div>
    <div class="mt-10 grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
      <div>
        <p class="font-oswald text-2xl text-primary">{localFacts.medianHomeValue}</p>
        <p class="text-sm text-muted">Median home value</p>
      </div>
      <div>
        <p class="font-oswald text-2xl text-primary">{localFacts.population}</p>
        <p class="text-sm text-muted">Population</p>
      </div>
      <div>
        <p class="font-oswald text-2xl text-primary">{localFacts.driveTime}</p>
        <p class="text-sm text-muted">From our office</p>
      </div>
      {localFacts.fireZone && (
        <div>
          <p class="font-oswald text-2xl text-primary">WUI Zone</p>
          <p class="text-sm text-muted">Fire-rated materials required</p>
        </div>
      )}
    </div>
    <div class="mt-8 rounded bg-white p-6">
      <h3 class="mb-2 text-lg">Permit Authority</h3>
      <p class="text-sm text-charcoal">
        {localFacts.permitAuthority}{localFacts.permitPhone && ` · ${localFacts.permitPhone}`}
      </p>
    </div>
    {localFacts.localTip && (
      <div class="mt-4 rounded bg-white p-6">
        <h3 class="mb-2 text-lg">Local Tip</h3>
        <p class="text-sm leading-[1.7] text-charcoal">{localFacts.localTip}</p>
      </div>
    )}
  </Section>
)}

<!-- Services Grid -->
<Section bg="white" padding="lg">
  <SectionLabel class="mb-3">What We Build</SectionLabel>
  <h2
    class="mb-12 text-[clamp(28px,5vw,40px)] leading-tight"
  >
    Custom Home & Exterior Services in {data.city}
  </h2>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {data.services.map((service) => (
      <ServiceCard
        title={service.title}
        description={service.description}
        image={resolveImage(service.imageKey)}
        href={service.href}
        city={data.city}
      />
    ))}
  </div>
</Section>

<!-- Difference -->
<Difference />

<!-- Neighborhoods Section -->
{data.neighborhoods && (
  <Section bg="white" padding="lg">
    <h2 class="mb-4">
      {data.neighborhoods.title}
    </h2>
    <p class="mb-10 max-w-[640px] text-base leading-[1.7] text-muted">
      {data.neighborhoods.subtitle}
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {data.neighborhoods.items.map((hood) => (
        <div class="bg-cream p-8">
          <h3 class="mb-2 text-xl">
            {hood.title}
          </h3>
          <p class="text-sm leading-[1.7] text-muted">
            {hood.description}
          </p>
        </div>
      ))}
    </div>
  </Section>
)}

<!-- FAQ -->
<FAQ extraFaqs={data.faqs} />

<!-- Contact Us -->
<ContactUs />

<!-- Google Maps embed — GBP association signal for local SEO -->
<Section bg="white" padding="sm" borderTop>
  <h2 class="mb-4 text-xl">Hamilton Exteriors — Serving {data.city}, CA</h2>
  <div class="overflow-hidden rounded-lg border border-border">
    <iframe
      src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d202254.9!2d${mapLng}!3d${mapLat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x808f0e3e85db5c71%3A0x31a1e9b44fdf2371!2sHamilton%20Exteriors!5e0!3m2!1sen!2sus!4v1`}
      width="100%"
      height="300"
      class="block border-0"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={`Hamilton Exteriors service area map near ${data.city}, California`}
    ></iframe>
  </div>
</Section>

<!-- Nearby Cities -->
{data.nearbyCities && data.nearbyCities.length > 0 && (
  <Section bg="cream" padding="sm" borderTop>
    <h2 class="mb-5 text-2xl">
      Nearby Cities We Serve
    </h2>
    <div class="flex flex-wrap gap-3">
      {data.nearbyCities.map((city) => (
        <a
          href={city.href}
          class="rounded-full border border-border bg-white px-4 py-2 text-sm text-primary-dark no-underline transition-opacity duration-200 hover:opacity-90"
        >
          {city.name}
        </a>
      ))}
    </div>
  </Section>
)}

<!-- Popular services in this city -->
<Section bg="white" padding="sm">
    <h3 class="mb-4 text-xl">
      Services in {data.city}
    </h3>
    <div class="flex flex-wrap gap-2">
      {data.services.map(s => (
        <a href={s.href} class="rounded-full border border-border px-4 py-2 text-[0.8125rem] font-medium text-primary no-underline transition-opacity hover:opacity-80">
          {s.title} in {data.city} →
        </a>
      ))}
    </div>
</Section>

<!-- Footer -->
<Footer slot="footer" />
