---
import type { GeneralCityPageData } from '../lib/general-city-types';
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Difference from './Difference.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import { resolveImage } from '../lib/image-map';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getCityProximity } from '../lib/city-coordinates';
import Reviews from './Reviews.astro';
import Breadcrumb from './Breadcrumb.astro';
import SectionLabel from './SectionLabel.astro';
import StarRating from './StarRating.astro';
import ServiceCard from './ServiceCard.astro';

interface Props {
  data: GeneralCityPageData;
}

const { data } = Astro.props;
const proximity = getCityProximity(data.slug);

// Seed data uses short county slugs ("alameda"), URLs use full slugs ("alameda-county-ca")
const countyUrlSlug = data.countySlug.endsWith('-county-ca') ? data.countySlug : `${data.countySlug}-county-ca`;
const cityUrlSlug = data.slug.endsWith('-ca') ? data.slug : `${data.slug}-ca`;
const basePath = `/service-areas/${countyUrlSlug}/${cityUrlSlug}`;

// Fallback services grid if Ghost data doesn't include it (old ADU-format data)
const services = data.services || [
  { title: 'Roofing', description: 'Full roof replacements and repairs with GAF-certified shingles and a 50-year warranty. Most jobs done in 3–5 days.', imageKey: 'serviceRoofing', href: `${basePath}/roofing` },
  { title: 'Siding', description: 'James Hardie fiber cement siding that protects your home and looks great for decades. We handle dry rot repair and full replacements.', imageKey: 'serviceSiding', href: `${basePath}/siding` },
  { title: 'Windows', description: 'Energy-efficient window replacements that transform comfort and curb appeal. Double-hung, casement, bay, and more.', imageKey: 'serviceWindows', href: `${basePath}/windows` },
  { title: 'ADUs', description: 'Detached ADUs, garage conversions, and junior ADUs. Design, permits, and construction from start to finish.', imageKey: 'serviceAdu', href: `${basePath}/adu` },
  { title: 'Custom Homes', description: 'Ground-up custom home construction tailored to your vision. From foundation to finishing touches.', imageKey: 'serviceCustomHomes', href: `${basePath}/custom-homes` },
  { title: 'Additions', description: 'Seamless room additions that match your home\u2019s existing style. We handle permits, design, and construction.', imageKey: 'serviceAdditions', href: `${basePath}/additions` },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': `${data.county} County`, 'item': `https://hamilton-exteriors.com/service-areas/${countyUrlSlug}` },
    { '@type': 'ListItem', 'position': 4, 'name': `${data.city}, ${data.state}`, 'item': `https://hamilton-exteriors.com/service-areas/${countyUrlSlug}/${data.slug}` },
  ],
};
---

<AnnouncementBar />
<Navbar />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: `${data.county} County`, href: `/service-areas/${countyUrlSlug}` },
  { label: `${data.city}, ${data.state}` },
]} />

<!-- BreadcrumbList JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Hero -->
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  badges={data.hero.badges}
  proximity={proximity}
/>

<!-- Logo Slider -->
<LogoSlider />

<!-- Stats Strip -->
{data.stats && data.stats.length > 0 && (
  <section class="w-full" style="background-color: var(--color-heading); padding: 48px 0;">
    <div class="mx-auto max-w-[1200px] px-5 grid grid-cols-2 md:grid-cols-4 gap-8">
      {data.stats.map((stat) => (
        <div class="text-center">
          <div style="font-family: var(--font-oswald); font-size: 2.625rem; font-weight: 400; color: var(--color-yellow);">{stat.value}</div>
          <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: rgba(255,255,255,0.65);">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>
)}

<!-- Reviews Section — uses real reviews from Reviews.astro -->
<Reviews />

<!-- Services Grid -->
<section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
  <div class="mx-auto max-w-[1200px] px-5">
    <SectionLabel class="mb-3">Our Services</SectionLabel>
    <h2
      style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); line-height: 1.25; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 48px;"
    >
      Design-Build Services in {data.city}
    </h2>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          image={resolveImage(service.imageKey)}
          href={service.href}
          city={data.city}
        />
      ))}
    </div>
  </div>
</section>

<!-- Difference -->
<Difference />

<!-- Neighborhoods Section -->
{data.neighborhoods && (
  <section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="margin-bottom: 16px;"
      >
        {data.neighborhoods.title}
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 40px; max-width: 640px;">
        {data.neighborhoods.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.neighborhoods.items.map((hood) => (
          <div class="p-8" style="background-color: var(--color-cream);">
            <h3
              style="font-size: 1.25rem; margin-bottom: 8px;"
            >
              {hood.title}
            </h3>
            <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; line-height: 1.7; color: var(--color-muted);">
              {hood.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- FAQ -->
<FAQ extraFaqs={data.faqs} />

<!-- Contact Us -->
<ContactUs />

<!-- Nearby Cities -->
{data.nearbyCities && data.nearbyCities.length > 0 && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 48px 0; border-top: 1px solid var(--color-border);">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="font-size: 1.5rem; margin-bottom: 20px;"
      >
        Nearby Cities We Serve
      </h2>
      <div class="flex flex-wrap gap-3">
        {data.nearbyCities.map((city) => (
          <a
            href={city.href}
            style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-primary-dark); text-decoration: none; padding: 8px 16px; background-color: var(--color-white); border: 1px solid var(--color-border); border-radius: 8px;"
            class="hover:opacity-90 transition-opacity duration-200"
          >
            {city.name}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Popular services in this city -->
<section class="w-full" style="background-color: var(--color-white); padding: 40px 0;">
  <div class="mx-auto max-w-[1200px] px-5">
    <h3 style="font-size: 1.25rem; margin-bottom: 16px;">
      Services in {data.city}
    </h3>
    <div class="flex flex-wrap gap-2">
      {services.map(s => (
        <a href={s.href} style="font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 500; color: var(--color-primary); text-decoration: none; padding: 8px 16px; border: 1px solid var(--color-border); border-radius: 100px;" class="hover:opacity-80 transition-opacity">
          {s.title} in {data.city} →
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<Footer />
