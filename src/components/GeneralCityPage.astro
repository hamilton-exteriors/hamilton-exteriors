---
import type { GeneralCityPageData } from '../lib/general-city-types';
import { Image } from 'astro:assets';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Difference from './Difference.astro';
import FAQ from './FAQ.astro';
import ContactUs from './ContactUs.astro';
import Footer from './Footer.astro';
import IconStar from './icons/IconStar.astro';
import { resolveImage } from '../lib/image-map';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getCityProximity } from '../lib/city-coordinates';

interface Props {
  data: GeneralCityPageData;
}

const { data } = Astro.props;
const proximity = getCityProximity(data.slug);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://hamilton-exteriors.com/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': 'https://hamilton-exteriors.com/service-areas' },
    { '@type': 'ListItem', 'position': 3, 'name': data.county, 'item': `https://hamilton-exteriors.com/service-areas/${data.countySlug}` },
    { '@type': 'ListItem', 'position': 4, 'name': `${data.city}, ${data.state}` },
  ],
};
---

<AnnouncementBar />
<Navbar />

<!-- Breadcrumb -->
<nav class="w-full" style="background-color: var(--color-cream); border-bottom: 1px solid var(--color-border);">
  <div class="mx-auto flex items-center gap-2 px-5" style="max-width: 1294px; padding-top: 14px; padding-bottom: 14px;">
    <a href="/" style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">Home</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <a href="/service-areas" style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">Service Areas</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <a href={`/service-areas/${data.countySlug}`} style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">{data.county}</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-heading); font-weight: 600;">{data.city}, {data.state}</span>
  </div>
</nav>

<!-- BreadcrumbList JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Hero -->
<Hero
  headline={data.hero.headline}
  formTitle={data.hero.formTitle}
  formSubtitle={data.hero.formSubtitle}
  badges={data.hero.badges}
  proximity={proximity}
/>

<!-- Logo Slider -->
<LogoSlider />

<!-- Stats Strip -->
{data.stats && data.stats.length > 0 && (
  <section class="w-full" style="background-color: var(--color-heading); padding: 48px 0;">
    <div class="mx-auto max-w-[1200px] px-5 grid grid-cols-2 md:grid-cols-4 gap-8">
      {data.stats.map((stat) => (
        <div class="text-center">
          <div style="font-family: var(--font-oswald); font-size: 42px; font-weight: 700; color: var(--color-yellow);">{stat.value}</div>
          <p style="font-family: var(--font-dm-sans); font-size: 14px; color: rgba(255,255,255,0.8);">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>
)}

<!-- Reviews Section -->
{data.reviews && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <!-- Section Label -->
      <div class="mb-4 flex items-center gap-2">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <IconStar size={18} fill="#FFDE21" class="h-[18px] w-[18px]" />
          ))}
        </div>
        <span style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.05em;">
          On Google Reviews
        </span>
      </div>

      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 40px;"
      >
        {data.reviews.sectionTitle}
      </h2>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <!-- Featured review -->
        <div class="lg:col-span-2 p-8" style="background-color: var(--color-heading);">
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <IconStar size={20} fill="#FFDE21" class="h-[20px] w-[20px]" />
            ))}
          </div>
          <p style="font-family: var(--font-dm-sans); font-size: 18px; line-height: 30px; color: rgba(255,255,255,0.92); margin-bottom: 24px;">
            "{data.reviews.featured.text}"
          </p>
          <div>
            <p style="font-family: var(--font-dm-sans); font-size: 16px; font-weight: 600; color: var(--color-white); margin-bottom: 2px;">{data.reviews.featured.name}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; color: rgba(255,255,255,0.8);">{data.reviews.featured.location}</p>
          </div>
        </div>

        <!-- Side reviews -->
        <div class="flex flex-col gap-6">
          {data.reviews.side.map((review) => (
            <div class="p-6" style="background-color: var(--color-white);">
              <div class="flex gap-0.5 mb-3">
                {Array.from({ length: 5 }).map(() => (
                  <IconStar size={16} fill="#FFDE21" class="h-[16px] w-[16px]" />
                ))}
              </div>
              <p style="font-family: var(--font-dm-sans); font-size: 14px; line-height: 24px; color: var(--color-muted); margin-bottom: 16px;">
                "{review.text}"
              </p>
              <div>
                <p style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-heading);">{review.name}</p>
                <p style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">{review.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Services Grid -->
<section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
  <div class="mx-auto max-w-[1200px] px-5">
    <p style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary-dark); margin-bottom: 12px;">
      Our Services
    </p>
    <h2
      style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 40px); line-height: 1.25; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 48px;"
    >
      Design-Build Services in {data.city}
    </h2>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {data.services.map((service) => (
        <a
          href={service.href}
          class="block text-decoration-none"
          style="text-decoration: none; color: inherit;"
        >
          <div class="overflow-hidden" style="background-color: var(--color-cream);">
            <div class="w-full overflow-hidden">
              <Image
                src={resolveImage(service.imageKey)}
                alt={`${service.title} services by Hamilton Exteriors in ${data.city}`}
                width={400}
                height={240}
                style="width: 100%; height: auto; aspect-ratio: 400 / 240; object-fit: cover; display: block;"
                loading="lazy"
                class="hover:opacity-90 transition-opacity duration-200"
              />
            </div>
            <div style="padding: 20px;">
              <h3
                style="font-family: var(--font-oswald); font-size: 1.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 8px; color: var(--color-heading); text-transform: uppercase;"
              >
                {service.title}
              </h3>
              <p
                style="font-family: var(--font-dm-sans); font-size: 0.875rem; line-height: 1.6; color: var(--color-muted); margin-bottom: 16px;"
              >
                {service.description}
              </p>
              <span
                style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-primary-dark);"
              >
                Learn More &rarr;
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Difference -->
<Difference />

<!-- Neighborhoods Section -->
{data.neighborhoods && (
  <section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 16px;"
      >
        {data.neighborhoods.title}
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 16px; line-height: 26px; color: var(--color-muted); margin-bottom: 40px; max-width: 640px;">
        {data.neighborhoods.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.neighborhoods.items.map((hood) => (
          <div class="p-8" style="background-color: var(--color-cream);">
            <h3
              style="font-family: var(--font-oswald); font-size: 20px; font-weight: 700; line-height: 1.3; color: var(--color-heading); text-transform: uppercase; margin-bottom: 8px;"
            >
              {hood.title}
            </h3>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; line-height: 24px; color: var(--color-muted);">
              {hood.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- FAQ -->
<FAQ extraFaqs={data.faqs} />

<!-- Contact Us -->
<ContactUs />

<!-- Nearby Cities -->
{data.nearbyCities && data.nearbyCities.length > 0 && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 48px 0; border-top: 1px solid var(--color-border);">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="font-family: var(--font-oswald); font-size: 24px; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 20px;"
      >
        Nearby Cities We Serve
      </h2>
      <div class="flex flex-wrap gap-3">
        {data.nearbyCities.map((city) => (
          <a
            href={city.href}
            style="font-family: var(--font-dm-sans); font-size: 14px; color: var(--color-primary-dark); text-decoration: none; padding: 8px 16px; background-color: var(--color-white); border: 1px solid var(--color-border);"
            class="hover:opacity-90 transition-opacity duration-200"
          >
            {city.name}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Popular services in this city -->
<section class="w-full" style="background-color: var(--color-white); padding: 40px 0;">
  <div class="mx-auto max-w-[1200px] px-5">
    <h3 style="font-family: var(--font-oswald); font-size: 20px; font-weight: 400; color: var(--color-heading); text-transform: uppercase; margin-bottom: 16px;">
      Services in {data.city}
    </h3>
    <div class="flex flex-wrap gap-2">
      {data.services.map(s => (
        <a href={s.href} style="font-family: var(--font-dm-sans); font-size: 13px; font-weight: 500; color: var(--color-primary); text-decoration: none; padding: 8px 16px; border: 1px solid var(--color-border); border-radius: 100px;">
          {s.title} in {data.city} →
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<Footer />
