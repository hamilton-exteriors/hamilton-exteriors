---
import { Image } from 'astro:assets';
import { reviewLogoGoogle, reviewLogoYelp } from '../lib/images';
import IconStar from './icons/IconStar.astro';
/**
 * ReviewLogos – 4 platform rating cards in a horizontal row.
 * Matches the Framer site: BBB shield, Trustpilot, Google, Yelp.
 */
const platforms = [
  {
    name: 'BBB',
    logo: reviewLogoGoogle,
    logoWidth: 44,
    logoHeight: 44,
    score: '4.8',
    showStars: true,
    ratingLabel: 'Rated 4.5/5.0',
  },
  {
    name: 'Trustpilot',
    logo: '',
    logoWidth: 0,
    logoHeight: 0,
    score: '',
    showStars: false,
    ratingLabel: 'Rated 4.5/5.0',
  },
  {
    name: 'Google',
    logo: '',
    logoWidth: 0,
    logoHeight: 0,
    score: '4.8',
    showStars: true,
    ratingLabel: 'Rated 4.5/5.0',
  },
  {
    name: 'Yelp',
    logo: reviewLogoYelp,
    logoWidth: 130,
    logoHeight: 55,
    score: '',
    showStars: false,
    showYelpStars: true,
    ratingLabel: 'Rated 4.5/5.0',
  },
];

const starColor = 'var(--color-primary)';
---

<section class="w-full py-10 lg:py-16">
  <div class="mx-auto max-w-[1200px] px-5">
    <!-- Heading -->
    <p
      class="text-center font-dm-sans"
      style="font-size: 1rem; font-weight: 400; line-height: 1.5; color: var(--color-heading);"
    >
      Rated 4.8 Stars by Bay Area Homeowners &ndash; See Why Customers Love Us!
    </p>

    <!-- Platform logos row -->
    <div class="review-logos-row">
      {platforms.map((platform) => (
        <div class="review-card">
          <!-- Logo / Icon -->
          <div class="review-card__logo">
            {platform.name === 'BBB' && (
              <Image
                src={platform.logo}
                alt="BBB"
                width={platform.logoWidth}
                height={platform.logoHeight}
                style={`width: ${platform.logoWidth}px; height: ${platform.logoHeight}px; object-fit: contain;`}
                loading="lazy"
              />
            )}
            {platform.name === 'Trustpilot' && (
              /* Trustpilot green star icon (36x35 SVG) */
              <svg viewBox="0 0 36 35" width="36" height="35" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="#00B67A" d="M18 0l4.326 13.314H36l-11.063 8.037L29.263 34.665 18 26.628 6.737 34.665l4.326-13.314L0 13.314h13.674z"/>
              </svg>
            )}
            {platform.name === 'Google' && (
              /* Google "G" multicolor icon */
              <svg viewBox="0 0 48 48" width="44" height="44" xmlns="http://www.w3.org/2000/svg">
                <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                <path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
                <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
                <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
              </svg>
            )}
            {platform.name === 'Yelp' && (
              <Image
                src={platform.logo}
                alt="Yelp"
                width={platform.logoWidth}
                height={platform.logoHeight}
                style={`width: ${platform.logoWidth}px; height: ${platform.logoHeight}px; object-fit: contain;`}
                loading="lazy"
              />
            )}
          </div>

          <!-- Score + Stars row (for BBB and Google) -->
          {platform.score && (
            <div class="review-card__score-row">
              <span class="review-card__score">{platform.score}</span>
              {platform.showStars && (
                <div class="review-card__stars">
                  {[1,2,3,4,5].map(() => (
                    <IconStar size={18} fill={starColor} />
                  ))}
                </div>
              )}
            </div>
          )}


          <!-- Trustpilot 5-star bar -->
          {platform.name === 'Trustpilot' && (
            <div class="review-card__trustpilot-stars">
              {[1,2,3,4,5].map(() => (
                <div class="trustpilot-star-box">
                  <IconStar size={14} fill="#fff" />
                </div>
              ))}
            </div>
          )}

          <!-- Yelp red star bar -->
          {platform.showYelpStars && (
            <div class="review-card__yelp-stars">
              {[1,2,3,4,5].map(() => (
                <div class="yelp-star-box">
                  <IconStar size={14} fill="#fff" />
                </div>
              ))}
            </div>
          )}

          <!-- Rating label -->
          <span class="review-card__rating">{platform.ratingLabel}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .review-logos-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 16px;
    margin-top: 24px;
  }

  @media (min-width: 768px) {
    .review-logos-row {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  .review-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .review-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
  }
  .review-card__logo svg,
  .review-card__logo img {
    max-height: 28px;
    width: auto;
  }

  .review-card__logo img {
    display: block;
  }

  .review-card__score-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .review-card__score {
    font-family: var(--font-dm-sans);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.3;
    text-align: center;
    color: var(--color-primary);
  }

  .review-card__stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .review-card__trustpilot-name {
    font-family: var(--font-oswald);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    color: var(--color-charcoal);
  }

  .review-card__trustpilot-stars {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .trustpilot-star-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 21px;
    background-color: #00B67A;
  }

  .review-card__yelp-stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .yelp-star-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 21px;
    background-color: #D32323;
  }

  .review-card__rating {
    font-family: var(--font-dm-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-light);
    text-align: center;
  }

  @media (max-width: 640px) {
    .review-logos-row {
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }

    .review-card {
      flex: 0 0 auto;
      min-width: 140px;
      max-width: 160px;
    }
  }
</style>
