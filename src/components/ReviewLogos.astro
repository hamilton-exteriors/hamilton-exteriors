---
import { siTrustpilot, siYelp } from 'simple-icons';
import IconStar from './icons/IconStar.astro';
/**
 * ReviewLogos – 4 platform rating cards in a horizontal row.
 * Uses simple-icons for Trustpilot/Google/Yelp, custom SVG for BBB.
 */

const platforms = [
  { name: 'BBB', score: '4.8', showStars: true, ratingLabel: 'Rated 4.8/5.0' },
  { name: 'Trustpilot', score: '', showStars: false, ratingLabel: 'Rated 4.8/5.0' },
  { name: 'Google', score: '4.8', showStars: true, ratingLabel: 'Rated 4.8/5.0' },
  { name: 'Yelp', score: '', showStars: false, showYelpStars: true, ratingLabel: 'Rated 4.8/5.0' },
];

const starColor = 'var(--color-primary)';
---

<section class="w-full py-6 lg:py-10">
  <div class="mx-auto max-w-[1200px] px-5">
    <p class="text-center font-dm-sans text-base/normal font-normal text-heading">
      Rated 4.8 stars by Bay Area homeowners across BBB, Trustpilot, Google, and Yelp
    </p>

    <div class="review-logos-row">
      {platforms.map((platform) => (
        <div class="review-card">
          <div class="review-card__logo">
            {platform.name === 'BBB' && (
              /* Official BBB torch logo (Wikimedia Commons) */
              <svg viewBox="0 0 562 961" width="28" height="48" aria-label="Better Business Bureau" role="img" xmlns="http://www.w3.org/2000/svg">
                <path fill="#005f86" d="M438.82 541.64H122.78l-11.45 37.79h84.27l15.98 52.1h138.43l16.08-52.1h84.17zM174.39 329.5c-24.21 33.38-16.79 80.06 16.58 104.29l75.68 54.96c8.4 6.05 10.26 17.79 4.14 26.15l11.35 8.19 39.96-55.06c9.28-12.69 14.29-27.99 14.31-43.71-.03-4-.36-7.99-.99-11.94-3.02-19.53-13.67-37.06-29.6-48.74l-75.58-54.86c-4.21-2.82-7.06-7.24-7.89-12.24-.1-.99-.1-1.97 0-2.96.03-3.93 1.27-7.76 3.55-10.95l-11.35-8.29zm45.59-220.82c-13.4 18.4-20.62 40.58-20.62 63.35-.03 5.78.43 11.56 1.38 17.27 4.41 28.39 20.01 53.84 43.32 70.65l95.12 69.07c12.46 9 20.81 22.61 23.19 37.79.51 3.07.77 6.17.79 9.28-.05 12.14-3.95 23.96-11.15 33.74l9.18 6.61 74.89-103.5C471.03 264.44 460.21 196.82 411.89 161.66L297.13 78.28c-7.18-5.2-11.97-13.05-13.32-21.81-1.46-8.75.67-17.72 5.92-24.86l-9.08-6.61zM25.79 663.1h86.63c17.79-1.18 35.32 4.75 48.74 16.48 8.43 8.35 13.04 19.81 12.73 31.67v.59c.48 17.04-9.11 32.77-24.47 40.16 21.51 8.29 34.83 20.82 34.83 45.88 0 34.14-27.63 51.21-69.76 51.21H25.69zm78.15 75.38c18.06 0 29.6-5.92 29.6-19.73 0-12.33-9.87-19.73-26.94-19.73H65.75v39.47zm10.85 75.09c18.16 0 29.01-6.41 29.01-19.73v-.59c0-12.43-9.28-19.73-30.29-19.73H65.75v41.05zM202.61 663.1h86.63c17.79-1.18 35.32 4.75 48.74 16.48 8.39 8.37 12.96 19.83 12.63 31.67v.59c.48 17.04-9.11 32.77-24.47 40.16 21.61 8.29 34.93 20.82 34.93 45.88 0 34.14-27.73 51.21-69.86 51.21h-88.6zm77.85 75.38c18.06 0 29.6-5.92 29.6-19.73 0-12.33-9.87-19.73-26.84-19.73h-41.15v39.47zm10.85 75.09c18.16 0 29.01-6.41 29.01-19.73v-.59c0-12.43-9.28-19.73-30.29-19.73h-47.95v41.05zM378.44 663.1h86.63c17.79-1.18 35.32 4.75 48.74 16.48 8.43 8.35 13.04 19.81 12.73 31.67v.59c.48 17.04-9.11 32.77-24.47 40.16 21.61 8.29 34.93 20.82 34.93 45.88 0 34.14-27.73 51.21-69.86 51.21h-88.8zm77.85 75.38c18.06 0 29.6-5.92 29.6-19.73 0-12.33-9.87-19.73-26.84-19.73h-40.65v39.47zm10.85 75.09c18.16 0 29.11-6.41 29.11-19.73v-.59c0-12.43-9.37-19.73-30.39-19.73h-47.46v41.05z"/>
              </svg>
            )}
            {platform.name === 'Trustpilot' && (
              <svg viewBox="0 0 24 24" width="36" height="36" aria-label="Trustpilot" role="img" xmlns="http://www.w3.org/2000/svg">
                <path fill={`#${siTrustpilot.hex}`} d={siTrustpilot.path} />
              </svg>
            )}
            {platform.name === 'Google' && (
              <svg viewBox="0 0 24 24" width="36" height="36" aria-label="Google" role="img" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            )}
            {platform.name === 'Yelp' && (
              <svg viewBox="0 0 24 24" width="36" height="36" aria-label="Yelp" role="img" xmlns="http://www.w3.org/2000/svg">
                <path fill={`#${siYelp.hex}`} d={siYelp.path} />
              </svg>
            )}
          </div>

          {/* Score + Stars */}
          {platform.score && (
            <div class="review-card__score-row">
              <span class="review-card__score">{platform.score}</span>
              {platform.showStars && (
                <div class="review-card__stars">
                  {[1,2,3,4,5].map(() => <IconStar size={18} fill={starColor} />)}
                </div>
              )}
            </div>
          )}

          {/* Trustpilot 5-star bar */}
          {platform.name === 'Trustpilot' && (
            <div class="review-card__trustpilot-stars">
              {[1,2,3,4,5].map(() => (
                <div class="trustpilot-star-box">
                  <IconStar size={14} fill="#fff" />
                </div>
              ))}
            </div>
          )}

          {/* Yelp red star bar */}
          {platform.showYelpStars && (
            <div class="review-card__yelp-stars">
              {[1,2,3,4,5].map(() => (
                <div class="yelp-star-box">
                  <IconStar size={14} fill="#fff" />
                </div>
              ))}
            </div>
          )}

          <span class="review-card__rating">{platform.ratingLabel}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .review-logos-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 16px;
    margin-top: 24px;
  }
  @media (min-width: 768px) {
    .review-logos-row { grid-template-columns: repeat(4, 1fr); gap: 16px; }
  }
  .review-card { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .review-card__logo { display: flex; align-items: center; justify-content: center; height: 48px; }
  .review-card__score-row { display: flex; align-items: center; gap: 6px; }
  .review-card__score { font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 800; line-height: 1.3; color: var(--color-primary); }
  .review-card__stars { display: flex; align-items: center; gap: 2px; }
  .review-card__trustpilot-stars { display: flex; align-items: center; gap: 1px; }
  .trustpilot-star-box { display: flex; align-items: center; justify-content: center; width: 22px; height: 21px; background-color: var(--color-brand-trustpilot); }
  .review-card__yelp-stars { display: flex; align-items: center; gap: 2px; }
  .yelp-star-box { display: flex; align-items: center; justify-content: center; width: 22px; height: 21px; background-color: var(--color-brand-yelp); }
  .review-card__rating { font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 500; line-height: 1.4; color: var(--color-muted); text-align: center; }
  @media (max-width: 640px) {
    .review-logos-row { flex-wrap: wrap; justify-content: center; gap: 24px; }
    .review-card { flex: 0 0 auto; min-width: 140px; max-width: 160px; }
  }
</style>
