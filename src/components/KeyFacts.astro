---
import SectionLabel from './SectionLabel.astro';

interface Props {
  title?: string;
  facts: Array<{
    stat: string;
    claim: string;
    source?: string;
    sourceUrl?: string;
  }>;
}

const { title = 'Key Facts', facts } = Astro.props;
---

<aside
  role="complementary"
  aria-label={title}
  class="my-8 max-w-[800px] rounded-[4px] bg-cream px-7 py-6"
>
  <SectionLabel>{title}</SectionLabel>

  <dl class="m-0">
    {facts.map((fact, i) => (
      <div class={`py-3 ${i < facts.length - 1 ? 'border-b border-border' : ''}`}>
        <dt class="m-0 text-base/normal text-heading">
          <strong>{fact.stat}</strong>
          {' '}&mdash; {fact.claim}
        </dt>
        {fact.source && (
          <dd class="mt-1 mb-0 ml-0 text-[0.8125rem] leading-[1.4] text-muted">
            {fact.sourceUrl ? (
              <a
                href={fact.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted underline underline-offset-2"
              >
                {fact.source}
              </a>
            ) : (
              fact.source
            )}
          </dd>
        )}
      </div>
    ))}
  </dl>
</aside>
