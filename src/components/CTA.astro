---
import { Image, getImage } from 'astro:assets';
import { financingWorker, iconCheckmarkCircle, ctaAssistant } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import SectionLabel from './SectionLabel.astro';

const [ctaMobile, ctaTablet, ctaDesktop] = await Promise.all([
  getImage({ src: ctaAssistant, width: 600, height: 450, format: 'webp', quality: 65 }),
  getImage({ src: ctaAssistant, width: 900, height: 675, format: 'webp', quality: 65 }),
  getImage({ src: ctaAssistant, width: 1200, height: 900, format: 'webp', quality: 60 }),
]);
---

<section class="cv-auto w-full bg-white">
  <div class="mx-auto flex max-w-[1170px] flex-col lg:flex-row">

    <!-- Left Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-10 lg:py-16">

      <!-- Heading -->
      <SectionLabel>Your Next Step</SectionLabel>
      <h2 class="m-0 text-[clamp(32px,5vw,52px)] leading-[1.1] text-charcoal">
        Get Started with <span class="text-primary" style="background: linear-gradient(transparent 60%, rgba(255, 222, 33, 0.35) 60%);">$0 Down*</span>
      </h2>

      <!-- Credit score note -->
      <p class="mt-3 text-[0.8125rem] leading-normal font-normal text-muted">
        * Depending on credit score
      </p>
      <h3 class="mt-0.5 text-base/normal font-bold text-heading normal-case">
        Call to Schedule Your Free Inspection
      </h3>

      <!-- Trust line -->
      <p class="m-0 mt-5 text-[0.9375rem] leading-[1.6] text-body">
        We'll call within <strong>3–5 minutes</strong>. A specialist will visit your home within <strong>3 days</strong> to measure and quote — at no cost.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={PHONE_HREF}
          class="flex min-h-[52px] items-center justify-center gap-2.5 rounded-full bg-yellow px-7 py-4 font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-heading uppercase no-underline transition-opacity hover:opacity-90"
          data-track="cta_section_call"
        >
          <Image src={iconCheckmarkCircle} alt="" width={18} height={18} class="block" />
          Call Now {PHONE_DISPLAY}
        </a>
        <a
          href="#quote"
          class="flex min-h-[52px] items-center justify-center rounded-full bg-primary px-7 py-4 font-oswald text-base font-bold tracking-[0.04em] whitespace-nowrap text-white uppercase no-underline transition-opacity hover:opacity-90"
          data-track="cta_section_quote"
        >
          Get Your Free Quote
        </a>
      </div>
    </div>

    <!-- Right Column: Construction Photo -->
    <div class="relative aspect-4/3 min-h-[250px] w-full lg:w-1/2">
      <picture>
        <source srcset={ctaMobile.src} media="(max-width: 640px)" type="image/webp" width="600" height="450" />
        <source srcset={ctaTablet.src} media="(max-width: 1024px)" type="image/webp" width="900" height="675" />
        <source srcset={ctaDesktop.src} type="image/webp" width="1200" height="900" />
        <img
          src={ctaDesktop.src}
          alt="Hamilton Exteriors crew installing siding on a Bay Area home"
          width="1200"
          height="900"
          class="absolute inset-0 size-full object-cover object-top"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
  </div>
</section>
