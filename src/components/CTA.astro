---
import { Image } from 'astro:assets';
import { financingWorker, iconCheckmarkCircle, ctaAssistant } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
---

<section class="w-full" style="background-color: var(--color-white);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px;">

    <!-- Left Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-10 lg:py-16">

      <!-- Heading -->
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 5vw, 48px); line-height: 1.15; color: var(--color-charcoal); font-weight: 400; text-transform: uppercase; margin: 0;">
        Get Started with as Little as <span style="color: var(--color-primary);">$0 Down*</span>
      </h2>

      <!-- Credit score note -->
      <p class="mt-3" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 400; line-height: 1.5; color: var(--color-muted);">
        * Depending on credit score
      </p>
      <p style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 700; line-height: 1.5; color: var(--color-heading); margin-top: 2px;">
        Call to Schedule Your Free Inspection
      </p>

      <!-- Trust line -->
      <p class="mt-5" style="font-family: var(--font-dm-sans); font-size: 0.9375rem; line-height: 1.6; color: var(--color-body); margin: 0;">
        We'll call within <strong>5 minutes</strong>. A specialist will visit your home within <strong>3 days</strong> to measure and quote — at no cost.
      </p>

      <!-- Buttons -->
      <div class="mt-5 flex flex-col gap-3 lg:flex-row lg:items-center">
        <a
          href={PHONE_HREF}
          class="flex items-center justify-center gap-2 rounded-lg border border-gray-200 px-5 py-3 text-sm font-semibold transition-colors hover:bg-gray-50 whitespace-nowrap"
          style="font-family: var(--font-dm-sans); color: var(--color-heading); text-decoration: none;"
        >
          <Image src={iconCheckmarkCircle} alt="" width={15} height={15} style="display: block;" />
          Call Now {PHONE_DISPLAY}
        </a>
        <a
          href="#contact"
          class="flex items-center justify-center rounded-lg px-5 py-3 text-sm font-semibold transition-opacity hover:opacity-90 whitespace-nowrap"
          style="background-color: var(--color-primary); color: var(--color-white); text-decoration: none; font-family: var(--font-dm-sans);"
        >
          Schedule a FREE Inspection
        </a>
      </div>
    </div>

    <!-- Right Column: Construction Photo -->
    <div class="relative w-full lg:w-1/2" style="min-height: 250px;">
      <Image
        src={ctaAssistant}
        alt="Hamilton Exteriors crew installing siding on a Bay Area home"
        width={1200}
        height={900}
        class="absolute inset-0 h-full w-full object-cover"
        style="object-position: center top;"
        loading="lazy"
      />
    </div>
  </div>
</section>
