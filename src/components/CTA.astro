---
import { Image, getImage } from 'astro:assets';
import { financingWorker, iconCheckmarkCircle, ctaAssistant } from '../lib/images';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';

const [ctaMobile, ctaTablet, ctaDesktop] = await Promise.all([
  getImage({ src: ctaAssistant, width: 600, height: 450, format: 'webp', quality: 65 }),
  getImage({ src: ctaAssistant, width: 900, height: 675, format: 'webp', quality: 65 }),
  getImage({ src: ctaAssistant, width: 1200, height: 900, format: 'webp', quality: 60 }),
]);
---

<section class="cv-auto w-full" style="background-color: var(--color-white);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px;">

    <!-- Left Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-10 lg:py-16">

      <!-- Heading -->
      <p style="font-family: var(--font-satoshi); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); margin-bottom: 12px;">
        Ready to Start?
      </p>
      <h2 style="font-family: var(--font-oswald); font-size: clamp(32px, 5vw, 52px); line-height: 1.1; color: var(--color-charcoal); font-weight: 400; text-transform: uppercase; margin: 0;">
        Get Started with <span style="color: var(--color-primary); background: linear-gradient(transparent 60%, rgba(255, 222, 33, 0.35) 60%);">$0 Down*</span>
      </h2>

      <!-- Credit score note -->
      <p class="mt-3" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 400; line-height: 1.5; color: var(--color-muted);">
        * Depending on credit score
      </p>
      <h3 style="font-family: var(--font-dm-sans); font-size: 1rem; font-weight: 700; line-height: 1.5; color: var(--color-heading); margin-top: 2px; text-transform: none;">
        Call to Schedule Your Free Inspection
      </h3>

      <!-- Trust line -->
      <p class="mt-5" style="font-family: var(--font-dm-sans); font-size: 0.9375rem; line-height: 1.6; color: var(--color-body); margin: 0;">
        We'll call within <strong>5 minutes</strong>. A specialist will visit your home within <strong>3 days</strong> to measure and quote — at no cost.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={PHONE_HREF}
          class="flex items-center justify-center gap-2.5 rounded-full min-h-[52px] px-7 py-4 transition-opacity hover:opacity-90 whitespace-nowrap"
          style="background-color: var(--color-yellow); font-family: var(--font-oswald); font-size: 1rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-primary); text-decoration: none;"
        >
          <Image src={iconCheckmarkCircle} alt="" width={18} height={18} style="display: block;" />
          Call Now {PHONE_DISPLAY}
        </a>
        <a
          href="#quote"
          class="flex items-center justify-center rounded-full min-h-[52px] px-7 py-4 transition-opacity hover:opacity-90 whitespace-nowrap"
          style="background-color: var(--color-primary); color: var(--color-white); text-decoration: none; font-family: var(--font-oswald); font-size: 1rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;"
        >
          Get Your Free Quote
        </a>
      </div>
    </div>

    <!-- Right Column: Construction Photo -->
    <div class="relative w-full lg:w-1/2" style="min-height: 250px; aspect-ratio: 4/3;">
      <picture>
        <source srcset={ctaMobile.src} media="(max-width: 640px)" type="image/webp" width="600" height="450" />
        <source srcset={ctaTablet.src} media="(max-width: 1024px)" type="image/webp" width="900" height="675" />
        <source srcset={ctaDesktop.src} type="image/webp" width="1200" height="900" />
        <img
          src={ctaDesktop.src}
          alt="Hamilton Exteriors crew installing siding on a Bay Area home"
          width="1200"
          height="900"
          class="absolute inset-0 h-full w-full object-cover"
          style="object-position: center top;"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
  </div>
</section>
