---
import { Image } from 'astro:assets';
import { financingWorker, iconCheckmarkCircle, ctaAssistant } from '../lib/images';
---

<section class="w-full" style="background-color: rgb(255, 255, 255);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px;">

    <!-- Left Column: Content -->
    <div class="flex w-full flex-col justify-center px-5 py-10 lg:w-1/2 lg:px-10 lg:py-16">

      <!-- Heading -->
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(28px, 5vw, 48px); line-height: 1.15; color: rgb(51, 51, 51); font-weight: 400; text-transform: uppercase; margin: 0;">
        Get Started with as Little as <span style="color: rgb(33, 150, 83);">$0 Down*</span>
      </h2>

      <!-- Credit score note -->
      <p class="mt-3" style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 400; line-height: 1.5; color: rgb(100, 100, 100);">
        * Depending on credit score
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; line-height: 1.5; color: rgb(13, 43, 29); margin-top: 2px;">
        Call Right Now and Request a Free Inspection
      </p>

      <!-- Assistant -->
      <div class="mt-5 flex items-start gap-3">
        <div class="shrink-0 overflow-hidden rounded-full" style="width: 44px; height: 44px;">
          <Image
            src={financingWorker}
            alt="Customer service representative"
            width={63}
            height={63}
            class="h-full w-full object-cover"
          />
        </div>
        <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 400; line-height: 1.5; color: rgb(13, 43, 29); margin: 0;">
          Our assistant will contact you within <strong>5 minutes</strong>. A specialist will visit within <strong>3 working days</strong> for a detailed estimate.
        </p>
      </div>

      <!-- Buttons -->
      <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="tel:6509773351"
          class="flex items-center justify-center gap-2 rounded-lg border border-gray-200 px-5 py-3 text-sm font-semibold transition-colors hover:bg-gray-50"
          style="font-family: 'DM Sans', sans-serif; color: rgb(13, 43, 29); text-decoration: none;"
        >
          <Image src={iconCheckmarkCircle} alt="" width={15} height={15} style="display: block;" />
          Call Now (650) 977-3351
        </a>
        <a
          href="#contact"
          class="flex items-center justify-center rounded-lg px-5 py-3 text-sm font-semibold transition-opacity hover:opacity-90"
          style="background-color: rgb(37, 99, 70); color: rgb(246, 253, 252); text-decoration: none; font-family: 'DM Sans', sans-serif;"
        >
          Schedule a FREE Inspection
        </a>
      </div>
    </div>

    <!-- Right Column: Construction Photo -->
    <div class="relative w-full lg:w-1/2" style="min-height: 250px;">
      <Image
        src={ctaAssistant}
        alt="Workers installing siding on a home"
        width={1200}
        height={900}
        class="absolute inset-0 h-full w-full object-cover"
        style="object-position: center top;"
        loading="lazy"
      />
    </div>
  </div>
</section>
