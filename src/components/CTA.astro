---
import { Image } from 'astro:assets';
import { financingWorker, iconCheckmarkCircle, ctaAssistant } from '../lib/images';
---

<section class="w-full" style="background-color: rgb(255, 255, 255);">
  <div class="mx-auto flex flex-col lg:flex-row" style="max-width: 1170px; padding: 0 15px;">

    <!-- Left Column: Content -->
    <div class="flex w-full flex-col justify-center lg:w-1/2 px-5 py-10 lg:px-10 lg:py-16">

      <!-- Title + Info -->
      <div>
        <!-- Heading -->
        <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: clamp(32px, 5vw, 48px); line-height: 1.2; color: rgb(51, 51, 51); font-weight: 400; text-transform: uppercase; letter-spacing: 0px; margin: 0;">
          Get Started with as Little as <span style="color: rgb(33, 150, 83);">$0 Down*</span>
        </h2>

        <!-- Credit score note + subheading -->
        <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 400; line-height: 150%; color: rgb(13, 43, 29); margin-top: 12px;">
          * Depending on credit score<br />
          <span style="font-weight: 700;">Call Right Now and Request a Free Inspection</span>
        </p>
      </div>

      <!-- Assistant -->
      <div class="flex items-start" style="margin-top: 24px; gap: 12px;">
        <!-- Profile photo -->
        <div class="shrink-0 overflow-hidden rounded-full" style="width: 63px; height: 63px;">
          <Image
            src={financingWorker}
            alt="Customer service representative"
            width={63}
            height={63}
            class="h-full w-full object-cover"
          />
        </div>
        <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 400; line-height: 24px; color: rgb(13, 43, 29); margin: 0;">
          Fill out the form, and our assistant will contact you within <span style="font-weight: 700;">5 minutes</span>. A specialist will visit within <span style="font-weight: 700;">3 working days</span> for a detailed estimate.
        </p>
      </div>

      <!-- Buttons -->
      <div class="flex flex-col items-start" style="margin-top: 24px; gap: 12px;">
        <!-- Call Now Button -->
        <a
          href="tel:6509773351"
          class="flex items-center"
          style="gap: 8px; border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 10px; padding: 12px 24px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; line-height: 150%; color: rgb(13, 43, 29); text-decoration: none; background-color: transparent;"
        >
          <Image
            src={iconCheckmarkCircle}
            alt=""
            width={15}
            height={15}
            style="display: block;"
          />
          Call Now (650) 977-3351
        </a>

        <!-- Schedule Button -->
        <a
          href="#contact"
          style="display: inline-block; border-radius: 10px; background-color: rgb(37, 99, 70); padding: 12px 24px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; line-height: 150%; color: rgb(246, 253, 252); text-decoration: none; text-align: center;"
        >
          Schedule a FREE Inspection
        </a>
      </div>
    </div>

    <!-- Right Column: Construction Photo -->
    <div class="relative w-full lg:w-1/2" style="min-height: 400px;">
      <Image
        src={ctaAssistant}
        alt="Workers installing siding on a home"
        width={1200}
        height={900}
        class="absolute inset-0 h-full w-full"
        style="object-fit: cover; object-position: center top;"
        loading="lazy"
      />
    </div>
  </div>
</section>
