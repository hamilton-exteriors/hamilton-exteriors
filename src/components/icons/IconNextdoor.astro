---
import { siNextdoor } from 'simple-icons';
interface Props {
  size?: number;
  class?: string;
}
const { size = 26, class: className = '' } = Astro.props;
---
<svg viewBox="0 0 24 24" width={size} height={size} class={className} aria-hidden="true">
  <path fill={`#${siNextdoor.hex}`} d={siNextdoor.path} />
</svg>
