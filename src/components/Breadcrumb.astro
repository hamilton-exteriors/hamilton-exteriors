---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="w-full" aria-label="Breadcrumb" style="background-color: var(--color-cream); border-bottom: 1px solid var(--color-border);">
  <div class="mx-auto flex items-center gap-2 px-5" style="max-width: 1294px; min-height: 44px;">
    {items.map((item, i) => (
      <>
        {i > 0 && (
          <span style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted);">/</span>
        )}
        {item.href ? (
          <a href={item.href} style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted); text-decoration: none; padding: 8px 0; display: inline-block;">{item.label}</a>
        ) : (
          <span aria-current="page" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-heading); font-weight: 600;">{item.label}</span>
        )}
      </>
    ))}
  </div>
</nav>
