---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="w-full border-b border-border bg-cream" aria-label="Breadcrumb">
  <div class="mx-auto flex min-h-[44px] max-w-[1294px] items-center gap-2 overflow-hidden px-5">
    {items.map((item, i) => (
      <>
        {i > 0 && (
          <span class="text-[0.8125rem] text-muted">/</span>
        )}
        {item.href ? (
          <a href={item.href} class="inline-block min-w-0 truncate py-2 text-[0.8125rem] text-muted no-underline">{item.label}</a>
        ) : (
          <span aria-current="page" class="min-w-0 truncate text-[0.8125rem] font-semibold text-heading">{item.label}</span>
        )}
      </>
    ))}
  </div>
</nav>
