---
import { Image } from 'astro:assets';
import { heroBg, serviceRoofing, serviceSiding, serviceWindows, serviceAdu, iconContactPhone, iconContactEmail, iconContactClock } from '../lib/images';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Footer from './Footer.astro';
import type { ServiceAreaCity } from '../lib/service-area-types';
import StarRating from './StarRating.astro';
import IconCheck from './icons/IconCheck.astro';
import IconPlus from './icons/IconPlus.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
import { getCityProximity } from '../lib/city-coordinates';
import { getGoogleReviews, getDisplayReviews } from '../lib/google-reviews';
import Breadcrumb from './Breadcrumb.astro';
import Section from './Section.astro';
import SectionLabel from './SectionLabel.astro';

interface Props {
  data: ServiceAreaCity;
}

const { data } = Astro.props;
const { city, county, countySlug, hero, reviews, pricingCards, whyBuildStats, trustedExperts, process: processSection, projects, projectsTitle, regulations, neighborhoods, mobileProcessResources, faqs, faqTitle, contact, resources, pricingLabel, pricingTitle } = data;
const proximity = getCityProximity(data.slug);

/** Map imageKey strings to actual imported images */
const imageMap: Record<string, ImageMetadata> = {
  serviceRoofing,
  serviceSiding,
  serviceWindows,
  serviceAdu,
  heroBg,
};

// Build page URL for schemas
const countyUrlSlug = countySlug.endsWith('-county-ca') ? countySlug : `${countySlug}-county-ca`;
const cityUrlSlug = data.slug.endsWith('-ca') ? data.slug : `${data.slug}-ca`;
const pageUrl = `https://hamilton-exteriors.com/service-areas/${countyUrlSlug}/${cityUrlSlug}`;

// WebPage schema
const webPageSchema = {
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: `${city}, CA Contractor Services | Hamilton Exteriors`,
  isPartOf: { '@id': 'https://hamilton-exteriors.com/#website' },
  about: { '@id': 'https://hamilton-exteriors.com/#business' },
  inLanguage: 'en-US',
};

// Review schema with live data
const _rawReviews = await getGoogleReviews();
const _cityReviews = getDisplayReviews(_rawReviews);
const allReviews = reviews ? [reviews.featured, ...reviews.side] : [];
const reviewSchema = allReviews.length > 0 ? {
  '@type': 'GeneralContractor',
  '@id': 'https://hamilton-exteriors.com/#business',
  name: 'Hamilton Exteriors',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: _cityReviews.rating,
    reviewCount: _cityReviews.reviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  review: allReviews.map((r, i) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: { '@type': 'Rating', ratingValue: (r as any).rating || 5, bestRating: 5, worstRating: 1 },
    reviewBody: r.text,
    ...((r as any).date && { datePublished: (r as any).date }),
    publisher: { '@type': 'Organization', name: 'Google' },
  })),
} : null;

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hamilton-exteriors.com/" },
    { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://hamilton-exteriors.com/service-areas" },
    { "@type": "ListItem", "position": 3, "name": county, "item": `https://hamilton-exteriors.com/service-areas/${countySlug}` },
    { "@type": "ListItem", "position": 4, "name": `${city}, CA`, "item": pageUrl },
  ],
};

// FAQPage schema — emit when city page has FAQ content from Ghost CMS
const faqPageSchema = faqs && faqs.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

const cityGraphJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [breadcrumbSchema, webPageSchema, ...(reviewSchema ? [reviewSchema] : []), ...(faqPageSchema ? [faqPageSchema] : [])],
};
---

<AnnouncementBar slot="header" />
<Navbar slot="header" />

<!-- Breadcrumb -->
<Breadcrumb items={[
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: county, href: `/service-areas/${countySlug}` },
  { label: `${city}, CA` },
]} />
<!-- Structured data: BreadcrumbList + WebPage + Reviews -->
<script type="application/ld+json" set:html={JSON.stringify(cityGraphJsonLd)} />

<!-- Hero — shared component -->
<Hero
  headline={hero.headline}
  formTitle={hero.formTitle}
  formSubtitle={hero.formSubtitle}
  badges={hero.badges}
  proximity={proximity}
/>
<!-- END shared hero -->

<!-- Logo Slider + License -->
<LogoSlider />
<div class="w-full text-center bg-white py-4">
  <p class="text-xs text-muted tracking-[0.02em]">
    CA Contractor License #1082377
  </p>
</div>
<div class="mx-auto max-w-7xl px-4 py-2 text-center">
  <p class="text-[13px] text-muted">
    Reviewed by <a href="/about/alex-hamilton-li" class="text-muted underline underline-offset-[2px]">Alexander Hamilton Li</a>, Architect &amp; General Contractor · <a href="https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377" target="_blank" rel="noopener noreferrer" class="text-muted underline underline-offset-[2px]">CSLB #1082377</a> · Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
  </p>
</div>

<!-- Reviews Section -->
{reviews && (
  <Section bg="cream" padding="lg">
    <!-- Section Label -->
    <div class="mb-4 flex items-center gap-2">
        <StarRating size={18} fill="#FFDE21" />
        <span class="text-sm font-semibold text-muted uppercase tracking-[0.05em]">
          On Google Reviews
        </span>
      </div>

      <h2
        class="text-[40px] leading-[50px] mb-10"
      >
        {reviews.sectionTitle}
      </h2>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <!-- Featured review -->
        <div class="lg:col-span-2 p-8 bg-heading">
          <StarRating size={20} fill="#FFDE21" class="mb-4" />
          <p class="text-lg leading-[30px] text-white-85 mb-6">
            "{reviews.featured.text}"
          </p>
          <div>
            <p class="text-base font-semibold text-white mb-0.5">{reviews.featured.name}</p>
            <p class="text-sm text-white-80">{reviews.featured.location}</p>
          </div>
        </div>

        <!-- Side reviews -->
        <div class="flex flex-col gap-6">
          {reviews.side.map((review) => (
            <div class="p-6 bg-white">
              <StarRating size={16} fill="#FFDE21" class="mb-3" />
              <p class="text-sm leading-[24px] text-muted mb-4">
                "{review.text}"
              </p>
              <div>
                <p class="text-sm font-semibold text-heading">{review.name}</p>
                <p class="text-xs text-muted">{review.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>
)}

<!-- Services / Pricing Cards -->
{pricingCards && pricingCards.length > 0 && (
  <Section bg="white" padding="lg">
      <p class="text-sm font-semibold uppercase tracking-[0.08em] text-primary-dark mb-3">
        {pricingLabel || 'Our Services'}
      </p>
      <h2
        class="text-[40px] leading-[50px] mb-12"
      >
        {pricingTitle || `ADU Services Built for ${city} Homeowners`}
      </h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {pricingCards.map((card) => (
          card.highlighted ? (
            <div class="pricing-card relative flex flex-col p-6 bg-heading">
              {card.badge && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style={`background-color: ${card.badgeColor === 'yellow' ? 'var(--color-yellow)' : 'var(--color-primary-dark)'};`}>
                  <span class="font-satoshi text-xs font-bold uppercase tracking-[0.05em]" style={`color: ${card.badgeColor === 'yellow' ? 'var(--color-heading)' : 'var(--color-white)'};`}>{card.badge}</span>
                </div>
              )}
              <h3 class={`text-xl font-bold text-white mb-1${card.badge ? ' mt-2' : ''}`}>{card.title}</h3>
              <p class="text-sm text-white-80 mb-4">{card.subtitle}</p>
              <p class="font-hamilton-display text-[28px] font-bold text-yellow mb-1">{card.price}</p>
              <p class="text-xs text-white-80 mb-5">{card.sqft}</p>
              <ul class="flex flex-col gap-2 mt-auto">
                {card.features.map(item => (
                  <li class="flex items-start gap-2">
                    <IconCheck size={16} stroke="#FFDE21" class="h-[16px] w-[16px] shrink-0 mt-1" />
                    <span class="text-xs text-white-85 leading-5">{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#contact" class="mt-6 block w-full rounded-full py-3 text-center transition-opacity hover:opacity-90 bg-yellow text-sm font-semibold text-heading">
                Get a Quote
              </a>
            </div>
          ) : (
            <div class={`pricing-card flex flex-col p-6 bg-white ${card.badge ? 'relative' : ''}`}>
              {card.badge && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style={`background-color: ${card.badgeColor === 'yellow' ? 'var(--color-yellow)' : 'var(--color-primary-dark)'};`}>
                  <span class="font-satoshi text-xs font-bold uppercase tracking-[0.05em]" style={`color: ${card.badgeColor === 'yellow' ? 'var(--color-heading)' : 'var(--color-white)'};`}>{card.badge}</span>
                </div>
              )}
              <h3 class={`text-xl font-bold text-heading mb-1${card.badge ? ' mt-2' : ''}`}>{card.title}</h3>
              <p class="text-sm text-muted mb-4">{card.subtitle}</p>
              <p class="font-hamilton-display text-[28px] font-bold text-heading mb-1">{card.price}</p>
              <p class="text-xs text-muted mb-5">{card.sqft}</p>
              <ul class="flex flex-col gap-2 mt-auto">
                {card.features.map(item => (
                  <li class="flex items-start gap-2">
                    <IconCheck size={16} stroke="var(--color-primary)" class="h-[16px] w-[16px] shrink-0 mt-1" />
                    <span class="text-xs text-muted leading-5">{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#contact" class="mt-6 block w-full rounded-full py-3 text-center transition-opacity hover:opacity-90 bg-primary text-sm font-semibold text-white">
                Get a Quote
              </a>
            </div>
          )
        ))}
      </div>
    </div>
  </Section>
)}

<!-- Why Build an ADU Stats -->
{whyBuildStats && (
  <Section bg="cream" padding="md">
      <h2
        class="text-center text-[40px] leading-[50px] mb-4"
      >
        {whyBuildStats.title}
      </h2>
      <p class="text-center mx-auto text-base leading-[26px] text-muted max-w-[640px] mb-12">
        {whyBuildStats.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {whyBuildStats.stats.map((stat) => (
          <div class="p-8 text-center bg-white">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-[rgba(37,99,70,0.1)]">
              {stat.icon === 'dollar' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"></line>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
              )}
              {stat.icon === 'trend' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              )}
              {stat.icon === 'document' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              )}
            </div>
            <p class="font-hamilton-display text-[36px] font-bold text-heading mb-1">{stat.value}</p>
            <p class="text-base font-semibold text-heading mb-2">{stat.label}</p>
            <p class="text-sm leading-[22px] text-muted">
              {stat.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </Section>
)}

<!-- Trusted ADU Experts -->
{trustedExperts && (
  <Section bg="dark" padding="lg">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2
            class="text-[40px] leading-[50px] text-white mb-5"
          >
            {trustedExperts.title}
          </h2>
          {trustedExperts.paragraphs.map((p, i) => (
            <p class={`text-base leading-[30px] text-white-80 ${i === trustedExperts.paragraphs.length - 1 ? 'mb-8' : 'mb-6'}`}>
              {p}
            </p>
          ))}
          <a
            href={trustedExperts.ctaHref}
            class="inline-block transition-opacity hover:opacity-90 text-sm font-semibold leading-[24px] bg-yellow text-heading rounded-full py-3 px-7"
          >
            {trustedExperts.ctaText}
          </a>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {trustedExperts.stats.map((stat) => (
            <div class="p-6 text-center bg-white/[0.08]">
              <p class="font-hamilton-display text-[42px] font-bold text-yellow">{stat.value}</p>
              <p class="text-sm text-white-80">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Our Process (desktop) -->
{processSection && (
  <section class="hidden lg:block w-full bg-white py-20">
    <div class="mx-auto max-w-[1200px] px-5">
      <p class="text-xs font-semibold tracking-[2px] uppercase text-primary-dark mb-3">How It Works</p>
      <h2
        class="text-[40px] leading-[50px] mb-12"
      >
        {processSection.title}
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
        {processSection.steps.map((step, i) => (
          <div>
            <div class="w-12 h-12 rounded-full bg-primary-dark text-white flex items-center justify-center font-hamilton-display text-xl font-bold mb-4">{i + 1}</div>
            <h3 class="text-lg font-bold mb-2">{step.title}</h3>
            <p class="text-sm leading-[24px] text-muted">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>
)}

<!-- Recent ADU Projects -->
{projects && projects.length > 0 && (
  <Section bg="white" padding="lg">
      <h2
        class="text-[40px] leading-[50px] mb-10"
      >
        {projectsTitle || `Recent ADU Projects in ${city}`}
      </h2>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => {
          const img = imageMap[project.imageKey] || serviceRoofing;
          return (
            <div class="group overflow-hidden border border-border">
              <div class="relative w-full overflow-hidden aspect-[4/3]">
                <Image
                  src={img}
                  alt={project.title}
                  width={600}
                  height={450}
                  class="h-full w-full object-cover transition-opacity duration-300 group-hover:opacity-85"
                  loading="lazy"
                />
                <div class="absolute bottom-3 left-3 rounded-full px-3 py-1 bg-[rgba(13,43,29,0.85)]">
                  <span class="text-xs font-semibold text-white">{project.sqft}</span>
                </div>
              </div>
              <div class="p-5">
                <h3 class="text-base font-bold mb-1">{project.title}</h3>
                <p class="text-sm text-muted">{project.location}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </Section>
)}

<!-- Regulations Section -->
{regulations && (
  <Section bg="cream" padding="md">
      <h2
        class="text-center text-[40px] leading-[50px] mb-4"
      >
        {regulations.title}
      </h2>
      <p class="text-center mx-auto text-base leading-[26px] text-muted max-w-[640px] mb-12">
        {regulations.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {regulations.items.map((item) => (
          <div class="p-6 text-center bg-white">
            <p class="font-hamilton-display text-[42px] font-bold text-primary-dark mb-2">{item.value}</p>
            <p class="text-sm font-semibold text-heading mb-1">{item.label}</p>
            <p class="text-xs text-muted leading-5">{item.description}</p>
          </div>
        ))}
      </div>
  </Section>
)}

<!-- Neighborhoods Section -->
{neighborhoods && (
  <Section bg="white" padding="lg">
      <h2
        class="text-[40px] leading-[50px] mb-4"
      >
        {neighborhoods.title}
      </h2>
      <p class="text-base leading-[26px] text-muted mb-10 max-w-[640px]">
        {neighborhoods.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {neighborhoods.items.map((hood) => (
          <div class="p-8 bg-cream">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[rgba(37,99,70,0.1)]">
              {hood.icon === 'home' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
              )}
              {hood.icon === 'people' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              )}
              {hood.icon === 'building' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
                  <line x1="12" y1="18" x2="12" y2="18"></line>
                  <line x1="8" y1="6" x2="16" y2="6"></line>
                  <line x1="8" y1="10" x2="16" y2="10"></line>
                  <line x1="8" y1="14" x2="16" y2="14"></line>
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold mb-2">{hood.title}</h3>
            <p class="text-sm leading-[24px] text-muted">
              {hood.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </Section>
)}

<!-- Mobile: Our Process + Resources -->
{mobileProcessResources && (
  <Section bg="dark" padding="sm" class="md:hidden">
      <h2 class="text-[28px] leading-[1.2] text-white mb-4">
        {mobileProcessResources.processTitle}
      </h2>
      <p class="text-sm leading-[24px] text-white-80 mb-6">
        {mobileProcessResources.processSummary}
      </p>
      <h2 class="text-[28px] leading-[1.2] text-white mb-4 mt-8">
        {mobileProcessResources.resourcesTitle}
      </h2>
      <div class="grid grid-cols-1 gap-4">
        {mobileProcessResources.nearbyLinks.map((link) => (
          <a href={link.href} class="p-5 block bg-white/[0.05]">
            <h3 class="text-base font-bold text-white mb-1">{link.title}</h3>
            <span class="text-xs font-semibold text-primary-dark">View Services &rarr;</span>
          </a>
        ))}
      </div>
      <div class="mt-6 grid grid-cols-1 gap-4">
        {mobileProcessResources.infoCards.map((card) => (
          <div class="p-5 bg-white/[0.05]">
            <h3 class="text-base font-bold text-white mb-2">{card.title}</h3>
            <p class="text-sm leading-[22px] text-white-80">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </Section>
)}

<!-- FAQ Section -->
{faqs && faqs.length > 0 && (
  <section class="w-full bg-cream">
    <div class="mx-auto max-w-[1170px] py-20 px-[15px]">
      <div class="flex flex-col items-start justify-between md:flex-row md:items-center gap-4 mb-10">
        <h2 class="text-[40px] leading-[50px] m-0">
          {faqTitle || `Common Questions About ${city} ADUs`}
        </h2>
        <p class="text-sm font-normal leading-[150%] text-heading text-right m-0 whitespace-normal md:whitespace-nowrap">
          Have more questions?{' '}
          <a href={PHONE_HREF} class="font-semibold text-heading no-underline">
            Call {PHONE_DISPLAY}
          </a>
        </p>
      </div>

      <div class="mx-auto max-w-full">
        {faqs.map((faq) => (
          <details
            class="group border-b border-border bg-transparent"
          >
            <summary class="flex cursor-pointer items-center justify-between list-none [&::-webkit-details-marker]:hidden py-5">
              <span class="text-sm font-normal leading-[24px] text-charcoal pr-4">
                {faq.question}
              </span>
              <span class="relative flex shrink-0 items-center justify-center w-6 h-6 text-charcoal">
                <IconPlus />
              </span>
            </summary>
            <div class="pb-5 pr-12">
              <p class="text-sm font-normal leading-[24px] text-charcoal opacity-70 m-0">
                {faq.answer}
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Contact / CTA Section — links back to hero form -->
{contact && (
  <section id="contact" class="w-full bg-heading py-20">
    <div class="mx-auto flex flex-col md:flex-row items-center max-w-[1170px] px-[15px] gap-[42px]">

      <!-- Left Column — Contact Info -->
      <div class="flex w-full flex-col md:w-1/2">
        <h2 class="text-[clamp(28px,4vw,40px)] leading-[1.2] text-white m-0 mb-4">
          {contact.title}
        </h2>
        <p class="text-base leading-[26px] text-white-80 mb-8">
          {contact.subtitle}
        </p>

        <div class="flex flex-col gap-4 mb-8">
          <div class="flex items-center gap-2.5">
            <div class="shrink-0 w-[17px] h-[17px]">
              <Image src={iconContactPhone} alt="" width={17} height={17} class="block w-full h-full object-contain" style="filter: brightness(0) invert(1);" />
            </div>
            <a href={PHONE_HREF} class="text-base font-semibold leading-[24px] text-white no-underline">
              {PHONE_DISPLAY}
            </a>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="shrink-0 w-4 h-[13px]">
              <Image src={iconContactEmail} alt="" width={16} height={13} class="block w-full h-full object-contain" style="filter: brightness(0) invert(1);" />
            </div>
            <a href="mailto:support@hamilton-exteriors.com" class="text-base font-semibold leading-[24px] text-white no-underline">
              support@hamilton-exteriors.com
            </a>
          </div>
          <div class="flex items-start gap-2.5">
            <div class="shrink-0 w-3 h-[18px] mt-[3px]">
              <Image src={iconContactClock} alt="" width={12} height={18} class="block w-full h-full object-contain" style="filter: brightness(0) invert(1);" />
            </div>
            <span class="text-base font-semibold leading-[24px] text-white">
              21634 Redwood Rd Unit F, Castro Valley, CA 94546
            </span>
          </div>
        </div>
      </div>

      <!-- Right Column — CTA to hero form -->
      <div class="flex w-full flex-col items-center md:w-1/2 text-center p-0">
        <div>
          <p class="font-hamilton-display text-[clamp(28px,4vw,40px)] font-normal text-white uppercase leading-[1.15] mb-4">
            Ready to Start?
          </p>
          <p class="text-base leading-[26px] text-white-80 mb-8">
            Fill out the form above or call us — we respond within 5 minutes.
          </p>
          <div class="flex flex-col gap-3 w-full max-w-[320px]">
            <a
              href="#quote"
              class="block w-full rounded-full text-center py-4 transition-opacity hover:opacity-90 bg-yellow text-heading font-hamilton-display text-base font-bold uppercase tracking-[0.04em] no-underline"
            >
              Get Your Consultation
            </a>
            <a
              href={PHONE_HREF}
              class="block w-full rounded-full text-center py-4 transition-opacity hover:opacity-90 border-2 border-white/30 text-white text-sm font-semibold no-underline"
            >
              Call {PHONE_DISPLAY}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<!-- More Resources (desktop) -->
{resources && (
  <section class="hidden lg:block w-full bg-heading py-20">
    <div class="mx-auto max-w-[1200px] px-5">
      <p class="text-xs font-semibold tracking-[2px] uppercase text-green-light mb-3">Related Resources</p>
      <h2
        class="text-[40px] leading-[50px] text-white mb-4"
      >
        {resources.title}
      </h2>
      <p class="text-base leading-[26px] text-white-80 mb-12 max-w-[640px]">
        {resources.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3 mb-12">
        {resources.nearbyLinks.map((link) => (
          <a href={link.href} class="p-6 block bg-white/[0.05]">
            <p class="text-xs font-semibold tracking-[1.5px] uppercase text-green-light mb-2">Nearby City</p>
            <h3 class="text-lg font-bold text-white mb-2">{link.title}</h3>
            <p class="text-sm leading-[22px] text-white-80 mb-3">{link.description}</p>
            <span class="text-sm font-semibold text-green-light">View Services &rarr;</span>
          </a>
        ))}
      </div>

      {resources.infoCards && resources.infoCards.length > 0 && (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {resources.infoCards.map((card) => (
            <div class="p-8 bg-white/[0.05]">
              <h3 class="text-lg font-bold text-white mb-3">{card.title}</h3>
              <p class="text-sm leading-[24px] text-white-80">
                {card.description}
              </p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<Footer slot="footer" />

<style>
  .hero-input {
    font-family: var(--font-dm-sans);
    font-size: 16px;
    font-weight: 400;
    line-height: 26px;
    color: var(--color-charcoal);
    background-color: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    padding: 12px;
    outline: none;
    transition: border-color 0.2s;
  }
  .hero-input::placeholder {
    color: var(--color-muted);
  }
  .hero-input:focus {
    border-color: var(--color-primary);
  }

  .contact-input {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    padding: 10px 16px;
    font-family: var(--font-dm-sans);
    font-size: 14px;
    color: var(--color-muted);
    outline: none;
    background-color: var(--color-white);
    transition: border-color 0.2s;
  }
  .contact-input::placeholder {
    color: var(--color-light);
  }
  .contact-input:focus {
    border-color: var(--color-primary);
  }

  /* FAQ accordion toggle */
  details[open] summary svg g path {
    d: path("M228,128a12,12,0,0,1-12,12H40a12,12,0,0,1,0-24H216A12,12,0,0,1,228,128Z");
  }

  /* Responsive headline scaling */
  @media (max-width: 1023px) {
    h1 {
      font-size: 42px !important;
      line-height: 52px !important;
    }
  }
  @media (max-width: 767px) {
    h1 {
      font-size: 32px !important;
      line-height: 42px !important;
    }
    h2 {
      font-size: 30px !important;
      line-height: 40px !important;
    }
  }
</style>
