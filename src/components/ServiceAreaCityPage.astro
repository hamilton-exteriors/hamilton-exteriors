---
import { Image } from 'astro:assets';
import { heroBg, serviceRoofing, serviceSiding, serviceWindows, serviceAdu, iconContactPhone, iconContactEmail, iconContactClock, iconContactMap } from '../lib/images';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import LogoSlider from './LogoSlider.astro';
import Footer from './Footer.astro';
import type { ServiceAreaCity } from '../lib/service-area-types';
import IconStar from './icons/IconStar.astro';
import IconCheck from './icons/IconCheck.astro';
import IconPlus from './icons/IconPlus.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';

interface Props {
  data: ServiceAreaCity;
}

const { data } = Astro.props;
const { city, county, countySlug, hero, reviews, pricingCards, whyBuildStats, trustedExperts, process: processSection, projects, projectsTitle, regulations, neighborhoods, mobileProcessResources, faqs, faqTitle, contact, resources, pricingLabel, pricingTitle } = data;

/** Map imageKey strings to actual imported images */
const imageMap: Record<string, ImageMetadata> = {
  serviceRoofing,
  serviceSiding,
  serviceWindows,
  serviceAdu,
  heroBg,
};
---

<AnnouncementBar />
<Navbar />

<!-- Breadcrumb -->
<nav class="w-full" style="background-color: var(--color-cream); border-bottom: 1px solid var(--color-border);">
  <div class="mx-auto flex items-center gap-2 px-5" style="max-width: 1294px; padding-top: 14px; padding-bottom: 14px;">
    <a href="/" style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">Home</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <a href="/service-areas" style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">Service Areas</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <a href={`/service-areas/${countySlug}`} style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); text-decoration: none;">{county}</a>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">/</span>
    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-heading); font-weight: 600;">{city}, CA</span>
  </div>
</nav>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hamilton-exteriors.com/" },
    { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://hamilton-exteriors.com/service-areas" },
    { "@type": "ListItem", "position": 3, "name": county, "item": `https://hamilton-exteriors.com/service-areas/${countySlug}` },
    { "@type": "ListItem", "position": 4, "name": `${city}, CA` }
  ]
})} />

<!-- Hero — shared component -->
<Hero
  headline={hero.headline}
  formTitle={hero.formTitle}
  formSubtitle={hero.formSubtitle}
  badges={hero.badges}
/>
<!-- END shared hero -->

<!-- Logo Slider + License -->
<LogoSlider />
<div class="w-full text-center" style="background-color: var(--color-white); padding: 16px 0;">
  <p style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); letter-spacing: 0.02em;">
    CA Contractor License #1078806
  </p>
</div>

<!-- Reviews Section -->
{reviews && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <!-- Section Label -->
      <div class="mb-4 flex items-center gap-2">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <IconStar size={18} fill="#FFDE21" class="h-[18px] w-[18px]" />
          ))}
        </div>
        <span style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.05em;">
          On Google Reviews
        </span>
      </div>

      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 40px;"
      >
        {reviews.sectionTitle}
      </h2>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <!-- Featured review -->
        <div class="lg:col-span-2 p-8" style="background-color: var(--color-heading);">
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <IconStar size={20} fill="#FFDE21" class="h-[20px] w-[20px]" />
            ))}
          </div>
          <p style="font-family: var(--font-dm-sans); font-size: 18px; line-height: 30px; color: rgba(255,255,255,0.92); margin-bottom: 24px;">
            "{reviews.featured.text}"
          </p>
          <div>
            <p style="font-family: var(--font-dm-sans); font-size: 16px; font-weight: 600; color: var(--color-white); margin-bottom: 2px;">{reviews.featured.name}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; color: rgba(255,255,255,0.8);">{reviews.featured.location}</p>
          </div>
        </div>

        <!-- Side reviews -->
        <div class="flex flex-col gap-6">
          {reviews.side.map((review) => (
            <div class="p-6" style="background-color: var(--color-white);">
              <div class="flex gap-0.5 mb-3">
                {Array.from({ length: 5 }).map(() => (
                  <IconStar size={16} fill="#FFDE21" class="h-[16px] w-[16px]" />
                ))}
              </div>
              <p style="font-family: var(--font-dm-sans); font-size: 14px; line-height: 24px; color: var(--color-muted); margin-bottom: 16px;">
                "{review.text}"
              </p>
              <div>
                <p style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-heading);">{review.name}</p>
                <p style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted);">{review.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Services / Pricing Cards -->
{pricingCards && pricingCards.length > 0 && (
  <section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <p style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary-dark); margin-bottom: 12px;">
        {pricingLabel || 'Our Services'}
      </p>
      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 48px;"
      >
        {pricingTitle || `ADU Services Built for ${city} Homeowners`}
      </h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {pricingCards.map((card) => (
          card.highlighted ? (
            <div class="pricing-card relative flex flex-col p-6" style="background-color: var(--color-heading);">
              {card.badge && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style={`background-color: ${card.badgeColor === 'yellow' ? 'var(--color-yellow)' : 'var(--color-primary-dark)'};`}>
                  <span style={`font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; text-transform: uppercase; color: ${card.badgeColor === 'yellow' ? 'var(--color-heading)' : 'var(--color-white)'}; letter-spacing: 0.05em;`}>{card.badge}</span>
                </div>
              )}
              <h3 style={`font-family: var(--font-oswald); font-size: 20px; font-weight: 700; color: var(--color-white); margin-bottom: 4px;${card.badge ? ' margin-top: 8px;' : ''}`}>{card.title}</h3>
              <p style="font-family: var(--font-dm-sans); font-size: 14px; color: rgba(255,255,255,0.8); margin-bottom: 16px;">{card.subtitle}</p>
              <p style="font-family: var(--font-oswald); font-size: 28px; font-weight: 700; color: var(--color-yellow); margin-bottom: 4px;">{card.price}</p>
              <p style="font-family: var(--font-dm-sans); font-size: 12px; color: rgba(255,255,255,0.8); margin-bottom: 20px;">{card.sqft}</p>
              <ul class="flex flex-col gap-2 mt-auto">
                {card.features.map(item => (
                  <li class="flex items-start gap-2">
                    <IconCheck size={16} stroke="#FFDE21" class="h-[16px] w-[16px] shrink-0 mt-1" />
                    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: rgba(255,255,255,0.85); line-height: 20px;">{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#contact" class="mt-6 block w-full rounded-lg py-3 text-center transition-opacity hover:opacity-90" style="background-color: var(--color-yellow); font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-heading);">
                Get a Quote
              </a>
            </div>
          ) : (
            <div class={`pricing-card flex flex-col p-6 ${card.badge ? 'relative' : ''}`} style="background-color: var(--color-white);">
              {card.badge && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style={`background-color: ${card.badgeColor === 'yellow' ? 'var(--color-yellow)' : 'var(--color-primary-dark)'};`}>
                  <span style={`font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; text-transform: uppercase; color: ${card.badgeColor === 'yellow' ? 'var(--color-heading)' : 'var(--color-white)'}; letter-spacing: 0.05em;`}>{card.badge}</span>
                </div>
              )}
              <h3 style={`font-family: var(--font-oswald); font-size: 20px; font-weight: 700; color: var(--color-heading); margin-bottom: 4px;${card.badge ? ' margin-top: 8px;' : ''}`}>{card.title}</h3>
              <p style="font-family: var(--font-dm-sans); font-size: 14px; color: var(--color-muted); margin-bottom: 16px;">{card.subtitle}</p>
              <p style="font-family: var(--font-oswald); font-size: 28px; font-weight: 700; color: var(--color-heading); margin-bottom: 4px;">{card.price}</p>
              <p style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); margin-bottom: 20px;">{card.sqft}</p>
              <ul class="flex flex-col gap-2 mt-auto">
                {card.features.map(item => (
                  <li class="flex items-start gap-2">
                    <IconCheck size={16} stroke="var(--color-primary)" class="h-[16px] w-[16px] shrink-0 mt-1" />
                    <span style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); line-height: 20px;">{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#contact" class="mt-6 block w-full rounded-lg py-3 text-center transition-opacity hover:opacity-90" style="background-color: var(--color-primary-dark); font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-white);">
                Get a Quote
              </a>
            </div>
          )
        ))}
      </div>
    </div>
  </section>
)}

<!-- Why Build an ADU Stats -->
{whyBuildStats && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 64px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        class="text-center"
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 16px;"
      >
        {whyBuildStats.title}
      </h2>
      <p class="text-center mx-auto" style="font-family: var(--font-dm-sans); font-size: 16px; line-height: 26px; color: var(--color-muted); max-width: 640px; margin-bottom: 48px;">
        {whyBuildStats.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {whyBuildStats.stats.map((stat) => (
          <div class="p-8 text-center" style="background-color: var(--color-white);">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full" style="background-color: rgba(37, 99, 70, 0.1);">
              {stat.icon === 'dollar' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"></line>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
              )}
              {stat.icon === 'trend' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              )}
              {stat.icon === 'document' && (
                <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              )}
            </div>
            <p style="font-family: var(--font-oswald); font-size: 36px; font-weight: 700; color: var(--color-heading); margin-bottom: 4px;">{stat.value}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 16px; font-weight: 600; color: var(--color-heading); margin-bottom: 8px;">{stat.label}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; line-height: 22px; color: var(--color-muted);">
              {stat.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Trusted ADU Experts -->
{trustedExperts && (
  <section class="w-full" style="background-color: var(--color-heading); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2
            style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-white); text-transform: uppercase; margin-bottom: 20px;"
          >
            {trustedExperts.title}
          </h2>
          {trustedExperts.paragraphs.map((p, i) => (
            <p style={`font-family: var(--font-dm-sans); font-size: 16px; line-height: 30px; color: rgba(255,255,255,0.8); margin-bottom: ${i === trustedExperts.paragraphs.length - 1 ? '32' : '24'}px;`}>
              {p}
            </p>
          ))}
          <a
            href={trustedExperts.ctaHref}
            class="inline-block transition-opacity hover:opacity-90"
            style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; line-height: 24px; background-color: var(--color-yellow); color: var(--color-heading); border-radius: 8px; padding: 12px 28px;"
          >
            {trustedExperts.ctaText}
          </a>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {trustedExperts.stats.map((stat) => (
            <div class="p-6 text-center" style="background-color: rgba(255,255,255,0.08);">
              <p style="font-family: var(--font-oswald); font-size: 42px; font-weight: 700; color: var(--color-yellow);">{stat.value}</p>
              <p style="font-family: var(--font-dm-sans); font-size: 14px; color: rgba(255,255,255,0.8);">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Our Process (desktop) -->
{processSection && (
  <section class="hidden lg:block w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <p style="font-family: var(--font-dm-sans); font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-primary-dark); margin-bottom: 12px;">HOW IT WORKS</p>
      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 48px;"
      >
        {processSection.title}
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
        {processSection.steps.map((step, i) => (
          <div>
            <div style="width: 48px; height: 48px; border-radius: 50%; background-color: var(--color-primary-dark); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-family: var(--font-oswald); font-size: 20px; font-weight: 700; margin-bottom: 16px;">{i + 1}</div>
            <h3 style="font-family: var(--font-oswald); font-size: 18px; font-weight: 700; color: var(--color-heading); margin-bottom: 8px;">{step.title}</h3>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; line-height: 24px; color: var(--color-muted);">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Recent ADU Projects -->
{projects && projects.length > 0 && (
  <section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 40px;"
      >
        {projectsTitle || `Recent ADU Projects in ${city}`}
      </h2>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => {
          const img = imageMap[project.imageKey] || serviceRoofing;
          return (
            <div class="group overflow-hidden" style="border: 1px solid var(--color-border);">
              <div class="relative w-full overflow-hidden" style="aspect-ratio: 4/3;">
                <Image
                  src={img}
                  alt={project.title}
                  width={600}
                  height={450}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute bottom-3 left-3 rounded-full px-3 py-1" style="background-color: rgba(13, 43, 29, 0.85);">
                  <span style="font-family: var(--font-dm-sans); font-size: 12px; font-weight: 600; color: var(--color-white);">{project.sqft}</span>
                </div>
              </div>
              <div class="p-5">
                <h3 style="font-family: var(--font-oswald); font-size: 16px; font-weight: 700; color: var(--color-heading); margin-bottom: 4px;">{project.title}</h3>
                <p style="font-family: var(--font-dm-sans); font-size: 14px; color: var(--color-muted);">{project.location}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}

<!-- Regulations Section -->
{regulations && (
  <section class="w-full" style="background-color: var(--color-cream); padding: 64px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        class="text-center"
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 16px;"
      >
        {regulations.title}
      </h2>
      <p class="text-center mx-auto" style="font-family: var(--font-dm-sans); font-size: 16px; line-height: 26px; color: var(--color-muted); max-width: 640px; margin-bottom: 48px;">
        {regulations.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {regulations.items.map((item) => (
          <div class="p-6 text-center" style="background-color: var(--color-white);">
            <p style="font-family: var(--font-oswald); font-size: 42px; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 8px;">{item.value}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-heading); margin-bottom: 4px;">{item.label}</p>
            <p style="font-family: var(--font-dm-sans); font-size: 12px; color: var(--color-muted); line-height: 20px;">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Neighborhoods Section -->
{neighborhoods && (
  <section class="w-full" style="background-color: var(--color-white); padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2
        style="font-family: var(--font-oswald); font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: var(--color-heading); text-transform: uppercase; margin-bottom: 16px;"
      >
        {neighborhoods.title}
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 16px; line-height: 26px; color: var(--color-muted); margin-bottom: 40px; max-width: 640px;">
        {neighborhoods.subtitle}
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {neighborhoods.items.map((hood) => (
          <div class="p-8" style="background-color: var(--color-cream);">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full" style="background-color: rgba(37, 99, 70, 0.1);">
              {hood.icon === 'home' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
              )}
              {hood.icon === 'people' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
