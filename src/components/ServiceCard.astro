---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface SubLink {
  name: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  href: string;
  city: string;
  ctaLabel?: string;
  subLinks?: SubLink[];
  class?: string;
}

const {
  title,
  description,
  image,
  href,
  city,
  ctaLabel,
  subLinks = [],
  class: className = '',
} = Astro.props;

const effectiveCtaLabel = ctaLabel || `Explore ${title.toLowerCase()}`;
---

<article class={`service-card flex flex-col rounded-[6px] border border-black/6 bg-white overflow-hidden ${className}`}>
  <a href={href} class="service-card-media block w-full overflow-hidden no-underline">
    <Image
      src={image}
      alt={`${title} services by Hamilton Exteriors in ${city}`}
      width={566}
      height={292}
      class="block aspect-566/292 h-auto w-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="mb-2 text-2xl leading-[1.2] font-normal tracking-[0.01em]">
      <a href={href} class="text-heading no-underline transition-opacity hover:opacity-85">
        {title}
      </a>
    </h3>
    <p class="mb-4 text-[0.9375rem] leading-[1.55] text-muted">
      {description}
    </p>
    {subLinks.length > 0 && (
      <ul class="mb-4 flex flex-wrap gap-1.5 list-none p-0">
        {subLinks.map((sub) => (
          <li>
            <a
              href={sub.href}
              class="inline-block rounded-full border border-primary/25 bg-cream px-3 py-1 font-satoshi text-[0.75rem] font-medium text-heading no-underline transition-opacity hover:opacity-80"
            >
              {sub.name}
            </a>
          </li>
        ))}
      </ul>
    )}
    <div class="mt-auto pt-1">
      <a
        href={href}
        class="inline-flex items-center gap-1.5 font-satoshi text-[0.8125rem] font-semibold tracking-[0.04em] text-primary uppercase no-underline transition-opacity hover:opacity-80"
      >
        {effectiveCtaLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</article>

<style>
  .service-card {
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .service-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
  }
  .service-card-media {
    transition: opacity 0.2s ease;
  }
  .service-card-media:hover {
    opacity: 0.9;
  }
  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .service-card-media {
      transition: none;
    }
  }
</style>
