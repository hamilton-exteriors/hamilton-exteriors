---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  href: string;
  city: string;
  class?: string;
}

const { title, description, image, href, city, class: className = '' } = Astro.props;
---

<a href={href} class={`service-card ${className}`}>
  <div class="w-full overflow-hidden">
    <Image
      src={image}
      alt={`${title} services by Hamilton Exteriors in ${city}`}
      width={566}
      height={292}
      class="block aspect-566/292 h-auto w-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="pt-4">
    <h3
      class="mb-1.5 text-2xl leading-[1.3] font-normal tracking-[0.01em]"
    >
      {title}
    </h3>
    <p class="text-base/normal text-muted">
      {description}
    </p>
  </div>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }
  .service-card:hover {
    opacity: 0.85;
  }
</style>
