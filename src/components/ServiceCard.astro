---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  href: string;
  city: string;
  class?: string;
}

const { title, description, image, href, city, class: className = '' } = Astro.props;
---

<a href={href} class={`service-card ${className}`}>
  <div class="w-full overflow-hidden">
    <Image
      src={image}
      alt={`${title} services by Hamilton Exteriors in ${city}`}
      width={566}
      height={292}
      style="width: 100%; height: auto; aspect-ratio: 566 / 292; object-fit: cover; display: block;"
      loading="lazy"
    />
  </div>
  <div style="padding-top: 16px;">
    <h3
      style="font-family: var(--font-oswald); font-size: 1.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 6px; color: var(--color-heading); text-transform: uppercase;"
    >
      {title}
    </h3>
    <p style="font-size: 0.875rem; line-height: 1.5; color: var(--color-muted);">
      {description}
    </p>
  </div>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }
  .service-card:hover {
    opacity: 0.85;
  }
</style>
