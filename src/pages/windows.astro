---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
import Difference from '../components/Difference.astro';
import Financing from '../components/Financing.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Projects from '../components/Projects.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';
import { heroWindows, windowDoubleHung, windowCasement, windowSliding, windowBay, windowPicture, windowGarden } from '../lib/images';

const windowStyles = [
  {
    title: 'Single Hung',
    image: windowDoubleHung,
    description: "A single-hung window features a fixed upper sash and a movable lower sash that slides vertically. It's space-efficient, easy to use, and offers great ventilation with a classic, versatile design.",
  },
  {
    title: 'Single Slider',
    image: windowCasement,
    description: "A single slider window has one fixed pane and one sliding pane for easy horizontal operation. It's space-efficient, versatile, and offers excellent ventilation with a modern look.",
  },
  {
    title: 'Sliding Glass Doors',
    image: windowSliding,
    description: 'A sliding glass door features large glass panels that glide smoothly on tracks, offering easy access, natural light, and a sleek, space-saving design.',
  },
  {
    title: 'Picture Windows',
    image: windowBay,
    description: 'A picture window is a large, fixed-pane window that provides expansive views and abundant natural light. Its clean, modern design enhances any space while improving energy efficiency.',
  },
  {
    title: 'Double Hung',
    image: windowPicture,
    description: 'A double-hung window has two movable sashes that slide vertically, offering versatile ventilation and easy cleaning. Its classic design fits a variety of architectural styles.',
  },
  {
    title: 'Casement Windows',
    image: windowGarden,
    description: 'A casement window features a single sash that opens outward on side hinges, operated by a crank mechanism. It provides excellent ventilation, unobstructed views, and a tight seal for superior energy efficiency. Perfect for modern and traditional styles alike.',
  },
];
---

<Layout
  title="Energy-Efficient Windows in Castro Valley, CA | Hamilton Exteriors"
  description="Hamilton Exteriors provides top-rated window installation in Castro Valley. Single hung, double hung, sliding, casement, and more."
>
  <AnnouncementBar />
  <Navbar />
  <Hero
    headline="We are the Best Window Company in the Bay Area"
    formTitle="Get A FREE Window Quote"
    formSubtitle="We'll contact you in 3-5 minutes to schedule a FREE Window inspection."
    ctaText="Call Now (650) 977-3351"
    heroImage={heroWindows}
  />
  <LogoSlider />
  <Reviews />
  <CTA />
  <ReviewLogos />

  <!-- Window Styles Offered -->
  <section class="w-full bg-cream">
    <div class="mx-auto max-w-[1294px] px-5 py-20">
      <h2
        class="mb-4 text-center"
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-size: 40px; line-height: 50px; letter-spacing: 0px; font-weight: 400; color: rgb(13, 43, 29);"
      >
        Window Styles Offered
      </h2>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {windowStyles.map((style, i) => (
          <div class:list={["overflow-hidden rounded-2xl bg-white shadow-sm", i >= 3 && "hidden sm:block"]}>
            <div class="h-[240px] sm:h-[362px] w-full overflow-hidden">
              <Image
                src={style.image}
                alt={style.title}
                width={566}
                height={362}
                class="h-full w-full object-fill"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3
                class="mb-2"
                style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 18px; font-weight: 800; line-height: 24px;"
              >
                {style.title}
              </h3>
              <p style="font-size: 14px; line-height: 150%; color: rgb(104, 104, 105);">
                {style.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Difference />
  <Projects />
  <div class="hidden lg:block w-full text-center" style="background-color: rgb(255, 222, 33); padding: 14px 0;">
    <a href="#contact" style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; color: rgb(13, 43, 29); text-decoration: none;">Schedule a FREE Inspection &rarr;</a>
  </div>
  <Financing />
  <FAQ />
  <ContactUs />
  <Footer />
</Layout>
