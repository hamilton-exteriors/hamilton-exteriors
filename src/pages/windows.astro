---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/windows';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Windows', item: `${siteUrl}/windows` },
  ],
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/windows#service`,
  name: 'Windows',
  description: 'Energy-efficient window replacement across the Bay Area. Double hung, casement, sliding, bay, and picture windows. 50-year warranty, licensed and insured.',
  url: `${siteUrl}/windows`,
  serviceType: ['Window Replacement', 'Window Installation', 'Energy-Efficient Windows'],
  provider: { '@type': 'GeneralContractor', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'County', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '400',
    highPrice: '1500',
    unitText: 'per window',
    description: 'Window replacement cost depends on size, style, and glass options',
  },
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/windows#webpage`,
  url: `${siteUrl}/windows`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/windows#service` },
  inLanguage: 'en-US',
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
