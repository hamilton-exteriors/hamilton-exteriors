---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/additions';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Additions', item: `${siteUrl}/additions` },
  ],
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/additions#service`,
  name: 'Home Additions',
  description: 'Bay Area home additions, second stories, room extensions, and full remodels. Design, structural engineering, permits, and construction under one roof.',
  url: `${siteUrl}/additions`,
  serviceType: ['Second Story Addition', 'Room Addition', 'Home Remodel', 'Home Extension'],
  provider: { '@type': 'GeneralContractor', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'County', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '200',
    highPrice: '500',
    unitText: 'per square foot',
    description: 'Home addition cost depends on scope, finishes, and structural requirements',
  },
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/additions#webpage`,
  url: `${siteUrl}/additions`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/additions#service` },
  inLanguage: 'en-US',
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
