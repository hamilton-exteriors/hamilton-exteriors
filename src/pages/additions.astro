---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/additions';

const siteUrl = 'https://hamilton-exteriors.com';
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/additions#webpage`,
  url: `${siteUrl}/additions`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/additions#service` },
  inLanguage: 'en-US',
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.local-context p:first-of-type', 'details:first-of-type p', 'h2 + p'] },
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[webPageJsonLd]}>
  <ServicePage data={data} />
</Layout>
