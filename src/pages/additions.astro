---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/additions';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Additions', item: `${siteUrl}/additions` },
  ],
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero jsonLd={breadcrumbJsonLd}>
  <ServicePage data={data} />
</Layout>
