---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { logoNav, heroBg, ctaAssistant, financingHouse } from '../lib/images';
---

<Layout
  noindex
  title="Get Your Free Estimate | Hamilton Exteriors"
  description="Complete our quick quiz to get a free estimate for your ADU, home addition, or garage conversion project in Castro Valley, CA."
>

<!-- Header with logo and progress -->
<div class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm">
  <div class="mx-auto max-w-5xl px-4 py-3">
    <div class="flex flex-col items-center gap-3">
      <a href="/">
        <Image
          src={logoNav}
          alt="Hamilton Exteriors"
          width={469}
          height={194}
          class="h-10 w-auto sm:h-12"
          loading="eager"
        />
      </a>

      <!-- Progress bar -->
      <div class="w-full max-w-md">
        <div class="mb-2 flex items-center justify-between">
          <span class="text-xs font-medium text-gray-500">Project Details</span>
          <span class="text-xs font-semibold text-primary">Step 1 of 6</span>
        </div>
        <div class="relative h-1.5 w-full overflow-hidden rounded-full bg-gray-200">
          <div
            class="h-full rounded-full bg-primary transition-all"
            style="width: 16%;"
          ></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main content -->
<div class="mx-auto max-w-4xl px-4 py-8 pb-28">
  <div class="space-y-6">

    <!-- Heading -->
    <div class="mb-8 space-y-3 text-center">
      <h1
        class="text-3xl/tight font-bold text-charcoal sm:text-4xl"
      >
        COMPLETE AND GET YOUR FREE ESTIMATE
      </h1>
      <p class="text-base text-gray-500">
        Firstly, what type of addition would you like to add?
      </p>
    </div>

    <!-- Options grid -->
    <div class="grid gap-3 sm:gap-4">

      <!-- Option 1: Detached ADU -->
      <a
        href="tel:+16509773351"
        class="group flex min-h-[100px] items-center overflow-hidden rounded-[4px] border-2 border-gray-200 bg-white shadow-sm transition-all duration-300 hover:border-green-600/50 hover:shadow-md active:scale-[0.98]"
      >
        <div class="h-full w-24 shrink-0 sm:w-32">
          <Image
            src={heroBg}
            alt="Detached ADU built by Hamilton Exteriors in the Bay Area"
            width={400}
            height={300}
            class="size-full min-h-[100px] object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex flex-1 items-center justify-between p-4">
          <div class="flex-1 pr-3">
            <h3 class="text-base font-semibold text-charcoal sm:text-lg">Detached ADU</h3>
            <p class="mt-1 text-sm text-gray-500">Complete structure from main home</p>
          </div>
          <div class="size-5 shrink-0 rounded-full border-2 border-gray-300 transition-colors group-hover:border-green-600"></div>
        </div>
      </a>

      <!-- Option 2: Attached ADU -->
      <a
        href="tel:+16509773351"
        class="group flex min-h-[100px] items-center overflow-hidden rounded-[4px] border-2 border-gray-200 bg-white shadow-sm transition-all duration-300 hover:border-green-600/50 hover:shadow-md active:scale-[0.98]"
      >
        <div class="h-full w-24 shrink-0 sm:w-32">
          <Image
            src={ctaAssistant}
            alt="Attached ADU addition by Hamilton Exteriors in the Bay Area"
            width={400}
            height={300}
            class="size-full min-h-[100px] object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex flex-1 items-center justify-between p-4">
          <div class="flex-1 pr-3">
            <h3 class="text-base font-semibold text-charcoal sm:text-lg">Attached ADU</h3>
            <p class="mt-1 text-sm text-gray-500">Connected to existing home</p>
          </div>
          <div class="size-5 shrink-0 rounded-full border-2 border-gray-300 transition-colors group-hover:border-green-600"></div>
        </div>
      </a>

      <!-- Option 3: Second Story Addition -->
      <a
        href="tel:+16509773351"
        class="group flex min-h-[100px] items-center overflow-hidden rounded-[4px] border-2 border-gray-200 bg-white shadow-sm transition-all duration-300 hover:border-green-600/50 hover:shadow-md active:scale-[0.98]"
      >
        <div class="h-full w-24 shrink-0 sm:w-32">
          <Image
            src={financingHouse}
            alt="Second story addition by Hamilton Exteriors in the Bay Area"
            width={400}
            height={300}
            class="size-full min-h-[100px] object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex flex-1 items-center justify-between p-4">
          <div class="flex-1 pr-3">
            <h3 class="text-base font-semibold text-charcoal sm:text-lg">Second Story Addition</h3>
            <p class="mt-1 text-sm text-gray-500">Add a second floor to existing structure</p>
          </div>
          <div class="size-5 shrink-0 rounded-full border-2 border-gray-300 transition-colors group-hover:border-green-600"></div>
        </div>
      </a>

      <!-- Option 4: Garage Conversion -->
      <a
        href="tel:+16509773351"
        class="group flex min-h-[100px] items-center overflow-hidden rounded-[4px] border-2 border-gray-200 bg-white shadow-sm transition-all duration-300 hover:border-green-600/50 hover:shadow-md active:scale-[0.98]"
      >
        <div class="h-full w-24 shrink-0 sm:w-32">
          <Image
            src={heroBg}
            alt="Garage conversion by Hamilton Exteriors in the Bay Area"
            width={400}
            height={300}
            class="size-full min-h-[100px] object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex flex-1 items-center justify-between p-4">
          <div class="flex-1 pr-3">
            <h3 class="text-base font-semibold text-charcoal sm:text-lg">Garage Conversion</h3>
            <p class="mt-1 text-sm text-gray-500">Transform existing garage space</p>
          </div>
          <div class="size-5 shrink-0 rounded-full border-2 border-gray-300 transition-colors group-hover:border-green-600"></div>
        </div>
      </a>

      <!-- Option 5: Don't Know Yet -->
      <a
        href="tel:+16509773351"
        class="group flex min-h-[80px] items-center overflow-hidden rounded-[4px] border-2 border-gray-200 bg-white shadow-sm transition-all duration-300 hover:border-green-600/50 hover:shadow-md active:scale-[0.98]"
      >
        <div class="flex flex-1 items-center justify-between p-5">
          <div class="flex-1 pr-3">
            <h3 class="text-base font-semibold text-charcoal sm:text-lg">Don't Know Yet</h3>
            <p class="mt-1 text-sm text-gray-500">Need help deciding the best option for you</p>
          </div>
          <div class="size-5 shrink-0 rounded-full border-2 border-gray-300 transition-colors group-hover:border-green-600"></div>
        </div>
      </a>

    </div>

    <!-- Help link -->
    <div class="pt-2 text-center">
      <a
        href="tel:+16509773351"
        class="text-sm text-primary underline transition-colors hover:opacity-70"
      >
        Need help deciding the best option for you?
      </a>
    </div>
  </div>
</div>

<!-- Fixed bottom bar with Continue button -->
<div class="fixed inset-x-0 bottom-0 z-50 border-t border-gray-200 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto max-w-4xl p-4">
    <div class="flex gap-3">
      <a
        href="tel:+16509773351"
        class="flex min-h-[48px] flex-1 items-center justify-center gap-2 rounded-md bg-primary px-8 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:opacity-90"
      >
        Continue
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
      </a>
    </div>
  </div>
</div>

</Layout>

<style>
  body {
    background-color: rgb(250, 250, 250);
  }
</style>
