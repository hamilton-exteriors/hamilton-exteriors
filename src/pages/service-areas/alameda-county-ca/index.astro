---
import Layout from '../../../layouts/Layout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navbar from '../../../components/Navbar.astro';
import Hero from '../../../components/Hero.astro';
import LogoSlider from '../../../components/LogoSlider.astro';
import Reviews from '../../../components/Reviews.astro';
import ReviewLogos from '../../../components/ReviewLogos.astro';
import Services from '../../../components/Services.astro';
import CTA from '../../../components/CTA.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactUs from '../../../components/ContactUs.astro';
import Footer from '../../../components/Footer.astro';

const county = 'Alameda County';
const cities = [
  { name: 'Oakland', slug: '/service-areas/alameda-county-ca/oakland-ca' },
  { name: 'Fremont', slug: '/service-areas/alameda-county-ca/fremont-ca' },
  { name: 'Hayward', slug: '/service-areas/alameda-county-ca/hayward-ca' },
  { name: 'Berkeley', slug: '/service-areas/alameda-county-ca/berkeley-ca' },
  { name: 'San Leandro', slug: '/service-areas/alameda-county-ca/san-leandro-ca' },
];
---

<Layout
  title={`Trusted ADU Contractors in ${county}, CA | Hamilton Exteriors`}
  description={`Hamilton Exteriors provides expert roofing, siding, and window services throughout ${county}, CA. Get a free inspection today.`}
>
  <AnnouncementBar />
  <Navbar />
  <Hero
    formTitle={`Get a FREE Estimate in ${county}`}
    headline={`ADU Contractor in ${county}, CA`}
  />
  <LogoSlider />

  <!-- City Cards -->
  <section class="w-full bg-white py-20">
    <div class="mx-auto max-w-[1294px] px-5">
      <h2 class="mb-10 text-center font-['Playfair_Display'] text-[32px] font-semibold text-[rgb(28,28,28)] md:text-[44px]">
        Cities We Serve in {county}
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cities.map((city) => (
          <a href={city.slug} class="group rounded-2xl border border-gray-200 p-6 transition-shadow hover:shadow-lg">
            <div class="mb-4 h-40 w-full rounded-xl bg-gray-200"></div>
            <h3 class="font-['Playfair_Display'] text-xl font-semibold text-[rgb(28,28,28)]">{city.name}, CA</h3>
            <span class="mt-2 inline-block font-dm-sans text-sm font-semibold text-primary group-hover:underline">View Services &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Services />
  <Reviews />
  <ReviewLogos />

  <!-- Why Homeowners Choose - mobile/tablet content to match production -->
  <section class="w-full md:hidden" style="background-color: #f9f8f6; padding: 60px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: rgb(13, 43, 29); text-transform: uppercase; margin-bottom: 16px;">
        Why Homeowners Choose Hamilton Exteriors
      </h2>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Alameda County homeowners trust Hamilton Exteriors because we combine local expertise with proven construction methods. Our team understands the unique building codes across Oakland, Berkeley, Fremont, Hayward, and San Leandro — ensuring your ADU project moves smoothly from permits through final inspection.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        We handle every phase of your ADU project in-house, from architectural design and engineering to foundation, framing, electrical, plumbing, and finish work. No subcontractors means better quality control, clearer communication, and a single point of accountability throughout your build.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Our commitment to transparency means you'll always know where your project stands. We provide detailed written estimates, realistic timelines, and regular progress updates so there are never any surprises.
      </p>
    </div>
  </section>

  <section class="w-full md:hidden" style="background-color: #0d2b1d; padding: 60px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: white; text-transform: uppercase; margin-bottom: 16px;">
        Benefits of Building an ADU in Alameda County
      </h2>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgba(255,255,255,0.8); margin-bottom: 16px;">
        Alameda County is one of the Bay Area's most ADU-friendly jurisdictions. With streamlined permitting processes and strong rental demand, building an ADU is one of the smartest investments you can make as a homeowner.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgba(255,255,255,0.8); margin-bottom: 16px;">
        A well-built ADU can generate $2,000–$3,500 per month in rental income, or provide private living space for aging parents, adult children, or a home office. With property values continuing to rise across Alameda County, an ADU can add 20–35% to your home's overall value.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgba(255,255,255,0.8); margin-bottom: 16px;">
        California's ADU laws have removed many traditional barriers to construction, including reduced setback requirements, eliminated parking mandates near transit, and simplified permitting timelines. Hamilton Exteriors navigates these regulations daily, ensuring your project takes full advantage of every available benefit.
      </p>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="rounded-xl p-6" style="background-color: rgba(255,255,255,0.08);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 8px;">Rental Income</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 24px; color: rgba(255,255,255,0.7);">Generate $2,000–$3,500/month in passive income from your ADU investment.</p>
        </div>
        <div class="rounded-xl p-6" style="background-color: rgba(255,255,255,0.08);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 8px;">Property Value</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 24px; color: rgba(255,255,255,0.7);">Add 20–35% to your home's appraised value with a professionally built ADU.</p>
        </div>
        <div class="rounded-xl p-6" style="background-color: rgba(255,255,255,0.08);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 8px;">Multigenerational Living</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 24px; color: rgba(255,255,255,0.7);">House aging parents or adult children with privacy and independence on your property.</p>
        </div>
        <div class="rounded-xl p-6" style="background-color: rgba(255,255,255,0.08);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 8px;">$0 Down Financing</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 24px; color: rgba(255,255,255,0.7);">Start your ADU project with flexible financing and no upfront investment required.</p>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <FAQ />
  <ContactUs />
  <Footer />
</Layout>
