---
import Layout from '../../../layouts/Layout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navbar from '../../../components/Navbar.astro';
import LogoSlider from '../../../components/LogoSlider.astro';
import Footer from '../../../components/Footer.astro';

const city = 'Oakland';
const county = 'Alameda County';

const faqs = [
  {
    question: 'How long does it take to build an ADU in Oakland?',
    answer: 'A typical Oakland ADU project takes 6-10 months from design to completion. This includes 2-4 weeks for design, 60 days for permits (our guarantee), and 4-6 months for construction. Our streamlined process and local expertise help minimize delays.',
  },
  {
    question: 'How much does an ADU cost in Oakland?',
    answer: 'ADU costs in Oakland range from $60,000 for a Junior ADU to $350,000+ for a large detached unit. The final cost depends on size, design complexity, site conditions, and finishes. We offer $0 down financing and free consultations to help you understand all costs upfront.',
  },
  {
    question: 'Do I need a permit to build an ADU in Oakland?',
    answer: 'Yes, all ADUs in Oakland require building permits. The good news is Oakland has streamlined its ADU permitting process significantly. We handle the entire permit process for you and guarantee permit approval within 60 days.',
  },
  {
    question: 'What is the maximum size for an ADU in Oakland?',
    answer: 'In Oakland, detached ADUs can be up to 1,200 square feet. Attached ADUs can be up to 50% of the existing home\'s living area or 1,200 sq ft, whichever is less. Junior ADUs (JADUs) are limited to 500 square feet and must be within the existing home footprint.',
  },
  {
    question: 'Can I rent out my Oakland ADU?',
    answer: 'Absolutely. Oakland encourages ADU rentals as part of its housing strategy. There are no owner-occupancy requirements for properties with ADUs in Oakland. Many homeowners earn $2,000-$3,500+ per month renting their ADU, making it an excellent investment.',
  },
  {
    question: 'Does Oakland charge impact fees for ADUs?',
    answer: 'Oakland has waived most impact fees for ADUs under 750 square feet. For larger units, fees are significantly reduced compared to standard construction. This is one of the reasons Oakland is one of the most ADU-friendly cities in California.',
  },
];

const projects = [
  {
    title: 'Detached ADU - Modern Studio',
    location: 'Rockridge, Oakland',
    sqft: '650 sq ft',
    image: 'https://framerusercontent.com/images/hakr7OWoKe15ZF1PJ4Ckr7hRI.png',
  },
  {
    title: 'Two-Story ADU Build',
    location: 'Temescal, Oakland',
    sqft: '1,100 sq ft',
    image: 'https://framerusercontent.com/images/abwzIHTvES7vwiSos5d3WPfIaA.png',
  },
  {
    title: 'Garage Conversion ADU',
    location: 'Montclair, Oakland',
    sqft: '480 sq ft',
    image: 'https://framerusercontent.com/images/pzaFvzI3i6hTZpGQ93e3UdUGriU.png',
  },
  {
    title: 'Attached ADU Suite',
    location: 'Oakland Hills',
    sqft: '750 sq ft',
    image: 'https://framerusercontent.com/images/aGE7RTabo86d7bQllJ13VZdMVw4.png',
  },
  {
    title: 'Junior ADU Conversion',
    location: 'West Oakland',
    sqft: '450 sq ft',
    image: 'https://framerusercontent.com/images/i7BMps6r4h2wo0XMZKI0lLqZg4.png',
  },
  {
    title: 'Detached ADU - Family Unit',
    location: 'Jack London District',
    sqft: '1,200 sq ft',
    image: 'https://framerusercontent.com/images/hakr7OWoKe15ZF1PJ4Ckr7hRI.png',
  },
];
---

<Layout
  title={`Affordable ADU Contractors in ${city}, CA | Hamilton Exteriors`}
  description={`Hamilton Exteriors is Oakland's trusted ADU builder. From design and permits to construction — we handle every detail. $0 down financing available. Call for a free consultation!`}
>
  <AnnouncementBar />
  <Navbar />

  <!-- Breadcrumb -->
  <nav class="w-full" style="background-color: #f9f8f6; border-bottom: 1px solid #e8e5df;">
    <div class="mx-auto flex items-center gap-2 px-5" style="max-width: 1294px; padding-top: 14px; padding-bottom: 14px;">
      <a href="/" style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105); text-decoration: none;">Home</a>
      <span style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105);">/</span>
      <a href="/service-areas" style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105); text-decoration: none;">Service Areas</a>
      <span style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105);">/</span>
      <a href="/service-areas/alameda-county-ca" style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105); text-decoration: none;">{county}</a>
      <span style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105);">/</span>
      <span style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(13, 43, 29); font-weight: 500;">{city}, CA</span>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="quote" class="relative w-full overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://framerusercontent.com/images/i7BMps6r4h2wo0XMZKI0lLqZg4.png"
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(13, 43, 29, 0.92) 0%, rgba(13, 43, 29, 0.78) 100%);"></div>
    </div>

    <div
      class="relative mx-auto flex flex-col gap-10 px-5 lg:flex-row lg:items-start lg:gap-12"
      style="max-width: 1294px; padding-top: 50px; padding-bottom: 50px;"
    >
      <!-- Left Column -->
      <div class="flex flex-col items-start gap-6 lg:w-[55%] lg:py-6">
        <!-- Rating badge -->
        <div class="inline-flex items-center gap-2 rounded-full" style="background: rgba(255,255,255,0.12); padding: 8px 18px;">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <div class="relative h-[18px] w-[18px] shrink-0">
                <svg viewBox="0 0 24 24" fill="#FFDE21" class="h-full w-full">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
            ))}
          </div>
          <span
            class="text-white"
            style="font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase;"
          >
            50+ Five-Star Reviews
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="text-white"
          style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-size: 56px; line-height: 68px; letter-spacing: normal; font-weight: 400;"
        >
          Build Your Dream ADU in Oakland
        </h1>

        <!-- Subtitle -->
        <p
          class="text-white"
          style="font-family: 'DM Sans', sans-serif; font-size: 19px; line-height: 30px; opacity: 0.9; max-width: 520px;"
        >
          From permit to keys in hand — we handle every detail of your Oakland ADU project so you can focus on what matters.
        </p>

        <!-- Trust badges / bullets -->
        <div class="flex flex-col gap-3">
          {[
            '15+ years of Oakland ADU expertise',
            '$0 down financing available',
            'Design, permits & build — all in-house',
            '60-day Oakland permit guarantee',
          ].map((badge) => (
            <div class="flex items-center gap-3">
              <div class="flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full" style="background: rgba(255, 222, 33, 0.2);">
                <svg viewBox="0 0 20 20" class="h-[14px] w-[14px]">
                  <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#FFDE21" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
              </div>
              <span class="text-white" style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 24px; font-weight: 500;">{badge}</span>
            </div>
          ))}
        </div>

        <!-- CTA button -->
        <a
          href="tel:6509773351"
          class="inline-block transition-opacity hover:opacity-90"
          style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; line-height: 24px; background-color: rgb(255, 222, 33); color: rgb(13, 43, 29); border-radius: 8px; padding: 12px 28px;"
        >
          Call Us - (650) 977-3351
        </a>
      </div>

      <!-- Right Column — Lead Form -->
      <div class="w-full lg:w-[45%]">
        <div
          class="w-full"
          style="background: linear-gradient(rgb(255, 255, 255) 0%, rgb(153, 153, 153) 107%); border-radius: 30px;"
        >
          <div style="background-color: rgb(255, 255, 255); border-radius: 30px; padding: 30px 28px 28px;">
            <h2
              class="mb-1 text-center"
              style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT (FREE VERSION) Placeholder', sans-serif; font-size: 26px; line-height: 1.2; font-weight: 400; color: rgb(13, 43, 29);"
            >
              Get Your FREE ADU Consultation
            </h2>
            <p
              class="mb-5 text-center"
              style="font-family: 'Poppins', sans-serif; line-height: 26px; color: rgb(134, 134, 134); font-size: 14px;"
            >
              We'll contact you within 24 hours to discuss your ADU project.
            </p>

            <form action="/success" method="POST">
              <div class="flex flex-col gap-3">
                <input type="text" name="fullName" placeholder="Name" required class="hero-input w-full" />
                <div class="flex gap-3">
                  <div class="relative w-1/2">
                    <div class="flex overflow-hidden" style="border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 10px;">
                      <div class="flex items-center shrink-0" style="padding: 12px 0 12px 12px; width: 52px;">
                        <span style="font-family: 'Poppins', sans-serif; font-size: 16px; line-height: 26px; color: rgb(32, 26, 22);">+1</span>
                      </div>
                      <div style="width: 1px; margin-top: 8px; margin-bottom: 8px; background-color: rgba(0, 0, 0, 0.2);"></div>
                      <input
                        type="tel"
                        name="phone"
                        placeholder="Phone Number"
                        required
                        class="flex-1 border-none bg-transparent outline-none"
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 400; line-height: 26px; color: rgb(32, 26, 22); padding: 12px;"
                      />
                    </div>
                  </div>
                  <input type="email" name="email" placeholder="Email" required class="hero-input w-1/2" />
                </div>
                <input type="text" name="address" placeholder="Project Address" required class="hero-input w-full" />
                <textarea
                  name="message"
                  rows="3"
                  placeholder="Tell us about your ADU project — type, size, timeline?"
                  class="hero-input w-full resize-none"
                ></textarea>
                <label class="flex items-start gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    name="consent"
                    required
                    class="mt-0.5 h-4 w-4 shrink-0"
                    style="border-radius: 4px; border: 1px solid rgba(136, 136, 136, 0.2); background: rgba(187, 187, 187, 0.2);"
                  />
                  <span
                    class="italic"
                    style="font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 500; line-height: 17px; color: rgb(136, 136, 136);"
                  >
                    <strong>I agree to receive promotional messages sent via an autodialer, and this agreement isn't a condition of any purchase.</strong>
                    <br /><br />
                    <strong>I also agree to the <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Terms of Service</a> and <a href="/privacy-policy" class="underline" target="_blank" rel="noopener">Privacy Policy</a>. 4 Msgs/Month. Msg &amp; Data rates may apply. Text HELP for help or STOP to stop.</strong>
                  </span>
                </label>
                <button type="submit" class="mt-1 w-full" style="border-radius: 10px;">
                  <div class="w-full py-4" style="background-color: rgb(36, 99, 69); border-radius: 40px;">
                    <p class="text-center text-white uppercase" style="font-family: 'Poppins', sans-serif; font-size: 17px; font-weight: 700; line-height: 17px;">
                      Get My Free Consultation
                    </p>
                  </div>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Slider + License -->
  <LogoSlider />
  <div class="w-full text-center" style="background-color: #fff; margin-top: -40px; padding-bottom: 40px;">
    <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: rgb(104, 104, 105);">
      CA Contractor License #1082377
    </p>
  </div>

  <!-- Reviews Section -->
  <section class="w-full" style="background-color: #f9f8f6; padding: 105px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <!-- Section Label -->
      <div class="mb-4 flex items-center gap-2">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="#FFDE21">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <span style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; color: rgb(104, 104, 105); text-transform: uppercase; letter-spacing: 0.05em;">
          On Google Reviews
        </span>
      </div>

      <h2
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: rgb(13, 43, 29); text-transform: uppercase; margin-bottom: 40px;"
      >
        What Oakland Homeowners Say
      </h2>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <!-- Featured review -->
        <div class="lg:col-span-2 rounded-2xl p-8" style="background-color: rgb(13, 43, 29);">
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-[20px] w-[20px]" viewBox="0 0 24 24" fill="#FFDE21">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 18px; line-height: 30px; color: rgba(255,255,255,0.92); margin-bottom: 24px;">
            "Hamilton Exteriors built our detached ADU in Rockridge and we couldn't be happier. From the initial design consultation to the final walkthrough, their team was professional, communicative, and detail-oriented. They handled all the permits with the city and finished on schedule. Our ADU is now rented out and generating over $3,000/month in income. Best investment we've ever made."
          </p>
          <div>
            <p style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; color: white; margin-bottom: 2px;">Michael T.</p>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: rgba(255,255,255,0.6);">Rockridge, Oakland</p>
          </div>
        </div>

        <!-- Side reviews -->
        <div class="flex flex-col gap-6">
          <div class="rounded-2xl p-6" style="background-color: white; border: 1px solid #e8e5df;">
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: 5 }).map(() => (
                <svg class="h-[16px] w-[16px]" viewBox="0 0 24 24" fill="#FFDE21">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 26px; color: rgb(104, 104, 105); margin-bottom: 16px;">
              "They converted our garage into a beautiful ADU for my mother-in-law. The whole process was seamless and the quality of work exceeded our expectations."
            </p>
            <div>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: rgb(13, 43, 29);">Sarah L.</p>
              <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105);">Temescal, Oakland</p>
            </div>
          </div>

          <div class="rounded-2xl p-6" style="background-color: white; border: 1px solid #e8e5df;">
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: 5 }).map(() => (
                <svg class="h-[16px] w-[16px]" viewBox="0 0 24 24" fill="#FFDE21">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 26px; color: rgb(104, 104, 105); margin-bottom: 16px;">
              "Our two-story ADU in Montclair turned out amazing. Hamilton handled everything from permits to final inspection. Truly a turnkey experience."
            </p>
            <div>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: rgb(13, 43, 29);">David & Maria R.</p>
              <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgb(104, 104, 105);">Montclair, Oakland</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services / Pricing Cards -->
  <section class="w-full" style="background-color: #fff; padding: 105px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgb(36, 99, 69); margin-bottom: 12px;">
        Our Services
      </p>
      <h2
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 40px; line-height: 50px; font-weight: 400; letter-spacing: 0px; color: rgb(13, 43, 29); text-transform: uppercase; margin-bottom: 48px;"
      >
        ADU Services Built for Oakland Homeowners
      </h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Detached ADU -->
        <div class="pricing-card relative flex flex-col rounded-2xl p-6" style="background-color: rgb(13, 43, 29); border: 2px solid rgb(13, 43, 29);">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style="background-color: rgb(255, 222, 33);">
            <span style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; color: rgb(13, 43, 29); letter-spacing: 0.05em;">Most Popular</span>
          </div>
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 4px; margin-top: 8px;">Detached ADU</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 16px;">Standalone backyard unit</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 800; color: rgb(255, 222, 33); margin-bottom: 4px;">$180K - $350K</p>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 20px;">400 - 1,200 sq ft</p>
          <ul class="flex flex-col gap-2 mt-auto">
            {['Maximum privacy & flexibility', 'Full kitchen & bathroom', 'Highest rental income potential', 'Custom design options'].map(item => (
              <li class="flex items-start gap-2">
                <svg class="h-[16px] w-[16px] shrink-0 mt-1" viewBox="0 0 20 20"><path d="M16.667 5L7.5 14.167L3.333 10" stroke="#FFDE21" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <span style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgba(255,255,255,0.85); line-height: 20px;">{item}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class="mt-6 block w-full rounded-lg py-3 text-center transition-opacity hover:opacity-90" style="background-color: rgb(255, 222, 33); font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: rgb(13, 43, 29);">
            Get a Quote
          </a>
        </div>

        <!-- Attached ADU -->
        <div class="pricing-card flex flex-col rounded-2xl p-6" style="background-color: white; border: 1px solid #e8e5df;">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: rgb(13, 43, 29); margin-bottom: 4px;">Attached ADU</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: rgb(104, 104, 105); margin-bottom: 16px;">Connected to your home</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 800; color: rgb(13, 43, 29); margin-bottom: 4px;">$150K - $280K</p>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgb(104, 104, 105); margin-bottom: 20px;">400 - 1,200 sq ft</p>
          <ul class="flex flex-col gap-2 mt-auto">
            {['Shared wall with main home', 'Lower construction costs', 'Separate entrance', 'Ideal for family members'].map(item => (
              <li class="flex items-start gap-2">
                <svg class="h-[16px] w-[16px] shrink-0 mt-1" viewBox="0 0 20 20"><path d="M16.667 5L7.5 14.167L3.333 10" stroke="rgb(36, 99, 69)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <span style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgb(104, 104, 105); line-height: 20px;">{item}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class="mt-6 block w-full rounded-lg py-3 text-center transition-opacity hover:opacity-90" style="background-color: rgb(36, 99, 69); font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: white;">
            Get a Quote
          </a>
        </div>

        <!-- Junior ADU -->
        <div class="pricing-card relative flex flex-col rounded-2xl p-6" style="background-color: white; border: 1px solid #e8e5df;">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1" style="background-color: rgb(36, 99, 69);">
            <span style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; color: white; letter-spacing: 0.05em;">Best Value</span>
          </div>
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: rgb(13, 43, 29); margin-bottom: 4px; margin-top: 8px;">Junior ADU</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: rgb(104, 104, 105); margin-bottom: 16px;">Within existing home</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 800; color: rgb(13, 43, 29); margin-bottom: 4px;">$60K - $120K</p>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgb(104, 104, 105); margin-bottom: 20px;">Up to 500 sq ft</p>
          <ul class="flex flex-col gap-2 mt-auto">
            {['Most affordable option', 'Fastest build time', 'Minimal site work needed', 'Great starter rental'].map(item => (
              <li class="flex items-start gap-2">
