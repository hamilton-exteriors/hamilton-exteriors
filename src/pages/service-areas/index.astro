---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import LogoSlider from '../../components/LogoSlider.astro';
import ContactUs from '../../components/ContactUs.astro';
import Reviews from '../../components/Reviews.astro';
import Footer from '../../components/Footer.astro';
import { areaOakland, areaFremont, areaHayward, areaBerkeley, areaSanLeandro } from '../../lib/images';

const counties = [
  { name: 'Alameda County, CA', slug: '/service-areas/alameda-county-ca', image: areaOakland },
  { name: 'Contra Costa County, CA', slug: '/service-areas/contra-costa-county-ca', image: areaFremont },
  { name: 'Napa County, CA', slug: '/service-areas/napa-county-ca', image: areaHayward },
  { name: 'Santa Clara County, CA', slug: '/service-areas/santa-clara-county-ca', image: areaBerkeley },
  { name: 'Marin County, CA', slug: '/service-areas/marin-county-ca', image: areaSanLeandro },
];
---

<Layout
  title="Service Areas for ADU Contractor in Castro valley, CA | Hamilton Exteriors"
  description="Hamilton Exteriors serves the entire Bay Area. Find your local service area for expert ADU construction, roofing, siding, and window services."
  includeMapbox
>
  <AnnouncementBar />
  <Navbar />
  <Hero
    formTitle="Get a FREE QUOTE"
    headline="Service Areas  ADU Contractor  Castro Valley"
  />
  <LogoSlider />

  <!-- Locations Grid — matches production -->
  <section id="service" class="w-full" style="padding: 79px 0;">
    <div class="mx-auto max-w-[1170px] px-4">
      <p style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgb(13, 43, 29); margin: 0 0 32px 0;">
        LOCATIONS
      </p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {counties.map((county) => (
          <a href={county.slug} class="county-card group">
            <div class="w-full overflow-hidden" style="border-radius: 12px;">
              <Image
                src={county.image}
                alt={county.name}
                width={540}
                height={312}
                style="width: 100%; height: auto; aspect-ratio: 540 / 312; object-fit: cover; display: block;"
                loading="lazy"
              />
            </div>
            <div style="padding: 16px 0 0;">
              <h3
                style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 18px; font-weight: 600; line-height: 1.4; color: rgb(13, 43, 29); margin: 0 0 8px;"
              >
                {county.name}
              </h3>
              <span style="font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; color: rgb(37, 99, 70);" class="group-hover:underline">
                Explore Service Area &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactUs />
  <Reviews />
  <Footer />
</Layout>

<style>
  .county-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .county-card:hover img {
    transform: scale(1.03);
    transition: transform 0.3s ease;
  }
</style>
