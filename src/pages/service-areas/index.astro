---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import LogoSlider from '../../components/LogoSlider.astro';
import ContactUs from '../../components/ContactUs.astro';
import Reviews from '../../components/Reviews.astro';
import Footer from '../../components/Footer.astro';
import Services from '../../components/Services.astro';
import {
  pageTitle, pageDescription, heroHeadline, heroFormTitle, counties,
} from '../../data/service-areas-index';

const siteUrl = 'https://hamilton-exteriors.com';

const itemListJsonLd = {
  '@type': 'ItemList',
  name: 'Hamilton Exteriors Service Areas',
  itemListElement: counties.map((county, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: county.name,
    item: `${siteUrl}${county.slug}`,
  })),
};

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${siteUrl}/service-areas` },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  includeMapbox
  jsonLd={[itemListJsonLd, breadcrumbJsonLd]}
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />
  <Hero
    formTitle={heroFormTitle}
    headline={heroHeadline}
  />
  <LogoSlider />

  <!-- Stats Strip -->
  <section class="w-full bg-heading py-10">
    <div class="mx-auto grid max-w-[1170px] grid-cols-2 gap-6 px-5 text-center md:grid-cols-4">
      <div>
        <p class="font-hamilton-display text-[clamp(32px,5vw,48px)] leading-none font-normal text-yellow uppercase">6</p>
        <p class="mt-1.5 text-[0.8125rem] text-white-65">Counties Served</p>
      </div>
      <div>
        <p class="font-hamilton-display text-[clamp(32px,5vw,48px)] leading-none font-normal text-white uppercase">500+</p>
        <p class="mt-1.5 text-[0.8125rem] text-white-65">Projects Completed</p>
      </div>
      <div>
        <p class="font-hamilton-display text-[clamp(32px,5vw,48px)] leading-none font-normal text-white uppercase">50-Year</p>
        <p class="mt-1.5 text-[0.8125rem] text-white-65">Warranty Coverage</p>
      </div>
      <div>
        <p class="font-hamilton-display text-[clamp(32px,5vw,48px)] leading-none font-normal text-white uppercase">4.8</p>
        <p class="mt-1.5 text-[0.8125rem] text-white-65">Google Rating</p>
      </div>
    </div>
  </section>

  <!-- Locations Grid -->
  <section id="service" class="w-full py-20">
    <div class="mx-auto max-w-[1170px] px-5">
      <p class="text-label m-0 mb-3 text-primary">
        Service Areas
      </p>
      <h2 class="m-0 mb-3 text-[clamp(28px,5vw,44px)] leading-[1.15]">
        6 Counties. 47 Cities. One Standard.
      </h2>
      <p class="m-0 mb-12 max-w-[55ch] text-base leading-[1.7] text-muted">
        Licensed, bonded, and insured across the Bay Area. Find your county below to see what we're building near you.
      </p>
      <div class="county-grid">
        {counties.map((county) => (
          <a href={county.slug} class="county-card group">
            <div class="county-card__img relative w-full overflow-hidden rounded-[4px]">
              <Image
                src={county.image}
                alt={`Hamilton Exteriors service area in ${county.name}, California`}
                width={540}
                height={312}
                class="block aspect-540/312 h-auto w-full object-cover"
                loading="lazy"
              />
              <div class="county-card__overlay">
                <span class="flex items-center gap-1.5 font-satoshi text-xs font-bold tracking-[0.15em] text-white uppercase">
                  {county.cities.length > 0 ? `View ${county.cities.length} Cities` : 'View Service Area'} <span>&rarr;</span>
                </span>
              </div>
            </div>
            <div class="pt-3.5">
              <h3
                class="m-0 mb-1.5 text-[clamp(1.25rem,3vw,1.5rem)]"
              >
                {county.name}
              </h3>
              {county.cities.length > 0 && (
                <p style="font-family: var(--font-dm-sans); font-size: 0.8125rem; line-height: 1.5; color: var(--color-muted); margin: 0;">
                  {county.cities.join(' · ')}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Services />

  <ContactUs />
  <Reviews />
  <Footer slot="footer" />
</Layout>

<style>
  .county-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .county-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .county-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    /* First 3 cards: each takes 2 cols = fills 6 */
    .county-card:nth-child(-n+3) {
      grid-column: span 2;
    }
    /* Last 2 cards: each takes 3 cols = fills 6, centered */
    .county-card:nth-child(n+4) {
      grid-column: span 3;
    }
  }
  .county-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .county-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(13, 43, 29, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .county-card:hover .county-card__overlay {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .county-card, .county-card__img img, .county-card__overlay {
      transition: none !important;
    }
  }
</style>
