---
/**
 * Catch-all route for service area pages.
 * All content comes from Ghost CMS. No fallbacks.
 *
 * Handles:
 *   /service-areas/{countySlug}                     → County page
 *   /service-areas/{countySlug}/{city}              → City page
 *   /service-areas/{countySlug}/{city}/{service}    → City+service page
 *   /service-areas/{countySlug}/{service}           → County+service page
 */
import Layout from '../../layouts/Layout.astro';
import CountyPage from '../../components/CountyPage.astro';
import ServiceAreaCityPage from '../../components/ServiceAreaCityPage.astro';
import ServicePage from '../../components/ServicePage.astro';
import { getServiceAreaCity, getServiceAreaCounty, getServiceAreaCityService } from '../../lib/ghost';
import { resolveImages } from '../../lib/image-map';
import type { ServiceAreaCity } from '../../lib/service-area-types';
import type { CountyPageData } from '../../lib/county-page-types';
import type { CityServicePageData } from '../../lib/city-service-types';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/service-areas');

const segments = slug.split('/');

const SERVICE_SLUGS = ['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions'];

let pageType: 'county' | 'city' | 'cityService' | 'countyService' | null = null;
let cityData: ServiceAreaCity | null = null;
let countyData: CountyPageData | null = null;
let cityServiceData: CityServicePageData | null = null;
let countyServiceData: CityServicePageData | null = null;

if (segments.length === 3) {
  // City+service page: /service-areas/{county}/{city}/{service}
  const [countySlug, citySlug, serviceSlug] = segments;
  pageType = 'cityService';
  cityServiceData = await getServiceAreaCityService(countySlug, citySlug, serviceSlug);
  if (!cityServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2 && SERVICE_SLUGS.includes(segments[1])) {
  // County+service page: /service-areas/{county}/{service}
  const [countySlug, serviceSlug] = segments;
  pageType = 'countyService';
  countyServiceData = await getServiceAreaCityService(countySlug, countySlug, serviceSlug);
  if (!countyServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2) {
  // City page: /service-areas/{county}/{city}
  const [countySlug, citySlug] = segments;
  pageType = 'city';
  cityData = await getServiceAreaCity(countySlug, citySlug);
  if (!cityData) return Astro.rewrite('/404');

} else if (segments.length === 1) {
  // County page: /service-areas/{county}
  const [countySlug] = segments;
  pageType = 'county';
  countyData = await getServiceAreaCounty(countySlug);
  if (!countyData) return Astro.rewrite('/404');

  if (countyData.cities) {
    countyData.cities = resolveImages(countyData.cities) as typeof countyData.cities;
  }

} else {
  return Astro.rewrite('/404');
}

// --- Structured data ---

const siteUrl = 'https://hamilton-exteriors.com';

let jsonLd: Record<string, unknown>[] | undefined;

if (pageType === 'cityService' && cityServiceData) {
  const [urlCountySlug, urlCitySlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${cityServiceData.county} County`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': `${cityServiceData.city}, ${cityServiceData.state}`, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}` },
        { '@type': 'ListItem', 'position': 5, 'name': cityServiceData.serviceName, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}/${segments[2]}` },
      ],
    },
  ];
} else if (pageType === 'city' && cityData) {
  const [urlCountySlug, urlCitySlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': cityData.county || segments[0].replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()), 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': cityData.cityName || cityData.title?.split(' in ')?.[1]?.split(' |')?.[0] || urlCitySlug, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}` },
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'Service',
      'name': `Roofing and Exterior Services in ${cityData.cityName || urlCitySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}, CA`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}`,
      'provider': { '@type': 'RoofingContractor', '@id': `${siteUrl}/#business`, 'name': 'Hamilton Exteriors' },
      'areaServed': { '@type': 'City', 'name': cityData.cityName || urlCitySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()), 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
    },
  ];
} else if (pageType === 'county' && countyData) {
  const [urlCountySlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': countyData.title?.split(' |')?.[0] || urlCountySlug, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
      ],
    },
  ];
} else if (pageType === 'countyService' && countyServiceData) {
  const [urlCountySlug, serviceSlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${countyServiceData.county} County`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': countyServiceData.serviceName, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${serviceSlug}` },
      ],
    },
  ];
}
---

{pageType === 'countyService' && countyServiceData && (
  <Layout title={countyServiceData.title} description={countyServiceData.description} jsonLd={jsonLd} includeMapbox>
    <ServicePage data={countyServiceData as any} />
  </Layout>
)}

{pageType === 'cityService' && cityServiceData && (
  <Layout title={cityServiceData.title} description={cityServiceData.description} jsonLd={jsonLd} includeMapbox geoPlacename={`${cityServiceData.city}, CA`}>
    <ServicePage data={cityServiceData as any} />
  </Layout>
)}

{pageType === 'city' && cityData && (
  <Layout title={cityData.title} description={cityData.description} jsonLd={jsonLd} includeMapbox geoPlacename={`${cityData.cityName || ''}, CA`}>
    <ServiceAreaCityPage data={cityData} />
  </Layout>
)}

{pageType === 'county' && countyData && (
  <Layout title={countyData.title} description={countyData.description} jsonLd={jsonLd} includeMapbox>
    <CountyPage data={countyData} />
  </Layout>
)}
