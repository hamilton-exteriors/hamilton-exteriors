---
/**
 * Catch-all route for service area pages.
 * All content comes from Ghost CMS. No fallbacks.
 *
 * Handles:
 *   /service-areas/{countySlug}                     → County page
 *   /service-areas/{countySlug}/{city}              → City page
 *   /service-areas/{countySlug}/{city}/{service}    → City+service page
 *   /service-areas/{countySlug}/{service}           → County+service page
 */
import Layout from '../../layouts/Layout.astro';
import CountyPage from '../../components/CountyPage.astro';
import GeneralCityPage from '../../components/GeneralCityPage.astro';
import ServicePage from '../../components/ServicePage.astro';
import { getServiceAreaCity, getServiceAreaCounty, getServiceAreaCityService } from '../../lib/ghost';
import { resolveImages } from '../../lib/image-map';
import type { GeneralCityPageData } from '../../lib/general-city-types';
import type { CountyPageData } from '../../lib/county-page-types';
import type { CityServicePageData } from '../../lib/city-service-types';
import { getCityProximity } from '../../lib/city-coordinates';
import { getCityWikipedia } from '../../lib/city-wikipedia';
import { getCityOgImage } from '../../lib/city-og-images';

/** Convert getCityProximity "lng,lat" to geo.position "lat;lng" meta tag format */
function toGeoPosition(citySlug: string): string | undefined {
  const proximity = getCityProximity(citySlug);
  if (!proximity) return undefined;
  const [lng, lat] = proximity.split(',');
  return `${lat};${lng}`;
}

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/service-areas');

// Redirect legacy short slugs (e.g., /alameda/berkeley) to canonical form (/alameda-county-ca/berkeley-ca)
const rawSegments = slug.split('/');
const COUNTY_SHORT_TO_FULL: Record<string, string> = {
  alameda: 'alameda-county-ca',
  'alameda-ca': 'alameda-county-ca',
  'contra-costa': 'contra-costa-county-ca',
  'contra-costa-ca': 'contra-costa-county-ca',
  marin: 'marin-county-ca',
  'marin-ca': 'marin-county-ca',
  napa: 'napa-county-ca',
  'napa-ca': 'napa-county-ca',
  'san-mateo': 'san-mateo-county-ca',
  'san-mateo-ca': 'san-mateo-county-ca',
  'santa-clara': 'santa-clara-county-ca',
  'santa-clara-ca': 'santa-clara-county-ca',
};
if (rawSegments[0] && COUNTY_SHORT_TO_FULL[rawSegments[0]]) {
  const fixedSegments = [COUNTY_SHORT_TO_FULL[rawSegments[0]], ...rawSegments.slice(1)];
  // Append -ca to city slugs that are missing it
  if (fixedSegments[1] && !fixedSegments[1].endsWith('-ca') && !['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions', 'decks'].includes(fixedSegments[1])) {
    fixedSegments[1] = `${fixedSegments[1]}-ca`;
  }
  return Astro.redirect(`/service-areas/${fixedSegments.join('/')}`, 301);
}

const segments = slug.split('/');

const SERVICE_SLUGS = ['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions', 'decks'];

let pageType: 'county' | 'city' | 'cityService' | 'countyService' | null = null;
let cityData: GeneralCityPageData | null = null;
let countyData: CountyPageData | null = null;
let cityServiceData: CityServicePageData | null = null;
let countyServiceData: CityServicePageData | null = null;

if (segments.length === 3) {
  // City+service page: /service-areas/{county}/{city}/{service}
  const [countySlug, citySlug, serviceSlug] = segments;
  pageType = 'cityService';
  cityServiceData = await getServiceAreaCityService(countySlug, citySlug, serviceSlug);
  if (!cityServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2 && SERVICE_SLUGS.includes(segments[1])) {
  // County+service page: /service-areas/{county}/{service}
  const [countySlug, serviceSlug] = segments;
  pageType = 'countyService';
  countyServiceData = await getServiceAreaCityService(countySlug, countySlug, serviceSlug);
  if (!countyServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2) {
  // City page: /service-areas/{county}/{city}
  const [countySlug, citySlug] = segments;
  pageType = 'city';
  cityData = await getServiceAreaCity(countySlug, citySlug);
  if (!cityData) return Astro.rewrite('/404');

} else if (segments.length === 1) {
  // County page: /service-areas/{county}
  const [countySlug] = segments;
  pageType = 'county';
  countyData = await getServiceAreaCounty(countySlug);
  if (!countyData) return Astro.rewrite('/404');

  if (countyData.cities) {
    countyData.cities = resolveImages(countyData.cities) as typeof countyData.cities;
  }

} else {
  return Astro.rewrite('/404');
}

// --- Structured data ---

const siteUrl = 'https://hamilton-exteriors.com';

// FAQPage schema removed — Google restricted FAQ rich results to gov/healthcare sites (Aug 2023)

// Shared AggregateRating for all Service schemas on service-area pages.
// Matches homepage data (4.8/37). Nested inline so each Service node is self-contained
// and doesn't depend on Google merging by @id from other pages.
const SERVICE_AGGREGATE_RATING = {
  '@type': 'AggregateRating',
  'ratingValue': 4.8,
  'reviewCount': 37,
  'bestRating': 5,
  'worstRating': 1,
};

let jsonLd: Record<string, unknown>[] | undefined;

if (pageType === 'cityService' && cityServiceData) {
  const [urlCountySlug, urlCitySlug] = segments;
  const csProximity = getCityProximity(urlCitySlug);
  const [csLng, csLat] = csProximity ? csProximity.split(',').map(Number) : [undefined, undefined];
  const csWiki = getCityWikipedia(urlCitySlug);
  const pageUrl = `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}/${segments[2]}`;
  jsonLd = [
    {

      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${cityServiceData.county} County`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': `${cityServiceData.city}, ${cityServiceData.state}`, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}` },
        { '@type': 'ListItem', 'position': 5, 'name': cityServiceData.serviceName, 'item': pageUrl },
      ],
    },
    {

      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      'url': pageUrl,
      'name': cityServiceData.title,
      'description': cityServiceData.description,
      'isPartOf': { '@id': `${siteUrl}/#website` },
      'about': { '@id': `${pageUrl}#service` },
      'inLanguage': 'en-US',
    },
    {

      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      'name': `${cityServiceData.serviceName} in ${cityServiceData.city}, ${cityServiceData.state}`,
      'url': pageUrl,
      'serviceType': cityServiceData.serviceName,
      'provider': { '@type': 'GeneralContractor', '@id': 'https://hamilton-exteriors.com/#business' },
      'areaServed': {
        '@type': 'City',
        'name': cityServiceData.city,
        ...(csWiki && { 'sameAs': csWiki }),
        'containedInPlace': { '@type': 'State', 'name': 'California' },
        ...(csLat && csLng && { 'geo': { '@type': 'GeoCoordinates', 'latitude': csLat, 'longitude': csLng } }),
      },
      'aggregateRating': SERVICE_AGGREGATE_RATING,
    },
  ];
} else if (pageType === 'city' && cityData) {
  // BreadcrumbList is handled by ServiceAreaCityPage/GeneralCityPage components — only add Service schema here
  const [urlCountySlug, urlCitySlug] = segments;
  const cityProximity = getCityProximity(urlCitySlug);
  const [cityLng, cityLat] = cityProximity ? cityProximity.split(',').map(Number) : [undefined, undefined];
  const cityName = cityData.city || urlCitySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  jsonLd = [
    {

      '@type': 'Service',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}#service`,
      'name': `Roofing and Exterior Services in ${cityName}, CA`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}`,
      'provider': { '@id': `${siteUrl}/#business` },
      'areaServed': {
        '@type': 'City',
        'name': cityName,
        ...(getCityWikipedia(urlCitySlug) && { 'sameAs': getCityWikipedia(urlCitySlug) }),
        'containedInPlace': {
          '@type': 'County',
          'name': `${urlCountySlug.replace(/-county-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())} County`,
          'sameAs': `https://en.wikipedia.org/wiki/${urlCountySlug.replace(/-county-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()).replace(/ /g, '_')}_County,_California`,
          'containedInPlace': { '@type': 'State', 'name': 'California' },
        },
        ...(cityLat && cityLng && { 'geo': { '@type': 'GeoCoordinates', 'latitude': cityLat, 'longitude': cityLng } }),
      },
      'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
      'description': cityData.description || `Hamilton Exteriors provides roofing, siding, windows, ADUs, custom homes, and additions in ${cityName}, CA. Licensed, bonded, insured. 50-year warranty. CSLB #1078806.`,
      'offers': {
        '@type': 'AggregateOffer',
        'offerCount': 6,
        'lowPrice': 400,
        'highPrice': 3200,
        'priceCurrency': 'USD',
        'unitText': 'starting price varies by service',
      },
      'aggregateRating': SERVICE_AGGREGATE_RATING,
    },
  ];
} else if (pageType === 'county' && countyData) {
  const [urlCountySlug] = segments;
  const rawCountyName = countyData.county || urlCountySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  // Strip trailing "County" if already present (Ghost CMS may include it) to avoid "Alameda County County"
  const countyBase = rawCountyName.replace(/\s+County$/i, '');
  const countyName = `${countyBase} County`;
  jsonLd = [
    {

      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${countyName}, CA`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
      ],
    },
    {

      '@type': 'WebPage',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}#webpage`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}`,
      'name': `Roofing and Exterior Services in ${countyName}, CA`,
      'isPartOf': { '@id': `${siteUrl}/#website` },
      'about': { '@id': `${siteUrl}/service-areas/${urlCountySlug}#service` },
      'inLanguage': 'en-US',
    },
    {

      '@type': 'Service',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}#service`,
      'name': `Roofing and Exterior Services in ${countyName}, CA`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}`,
      'provider': { '@id': `${siteUrl}/#business` },
      'areaServed': { '@type': 'County', 'name': countyName, 'sameAs': `https://en.wikipedia.org/wiki/${countyBase.replace(/ /g, '_')}_County,_California`, 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
      'description': countyData.description || `Hamilton Exteriors serves ${countyName} with professional roofing, siding, windows, ADUs, and custom homes. CSLB #1078806.`,
      'offers': {
        '@type': 'AggregateOffer',
        'offerCount': 6,
        'lowPrice': 400,
        'highPrice': 3200,
        'priceCurrency': 'USD',
        'unitText': 'starting price varies by service',
      },
      'aggregateRating': SERVICE_AGGREGATE_RATING,
    },
  ];
} else if (pageType === 'countyService' && countyServiceData) {
  const [urlCountySlug, serviceSlug] = segments;
  const rawCounty = countyServiceData.county || urlCountySlug.replace(/-county-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  const countyBase = rawCounty.replace(/\s+County$/i, '');
  const countyDisplayName = `${countyBase} County`;
  const csPageUrl = `${siteUrl}/service-areas/${urlCountySlug}/${serviceSlug}`;
  jsonLd = [
    {

      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${countyDisplayName}, CA`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': countyServiceData.serviceName, 'item': csPageUrl },
      ],
    },
    {

      '@type': 'WebPage',
      '@id': `${csPageUrl}#webpage`,
      'url': csPageUrl,
      'name': countyServiceData.title,
      'description': countyServiceData.description,
      'isPartOf': { '@id': `${siteUrl}/#website` },
      'about': { '@id': `${csPageUrl}#service` },
      'inLanguage': 'en-US',
    },
    {

      '@type': 'Service',
      '@id': `${csPageUrl}#service`,
      'name': `${countyServiceData.serviceName} in ${countyDisplayName}, CA`,
      'url': csPageUrl,
      'serviceType': countyServiceData.serviceName,
      'provider': { '@type': 'GeneralContractor', '@id': `${siteUrl}/#business` },
      'areaServed': {
        '@type': 'County',
        'name': countyDisplayName,
        'sameAs': `https://en.wikipedia.org/wiki/${countyBase.replace(/ /g, '_')}_County,_California`,
        'containedInPlace': { '@type': 'State', 'name': 'California' },
      },
      'aggregateRating': SERVICE_AGGREGATE_RATING,
    },
  ];
}
---

{pageType === 'countyService' && countyServiceData && (
  <Layout title={countyServiceData.title} description={countyServiceData.description} jsonLd={jsonLd} includeMapbox preloadHero>
    <ServicePage data={countyServiceData as any} />
  </Layout>
)}

{pageType === 'cityService' && cityServiceData && (
  <Layout title={cityServiceData.title} description={cityServiceData.description} jsonLd={jsonLd} includeMapbox preloadHero geoPlacename={`${cityServiceData.city}, CA`} geoPosition={toGeoPosition(segments[1])} heroImage={getCityOgImage(segments[1])}>
    <ServicePage data={cityServiceData as any} />
  </Layout>
)}

{pageType === 'city' && cityData && (
  <Layout title={cityData.title} description={cityData.description} jsonLd={jsonLd} includeMapbox preloadHero geoPlacename={`${cityData.city || ''}, CA`} geoPosition={toGeoPosition(segments[1])} heroImage={getCityOgImage(segments[1])}>
    <GeneralCityPage data={cityData} heroImage={getCityOgImage(segments[1])} />
  </Layout>
)}

{pageType === 'county' && countyData && (
  <Layout title={countyData.title} description={countyData.description} jsonLd={jsonLd} includeMapbox preloadHero>
    <CountyPage data={countyData} />
  </Layout>
)}
