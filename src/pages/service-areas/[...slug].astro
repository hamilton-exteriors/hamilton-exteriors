---
/**
 * Catch-all route for service area pages.
 * All content comes from Ghost CMS. No fallbacks.
 *
 * Handles:
 *   /service-areas/{countySlug}                     → County page
 *   /service-areas/{countySlug}/{city}              → City page
 *   /service-areas/{countySlug}/{city}/{service}    → City+service page
 *   /service-areas/{countySlug}/{service}           → County+service page
 */
import Layout from '../../layouts/Layout.astro';
import CountyPage from '../../components/CountyPage.astro';
import GeneralCityPage from '../../components/GeneralCityPage.astro';
import ServicePage from '../../components/ServicePage.astro';
import { getServiceAreaCity, getServiceAreaCounty, getServiceAreaCityService } from '../../lib/ghost';
import { resolveImages } from '../../lib/image-map';
import type { GeneralCityPageData } from '../../lib/general-city-types';
import type { CountyPageData } from '../../lib/county-page-types';
import type { CityServicePageData } from '../../lib/city-service-types';
import { getCityProximity } from '../../lib/city-coordinates';
import { getCityWikipedia } from '../../lib/city-wikipedia';
import { getCityOgImage } from '../../lib/city-og-images';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/service-areas');

// Redirect legacy short slugs (e.g., /alameda/berkeley) to canonical form (/alameda-county-ca/berkeley-ca)
const rawSegments = slug.split('/');
const COUNTY_SHORT_TO_FULL: Record<string, string> = {
  alameda: 'alameda-county-ca',
  'contra-costa': 'contra-costa-county-ca',
  marin: 'marin-county-ca',
  napa: 'napa-county-ca',
  'san-mateo': 'san-mateo-county-ca',
  'santa-clara': 'santa-clara-county-ca',
};
if (rawSegments[0] && COUNTY_SHORT_TO_FULL[rawSegments[0]]) {
  const fixedSegments = [COUNTY_SHORT_TO_FULL[rawSegments[0]], ...rawSegments.slice(1)];
  // Append -ca to city slugs that are missing it
  if (fixedSegments[1] && !fixedSegments[1].endsWith('-ca') && !['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions'].includes(fixedSegments[1])) {
    fixedSegments[1] = `${fixedSegments[1]}-ca`;
  }
  return Astro.redirect(`/service-areas/${fixedSegments.join('/')}`, 301);
}

const segments = slug.split('/');

const SERVICE_SLUGS = ['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions'];

let pageType: 'county' | 'city' | 'cityService' | 'countyService' | null = null;
let cityData: GeneralCityPageData | null = null;
let countyData: CountyPageData | null = null;
let cityServiceData: CityServicePageData | null = null;
let countyServiceData: CityServicePageData | null = null;

if (segments.length === 3) {
  // City+service page: /service-areas/{county}/{city}/{service}
  const [countySlug, citySlug, serviceSlug] = segments;
  pageType = 'cityService';
  cityServiceData = await getServiceAreaCityService(countySlug, citySlug, serviceSlug);
  if (!cityServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2 && SERVICE_SLUGS.includes(segments[1])) {
  // County+service page: /service-areas/{county}/{service}
  const [countySlug, serviceSlug] = segments;
  pageType = 'countyService';
  countyServiceData = await getServiceAreaCityService(countySlug, countySlug, serviceSlug);
  if (!countyServiceData) return Astro.rewrite('/404');

} else if (segments.length === 2) {
  // City page: /service-areas/{county}/{city}
  const [countySlug, citySlug] = segments;
  pageType = 'city';
  cityData = await getServiceAreaCity(countySlug, citySlug);
  if (!cityData) return Astro.rewrite('/404');

} else if (segments.length === 1) {
  // County page: /service-areas/{county}
  const [countySlug] = segments;
  pageType = 'county';
  countyData = await getServiceAreaCounty(countySlug);
  if (!countyData) return Astro.rewrite('/404');

  if (countyData.cities) {
    countyData.cities = resolveImages(countyData.cities) as typeof countyData.cities;
  }

} else {
  return Astro.rewrite('/404');
}

// --- Structured data ---

const siteUrl = 'https://hamilton-exteriors.com';

let jsonLd: Record<string, unknown>[] | undefined;

if (pageType === 'cityService' && cityServiceData) {
  const [urlCountySlug, urlCitySlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${cityServiceData.county} County`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': `${cityServiceData.city}, ${cityServiceData.state}`, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}` },
        { '@type': 'ListItem', 'position': 5, 'name': cityServiceData.serviceName, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}/${segments[2]}` },
      ],
    },
  ];
} else if (pageType === 'city' && cityData) {
  // BreadcrumbList is handled by ServiceAreaCityPage/GeneralCityPage components — only add Service schema here
  const [urlCountySlug, urlCitySlug] = segments;
  const cityProximity = getCityProximity(urlCitySlug);
  const [cityLng, cityLat] = cityProximity ? cityProximity.split(',').map(Number) : [undefined, undefined];
  const cityName = cityData.city || urlCitySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'Service',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}#service`,
      'name': `Roofing and Exterior Services in ${cityName}, CA`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}/${urlCitySlug}`,
      'provider': { '@id': `${siteUrl}/#business` },
      'areaServed': {
        '@type': 'City',
        'name': cityName,
        ...(getCityWikipedia(urlCitySlug) && { 'sameAs': getCityWikipedia(urlCitySlug) }),
        'containedInPlace': {
          '@type': 'County',
          'name': `${urlCountySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())} County`,
          'sameAs': `https://en.wikipedia.org/wiki/${urlCountySlug.replace(/-ca$/, '').replace(/-/g, '_').replace(/\b\w/g, (c: string) => c.toUpperCase())}_County,_California`,
          'containedInPlace': { '@type': 'State', 'name': 'California' },
        },
        ...(cityLat && cityLng && { 'geo': { '@type': 'GeoCoordinates', 'latitude': cityLat, 'longitude': cityLng } }),
      },
      'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
      'description': cityData.description || `Hamilton Exteriors provides roofing, siding, windows, ADUs, custom homes, and additions in ${cityName}, CA. Licensed, bonded, insured. 50-year warranty. CSLB #1082377.`,
      'offers': {
        '@type': 'AggregateOffer',
        'offerCount': 6,
        'lowPrice': 400,
        'highPrice': 3200,
        'priceCurrency': 'USD',
        'unitText': 'starting price varies by service',
      },
      'aggregateRating': {
        '@type': 'AggregateRating',
        'ratingValue': 4.8,
        'reviewCount': 52,
        'bestRating': 5,
        'worstRating': 1,
      },
    },
  ];
} else if (pageType === 'county' && countyData) {
  const [urlCountySlug] = segments;
  const countyName = countyData.county || urlCountySlug.replace(/-ca$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${countyName} County, CA`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}#webpage`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}`,
      'name': `Roofing and Exterior Services in ${countyName} County, CA`,
      'isPartOf': { '@id': `${siteUrl}/#website` },
      'about': { '@id': `${siteUrl}/service-areas/${urlCountySlug}#service` },
      'inLanguage': 'en-US',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'Service',
      '@id': `${siteUrl}/service-areas/${urlCountySlug}#service`,
      'name': `Roofing and Exterior Services in ${countyName} County, CA`,
      'url': `${siteUrl}/service-areas/${urlCountySlug}`,
      'provider': { '@id': `${siteUrl}/#business` },
      'areaServed': { '@type': 'County', 'name': `${countyName} County`, 'sameAs': `https://en.wikipedia.org/wiki/${countyName.replace(/ /g, '_')}_County,_California`, 'containedInPlace': { '@type': 'State', 'name': 'California' } },
      'serviceType': ['Roofing', 'Siding', 'Windows', 'ADUs', 'Custom Homes', 'Additions'],
      'description': countyData.description || `Hamilton Exteriors serves ${countyName} County with professional roofing, siding, windows, ADUs, and custom homes. CSLB #1082377.`,
      'offers': {
        '@type': 'AggregateOffer',
        'offerCount': 6,
        'lowPrice': 400,
        'highPrice': 3200,
        'priceCurrency': 'USD',
        'unitText': 'starting price varies by service',
      },
      'aggregateRating': {
        '@type': 'AggregateRating',
        'ratingValue': 4.8,
        'reviewCount': 52,
        'bestRating': 5,
        'worstRating': 1,
      },
    },
  ];
} else if (pageType === 'countyService' && countyServiceData) {
  const [urlCountySlug, serviceSlug] = segments;
  jsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': `${countyServiceData.county} County`, 'item': `${siteUrl}/service-areas/${urlCountySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': countyServiceData.serviceName, 'item': `${siteUrl}/service-areas/${urlCountySlug}/${serviceSlug}` },
      ],
    },
  ];
}
---

{pageType === 'countyService' && countyServiceData && (
  <Layout title={countyServiceData.title} description={countyServiceData.description} jsonLd={jsonLd} includeMapbox preloadHero>
    <ServicePage data={countyServiceData as any} />
  </Layout>
)}

{pageType === 'cityService' && cityServiceData && (
  <Layout title={cityServiceData.title} description={cityServiceData.description} jsonLd={jsonLd} includeMapbox preloadHero geoPlacename={`${cityServiceData.city}, CA`} heroImage={getCityOgImage(segments[1])}>
    <ServicePage data={cityServiceData as any} />
  </Layout>
)}

{pageType === 'city' && cityData && (
  <Layout title={cityData.title} description={cityData.description} jsonLd={jsonLd} includeMapbox preloadHero geoPlacename={`${cityData.city || ''}, CA`} heroImage={getCityOgImage(segments[1])}>
    <GeneralCityPage data={cityData} />
  </Layout>
)}

{pageType === 'county' && countyData && (
  <Layout title={countyData.title} description={countyData.description} jsonLd={jsonLd} includeMapbox preloadHero>
    <CountyPage data={countyData} />
  </Layout>
)}
