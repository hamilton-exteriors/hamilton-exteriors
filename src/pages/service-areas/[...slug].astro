---
/**
 * Catch-all route for service area pages.
 * Handles:
 *   /service-areas/{countySlug}                     → County page
 *   /service-areas/{countySlug}/{city}              → General city page
 *   /service-areas/{countySlug}/{city}/{service}    → City+service page
 *
 * Fetches from Ghost CMS first, falls back to template generation / static data.
 */
import Layout from '../../layouts/Layout.astro';
import CountyPage from '../../components/CountyPage.astro';
import ServiceAreaCityPage from '../../components/ServiceAreaCityPage.astro';
import GeneralCityPage from '../../components/GeneralCityPage.astro';
import ServicePage from '../../components/ServicePage.astro';
import { getServiceAreaCity, getServiceAreaCounty, getServiceAreaCityService } from '../../lib/ghost';
import { resolveImages } from '../../lib/image-map';
import { generateGeneralCityPage, generateCityServicePage, generateCountyServicePage } from '../../lib/pseo/generate';
import { getCitySeed } from '../../lib/pseo/city-seed-data';
import { getServiceTemplate } from '../../lib/pseo/service-templates';
import type { ServiceAreaCity } from '../../lib/service-area-types';
import type { CountyPageData } from '../../lib/county-page-types';
import type { GeneralCityPageData } from '../../lib/general-city-types';
import type { CityServicePageData } from '../../lib/city-service-types';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/service-areas');

const segments = slug.split('/');

const SERVICE_SLUGS = ['roofing', 'siding', 'windows', 'adu', 'custom-homes', 'additions'];

let pageType: 'county' | 'city' | 'cityService' | 'countyService' | null = null;
let cityData: ServiceAreaCity | null = null;
let countyData: CountyPageData | null = null;
let generalCityData: GeneralCityPageData | null = null;
let cityServiceData: CityServicePageData | null = null;
let countyServiceData: CityServicePageData | null = null;

if (segments.length === 3) {
  // City+service page: /service-areas/{county}/{city}/{service}
  const [countySlug, citySlug, serviceSlug] = segments;
  pageType = 'cityService';

  // Try Ghost first
  cityServiceData = await getServiceAreaCityService(countySlug, citySlug, serviceSlug);

  // Fallback: generate from template
  if (!cityServiceData) {
    // Strip -ca suffix from city slug, -county-ca from county slug for seed lookup
    const seedCitySlug = citySlug.replace(/-ca$/, '');
    const seed = getCitySeed(seedCitySlug);
    const template = getServiceTemplate(serviceSlug);

    if (seed && template) {
      cityServiceData = generateCityServicePage(seed, template);
    }
  }

  if (!cityServiceData) return Astro.rewrite('/404');

  console.log(`[service-area] ${pageType} ${slug} — title: ${cityServiceData?.title?.slice(0,50)} desc: ${cityServiceData?.description?.slice(0,50)}`);

} else if (segments.length === 2 && SERVICE_SLUGS.includes(segments[1])) {
  // County-service page: /service-areas/{county}/{service}
  const [countySlug, serviceSlug] = segments;
  pageType = 'countyService';

  const template = getServiceTemplate(serviceSlug);
  if (template) {
    countyServiceData = generateCountyServicePage(countySlug, template);
  }

  if (!countyServiceData) return Astro.rewrite('/404');

  console.log(`[service-area] ${pageType} ${slug} — title: ${countyServiceData.title?.slice(0,50)}`);

} else if (segments.length === 2) {
  // City page: /service-areas/{county}/{city}
  const [countySlug, citySlug] = segments;
  pageType = 'city';

  // Try Ghost first
  const ghostCity = await getServiceAreaCity(countySlug, citySlug);

  if (ghostCity) {
    // Ghost returned old-format ServiceAreaCity data — use old component
    cityData = ghostCity;
  } else {
    // Fallback: generate GeneralCityPage from seed
    const seedCitySlug = citySlug.replace(/-ca$/, '');
    const seed = getCitySeed(seedCitySlug);

    if (seed) {
      generalCityData = generateGeneralCityPage(seed);
    } else {
      // Second fallback: static data files (backward compat)
      try {
        const mod = await import(`../../data/service-areas/${citySlug}.ts`);
        cityData = mod.data as ServiceAreaCity;
      } catch {
        // No static data either
      }
    }
  }

  if (!cityData && !generalCityData) return Astro.rewrite('/404');

  console.log(`[service-area] ${pageType} ${slug} — title: ${(generalCityData?.title ?? cityData?.title)?.slice(0,50)} desc: ${(generalCityData?.description ?? cityData?.description)?.slice(0,50)}`);

} else if (segments.length === 1) {
  // County page: /service-areas/{county}
  const [countySlug] = segments;
  pageType = 'county';

  // Try Ghost first
  countyData = await getServiceAreaCounty(countySlug);

  // Fallback to static data
  if (!countyData) {
    try {
      const mod = await import(`../../data/counties/${countySlug}.ts`);
      countyData = mod.data as CountyPageData;
    } catch {
      // No static data either
    }
  }

  if (!countyData) return Astro.rewrite('/404');

  console.log(`[service-area] ${pageType} ${slug} — title: ${countyData?.title?.slice(0,50)} desc: ${countyData?.description?.slice(0,50)}`);

  // Resolve any string image references on county cities
  if (countyData.cities) {
    countyData.cities = resolveImages(countyData.cities) as typeof countyData.cities;
  }

} else {
  return Astro.rewrite('/404');
}

// --- Structured data for pSEO pages ---

const siteUrl = 'https://hamilton-exteriors.com';

// City+service pages: localized Service + BreadcrumbList
let cityServiceJsonLd: Record<string, unknown>[] | undefined;
if (pageType === 'cityService' && cityServiceData) {
  cityServiceJsonLd = [
    {
      '@context': 'https://schema.org',
      '@type': 'Service',
      'name': `${cityServiceData.serviceName} in ${cityServiceData.city}, CA`,
      'provider': {
        '@type': 'HomeAndConstructionBusiness',
        'name': 'Hamilton Exteriors',
        'telephone': '+1-650-977-3351',
      },
      'areaServed': {
        '@type': 'City',
        'name': cityServiceData.city,
        'containedInPlace': { '@type': 'State', 'name': 'California' },
      },
      'description': cityServiceData.description,
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${siteUrl}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Service Areas', 'item': `${siteUrl}/service-areas` },
        { '@type': 'ListItem', 'position': 3, 'name': cityServiceData.county, 'item': `${siteUrl}/service-areas/${cityServiceData.countySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': `${cityServiceData.city}, ${cityServiceData.state}`, 'item': `${siteUrl}/service-areas/${cityServiceData.countySlug}/${cityServiceData.citySlug}` },
        { '@type': 'ListItem', 'position': 5, 'name': cityServiceData.serviceName },
      ],
    },
  ];
}

// General city pages: LocalBusiness schema
let generalCityJsonLd: Record<string, unknown> | undefined;
if (pageType === 'city' && generalCityData) {
  generalCityJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'HomeAndConstructionBusiness',
    'name': `Hamilton Exteriors - ${generalCityData.city}`,
    'telephone': '+1-650-977-3351',
    'areaServed': { '@type': 'City', 'name': generalCityData.city },
    'aggregateRating': { '@type': 'AggregateRating', 'ratingValue': '4.8', 'reviewCount': '50' },
  };
}
---

{pageType === 'countyService' && countyServiceData && (
  <Layout title={countyServiceData.title} description={countyServiceData.description} includeMapbox>
    <ServicePage data={countyServiceData as any} />
  </Layout>
)}

{pageType === 'cityService' && cityServiceData && (
  <Layout title={cityServiceData.title} description={cityServiceData.description} jsonLd={cityServiceJsonLd} includeMapbox>
    <ServicePage data={cityServiceData as any} />
  </Layout>
)}

{pageType === 'city' && generalCityData && (
  <Layout title={generalCityData.title} description={generalCityData.description} jsonLd={generalCityJsonLd} includeMapbox>
    <GeneralCityPage data={generalCityData} />
  </Layout>
)}

{pageType === 'city' && cityData && !generalCityData && (
  <Layout title={cityData.title} description={cityData.description} includeMapbox>
    <ServiceAreaCityPage data={cityData} />
  </Layout>
)}

{pageType === 'county' && countyData && (
  <Layout title={countyData.title} description={countyData.description} includeMapbox>
    <CountyPage data={countyData} />
  </Layout>
)}
