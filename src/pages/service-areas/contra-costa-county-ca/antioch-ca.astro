---
import Layout from '../../../layouts/Layout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navbar from '../../../components/Navbar.astro';
import Hero from '../../../components/Hero.astro';
import LogoSlider from '../../../components/LogoSlider.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactUs from '../../../components/ContactUs.astro';
import Footer from '../../../components/Footer.astro';

const city = 'Antioch';
const county = 'Contra Costa County';
const adjective = 'Professional';
---

<Layout
  title={`${adjective} ADU Contractors in ${city}, CA | Hamilton Exteriors`}
  description={`Hamilton Exteriors provides ${adjective.toLowerCase()} ADU contractors in ${city}, CA. Expert design, permits, and construction. Call for a free consultation!`}
>
  <AnnouncementBar />
  <Navbar />
  <Hero
    formTitle={`Get a FREE Estimate in ${city}`}
    headline={`${adjective} ADU Contractors in ${city}, CA`}
  />
  <LogoSlider />

  <!-- Why Choose Section -->
  <section class="w-full bg-white py-16 md:py-32">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: rgb(13, 43, 29); text-transform: uppercase; margin-bottom: 16px;">
        Why Choose Hamilton Exteriors as Your {adjective} ADU Contractors in {city}, CA?
      </h2>
      <h3 style="font-family: 'DM Sans', sans-serif; font-size: 22px; font-weight: 500; color: rgb(13, 43, 29); margin-bottom: 20px;">
        Dedicated. Skilled. Efficient.
      </h3>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Hamilton Exteriors provides professional ADU contractors in Antioch, CA who bring a disciplined, organized approach to every build in this fast-growing East Contra Costa city. Antioch's expanding residential areas and relatively affordable property prices make it a prime location for ADU investment, and our team delivers the professional-grade construction these projects demand.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Our professional process begins with a detailed consultation to understand your goals, followed by architectural planning, permit submission to the City of Antioch, and a structured construction timeline. We treat every ADU project with the same level of professionalism — clear contracts, licensed crews, proper insurance, and thorough documentation from start to finish.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Antioch's warm climate and larger lot sizes give homeowners excellent options for both attached and detached ADUs. We help you choose the best configuration for your property and build a unit that meets your family's needs and the city's building standards.
      </p>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105);">
            <strong style="color: rgb(13, 43, 29);">Licensed and Insured</strong> — We carry full licensing and insurance coverage, protecting you from liability and ensuring every aspect of your ADU build meets professional standards.
          </p>
        </div>
        <div>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105);">
            <strong style="color: rgb(13, 43, 29);">Structured Project Management</strong> — Every Antioch ADU project follows a clear timeline with defined milestones, keeping your build organized and on track from permit to completion.
          </p>
        </div>
        <div>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105);">
            <strong style="color: rgb(13, 43, 29);">Climate-Appropriate Design</strong> — We design ADUs suited to Antioch's hot summers, incorporating proper insulation, ventilation, and energy-efficient windows to keep your unit comfortable year-round.
          </p>
        </div>
        <div>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105);">
            <strong style="color: rgb(13, 43, 29);">Detailed Documentation</strong> — You receive complete project records including plans, permits, inspection reports, and warranty information for your files and future reference.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why ADU Contractors Section -->
  <section class="w-full bg-cream py-16 md:py-32">
    <div class="mx-auto max-w-[1200px] px-5">
      <h2 style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: rgb(13, 43, 29); text-transform: uppercase; margin-bottom: 16px;">
        Why {adjective} ADU Contractors in {city}, CA Are Important?
      </h2>
      <h3 style="font-family: 'DM Sans', sans-serif; font-size: 22px; font-weight: 500; color: rgb(13, 43, 29); margin-bottom: 20px;">
        Safety. Precision. Confidence.
      </h3>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Antioch is one of the fastest-growing cities in Contra Costa County, with new families and professionals drawn by its relative affordability compared to the inner Bay Area. ADUs are an increasingly popular way for Antioch homeowners to create rental income, accommodate extended family, or build a home office without the expense of a full addition or second mortgage.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105); margin-bottom: 16px;">
        Professional contractors are important in Antioch because the city's rapid growth means the building department is processing a high volume of permits. Plans that aren't prepared professionally get sent back for revisions, adding weeks or months to your timeline. A professional ADU contractor submits clean, complete plans that move through the review process efficiently.
      </p>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 30px; color: rgb(104, 104, 105);">
        By choosing a professional team, you avoid the risks that come with unlicensed or inexperienced builders — substandard work, failed inspections, and projects that stall halfway through. Your ADU will be built to code, on schedule, and to a standard that adds genuine value to your Antioch property.
      </p>
    </div>
  </section>


  <!-- ADU Services Section -->
  <section class="hidden lg:block w-full" style="background-color: #0d2b1d; padding: 80px 0;">
    <div class="mx-auto max-w-[1200px] px-5">
      <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: rgb(36, 99, 69); margin-bottom: 12px;">WHAT WE BUILD</p>
      <h2
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.2; font-weight: 400; color: white; text-transform: uppercase; margin-bottom: 48px;"
      >
        ADU Types We Specialize In
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <div class="rounded-2xl p-8" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 12px;">Detached ADUs</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 26px; color: rgba(255, 255, 255, 0.7);">
            Standalone backyard units up to 1,200 sq ft with full kitchens, bathrooms, and separate entrances. Ideal for rental income or multigenerational living with complete privacy.
          </p>
        </div>
        <div class="rounded-2xl p-8" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 12px;">Garage Conversions</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 26px; color: rgba(255, 255, 255, 0.7);">
            Transform your existing garage into a comfortable living space. The most cost-effective ADU option, with lower construction costs and faster completion timelines.
          </p>
        </div>
        <div class="rounded-2xl p-8" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
          <h3 style="font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 12px;">Junior ADUs</h3>
          <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 26px; color: rgba(255, 255, 255, 0.7);">
            Up to 500 sq ft units built within your existing home footprint. Perfect for a home office, guest suite, or compact rental — with minimal site disruption.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <ContactUs />
  <Footer />
</Layout>
