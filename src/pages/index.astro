---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
import Mission from '../components/Mission.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Services from '../components/Services.astro';
import Difference from '../components/Difference.astro';
import Projects from '../components/Projects.astro';
import Financing from '../components/Financing.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';
import { heroBg } from '../lib/images';
---

<Layout
  title="Bay Area Design-Build & Exteriors Contractor | Hamilton Exteriors"
  description="Bay Area's trusted design-build contractor. Roofing, siding, windows, ADUs & custom homes. 50-year warranty. $0 down. Call (650) 977-3351."
  includeMapbox
  preloadHero
  heroImage={heroBg}
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />
  <Hero formTitle="Get Your Free Quote" headline="Bay Area's Architect-Led  Design-Build &  Exteriors Firm" />
  <LogoSlider />
  <Reviews />
  <Financing />
  <Mission />
  <ReviewLogos />
  <Services />
  <Difference />
  <Projects />
  <CTA />
  <FAQ />
  <ContactUs />
  <Footer slot="footer" />
</Layout>

