---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
import Mission from '../components/Mission.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Services from '../components/Services.astro';
import Difference from '../components/Difference.astro';
import Projects from '../components/Projects.astro';
import Financing from '../components/Financing.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Top Rated Exterior Company in Castro Valley, CA | Hamilton Exteriors"
  description="Hamilton Exteriors is top rated Exterior Company in Castro Valley, CA. Our skilled team delivers high-value construction solutions. Call Now!"
>
  <AnnouncementBar />
  <Navbar />
  <Hero formTitle="Get a FREE QUOTE" />
  <LogoSlider />
  <Reviews />
  <Financing />
  <Mission />
  <ReviewLogos />
  <Services />
  <Difference />
  <Projects />
  <CTA />
  <FAQ />
  <ContactUs />
  <Footer />
</Layout>

<style>
  /* Mobile: tighten shared components to match production height */
  @media (max-width: 767px) {
    :global(#about) { padding: 40px 0 !important; }
    :global(#about p) { font-size: 18px !important; line-height: 36px !important; }
    :global(#financing) { padding: 40px 0 !important; }
    :global(#financing .relative.h-\[400px\]) { height: 240px !important; }
    :global(#quote) { }
    :global(#quote > div) { padding-top: 15px !important; padding-bottom: 15px !important; gap: 1.25rem !important; }
  }
</style>
