---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
import Mission from '../components/Mission.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Services from '../components/Services.astro';
import Difference from '../components/Difference.astro';
import Projects from '../components/Projects.astro';
import Financing from '../components/Financing.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';
import { heroBg } from '../lib/images';
---

<Layout
  title="Hamilton Exteriors | Bay Area General Contractor | Custom Homes, ADUs & Roofing"
  description="Architect-led Bay Area contractor. Roofing, siding, windows, ADUs & custom homes. 50-year warranty. CSLB #1082377. Free estimate: (650) 977-3351."
  includeMapbox
  preloadHero
  heroImage={heroBg}
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />
  <Hero formTitle="Get Your Free Quote" headline="Bay Area's Architect-Led  Custom Home  & Exteriors Contractor" />
  <LogoSlider />
  <Reviews />
  <Financing />
  <Mission />
  <ReviewLogos />
  <Services />
  <Difference />
  <Projects />
  <CTA />
  <FAQ extraFaqs={[
    {
      question: 'How much does a roof replacement cost in the Bay Area?',
      answer:
        'A full roof replacement in the San Francisco Bay Area typically costs between $15,000 and $100,000, depending on roof size, pitch, and material. Asphalt shingle roofs — installed on 75% of U.S. homes according to the Asphalt Roofing Manufacturers Association — start around $1,075 per roofing square. Metal roofing starts at $1,525 per square and reflects up to 70% of solar radiant heat (Oak Ridge National Laboratory, DOI:10.2172/1220146). Tile and slate cost more but can last 50–100 years. Permit fees in Bay Area counties range from $200 to $800, with Alameda and Santa Clara counties typically at the higher end. Hamilton Exteriors provides detailed square-footage pricing in every estimate so you can compare materials side by side before committing.',
    },
    {
      question: 'How long does a typical exterior project take?',
      answer:
        'Most residential roof replacements take 2–5 days of on-site work once materials arrive. Siding projects run 1–3 weeks depending on square footage. Window replacements average 1–2 days for a full home. Larger projects like ADUs and additions take 4–8 months from permit to move-in. Every Hamilton Exteriors estimate includes a written timeline with milestones so you know exactly what to expect. Your project manager sends daily photo updates through CompanyCam so you can track progress from anywhere.',
    },
    {
      question: 'What is a design-build contractor?',
      answer:
        'A design-build contractor handles both the architectural design and construction under one contract, one team, and one point of accountability. This eliminates the coordination gaps that happen when you hire a separate architect and builder. Hamilton Exteriors is led by a licensed architect (Alexander Hamilton Li) who also holds a General Contractor license (CSLB #1082377), which means your project is designed and built by the same person — reducing change orders, shortening timelines, and keeping the original design intent intact from blueprint through final inspection.',
    },
    {
      question: 'What warranty do you offer on exterior work?',
      answer:
        'Hamilton Exteriors offers a transferable 50-year warranty on roofing and siding installations, which stays with the home if you sell — making it a documentable asset in any real estate transaction. This is backed by manufacturer warranties from GAF, Owens Corning, CertainTeed, and James Hardie — we hold their highest-tier certifications, which require annual training and quality audits to maintain. Windows carry manufacturer warranties of 20–30 years depending on the product line. Our workmanship warranty covers labor for the full duration, not just the first few years. If an issue arises five, ten, or twenty years after installation, our warranty covers the repair at no additional cost to you. Every warranty is documented in writing before work begins.',
    },
  ]} />
  <ContactUs />
  <Footer slot="footer" />
</Layout>

