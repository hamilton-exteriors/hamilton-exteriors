---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';

const rawName = Astro.url.searchParams.get('name')?.trim().slice(0, 30) || '';
const service = Astro.url.searchParams.get('service')?.trim() || '';

// Use the name as-is (already the first name from the form)
const displayName = rawName;

// Service-specific messaging + contextual link
const serviceConfig: Record<string, { label: string; linkLabel: string; href: string }> = {
  roofing: { label: 'your roofing project', linkLabel: 'roofing', href: '/roofing' },
  siding: { label: 'your siding project', linkLabel: 'siding', href: '/siding' },
  windows: { label: 'your window replacement', linkLabel: 'windows', href: '/windows' },
  adu: { label: 'your ADU project', linkLabel: 'ADUs', href: '/adu' },
  'custom-homes': { label: 'your custom home build', linkLabel: 'custom homes', href: '/custom-homes' },
  additions: { label: 'your home addition', linkLabel: 'additions', href: '/additions' },
  decks: { label: 'your deck project', linkLabel: 'decks', href: '/decks' },
  bathrooms: { label: 'your bathroom remodel', linkLabel: 'bathrooms', href: '/bathrooms' },
};
const matched = serviceConfig[service.toLowerCase()];
const projectLabel = matched?.label || 'your project';
---

<Layout
  noindex
  title="Thank You | Hamilton Exteriors"
  description="Thank you for contacting Hamilton Exteriors. Your project manager will call you shortly."
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />

  <!-- Thank You Hero -->
  <section class="w-full bg-cream py-24 md:py-32">
    <div class="mx-auto max-w-[640px] px-5 text-center">
      <div class="mx-auto mb-6 flex size-20 items-center justify-center text-primary">
        <svg class="size-20" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none" stroke="currentColor" stroke-width="2" />
          <path class="checkmark-path" d="M14.5 27.5L22 35L37.5 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>

      <h1 class="font-hamilton-display text-[clamp(2rem,6vw,3rem)] leading-tight font-normal uppercase text-heading">
        {displayName ? `Thank You, ${displayName}.` : 'Thank You.'}
      </h1>

      <p class="mx-auto mt-4 max-w-[44ch] text-lg leading-relaxed text-muted">
        We're reviewing {projectLabel} now. Your project manager will call you within <strong class="text-heading">3-5 minutes</strong>.
      </p>

      <a
        href={PHONE_HREF}
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Can't wait? Call {PHONE_DISPLAY}
      </a>

      <!-- Trust line — collapsed stats into a single line -->
      <p class="mt-8 text-[0.8125rem] text-muted">
        500+ projects completed · 4.8 Google rating · 50-year warranty · CSLB #1078806
      </p>
    </div>
  </section>

  <!-- What Happens Next — vertical timeline instead of identical card grid -->
  <section class="w-full bg-white py-16 md:py-20">
    <div class="mx-auto max-w-[560px] px-5">
      <h2 class="mb-10 text-center font-hamilton-display text-[clamp(1.5rem,4vw,2rem)] font-normal uppercase text-heading">
        What Happens Next
      </h2>

      <ol class="timeline relative space-y-8 border-l-2 border-primary/20 pl-8">
        <li class="relative">
          <span class="absolute -left-[41px] flex size-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">1</span>
          <h3 class="font-hamilton-display text-lg font-normal uppercase text-heading">Quick Call</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted">Your project manager calls within 3-5 minutes to learn about {projectLabel} and answer your questions.</p>
        </li>
        <li class="relative">
          <span class="absolute -left-[41px] flex size-8 items-center justify-center rounded-full bg-primary/15 text-sm font-bold text-primary">2</span>
          <h3 class="font-hamilton-display text-lg font-normal uppercase text-heading">Free On-Site Inspection</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted">We visit your home to assess the work, take measurements, and discuss materials and options on site.</p>
        </li>
        <li class="relative">
          <span class="absolute -left-[41px] flex size-8 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">3</span>
          <h3 class="font-hamilton-display text-lg font-normal uppercase text-heading">Detailed Estimate</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted">Receive an itemized estimate with every option, material, and cost clearly explained. Full transparency, line by line.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Contextual link — one relevant suggestion, not seven generic pills -->
  <section class="w-full bg-cream py-12">
    <div class="mx-auto max-w-[560px] px-5 text-center">
      {matched ? (
        <p class="text-sm text-muted">
          While you wait, learn more about our <a href={matched.href} class="font-semibold text-primary underline underline-offset-2 transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:rounded-sm">{matched.linkLabel}</a> services, or <a href="/blog" class="font-semibold text-primary underline underline-offset-2 transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:rounded-sm">read our blog</a>.
        </p>
      ) : (
        <p class="text-sm text-muted">
          While you wait, <a href="/blog" class="font-semibold text-primary underline underline-offset-2 transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:rounded-sm">explore our cost guides</a> or <a href="/" class="font-semibold text-primary underline underline-offset-2 transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:rounded-sm">head back home</a>.
        </p>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* Animated checkmark */
  .checkmark-circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  .checkmark-path {
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.4s forwards;
  }
  @keyframes stroke {
    100% { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .checkmark-circle, .checkmark-path, a {
      animation: none !important;
      transition: none !important;
      stroke-dashoffset: 0;
    }
  }
</style>
