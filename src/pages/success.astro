---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  noindex
  title="Hamilton Exteriors"
  description="Thank you for contacting Hamilton Exteriors. We'll be in touch shortly."
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />

  <!-- Thank You Hero -->
  <section class="w-full bg-cream py-32">
    <div class="mx-auto max-w-[600px] px-5 text-center">
      <div class="mx-auto mb-8 flex size-20 items-center justify-center">
        <svg class="size-20" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none" stroke="rgb(37, 99, 70)" stroke-width="2" />
          <path class="checkmark-path" d="M14.5 27.5L22 35L37.5 18" fill="none" stroke="rgb(37, 99, 70)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <h1 class="font-oswald text-[36px] leading-tight font-bold text-[rgb(28,28,28)] md:text-[48px]">
        Thank You!
      </h1>
      <p class="mt-4 font-dm-sans text-lg text-gray-600">
        We'll contact you within <strong>3-5 minutes</strong>.
      </p>
      <p class="mt-2 font-dm-sans text-base text-gray-500">
        Your project manager will call to learn about your project and find a time for your on-site estimate.
      </p>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="w-full bg-white py-20">
    <div class="mx-auto max-w-[900px] px-5">
      <h2 class="mb-10 text-center font-oswald text-[28px] font-semibold text-[rgb(28,28,28)] md:text-[36px]">
        What Happens Next
      </h2>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex size-14 items-center justify-center rounded-full bg-primary/10">
            <span class="font-dm-sans text-xl font-bold text-primary">1</span>
          </div>
          <h3 class="mb-2 font-dm-sans text-lg font-semibold text-[rgb(28,28,28)]">Quick Call</h3>
          <p class="font-dm-sans text-sm text-gray-600">We'll call you within 3–5 minutes to understand your project and answer any questions.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex size-14 items-center justify-center rounded-full bg-primary/10">
            <span class="font-dm-sans text-xl font-bold text-primary">2</span>
          </div>
          <h3 class="mb-2 font-dm-sans text-lg font-semibold text-[rgb(28,28,28)]">Free Inspection</h3>
          <p class="font-dm-sans text-sm text-gray-600">We'll schedule an in-home or virtual consultation to assess your project needs.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex size-14 items-center justify-center rounded-full bg-primary/10">
            <span class="font-dm-sans text-xl font-bold text-primary">3</span>
          </div>
          <h3 class="mb-2 font-dm-sans text-lg font-semibold text-[rgb(28,28,28)]">Detailed Estimate</h3>
          <p class="font-dm-sans text-sm text-gray-600">Receive an itemized estimate with every option clearly explained.</p>
        </div>
      </div>
    </div>
  </section>

  <ReviewLogos />

  <!-- Quick Links -->
  <section class="w-full bg-cream py-16">
    <div class="mx-auto max-w-[600px] px-5 text-center">
      <p class="mb-4 font-dm-sans text-base text-gray-600">
        Had a great experience? Leave us a review:
      </p>
      <a
        href="https://www.google.com/maps/place/Hamilton+Exteriors,+21634+Redwood+Rd+Unit+F,+Castro+Valley,+CA+94546"
        target="_blank"
        rel="noopener noreferrer"
        class="mb-8 inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-6 py-2.5 font-dm-sans text-sm font-semibold text-gray-700 shadow-sm transition-colors hover:bg-gray-50"
      >
        <svg class="size-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Rate Us on Google
      </a>
      <p class="mb-6 font-dm-sans text-base text-gray-600">
        While you wait, explore our services:
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/roofing" class="rounded-full border border-primary px-6 py-2 font-dm-sans text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Roofing</a>
        <a href="/siding" class="rounded-full border border-primary px-6 py-2 font-dm-sans text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Siding</a>
        <a href="/windows" class="rounded-full border border-primary px-6 py-2 font-dm-sans text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Windows</a>
        <a href="/additions" class="rounded-full border border-primary px-6 py-2 font-dm-sans text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Additions</a>
        <a href="/adu" class="rounded-full border border-primary px-6 py-2 font-dm-sans text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">ADUs</a>
      </div>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-primary px-8 py-3 font-dm-sans text-sm font-semibold text-white transition-colors hover:bg-primary/90"
      >
        Back to Home
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
