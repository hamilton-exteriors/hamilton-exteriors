---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
import Difference from '../components/Difference.astro';
import Financing from '../components/Financing.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Projects from '../components/Projects.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';

const roofingStyles = [
  {
    title: 'Asphalt Shingles',
    description: 'Composite shingles are durable roofing materials made from a mixture of fiberglass, asphalt, and mineral granules. They offer excellent weather resistance and come in a variety of styles and colors to suit different architectural designs.',
    image: 'https://framerusercontent.com/images/78SpfVUD0CEzzt0mXOY0mac1iQI.png',
  },
  {
    title: 'Metal Roofs',
    description: 'Metal roofs offer outstanding longevity and energy efficiency, lasting up to 50 years or more. They come in various styles and colors, providing excellent protection against extreme weather while reflecting solar radiant heat to reduce cooling costs.',
    image: 'https://framerusercontent.com/images/QMTQaWPeeRKxJY08j2jMHjX9KHU.png',
  },
  {
    title: 'Tile Shingles',
    description: 'Tile roofing offers exceptional durability and aesthetic appeal, with options ranging from traditional clay to modern concrete designs. These versatile materials provide excellent insulation and fire resistance, making them a popular choice for homeowners seeking long-lasting, attractive roofing solutions.',
    image: 'https://framerusercontent.com/images/3weyvQn8HW3YUb9g4G7XaXxOhcg.png',
  },
  {
    title: 'Energy Roofs',
    description: 'The GAF Energy roof integrates solar technology directly into roofing materials, combining energy production with traditional roof protection. This innovative system offers a sleek, low-profile alternative to conventional solar panels while providing clean energy and potential savings on electricity bills.',
    image: 'https://framerusercontent.com/images/F4Yw7I2g5SM6tYvTiEAbllrwE0.png',
  },
];
---

<Layout
  title="Reliable Roofing in Castro Valley, CA | Hamilton Exteriors"
  description="Hamilton Exteriors provides top-rated roofing services in Castro Valley, CA. Composite shingles, metal roofs, tile, and solar. Call Now!"
>
  <AnnouncementBar text="Limited Time Get up to $2000 off your Roof Replacement*" />
  <Navbar />
  <Hero
    headline="Best Roofing Company IN Castro Valley, CA"
    formTitle="Get a FREE ROOF INSPECTION"
    formSubtitle="We'll contact you in 3-5 minutes to schedule a FREE roof inspection."
    ctaText="Call Now - We Answer Fast"
  />
  <LogoSlider />
  <Reviews />
  <CTA />
  <ReviewLogos />

  <!-- Roofing Styles Section -->
  <section class="w-full" style="padding: 79px 0;">
    <div class="mx-auto" style="max-width: 1182px; padding: 0 15px;">
      <h2
        class="mb-6 text-center"
        style="font-family: 'THE BOLD FONT (FREE VERSION)', 'THE BOLD FONT PRO', 'Oswald', sans-serif; font-size: 40px; line-height: 50px; letter-spacing: 0px; color: rgb(13, 43, 29); font-weight: 400; text-transform: uppercase;"
      >
        Roofing Styles Offered
      </h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2" style="margin-top: 20px;">
        {roofingStyles.map((style) => (
          <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
            <div class="overflow-hidden" style="height: 220px;">
              <img
                src={style.image}
                alt={style.title}
                class="h-full w-full"
                style="object-fit: fill;"
                loading="lazy"
              />
            </div>
            <div style="padding: 20px 24px 24px;">
              <h3
                style="font-family: 'Inter Display', 'Inter', sans-serif; font-size: 18px; font-weight: 800; line-height: 24px; color: rgb(13, 43, 29); margin-bottom: 6px;"
              >
                {style.title}
              </h3>
              <p style="font-size: 14px; line-height: 150%; color: rgb(104, 104, 105);">
                {style.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Difference />
  <Projects />
  <Financing />
  <FAQ />
  <ContactUs />
  <Footer />
</Layout>
