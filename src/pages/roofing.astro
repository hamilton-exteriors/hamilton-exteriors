---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/roofing';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${siteUrl}/roofing#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Roofing', item: `${siteUrl}/roofing` },
  ],
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/roofing#webpage`,
  url: `${siteUrl}/roofing`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/roofing#service` },
  inLanguage: 'en-US',
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.local-context p:first-of-type', 'details:first-of-type p', 'h2 + p'] },
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/roofing#service`,
  name: 'Roofing',
  url: `${siteUrl}/roofing`,
  description: data.description,
  provider: { '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'AdministrativeArea', name: 'San Mateo County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
