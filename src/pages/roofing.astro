---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/roofing';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Roofing', item: `${siteUrl}/roofing` },
  ],
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/roofing#service`,
  name: 'Roofing',
  description: 'Residential roof replacement, repair, and installation across the Bay Area. Asphalt shingles, metal roofing, tile, and GAF solar. 50-year warranty, licensed and insured.',
  url: `${siteUrl}/roofing`,
  serviceType: ['Roof Replacement', 'Roof Repair', 'Metal Roofing', 'Tile Roofing', 'Solar Roofing'],
  provider: { '@type': 'RoofingContractor', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'County', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '8000',
    highPrice: '45000',
    description: 'Roof replacement cost depends on size, pitch, and material',
  },
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/roofing#webpage`,
  url: `${siteUrl}/roofing`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/roofing#service` },
  inLanguage: 'en-US',
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
