---
import Layout from '../../layouts/Layout.astro';
import SubServicePage from '../../components/SubServicePage.astro';
import { SUB_SERVICE_IMAGES } from '../../data/sub-services';
import { getSubService } from '../../lib/ghost';
import type { SubServiceData } from '../../data/sub-services';

const { type } = Astro.params;
const images = SUB_SERVICE_IMAGES[`adu/${type}`];
if (!images) return Astro.redirect('/adu', 301);

const ghost = await getSubService('adu', type!);
if (!ghost) return Astro.redirect('/adu', 301);

const data: SubServiceData = { ...ghost, ...images } as SubServiceData;
---

<Layout title={data.title} description={data.description} heroImage={data.heroImage} preloadHero>
  <SubServicePage data={data} />
</Layout>
