---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTAButton from '../components/CTAButton.astro';
import { PHONE_DISPLAY, PHONE_HREF, EMAIL, ADDRESS, CSLB_URL } from '../lib/constants';

const siteUrl = import.meta.env.SITE || 'https://hamilton-exteriors.com';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Hamilton Exteriors',
  description: 'Get in touch with Hamilton Exteriors for roofing, siding, windows, ADUs, and custom home projects across the Bay Area.',
  url: `${siteUrl}/contact`,
  mainEntity: {
    '@type': 'GeneralContractor',
    '@id': `${siteUrl}/#business`,
    name: 'Hamilton Exteriors',
    telephone: '+16509773351',
    email: EMAIL,
    address: {
      '@type': 'PostalAddress',
      streetAddress: '21634 Redwood Rd Unit F',
      addressLocality: 'Castro Valley',
      addressRegion: 'CA',
      postalCode: '94546',
      addressCountry: 'US',
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Contact' },
  ],
};
---

<Layout
  title="Contact Hamilton Exteriors | Bay Area Contractor"
  description="Call (650) 977-3351 or visit us at 21634 Redwood Rd, Castro Valley. Free estimates for roofing, siding, windows, ADUs & custom homes. CSLB #1082377."
  jsonLd={[contactSchema, breadcrumbSchema]}
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />

  <main>
    <!-- Hero -->
    <section class="w-full bg-heading pt-28 pb-12 md:pt-32 md:pb-16">
      <div class="mx-auto max-w-[1170px] px-5">
        <nav class="mb-6 text-sm text-white/60" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white/80 transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white/90">Contact</span>
        </nav>
        <h1 class="font-hamilton-display text-[clamp(2.25rem,6vw,3.5rem)] leading-[1.05] font-bold text-white uppercase">
          Get in Touch
        </h1>
        <p class="mt-4 max-w-[50ch] text-lg leading-relaxed text-white/80">
          Whether you need a roof inspection, siding estimate, or want to discuss a custom home project, we're here to help.
        </p>
      </div>
    </section>

    <!-- Contact content -->
    <section class="w-full bg-cream py-16 md:py-20">
      <div class="mx-auto max-w-[1170px] px-5">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">

          <!-- Left: Contact details -->
          <div>
            <h2 class="font-hamilton-display text-2xl font-bold text-heading uppercase tracking-wide">Call Us</h2>
            <a
              href={PHONE_HREF}
              class="mt-4 block font-hamilton-display text-[clamp(2rem,5vw,3rem)] leading-none font-bold text-primary-dark no-underline transition-opacity hover:opacity-80"
            >
              {PHONE_DISPLAY}
            </a>
            <p class="mt-2 text-base text-muted">We pick up in minutes. Mon-Fri 7am-6pm, Sat 8am-2pm PT.</p>

            <h2 class="mt-10 font-hamilton-display text-2xl font-bold text-heading uppercase tracking-wide">Email</h2>
            <a href={`mailto:${EMAIL}`} class="mt-3 block text-lg text-primary-dark underline underline-offset-2 transition-opacity hover:opacity-80">
              {EMAIL}
            </a>

            <h2 class="mt-10 font-hamilton-display text-2xl font-bold text-heading uppercase tracking-wide">Office</h2>
            <address class="mt-3 text-base leading-relaxed text-body not-italic">
              <a
                href="https://maps.google.com/?cid=3578771346418026097"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-dark underline underline-offset-2 transition-opacity hover:opacity-80"
              >
                {ADDRESS}
              </a>
            </address>

            <h2 class="mt-10 font-hamilton-display text-2xl font-bold text-heading uppercase tracking-wide">License</h2>
            <p class="mt-3 text-base text-body">
              <a href={CSLB_URL} target="_blank" rel="noopener noreferrer" class="text-primary-dark underline underline-offset-2 transition-opacity hover:opacity-80">
                CSLB #1082377
              </a>
              — Licensed, bonded, and insured.
            </p>

            <div class="mt-10 flex flex-col gap-3 sm:flex-row">
              <CTAButton href="/#quote" size="lg">Get Your Free Quote</CTAButton>
              <CTAButton href={PHONE_HREF} variant="outline" size="lg">Call Now</CTAButton>
            </div>
          </div>

          <!-- Right: Map -->
          <div>
            <div class="overflow-hidden rounded-lg shadow-md">
              <iframe
                src="https://www.google.com/maps?cid=3578771346418026097&output=embed"
                width="100%"
                height="400"
                class="block border-0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Hamilton Exteriors — 21634 Redwood Rd Unit F, Castro Valley, CA 94546"
                allowfullscreen
              ></iframe>
            </div>

            <div class="mt-6">
              <h3 class="font-hamilton-display text-lg font-bold text-heading uppercase tracking-wide">Service Areas</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">
                Serving 6 Bay Area counties:
                <a href="/service-areas/alameda-county-ca" class="text-primary-dark underline underline-offset-2">Alameda</a>,
                <a href="/service-areas/contra-costa-county-ca" class="text-primary-dark underline underline-offset-2">Contra Costa</a>,
                <a href="/service-areas/marin-county-ca" class="text-primary-dark underline underline-offset-2">Marin</a>,
                <a href="/service-areas/napa-county-ca" class="text-primary-dark underline underline-offset-2">Napa</a>,
                <a href="/service-areas/san-mateo-county-ca" class="text-primary-dark underline underline-offset-2">San Mateo</a>, and
                <a href="/service-areas/santa-clara-county-ca" class="text-primary-dark underline underline-offset-2">Santa Clara</a>.
                <a href="/service-areas" class="ml-1 text-primary-dark underline underline-offset-2">All 47 cities &rarr;</a>
              </p>
            </div>

            <div class="mt-6">
              <h3 class="font-hamilton-display text-lg font-bold text-heading uppercase tracking-wide">Hours</h3>
              <div class="mt-2 text-sm leading-relaxed text-muted">
                <p>Monday - Friday: 7:00 AM - 6:00 PM</p>
                <p>Saturday: 8:00 AM - 2:00 PM</p>
                <p>Sunday: Closed</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
