---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Terms of Service | Hamilton Exteriors"
  description="Review the terms of service for Hamilton Exteriors. Understand your rights and responsibilities when using our website and services."
>
  <AnnouncementBar />
  <Navbar />

  <section class="w-full bg-cream py-20">
    <div class="mx-auto max-w-[800px] px-5">
      <h1 class="font-display text-[36px] font-bold leading-tight text-[rgb(28,28,28)] md:text-[48px]">
        Terms of Service
      </h1>

      <div class="mt-12 space-y-6 font-dm-sans text-base leading-relaxed text-gray-700">
        <p>This page is being updated. Please contact us at <a href="tel:6509773351" class="text-primary underline">(650) 977-3351</a> for any questions.</p>
      </div>
    </div>
  </section>

  <section class="w-full bg-white py-16">
    <div class="mx-auto max-w-[600px] px-5 text-center">
      <p class="font-dm-sans text-base text-gray-600">
        Have questions about our services?
      </p>
      <a
        href="/"
        class="mt-4 inline-block rounded-full bg-primary px-8 py-3 font-dm-sans text-sm font-semibold text-white transition-colors hover:bg-primary/90"
      >
        Back to Home
      </a>
    </div>
  </section>

  <Footer />
</Layout>
