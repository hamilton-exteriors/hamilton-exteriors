---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/adu';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'ADU', item: `${siteUrl}/adu` },
  ],
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/adu#service`,
  name: 'ADU Construction',
  description: 'Full-service ADU builder in the Bay Area. Detached ADUs, garage conversions, and junior ADUs. Design, architecture, engineering, permitting, and construction.',
  url: `${siteUrl}/adu`,
  serviceType: ['ADU Construction', 'Garage Conversion', 'Junior ADU', 'Detached ADU'],
  provider: { '@type': 'GeneralContractor', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'County', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '150000',
    highPrice: '350000',
    description: 'ADU cost depends on size, finishes, and whether new build or garage conversion',
  },
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/adu#webpage`,
  url: `${siteUrl}/adu`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/adu#service` },
  inLanguage: 'en-US',
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
