---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': 'https://hamilton-exteriors.com/buy#webapp',
  name: 'Hamilton Exteriors Online Roof Scanner',
  url: 'https://hamilton-exteriors.com/buy',
  applicationCategory: 'BusinessApplication',
  description: 'Scan your roof with satellite imagery and get an instant price for a new roof — no salesperson required.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free roof scan and instant pricing',
  },
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://hamilton-exteriors.com/buy#service',
  name: 'Online Roof Replacement',
  description: 'Buy a roof replacement online with satellite imagery pricing. No salespeople, no commission. GAF Master Elite certified installation with manufacturer warranty.',
  provider: { '@type': 'GeneralContractor', '@id': 'https://hamilton-exteriors.com/#business', name: 'Hamilton Exteriors' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Alameda County' },
    { '@type': 'AdministrativeArea', name: 'Contra Costa County' },
    { '@type': 'AdministrativeArea', name: 'Marin County' },
    { '@type': 'AdministrativeArea', name: 'Napa County' },
    { '@type': 'AdministrativeArea', name: 'Santa Clara County' },
    { '@type': 'AdministrativeArea', name: 'San Mateo County' },
  ],
  serviceType: 'Roof Replacement',
  termsOfService: 'https://hamilton-exteriors.com/terms',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Roofing Packages',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Standard Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '940', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Premium Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1000', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Designer Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1175', priceCurrency: 'USD', unitText: 'per roofing square' } },
    ],
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do you know what my roof needs without visiting?',
      acceptedAnswer: { '@type': 'Answer', text: 'We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.' },
    },
    {
      '@type': 'Question',
      name: 'How can you be so much cheaper without cutting corners?',
      acceptedAnswer: { '@type': 'Answer', text: 'Traditional roofing companies pay their salespeople 30-40% commission on every job. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.' },
    },
    {
      '@type': 'Question',
      name: 'What about the warranty?',
      acceptedAnswer: { '@type': 'Answer', text: 'Every roof comes with a manufacturer\'s warranty (25 years to lifetime, depending on the material) plus our own 35-year labor guarantee. We\'re a GAF Master Elite contractor — only 2% of roofers in the country qualify.' },
    },
    {
      '@type': 'Question',
      name: 'How does financing work?',
      acceptedAnswer: { '@type': 'Answer', text: 'We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.' },
    },
    {
      '@type': 'Question',
      name: 'What if the on-site inspection finds something different?',
      acceptedAnswer: { '@type': 'Answer', text: 'We\'ll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. No surprises.' },
    },
    {
      '@type': 'Question',
      name: 'How long does a typical roof take?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup.' },
    },
  ],
};
---

<Layout
  title="Buy Your Roof Online | Hamilton Exteriors"
  description="Skip the salesman. Enter your address, see your roof, get an instant price. Buy your new roof online from Hamilton Exteriors."
  jsonLd={[webAppJsonLd, serviceJsonLd, faqJsonLd]}
  noindex
>
  <Navbar slot="header" />

  <!-- ── HERO — address input drives to /buy/scan ──────────────────── -->
  <section id="buy-hero" class="relative z-2 w-full bg-footer">
    <div class="relative z-10 mx-auto max-w-[720px] text-center">
      <p class="mb-4 text-sm font-semibold tracking-[2px] text-yellow uppercase">No salespeople. No commission. No games.</p>
      <h1 class="mb-4 text-[clamp(40px,7vw,72px)] leading-[1.05] text-white">
        Buy Your Roof Online
      </h1>
      <p class="mx-auto mb-8 max-w-[480px] text-lg leading-[28px] text-white-70">
        Enter your address. We'll scan your roof and give you an instant price — no salesperson required.
      </p>
      <form id="hero-form" class="relative z-20 mx-auto max-w-[520px] px-1" action="/buy/scan">
        <input
          id="hero-address-input"
          name="address"
          type="text"
          placeholder="Enter your home address"
          autocomplete="off"
          required
          aria-label="Home address"
          maxlength="200"
          class="w-full rounded-[4px] border-2 border-white/15 bg-white/8 py-[18px] pr-[140px] pl-5 text-[17px] text-white transition-[border-color] duration-200 outline-none"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 right-[130px] hidden -translate-y-1/2" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] bg-yellow px-6 py-3 font-oswald text-sm font-bold tracking-[0.05em] text-footer uppercase transition-all hover:opacity-90"
        >
          Scan My Roof
        </button>
        <div id="hero-dropdown" class="addr-dropdown absolute inset-x-0 top-full z-50 mt-1 hidden overflow-hidden rounded-[4px] shadow-lg"></div>
      </form>
      <p class="mt-4 text-[13px] text-white-65">
        Serving all of California &middot; Bay Area, Sacramento, Stockton & beyond
      </p>
    </div>
  </section>

  <!-- ── WHY WE'RE DIFFERENT — comparison + stats ───────────────────── -->
  <section class="w-full bg-white px-5 pt-16 pb-0">
    <div class="mx-auto max-w-[1060px]">
      <h2 class="mb-4 text-center text-[clamp(28px,4vw,48px)] leading-[1.1] text-footer">
        Where does your money <em class="normal-case italic">actually</em> go?
      </h2>
      <p class="mx-auto mb-12 max-w-[600px] text-center text-muted">

        Most roofing companies are sales organizations with a construction crew attached. Here's the difference.
      </p>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Traditional -->
        <div class="rounded-[4px] border-2 border-border bg-cream p-8">
          <p class="text-label-uppercase mb-4 text-muted">Typical Roofing Company</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">30-40% sales commission</p>
                <p class="text-[13px] text-muted">The guy knocking on your door gets paid before anyone touches your roof.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">High-pressure sales tactics</p>
                <p class="text-[13px] text-muted">"This price is only good today." Sound familiar?</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Opaque pricing</p>
                <p class="text-[13px] text-muted">No breakdown, no comparison. Just a number on a clipboard.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Undertrained install crews</p>
                <p class="text-[13px] text-muted">Budget goes to sales, not skilled labor.</p>
              </div>
            </div>
          </div>
          <div class="bar-chart-track mt-6 h-8 overflow-hidden rounded-[4px] bg-[#e8e4de]">
            <div class="flex h-full">
              <div class="flex h-full w-[35%] items-center justify-center bg-[#c44] text-[11px] font-bold text-white">COMMISSION 35%</div>
              <div class="flex h-full w-[20%] items-center justify-center bg-[#e8a87c] text-[11px] font-semibold">Overhead</div>
              <div class="flex h-full w-[25%] items-center justify-center bg-border text-[11px] font-semibold">Materials</div>
              <div class="flex h-full w-[20%] items-center justify-center bg-[#b8b3a8] text-[11px] font-semibold">Labor</div>
            </div>
          </div>
        </div>
        <!-- Hamilton -->
        <div class="rounded-[4px] border-3 border-primary bg-cream p-8" style="box-shadow: 0 0 0 4px rgba(37,99,70,0.10), 0 8px 24px rgba(37,99,70,0.12);">
          <p class="text-label-uppercase mb-4 text-primary">Hamilton Exteriors</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">0% sales commission</p>
                <p class="text-[13px] text-muted">Buy online. No salesperson, no markup, no games.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Transparent, instant pricing</p>
                <p class="text-[13px] text-muted">See every line item. Materials, labor, permits — no hidden fees.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">100% focused on installation quality</p>
                <p class="text-[13px] text-muted">All staff, all budget, all energy goes into your roof — not closing deals.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Experienced, certified crews</p>
                <p class="text-[13px] text-muted">GAF Master Elite certified. We invest in craft, not commissions.</p>
              </div>
            </div>
          </div>
          <div class="bar-chart-track mt-6 h-8 overflow-hidden rounded-[4px] bg-[#e8e4de]">
            <div class="flex h-full">
              <div class="flex h-full w-[40%] items-center justify-center bg-primary text-[11px] font-bold text-white">MATERIALS 40%</div>
              <div class="flex h-full w-[35%] items-center justify-center bg-[rgb(45,110,70)] text-[11px] font-semibold text-white">Labor 35%</div>
              <div class="flex h-full w-[25%] items-center justify-center bg-[rgb(65,125,85)] text-[11px] font-semibold text-white">Permits 25%</div>
            </div>
          </div>
        </div>
      </div>
      <!-- Stats -->
      <div class="stats-row mt-10 rounded-[4px] border border-border bg-cream px-6 py-9">
        <div class="grid grid-cols-2 gap-6 text-center md:grid-cols-4">
          <div>
            <p class="font-oswald text-[clamp(36px,5vw,48px)] leading-none text-primary">0%</p>
            <p class="mt-1.5 text-[13px] text-muted">Sales Commission</p>
          </div>
          <div>
            <p class="font-oswald text-[clamp(36px,5vw,48px)] leading-none text-primary">$4,200</p>
            <p class="mt-1.5 text-[13px] text-muted">Avg. Customer Savings</p>
          </div>
          <div>
            <p class="font-oswald text-[clamp(36px,5vw,48px)] leading-none text-primary">500+</p>
            <p class="mt-1.5 text-[13px] text-muted">Roofs Completed</p>
          </div>
          <div>
            <p class="font-oswald text-[clamp(36px,5vw,48px)] leading-none text-primary">4.8</p>
            <p class="mt-1.5 text-[13px] text-muted">Google Rating</p>
          </div>
        </div>
        <!-- Trust badges -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4 border-t border-border pt-4">
          <span class="font-satoshi text-xs font-semibold tracking-[0.05em] text-primary uppercase">GAF Master Elite Contractor</span>
          <span class="text-xs text-border">&bull;</span>
          <span class="font-satoshi text-xs font-semibold tracking-[0.05em] text-muted uppercase">CSLB #1082377</span>
          <span class="text-xs text-border">&bull;</span>
          <span class="font-satoshi text-xs font-semibold tracking-[0.05em] text-muted uppercase">Licensed &amp; Insured</span>
        </div>
      </div>
      <div class="pb-12"></div>
    </div>
  </section>

  <!-- ── SOCIAL PROOF ──────────────────────────────────────────────── -->
  <section class="w-full bg-cream px-5 py-16 pb-14">
    <div class="mx-auto max-w-[1060px]">
      <p class="text-label-uppercase mb-6 text-center text-primary">What homeowners say</p>
      <div class="mx-auto mb-8 max-w-[760px] rounded-[4px] border border-border bg-white p-10">
        <blockquote class="text-center font-oswald text-[clamp(20px,3vw,28px)] leading-[1.4] text-charcoal italic">
          "I got three quotes from traditional roofers — all $15k+. Hamilton's online price was $11,200 for better materials. The savings from cutting out the salesman are real."
        </blockquote>
        <div class="mt-6 flex items-center justify-center gap-3">
          <div class="flex size-10 items-center justify-center rounded-full bg-primary text-[15px] font-semibold text-white">DK</div>
          <div>
            <p class="text-sm font-semibold text-charcoal">David & Lin K.</p>
            <p class="text-[13px] text-muted">San Leandro, CA &middot; Saved $3,800</p>
          </div>
        </div>
      </div>
      <div class="mx-auto grid max-w-[760px] grid-cols-1 gap-6 md:grid-cols-2">
        <div class="rounded-[4px] border border-border bg-white p-6">
          <div class="mb-2 flex gap-1">
            <span class="text-sm text-yellow">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="mb-3 text-sm leading-[1.7] text-charcoal">
            "Typed my address, got an instant price. No waiting for some guy to come measure. So easy."
          </p>
          <p class="text-[13px] font-semibold text-charcoal">Maria S. <span class="font-normal text-muted">&middot; Oakland</span></p>
        </div>
        <div class="rounded-[4px] border border-border bg-white p-6">
          <div class="mb-2 flex gap-1">
            <span class="text-sm text-yellow">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="mb-3 text-sm leading-[1.7] text-charcoal">
            "The transparency blew me away. Every line item right there. The crew showed up on time and did an incredible job."
          </p>
          <p class="text-[13px] font-semibold text-charcoal">James T. <span class="font-normal text-muted">&middot; Pleasanton</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MID-PAGE CTA ──────────────────────────────────────────────── -->
  <section class="w-full bg-primary px-5 py-12">
    <div class="mx-auto max-w-[600px] text-center">
      <p class="mb-4 font-oswald text-[clamp(22px,3.5vw,32px)] leading-[1.15] text-white uppercase">
        Ready to see your price?
      </p>
      <p class="mb-6 text-base text-white-75">
        Scan your roof in 30 seconds. No email required, no strings attached.
      </p>
      <a
        href="/buy/scan"
        class="inline-block rounded-[4px] bg-yellow px-10 py-4 font-oswald text-base font-bold tracking-[0.05em] text-footer uppercase no-underline transition-all hover:opacity-90"
      >
        Scan Your Roof Now
      </a>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────── -->
  <section class="w-full bg-white px-5 pt-14 pb-[72px]">
    <div class="mx-auto max-w-[720px]">
      <h2 class="mb-12 text-center text-[clamp(28px,4vw,48px)] leading-[1.1] text-footer">
        Common questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How do you know what my roof needs without visiting?</summary>
          <div class="faq-answer">
            <p>We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How can you be so much cheaper without cutting corners?</summary>
          <div class="faq-answer">
            <p>Traditional roofing companies pay their salespeople 30-40% commission on every job. That's $3,000-$8,000 per roof that goes to the person who knocked on your door — not to materials or labor. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">What about the warranty?</summary>
          <div class="faq-answer">
            <p>Every roof comes with a manufacturer's warranty (25 years to lifetime, depending on the material you choose) plus our own 35-year labor guarantee. We're a GAF Master Elite contractor — only 2% of roofers in the country qualify.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How does financing work?</summary>
          <div class="faq-answer">
            <p>We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">What if the on-site inspection finds something different?</summary>
          <div class="faq-answer">
            <p>We'll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. No surprises.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How long does a typical roof take?</summary>
          <div class="faq-answer">
            <p>Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup — you don't have to do anything.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────────────── -->
  <section class="w-full bg-footer px-5 py-[72px]">
    <div class="mx-auto max-w-[640px] text-center">
      <h2 class="mb-3 text-[clamp(28px,4vw,44px)] leading-[1.1] text-white">
        Your new roof is 3 clicks away
      </h2>
      <p class="mb-8 text-[17px] text-white-70">
        Enter your address, see your price, and buy your roof in minutes — no salesperson ever.
      </p>
      <form class="cta-address-form relative mx-auto max-w-[480px] px-1" action="/buy/scan">
        <input
          name="address"
          type="text"
          placeholder="Enter your home address"
          required
          autocomplete="off"
          aria-label="Home address"
          maxlength="200"
          class="cta-address-input w-full rounded-[4px] border-2 border-white/15 bg-white/8 py-[18px] pr-[140px] pl-5 text-[17px] text-white outline-none"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 right-[130px] hidden -translate-y-1/2" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <div class="cta-dropdown addr-dropdown absolute inset-x-0 top-full z-50 mt-1 hidden overflow-hidden rounded-[4px] shadow-lg"></div>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] bg-yellow px-6 py-3 font-oswald text-sm font-bold tracking-[0.05em] text-footer uppercase transition-all hover:opacity-90"
        >
          Scan My Roof
        </button>
      </form>
      <div class="mt-7 border-t border-white/10 pt-5">
        <p class="mb-2 text-sm text-white-60">Prefer to talk to a human?</p>
        <a href="tel:+16509773351" class="font-oswald text-[clamp(22px,3vw,28px)] font-bold tracking-[0.02em] text-yellow no-underline transition-opacity duration-150 hover:opacity-80">(650) 977-3351</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* Hero responsive padding */
  #buy-hero { padding: 80px 20px 56px; }
  @media (min-width: 768px) {
    #buy-hero { padding: 120px 24px 80px; }
  }

  #hero-address-input:focus {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.12);
  }
  #hero-address-input::placeholder {
    color: var(--color-white-45);
  }
  .faq-summary {
    list-style: none;
    cursor: pointer;
    min-height: 48px;
    padding: 16px 48px 16px 20px;
    font-family: var(--font-dm-sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-charcoal);
    position: relative;
    user-select: none;
    display: flex;
    align-items: center;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after {
    content: '+';
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-dm-sans);
    font-size: 22px;
    font-weight: 300;
    color: var(--color-muted);
  }
  .faq-item[open] .faq-summary::after { content: '\2212'; }
  .faq-answer {
    padding: 0 20px 20px;
    font-family: var(--font-dm-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
  }
  footer a[aria-label] {
    min-width: 44px;
    min-height: 44px;
    display: flex !important;
    align-items: center;
    justify-content: center;
  }
  /* Dark-themed address autocomplete dropdown — :global needed for JS-injected content */
  .addr-dropdown {
    background: #1c1c1c;
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  :global(.address-suggestion) {
    padding: 14px 16px;
    cursor: pointer;
    font-family: var(--font-dm-sans);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.15s;
    text-align: left;
  }
  :global(.address-suggestion:last-child) { border-bottom: none; }
  :global(.address-suggestion:hover),
  :global(.address-suggestion--active) {
    background: rgba(255,255,255,0.08);
  }
  :global(.address-suggestion .suggestion-name) {
    font-size: 15px;
    font-weight: 500;
    color: white;
    line-height: 1.3;
  }
  :global(.address-suggestion .suggestion-detail) {
    font-size: 13px;
    color: var(--color-white-50);
    margin-top: 2px;
  }
  /* Pin icon in suggestions */
  :global(.suggestion-icon) {
    flex-shrink: 0;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
  }
  /* Clear / X button */
  .addr-clear-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .addr-clear-btn.visible {
    display: flex !important;
  }
  .addr-clear-btn:hover { opacity: 1; }
  .addr-clear-btn:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }
  /* Comparison bar chart: taller + larger text on mobile */
  @media (max-width: 640px) {
    .bar-chart-track { height: 40px !important; }
    .bar-chart-track .h-full { font-size: 10px !important; }
    .stats-row .grid { gap: 12px; }
  }
</style>

<script define:vars={{ mapboxToken }}>
  window.__MAPBOX_TOKEN = mapboxToken;
</script>
<script is:inline>
(function() {
  var TOKEN = window.__MAPBOX_TOKEN || '';
  var session = crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2);
  var BA_BBOX = '-123.1,36.9,-121.2,38.9';
  var PIN_SVG = '<svg class="suggestion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>';

  function esc(s) { return s.replace(/[<>"&]/g, function(c) { return '&#' + c.charCodeAt(0) + ';'; }); }

  function setupAutofill(input, dropdown) {
    if (!input || !dropdown) return;
    var timer = null;
    var activeIdx = -1;
    var clearBtn = input.parentElement.querySelector('.addr-clear-btn');

    function toggleClear() {
      if (!clearBtn) return;
      clearBtn.classList.toggle('visible', input.value.trim().length > 0);
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        input.value = '';
        dropdown.classList.add('hidden');
        toggleClear();
        input.focus();
      });
    }

    function setActive(items, idx) {
      items.forEach(function(el, i) {
        el.classList.toggle('address-suggestion--active', i === idx);
      });
    }

    input.addEventListener('input', function() {
      clearTimeout(timer);
      toggleClear();
      activeIdx = -1;
      var v = input.value.trim();
      if (v.length < 4) { dropdown.classList.add('hidden'); return; }
      timer = setTimeout(function() {
        fetch('https://api.mapbox.com/search/searchbox/v1/suggest?q=' + encodeURIComponent(v) +
          '&types=address&country=us&language=en&limit=5&bbox=' + BA_BBOX +
          '&session_token=' + session + '&access_token=' + TOKEN)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (!data.suggestions || !data.suggestions.length) { dropdown.classList.add('hidden'); return; }
            dropdown.innerHTML = data.suggestions.map(function(s) {
              var name = esc(s.name || s.full_address || '');
              var detail = '';
              if (s.full_address && s.name && s.full_address !== s.name) {
                detail = esc(s.full_address.replace(s.name, '').replace(/^[\s,]+/, ''));
              } else if (s.place_formatted) {
                detail = esc(s.place_formatted);
              }
              return '<div class="address-suggestion flex items-start gap-3" role="option">' +
                PIN_SVG +
                '<div><div class="suggestion-name">' + name + '</div>' +
                (detail ? '<div class="suggestion-detail">' + detail + '</div>' : '') +
                '</div></div>';
            }).join('');
            dropdown.classList.remove('hidden');
            activeIdx = -1;
          })
          .catch(function() { dropdown.classList.add('hidden'); });
      }, 250);
    });

    input.addEventListener('keydown', function(e) {
      var items = dropdown.querySelectorAll('.address-suggestion');
      if (!items.length || dropdown.classList.contains('hidden')) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % items.length;
        setActive(items, activeIdx);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIdx = activeIdx <= 0 ? items.length - 1 : activeIdx - 1;
        setActive(items, activeIdx);
      } else if (e.key === 'Enter' && activeIdx >= 0) {
        e.preventDefault();
        var nameEl = items[activeIdx].querySelector('.suggestion-name');
        var detailEl = items[activeIdx].querySelector('.suggestion-detail');
        input.value = (nameEl ? nameEl.textContent : '') + (detailEl ? ', ' + detailEl.textContent : '');
        dropdown.classList.add('hidden');
        toggleClear();
      } else if (e.key === 'Escape') {
        dropdown.classList.add('hidden');
        activeIdx = -1;
      }
    });

    dropdown.addEventListener('click', function(e) {
      var item = e.target.closest('.address-suggestion');
      if (!item) return;
      var nameEl = item.querySelector('.suggestion-name');
      var detailEl = item.querySelector('.suggestion-detail');
      input.value = (nameEl ? nameEl.textContent : '') + (detailEl ? ', ' + detailEl.textContent : '');
      dropdown.classList.add('hidden');
      toggleClear();
      // Auto-submit the form after selecting a suggestion
      var form = input.closest('form');
      if (form) form.requestSubmit();
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('.address-suggestion') && e.target !== input && e.target !== clearBtn) {
        dropdown.classList.add('hidden');
      }
    });
  }

  // Hero form
  setupAutofill(document.getElementById('hero-address-input'), document.getElementById('hero-dropdown'));

  // CTA forms
  document.querySelectorAll('.cta-address-form').forEach(function(form) {
    setupAutofill(form.querySelector('.cta-address-input'), form.querySelector('.cta-dropdown'));
  });
})();
</script>
