---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Hamilton Exteriors Online Roof Scanner',
  url: 'https://hamilton-exteriors.com/buy',
  applicationCategory: 'BusinessApplication',
  description: 'Scan your roof with satellite imagery and get an instant price for a new roof — no salesperson required.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free roof scan and instant pricing',
  },
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Online Roof Replacement',
  description: 'Buy a roof replacement online with satellite imagery pricing. No salespeople, no commission. GAF Master Elite certified installation with manufacturer warranty.',
  provider: { '@type': 'RoofingContractor', '@id': 'https://hamilton-exteriors.com/#business', name: 'Hamilton Exteriors' },
  areaServed: [
    { '@type': 'County', name: 'Alameda County' },
    { '@type': 'County', name: 'Contra Costa County' },
    { '@type': 'County', name: 'Marin County' },
    { '@type': 'County', name: 'Napa County' },
    { '@type': 'County', name: 'Santa Clara County' },
  ],
  serviceType: 'Roof Replacement',
  termsOfService: 'https://hamilton-exteriors.com/terms',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Roofing Packages',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Standard Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '940', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Premium Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1000', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Designer Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1175', priceCurrency: 'USD', unitText: 'per roofing square' } },
    ],
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do you know what my roof needs without visiting?',
      acceptedAnswer: { '@type': 'Answer', text: 'We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.' },
    },
    {
      '@type': 'Question',
      name: 'How can you be so much cheaper without cutting corners?',
      acceptedAnswer: { '@type': 'Answer', text: 'Traditional roofing companies pay their salespeople 30-40% commission on every job. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.' },
    },
    {
      '@type': 'Question',
      name: 'What about the warranty?',
      acceptedAnswer: { '@type': 'Answer', text: 'Every roof comes with a manufacturer\'s warranty (25 years to lifetime, depending on the material) plus our own 10-year workmanship guarantee. We\'re a GAF Master Elite contractor — only 2% of roofers in the country qualify.' },
    },
    {
      '@type': 'Question',
      name: 'How does financing work?',
      acceptedAnswer: { '@type': 'Answer', text: 'We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.' },
    },
    {
      '@type': 'Question',
      name: 'What if the on-site inspection finds something different?',
      acceptedAnswer: { '@type': 'Answer', text: 'We\'ll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. No surprises.' },
    },
    {
      '@type': 'Question',
      name: 'How long does a typical roof take?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup.' },
    },
  ],
};
---

<Layout
  title="Buy Your Roof Online | Hamilton Exteriors"
  description="Skip the salesman. Enter your address, see your roof, get an instant price. Buy your new roof online from Hamilton Exteriors."
  jsonLd={[webAppJsonLd, serviceJsonLd]}
>
  <Navbar />

  <!-- ── HERO — address input drives to /buy/scan ──────────────────── -->
  <section class="w-full relative" style="background-color: var(--color-footer); padding: 120px 20px 80px; z-index: 2;">
    <div class="mx-auto text-center relative z-10" style="max-width: 720px;">
      <p class="mb-4" style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-yellow);">No salespeople. No commission. No games.</p>
      <h1 style="font-family: var(--font-oswald); font-size: clamp(40px, 7vw, 72px); line-height: 1.05; font-weight: 400; color: white; text-transform: uppercase; margin-bottom: 16px;">
        Buy Your Roof Online
      </h1>
      <p style="font-family: var(--font-dm-sans); font-size: 18px; line-height: 28px; color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto 32px;">
        Enter your address. We'll scan your roof and give you an instant price — no salesperson required.
      </p>
      <form id="hero-form" class="relative mx-auto" style="max-width: 520px; z-index: 20;" action="/buy/scan">
        <input
          id="hero-address-input"
          name="address"
          type="text"
          placeholder="Your address"
          autocomplete="off"
          required
          aria-label="Home address"
          maxlength="200"
          class="w-full rounded-[4px]"
          style="font-family: var(--font-dm-sans); padding: 18px 140px 18px 20px; border: 2px solid rgba(255,255,255,0.15); font-size: 17px; outline: none; background: rgba(255,255,255,0.08); color: white; transition: border-color 0.2s;"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 -translate-y-1/2 hidden" style="right:130px;" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] transition-all hover:opacity-90"
          style="padding: 12px 24px; font-size: 14px; font-family: var(--font-oswald); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; background-color: var(--color-yellow); color: var(--color-footer);"
        >
          Scan Roof
        </button>
        <div id="hero-dropdown" class="addr-dropdown hidden absolute left-0 right-0 top-full mt-1 rounded-[4px] shadow-lg overflow-hidden" style="z-index:50;"></div>
      </form>
      <p style="font-family: var(--font-dm-sans); font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 16px;">
        Bay Area only &middot; Alameda, Contra Costa, Marin, Napa & Santa Clara counties
      </p>
    </div>
  </section>

  <!-- ── WHY WE'RE DIFFERENT — comparison + stats ───────────────────── -->
  <section class="w-full bg-white" style="padding: 64px 20px 0;">
    <div class="mx-auto" style="max-width: 1060px;">
      <h2 class="text-center mb-4" style="font-family: var(--font-oswald); font-size: clamp(28px, 4vw, 48px); font-weight: 400; color: var(--color-footer); text-transform: uppercase; line-height: 1.1;">
        Where does your money <em style="font-style: italic; text-transform: none;">actually</em> go?
      </h2>
      <p class="text-center mb-12 mx-auto" style="font-family: var(--font-dm-sans); max-width: 600px; color: var(--color-muted);">

        Most roofing companies are sales organizations with a construction crew attached. Here's the difference.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Traditional -->
        <div class="rounded-[4px]" style="background: var(--color-cream); padding: 32px; border: 2px solid var(--color-border);">
          <p class="text-label-uppercase mb-4" style="color: var(--color-muted);">Typical Roofing Company</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span style="color: var(--color-error); font-size: 20px; line-height: 1.4;">&#10007;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">30-40% sales commission</p>
                <p style="font-size: 13px; color: var(--color-muted);">The guy knocking on your door gets paid before anyone touches your roof.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-error); font-size: 20px; line-height: 1.4;">&#10007;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">High-pressure sales tactics</p>
                <p style="font-size: 13px; color: var(--color-muted);">"This price is only good today." Sound familiar?</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-error); font-size: 20px; line-height: 1.4;">&#10007;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">Opaque pricing</p>
                <p style="font-size: 13px; color: var(--color-muted);">No breakdown, no comparison. Just a number on a clipboard.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-error); font-size: 20px; line-height: 1.4;">&#10007;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">Undertrained install crews</p>
                <p style="font-size: 13px; color: var(--color-muted);">Budget goes to sales, not skilled labor.</p>
              </div>
            </div>
          </div>
          <div class="mt-6 rounded-[4px] overflow-hidden" style="height: 32px; background: #e8e4de;">
            <div class="h-full flex">
              <div class="h-full flex items-center justify-center" style="width: 35%; background: #c44; color: white; font-size: 11px; font-weight: 700;">COMMISSION 35%</div>
              <div class="h-full flex items-center justify-center" style="width: 20%; background: #e8a87c; font-size: 11px; font-weight: 600;">Overhead</div>
              <div class="h-full flex items-center justify-center" style="width: 25%; background: var(--color-border); font-size: 11px; font-weight: 600;">Materials</div>
              <div class="h-full flex items-center justify-center" style="width: 20%; background: #b8b3a8; font-size: 11px; font-weight: 600;">Labor</div>
            </div>
          </div>
        </div>
        <!-- Hamilton -->
        <div class="rounded-[4px]" style="background: var(--color-cream); padding: 32px; border: 2px solid var(--color-primary);">
          <p class="text-label-uppercase text-primary mb-4">Hamilton Exteriors</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span style="color: var(--color-primary); font-size: 20px; line-height: 1.4;">&#10003;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">0% sales commission</p>
                <p style="font-size: 13px; color: var(--color-muted);">Buy online. No salesperson, no markup, no games.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-primary); font-size: 20px; line-height: 1.4;">&#10003;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">Transparent, instant pricing</p>
                <p style="font-size: 13px; color: var(--color-muted);">See every line item. Materials, labor, permits — no hidden fees.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-primary); font-size: 20px; line-height: 1.4;">&#10003;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">100% focused on installation quality</p>
                <p style="font-size: 13px; color: var(--color-muted);">All staff, all budget, all energy goes into your roof — not closing deals.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span style="color: var(--color-primary); font-size: 20px; line-height: 1.4;">&#10003;</span>
              <div>
                <p class="font-semibold text-charcoal" style="font-size: 15px;">Experienced, certified crews</p>
                <p style="font-size: 13px; color: var(--color-muted);">GAF Master Elite certified. We invest in craft, not commissions.</p>
              </div>
            </div>
          </div>
          <div class="mt-6 rounded-[4px] overflow-hidden" style="height: 32px; background: #e8e4de;">
            <div class="h-full flex">
              <div class="h-full flex items-center justify-center" style="width: 40%; background: var(--color-primary); color: white; font-size: 11px; font-weight: 700;">MATERIALS 40%</div>
              <div class="h-full flex items-center justify-center" style="width: 35%; background: rgb(45,110,70); color: white; font-size: 11px; font-weight: 600;">Labor 35%</div>
              <div class="h-full flex items-center justify-center" style="width: 25%; background: rgb(65,125,85); color: white; font-size: 11px; font-weight: 600;">Permits 25%</div>
            </div>
          </div>
        </div>
      </div>
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" style="padding: 40px 0 48px;">
        <div>
          <p class="font-oswald text-charcoal" style="font-size: clamp(32px, 4vw, 48px); line-height: 1;">0%</p>
          <p style="font-size: 13px; color: var(--color-muted); margin-top: 4px;">Sales Commission</p>
        </div>
        <div>
          <p class="font-oswald text-charcoal" style="font-size: clamp(32px, 4vw, 48px); line-height: 1;">$4,200</p>
          <p style="font-size: 13px; color: var(--color-muted); margin-top: 4px;">Avg. Customer Savings</p>
        </div>
        <div>
          <p class="font-oswald text-charcoal" style="font-size: clamp(32px, 4vw, 48px); line-height: 1;">500+</p>
          <p style="font-size: 13px; color: var(--color-muted); margin-top: 4px;">Roofs Completed</p>
        </div>
        <div>
          <p class="font-oswald text-charcoal" style="font-size: clamp(32px, 4vw, 48px); line-height: 1;">4.8</p>
          <p style="font-size: 13px; color: var(--color-muted); margin-top: 4px;">Google Rating</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SOCIAL PROOF ──────────────────────────────────────────────── -->
  <section class="w-full" style="background-color: var(--color-cream); padding: 64px 20px 56px;">
    <div class="mx-auto" style="max-width: 1060px;">
      <p class="text-label-uppercase text-primary text-center mb-6">What homeowners say</p>
      <div class="mb-8 rounded-[4px] bg-white mx-auto" style="max-width: 760px; padding: 40px; border: 1px solid var(--color-border);">
        <blockquote class="font-oswald text-charcoal text-center" style="font-size: clamp(20px, 3vw, 28px); line-height: 1.4; font-style: italic;">
          "I got three quotes from traditional roofers — all $15k+. Hamilton's online price was $11,200 for better materials. The savings from cutting out the salesman are real."
        </blockquote>
        <div class="flex items-center justify-center gap-3 mt-6">
          <div class="rounded-full bg-primary flex items-center justify-center text-white font-semibold" style="width: 40px; height: 40px; font-size: 15px;">DK</div>
          <div>
            <p class="font-semibold text-charcoal" style="font-size: 14px;">David & Lin K.</p>
            <p style="font-size: 13px; color: var(--color-muted);">San Leandro, CA &middot; Saved $3,800</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" style="max-width: 760px; margin: 0 auto;">
        <div class="rounded-[4px] bg-white" style="padding: 24px; border: 1px solid var(--color-border);">
          <div class="flex gap-1 mb-2">
            <span style="color: var(--color-yellow); font-size: 14px;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="text-charcoal mb-3" style="font-size: 14px; line-height: 1.7;">
            "Typed my address, got an instant price. No waiting for some guy to come measure. So easy."
          </p>
          <p class="font-semibold text-charcoal" style="font-size: 13px;">Maria S. <span style="font-weight: 400; color: var(--color-muted);">&middot; Oakland</span></p>
        </div>
        <div class="rounded-[4px] bg-white" style="padding: 24px; border: 1px solid var(--color-border);">
          <div class="flex gap-1 mb-2">
            <span style="color: var(--color-yellow); font-size: 14px;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="text-charcoal mb-3" style="font-size: 14px; line-height: 1.7;">
            "The transparency blew me away. Every line item right there. The crew showed up on time and did an incredible job."
          </p>
          <p class="font-semibold text-charcoal" style="font-size: 13px;">James T. <span style="font-weight: 400; color: var(--color-muted);">&middot; Pleasanton</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────── -->
  <section class="w-full bg-white" style="padding: 56px 20px 72px;">
    <div class="mx-auto" style="max-width: 720px;">
      <h2 class="text-center mb-12" style="font-family: var(--font-oswald); font-size: clamp(28px, 4vw, 48px); font-weight: 400; color: var(--color-footer); text-transform: uppercase; line-height: 1.1;">
        Common questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">How do you know what my roof needs without visiting?</summary>
          <div class="faq-answer">
            <p>We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">How can you be so much cheaper without cutting corners?</summary>
          <div class="faq-answer">
            <p>Traditional roofing companies pay their salespeople 30-40% commission on every job. That's $3,000-$8,000 per roof that goes to the person who knocked on your door — not to materials or labor. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">What about the warranty?</summary>
          <div class="faq-answer">
            <p>Every roof comes with a manufacturer's warranty (25 years to lifetime, depending on the material you choose) plus our own 10-year workmanship guarantee. We're a GAF Master Elite contractor — only 2% of roofers in the country qualify.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">How does financing work?</summary>
          <div class="faq-answer">
            <p>We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">What if the on-site inspection finds something different?</summary>
          <div class="faq-answer">
            <p>We'll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. No surprises.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
          <summary class="faq-summary">How long does a typical roof take?</summary>
          <div class="faq-answer">
            <p>Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup — you don't have to do anything.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────────────── -->
  <section class="w-full" style="background-color: var(--color-footer); padding: 64px 20px;">
    <div class="mx-auto text-center" style="max-width: 640px;">
      <h2 style="font-family: var(--font-oswald); font-size: clamp(28px, 4vw, 44px); font-weight: 400; color: white; text-transform: uppercase; line-height: 1.1; margin-bottom: 16px;">
        Ready to skip the salesman?
      </h2>
      <p style="font-family: var(--font-dm-sans); font-size: 17px; color: rgba(255,255,255,0.7); margin-bottom: 32px;">
        Enter your address, see your price, and buy your roof in minutes.
      </p>
      <form class="relative mx-auto cta-address-form" style="max-width: 480px;" action="/buy/scan">
        <input
          name="address"
          type="text"
          placeholder="Your address"
          required
          autocomplete="off"
          aria-label="Home address"
          maxlength="200"
          class="w-full rounded-[4px] cta-address-input"
          style="font-family: var(--font-dm-sans); padding: 18px 140px 18px 20px; border: 2px solid rgba(255,255,255,0.15); font-size: 17px; outline: none; background: rgba(255,255,255,0.08); color: white;"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 -translate-y-1/2 hidden" style="right:130px;" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <div class="cta-dropdown addr-dropdown hidden absolute left-0 right-0 top-full mt-1 rounded-[4px] shadow-lg overflow-hidden" style="z-index:50;"></div>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] transition-all hover:opacity-90"
          style="padding: 12px 24px; font-size: 14px; font-family: var(--font-oswald); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; background-color: var(--color-yellow); color: var(--color-footer);"
        >
          Scan Roof
        </button>
      </form>
      <p style="font-family: var(--font-dm-sans); font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 24px;">
        Or call us at <a href="tel:+16509773351" style="color: rgba(255,255,255,0.7); text-decoration: underline;">(650) 977-3351</a>
      </p>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  #hero-address-input:focus {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.12);
  }
  #hero-address-input::placeholder {
    color: rgba(255,255,255,0.4);
  }
  .faq-summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 48px 18px 20px;
    font-family: var(--font-dm-sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-charcoal);
    position: relative;
    user-select: none;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after {
    content: '+';
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-dm-sans);
    font-size: 22px;
    font-weight: 300;
    color: var(--color-muted);
  }
  .faq-item[open] .faq-summary::after { content: '\2212'; }
  .faq-answer {
    padding: 0 20px 20px;
    font-family: var(--font-dm-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
  }
  footer a[aria-label] {
    min-width: 44px;
    min-height: 44px;
    display: flex !important;
    align-items: center;
    justify-content: center;
  }
  /* Dark-themed address autocomplete dropdown — :global needed for JS-injected content */
  .addr-dropdown {
    background: #1c1c1c;
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  :global(.address-suggestion) {
    padding: 14px 16px;
    cursor: pointer;
    font-family: var(--font-dm-sans);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.15s;
    text-align: left;
  }
  :global(.address-suggestion:last-child) { border-bottom: none; }
  :global(.address-suggestion:hover),
  :global(.address-suggestion--active) {
    background: rgba(255,255,255,0.08);
  }
  :global(.address-suggestion .suggestion-name) {
    font-size: 15px;
    font-weight: 500;
    color: white;
    line-height: 1.3;
  }
  :global(.address-suggestion .suggestion-detail) {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-top: 2px;
  }
  /* Pin icon in suggestions */
  :global(.suggestion-icon) {
    flex-shrink: 0;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
  }
  /* Clear / X button */
  .addr-clear-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .addr-clear-btn.visible {
    display: flex !important;
  }
  .addr-clear-btn:hover { opacity: 1; }
  .addr-clear-btn:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
  }
</style>

<script define:vars={{ mapboxToken }}>
  window.__MAPBOX_TOKEN = mapboxToken;
</script>
<script is:inline>
(function() {
  var TOKEN = window.__MAPBOX_TOKEN || '';
  var session = crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2);
  var BA_BBOX = '-123.1,36.9,-121.2,38.9';
  var PIN_SVG = '<svg class="suggestion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>';

  function esc(s) { return s.replace(/[<>"&]/g, function(c) { return '&#' + c.charCodeAt(0) + ';'; }); }

  function setupAutofill(input, dropdown) {
    if (!input || !dropdown) return;
    var timer = null;
    var activeIdx = -1;
    var clearBtn = input.parentElement.querySelector('.addr-clear-btn');

    function toggleClear() {
      if (!clearBtn) return;
      clearBtn.classList.toggle('visible', input.value.trim().length > 0);
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        input.value = '';
        dropdown.classList.add('hidden');
        toggleClear();
        input.focus();
      });
    }

    function setActive(items, idx) {
      items.forEach(function(el, i) {
        el.classList.toggle('address-suggestion--active', i === idx);
      });
    }

    input.addEventListener('input', function() {
      clearTimeout(timer);
      toggleClear();
      activeIdx = -1;
      var v = input.value.trim();
      if (v.length < 4) { dropdown.classList.add('hidden'); return; }
      timer = setTimeout(function() {
        fetch('https://api.mapbox.com/search/searchbox/v1/suggest?q=' + encodeURIComponent(v) +
          '&types=address&country=us&language=en&limit=5&bbox=' + BA_BBOX +
          '&session_token=' + session + '&access_token=' + TOKEN)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (!data.suggestions || !data.suggestions.length) { dropdown.classList.add('hidden'); return; }
            dropdown.innerHTML = data.suggestions.map(function(s) {
              var name = esc(s.name || s.full_address || '');
              var detail = '';
              if (s.full_address && s.name && s.full_address !== s.name) {
                detail = esc(s.full_address.replace(s.name, '').replace(/^[\s,]+/, ''));
              } else if (s.place_formatted) {
                detail = esc(s.place_formatted);
              }
              return '<div class="address-suggestion flex items-start gap-3" role="option">' +
                PIN_SVG +
                '<div><div class="suggestion-name">' + name + '</div>' +
                (detail ? '<div class="suggestion-detail">' + detail + '</div>' : '') +
                '</div></div>';
            }).join('');
            dropdown.classList.remove('hidden');
            activeIdx = -1;
          })
          .catch(function() { dropdown.classList.add('hidden'); });
      }, 250);
    });

    input.addEventListener('keydown', function(e) {
      var items = dropdown.querySelectorAll('.address-suggestion');
      if (!items.length || dropdown.classList.contains('hidden')) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % items.length;
        setActive(items, activeIdx);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIdx = activeIdx <= 0 ? items.length - 1 : activeIdx - 1;
        setActive(items, activeIdx);
      } else if (e.key === 'Enter' && activeIdx >= 0) {
        e.preventDefault();
        var nameEl = items[activeIdx].querySelector('.suggestion-name');
        var detailEl = items[activeIdx].querySelector('.suggestion-detail');
        input.value = (nameEl ? nameEl.textContent : '') + (detailEl ? ', ' + detailEl.textContent : '');
        dropdown.classList.add('hidden');
        toggleClear();
      } else if (e.key === 'Escape') {
        dropdown.classList.add('hidden');
        activeIdx = -1;
      }
    });

    dropdown.addEventListener('click', function(e) {
      var item = e.target.closest('.address-suggestion');
      if (!item) return;
      var nameEl = item.querySelector('.suggestion-name');
      var detailEl = item.querySelector('.suggestion-detail');
      input.value = (nameEl ? nameEl.textContent : '') + (detailEl ? ', ' + detailEl.textContent : '');
      dropdown.classList.add('hidden');
      toggleClear();
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('.address-suggestion') && e.target !== input && e.target !== clearBtn) {
        dropdown.classList.add('hidden');
      }
    });
  }

  // Hero form
  setupAutofill(document.getElementById('hero-address-input'), document.getElementById('hero-dropdown'));

  // CTA forms
  document.querySelectorAll('.cta-address-form').forEach(function(form) {
    setupAutofill(form.querySelector('.cta-address-input'), form.querySelector('.cta-dropdown'));
  });
})();
</script>
