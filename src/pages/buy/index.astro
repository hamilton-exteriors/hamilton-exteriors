---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LogoSlider from '../../components/LogoSlider.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { Image, getImage } from 'astro:assets';
import { default as heroRoofing } from '../../assets/images/hero-roofing.png';
import { reviewLogoGoogle, reviewLogoYelp } from '../../lib/images';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

const [heroMobile, heroDesktop] = await Promise.all([
  getImage({ src: heroRoofing, width: 768, height: 960, format: 'webp', quality: 80 }),
  getImage({ src: heroRoofing, width: 1440, height: 810, format: 'webp', quality: 80 }),
]);

const webAppJsonLd = {
  '@type': 'WebApplication',
  '@id': 'https://hamilton-exteriors.com/buy#webapp',
  name: 'Hamilton Exteriors Online Roof Scanner',
  url: 'https://hamilton-exteriors.com/buy',
  applicationCategory: 'BusinessApplication',
  description: 'Scan your roof with satellite imagery and get an instant price for a new roof — buy direct, online in minutes.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free roof scan and instant pricing',
  },
};

const serviceJsonLd = {
  '@type': 'Service',
  '@id': 'https://hamilton-exteriors.com/buy#service',
  name: 'Online Roof Replacement',
  description: 'Buy a roof replacement online with satellite imagery pricing. Architect-led, direct pricing. GAF Master Elite certified installation with manufacturer warranty.',
  provider: { '@type': 'GeneralContractor', '@id': 'https://hamilton-exteriors.com/#business', name: 'Hamilton Exteriors' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Alameda County' },
    { '@type': 'AdministrativeArea', name: 'Contra Costa County' },
    { '@type': 'AdministrativeArea', name: 'Marin County' },
    { '@type': 'AdministrativeArea', name: 'Napa County' },
    { '@type': 'AdministrativeArea', name: 'Santa Clara County' },
    { '@type': 'AdministrativeArea', name: 'San Mateo County' },
  ],
  serviceType: 'Roof Replacement',
  termsOfService: 'https://hamilton-exteriors.com/terms',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Roofing Packages',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Standard Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '940', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Premium Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1000', priceCurrency: 'USD', unitText: 'per roofing square' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Designer Shingles' }, priceSpecification: { '@type': 'UnitPriceSpecification', price: '1175', priceCurrency: 'USD', unitText: 'per roofing square' } },
    ],
  },
};

const faqJsonLd = {
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do you know what my roof needs without visiting?',
      acceptedAnswer: { '@type': 'Answer', text: 'We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.' },
    },
    {
      '@type': 'Question',
      name: 'How can you be so much cheaper without cutting corners?',
      acceptedAnswer: { '@type': 'Answer', text: 'Traditional roofing companies pay their salespeople 30-40% commission on every job. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.' },
    },
    {
      '@type': 'Question',
      name: 'What about the warranty?',
      acceptedAnswer: { '@type': 'Answer', text: 'Every roof comes with a manufacturer\'s warranty (25 years to lifetime, depending on the material) plus our own 35-year labor guarantee. We\'re a GAF Master Elite contractor — only 2% of roofers in the country qualify.' },
    },
    {
      '@type': 'Question',
      name: 'How does financing work?',
      acceptedAnswer: { '@type': 'Answer', text: 'We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.' },
    },
    {
      '@type': 'Question',
      name: 'What if the on-site inspection finds something different?',
      acceptedAnswer: { '@type': 'Answer', text: 'We\'ll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. You\'ll see every line item before we move forward.' },
    },
    {
      '@type': 'Question',
      name: 'How long does a typical roof take?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup.' },
    },
  ],
};
---

<Layout
  title="Buy Your Roof Online | Hamilton Exteriors"
  description="Enter your address, see your roof, get an instant price. Buy your new roof online — direct from Hamilton Exteriors."
  jsonLd={[webAppJsonLd, serviceJsonLd, faqJsonLd]}
  noindex
>
  <Navbar slot="header" />

  <!-- ── HERO — address input drives to /buy/scan ──────────────────── -->
  <section id="buy-hero" class="relative z-2 w-full overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <picture>
        <source srcset={heroMobile.src} media="(max-width: 768px)" type="image/webp" width="768" height="960" />
        <source srcset={heroDesktop.src} type="image/webp" width="1440" height="810" />
        <img
          src={heroDesktop.src}
          alt="Hamilton Exteriors roofing project"
          width="1440"
          height="810"
          sizes="100vw"
          class="size-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </picture>
    </div>
    <!-- Dark scrim -->
    <div class="pointer-events-none absolute inset-0 z-1 bg-black/35" aria-hidden="true"></div>
    <!-- Film grain -->
    <div class="hero-grain pointer-events-none absolute inset-0 z-2" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-[720px] text-center">
      <p class="mb-4 font-satoshi text-xs font-bold tracking-[0.15em] text-yellow uppercase">Architect-led roofing</p>
      <h1 class="mb-4 font-hamilton-display text-[clamp(40px,7vw,72px)] leading-[1.05] text-white uppercase">
        Buy Your Roof Online
      </h1>
      <p class="mx-auto mb-5 max-w-[480px] text-[clamp(15px,2.5vw,18px)] leading-[1.6] text-white/75">
        Enter your address. We'll scan your roof and give you an instant price — buy direct, online in minutes.
      </p>

      <!-- Trust badges -->
      <div class="mx-auto mb-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {['GAF Master Elite Certified', '50-Year Warranty', '0% Sales Commission'].map((badge) => (
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="shrink-0">
              <circle cx="10" cy="10" r="10" fill="rgba(255,255,255,0.15)"/>
              <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-[13px] font-medium text-white/80">{badge}</span>
          </div>
        ))}
      </div>

      <form id="hero-form" class="relative z-20 mx-auto max-w-[520px] px-1" action="/buy/scan">
        <input
          id="hero-address-input"
          name="address"
          type="text"
          placeholder="Enter your home address"
          autocomplete="off"
          required
          aria-label="Home address"
          maxlength="200"
          class="w-full rounded-[4px] border-2 border-white/15 bg-white/8 py-[18px] pr-[140px] pl-5 text-[17px] text-white transition-[border-color] duration-200 outline-none"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 right-[130px] hidden -translate-y-1/2" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] bg-yellow px-6 py-3 font-hamilton-display text-sm font-bold tracking-[0.05em] text-footer uppercase transition-opacity duration-150 hover:opacity-90"
        >
          Scan My Roof
        </button>
        <div id="hero-dropdown" role="listbox" class="addr-dropdown absolute inset-x-0 top-full z-50 mt-1 hidden overflow-hidden rounded-[4px] shadow-lg"></div>
      </form>
      <p class="mt-3 text-[13px] text-white/55">
        Serving all of California &middot; Bay Area, Sacramento, Stockton &amp; beyond
      </p>
      <p class="mt-2 text-[13px] text-white/55">
        or call <a href="tel:+16509773351" class="font-semibold text-white/75 no-underline transition-opacity duration-150 hover:opacity-80">(650) 977-3351</a>
      </p>

      <!-- How it works -->
      <div class="mx-auto mt-10 flex max-w-[480px] items-center justify-center gap-3 sm:gap-5">
        <div class="flex flex-col items-center gap-1.5">
          <span class="flex size-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">1</span>
          <span class="text-[11px] text-white/55">Enter address</span>
        </div>
        <div class="h-px flex-1 bg-white/15" aria-hidden="true"></div>
        <div class="flex flex-col items-center gap-1.5">
          <span class="flex size-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">2</span>
          <span class="text-[11px] text-white/55">See your roof</span>
        </div>
        <div class="h-px flex-1 bg-white/15" aria-hidden="true"></div>
        <div class="flex flex-col items-center gap-1.5">
          <span class="flex size-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">3</span>
          <span class="text-[11px] text-white/55">Get your price</span>
        </div>
      </div>
    </div>
  </section>

  <LogoSlider />

  <!-- ── WHY WE'RE DIFFERENT — comparison + stats ───────────────────── -->
  <section class="cv-auto w-full bg-white px-5 py-12 lg:py-20">
    <div class="mx-auto max-w-[1060px]">
      <SectionLabel align="center">Transparent Pricing</SectionLabel>
      <h2 class="mb-4 text-center font-hamilton-display text-[clamp(28px,4vw,48px)] leading-[1.1] text-footer uppercase">
        Where does your money <em class="normal-case italic">actually</em> go?
      </h2>
      <p class="mx-auto mb-12 max-w-[600px] text-center text-muted">Most roofing companies are sales organizations with a construction crew attached. Here's the difference.</p>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Traditional -->
        <div class="rounded-[4px] border-2 border-border bg-cream p-8">
          <p class="text-label-uppercase mb-4 text-muted">Typical Roofing Company</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">30-40% sales commission</p>
                <p class="text-[13px] text-muted">The guy knocking on your door gets paid before anyone touches your roof.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">High-pressure sales tactics</p>
                <p class="text-[13px] text-muted">"This price is only good today." Sound familiar?</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Opaque pricing</p>
                <p class="text-[13px] text-muted">No breakdown, no comparison. Just a number on a clipboard.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-error">&#10007;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Undertrained install crews</p>
                <p class="text-[13px] text-muted">Budget goes to sales, not skilled labor.</p>
              </div>
            </div>
          </div>
          <div class="bar-chart-track mt-6 h-8 overflow-hidden rounded-[4px] bg-border/40">
            <div class="flex h-full">
              <div class="bar-segment flex h-full w-[35%] items-center justify-center bg-error font-bold text-white">Commission 35%</div>
              <div class="bar-segment flex h-full w-[20%] items-center justify-center bg-error/40 font-semibold text-charcoal">Overhead</div>
              <div class="bar-segment flex h-full w-[25%] items-center justify-center bg-border font-semibold text-charcoal">Materials</div>
              <div class="bar-segment flex h-full w-[20%] items-center justify-center bg-muted/30 font-semibold text-charcoal">Labor</div>
            </div>
          </div>
        </div>
        <!-- Hamilton -->
        <div class="rounded-[4px] border-3 border-primary bg-cream p-8" style="box-shadow: 0 0 0 4px rgba(37,99,70,0.10), 0 8px 24px rgba(37,99,70,0.12);">
          <p class="text-label-uppercase mb-4 text-primary">Hamilton Exteriors</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">0% sales commission</p>
                <p class="text-[13px] text-muted">Buy online. Direct pricing, transparent markup, straight talk.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Transparent, instant pricing</p>
                <p class="text-[13px] text-muted">See every line item. Materials, labor, permits — every cost itemized upfront.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">100% focused on installation quality</p>
                <p class="text-[13px] text-muted">All staff, all budget, all energy goes into your roof — not closing deals.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl leading-[1.4] text-primary">&#10003;</span>
              <div>
                <p class="text-[15px] font-semibold text-charcoal">Experienced, certified crews</p>
                <p class="text-[13px] text-muted">GAF Master Elite certified. We invest in craft, not commissions.</p>
              </div>
            </div>
          </div>
          <div class="bar-chart-track mt-6 h-8 overflow-hidden rounded-[4px] bg-border/40">
            <div class="flex h-full">
              <div class="bar-segment flex h-full w-[40%] items-center justify-center bg-primary font-bold text-white">Materials 40%</div>
              <div class="bar-segment flex h-full w-[35%] items-center justify-center bg-primary/75 font-semibold text-white">Labor 35%</div>
              <div class="bar-segment flex h-full w-[25%] items-center justify-center bg-primary/55 font-semibold text-white">Permits 25%</div>
            </div>
          </div>
        </div>
      </div>
      <!-- Stats -->
      <div class="stats-row mt-10 rounded-[4px] border border-border bg-cream px-6 py-9">
        <div class="grid grid-cols-2 gap-6 text-center md:grid-cols-4">
          <div>
            <p class="font-hamilton-display text-[clamp(36px,5vw,48px)] leading-none text-primary">0%</p>
            <p class="mt-1.5 text-[13px] text-muted">Sales Commission</p>
          </div>
          <div>
            <p class="font-hamilton-display text-[clamp(36px,5vw,48px)] leading-none text-primary">$4,200</p>
            <p class="mt-1.5 text-[13px] text-muted">Avg. Customer Savings</p>
          </div>
          <div>
            <p class="font-hamilton-display text-[clamp(36px,5vw,48px)] leading-none text-primary">500+</p>
            <p class="mt-1.5 text-[13px] text-muted">Roofs Completed</p>
          </div>
          <div>
            <p class="font-hamilton-display text-[clamp(36px,5vw,48px)] leading-none text-primary">4.8</p>
            <p class="mt-1.5 text-[13px] text-muted">Google Rating</p>
          </div>
        </div>
        <!-- Trust badges -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4 border-t border-border pt-4">
          <span class="font-satoshi text-xs font-bold tracking-[0.15em] text-primary uppercase">GAF Master Elite Contractor</span>
          <span class="text-xs text-border">&bull;</span>
          <span class="font-satoshi text-xs font-bold tracking-[0.15em] text-muted uppercase">CSLB #1082377</span>
          <span class="text-xs text-border">&bull;</span>
          <span class="font-satoshi text-xs font-bold tracking-[0.15em] text-muted uppercase">Licensed &amp; Insured</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SOCIAL PROOF ──────────────────────────────────────────────── -->
  <section class="cv-auto w-full bg-cream px-5 py-12 lg:py-20">
    <div class="mx-auto max-w-[1060px]">
      <SectionLabel align="center">What Homeowners Say</SectionLabel>
      <div class="mx-auto mb-8 max-w-[760px] rounded-[4px] border border-border bg-white px-8 py-10 sm:px-10">
        <div class="mb-4 flex items-center justify-center gap-3">
          <span class="text-lg text-yellow">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <Image src={reviewLogoGoogle} alt="Google review" width={60} height={20} class="h-5 w-auto opacity-60" loading="lazy" />
        </div>
        <blockquote class="text-center font-hamilton-display text-[clamp(20px,3vw,28px)] leading-[1.4] text-charcoal italic">
          "I got three quotes from traditional roofers — all $15k+. Hamilton's online price was $11,200 for better materials. The savings from cutting out the salesman are real."
        </blockquote>
        <div class="mt-6 flex items-center justify-center gap-3">
          <div class="flex size-10 items-center justify-center rounded-full bg-primary text-[15px] font-semibold text-white">DK</div>
          <div>
            <p class="text-sm font-semibold text-charcoal">David & Lin K.</p>
            <p class="text-[13px] text-muted">San Leandro, CA &middot; Saved $3,800</p>
          </div>
        </div>
      </div>
      <div class="mx-auto grid max-w-[760px] grid-cols-1 gap-6 md:grid-cols-2">
        <div class="rounded-[4px] border border-border bg-white p-6">
          <div class="mb-2 flex items-center gap-2">
            <span class="text-sm text-yellow">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <Image src={reviewLogoGoogle} alt="Google" width={48} height={16} class="h-4 w-auto opacity-50" loading="lazy" />
          </div>
          <p class="mb-3 text-sm leading-[1.7] text-charcoal">
            "Typed my address, got an instant price. No waiting for some guy to come measure. So easy."
          </p>
          <p class="text-[13px] font-semibold text-charcoal">Maria S. <span class="font-normal text-muted">&middot; Oakland</span></p>
        </div>
        <div class="rounded-[4px] border border-border bg-white p-6">
          <div class="mb-2 flex items-center gap-2">
            <span class="text-sm text-yellow">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <Image src={reviewLogoYelp} alt="Yelp" width={48} height={16} class="h-4 w-auto opacity-50" loading="lazy" />
          </div>
          <p class="mb-3 text-sm leading-[1.7] text-charcoal">
            "The transparency blew me away. Every line item right there. The crew showed up on time and did an incredible job."
          </p>
          <p class="text-[13px] font-semibold text-charcoal">James T. <span class="font-normal text-muted">&middot; Pleasanton</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ — before CTA so objections get answered first ─────────── -->
  <section class="cv-auto w-full bg-white px-5 py-12 lg:py-20">
    <div class="mx-auto max-w-[720px]">
      <SectionLabel align="center">FAQ</SectionLabel>
      <h2 class="mb-12 text-center font-hamilton-display text-[clamp(28px,4vw,48px)] leading-[1.1] text-footer uppercase">
        Common Questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How do you know what my roof needs without visiting?</summary>
          <div class="faq-answer">
            <p>We use high-resolution satellite imagery and aerial measurement technology — the same tools insurance adjusters use. Before any work begins, our project manager does a free on-site verification to confirm measurements and check for any hidden issues.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How can you be so much cheaper without cutting corners?</summary>
          <div class="faq-answer">
            <p>Traditional roofing companies pay their salespeople 30-40% commission on every job. That's $3,000-$8,000 per roof that goes to the person who knocked on your door — not to materials or labor. We eliminated the sales force entirely. Same materials, same (or better) installation crews, dramatically lower price.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">What about the warranty?</summary>
          <div class="faq-answer">
            <p>Every roof comes with a manufacturer's warranty (25 years to lifetime, depending on the material you choose) plus our own 35-year labor guarantee. We're a GAF Master Elite contractor — only 2% of roofers in the country qualify.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How does financing work?</summary>
          <div class="faq-answer">
            <p>We offer 0% APR financing for up to 60 months with approved credit. Apply during checkout — approval takes about 2 minutes. No prepayment penalties.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">What if the on-site inspection finds something different?</summary>
          <div class="faq-answer">
            <p>We'll update your quote with an itemized explanation of what changed and why. You approve any changes before we proceed. You'll see every line item before we move forward.</p>
          </div>
        </details>
        <details class="faq-item rounded-[4px] border border-border bg-cream">
          <summary class="faq-summary">How long does a typical roof take?</summary>
          <div class="faq-answer">
            <p>Most residential roofs are completed in 1-3 days depending on size and complexity. We handle permits, material delivery, and cleanup — you don't have to do anything.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ── MID-PAGE CTA — after FAQ so objections are defused ────────── -->
  <section class="cv-auto w-full bg-heading px-5 py-12 lg:py-20">
    <div class="mx-auto max-w-[600px] text-center">
      <SectionLabel align="center" color="yellow">Your Next Step</SectionLabel>
      <p class="mb-4 font-hamilton-display text-[clamp(24px,3.5vw,36px)] leading-[1.15] text-white uppercase">
        Ready to see your price?
      </p>
      <p class="mb-8 text-base text-white/70">
        Enter your address. Instant satellite scan. Transparent pricing.
      </p>
      <a
        href="/buy/scan"
        class="inline-block rounded-full bg-yellow px-10 py-4 font-hamilton-display text-base font-bold tracking-[0.04em] text-footer uppercase no-underline transition-opacity duration-150 hover:opacity-90"
      >
        Scan Your Roof Now
      </a>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────────────── -->
  <section class="w-full bg-footer px-5 py-12 lg:py-20">
    <div class="mx-auto max-w-[640px] text-center">
      <SectionLabel align="center" color="yellow">Get Started</SectionLabel>
      <h2 class="mb-3 font-hamilton-display text-[clamp(28px,4vw,44px)] leading-[1.1] text-white uppercase">
        Your new roof is 3 clicks away
      </h2>
      <p class="mb-8 text-[17px] text-white/70">
        Enter your address, see your price, and buy your roof in minutes — direct from our team.
      </p>
      <form class="cta-address-form relative mx-auto max-w-[480px] px-1" action="/buy/scan">
        <input
          name="address"
          type="text"
          placeholder="Enter your home address"
          required
          autocomplete="off"
          aria-label="Home address"
          maxlength="200"
          class="cta-address-input w-full rounded-[4px] border-2 border-white/15 bg-white/8 py-[18px] pr-[140px] pl-5 text-[17px] text-white transition-[border-color] duration-200 outline-none"
        />
        <button type="button" class="addr-clear-btn absolute top-1/2 right-[130px] hidden -translate-y-1/2" aria-label="Clear address">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
        </button>
        <div class="cta-dropdown addr-dropdown absolute inset-x-0 top-full z-50 mt-1 hidden overflow-hidden rounded-[4px] shadow-lg" role="listbox"></div>
        <button
          type="submit"
          class="absolute top-1/2 right-2 -translate-y-1/2 rounded-[4px] bg-yellow px-6 py-3 font-hamilton-display text-sm font-bold tracking-[0.05em] text-footer uppercase transition-opacity duration-150 hover:opacity-90"
        >
          Scan My Roof
        </button>
      </form>
      <div class="mt-8 border-t border-white/10 pt-6">
        <p class="mb-2 text-sm text-white/55">Prefer to talk to someone?</p>
        <a href="tel:+16509773351" class="font-hamilton-display text-[clamp(22px,3vw,28px)] font-bold tracking-[0.02em] text-yellow no-underline transition-opacity duration-150 hover:opacity-80">(650) 977-3351</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

