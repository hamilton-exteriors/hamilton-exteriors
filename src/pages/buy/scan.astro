---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---
<Layout title="Your Roof Scan | Hamilton Exteriors" description="See your roof measurements and get an instant price.">
<Navbar />
<section id="scanner" class="w-full" style="background-color:var(--color-cream);padding:40px 20px 80px;min-height:calc(100vh - 80px);">
<div class="mx-auto" style="max-width:1100px;">
<nav id="step-indicator" class="flex items-center justify-center gap-3 mb-10" aria-label="Purchase progress">
<div class="step-dot active" data-step="1" aria-current="step"><span class="step-num" aria-hidden="true">1</span><span class="step-label">Enter Address</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="2"><span class="step-num" aria-hidden="true">2</span><span class="step-label">Roof Scan</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="3"><span class="step-num" aria-hidden="true">3</span><span class="step-label">Choose & Buy</span></div>
</nav>
<div id="step-1" class="scanner-step">
<div class="bg-white rounded-2xl shadow-sm mx-auto" style="max-width:680px;padding:48px 40px;">
<h1 class="font-fraunces text-charcoal text-center mb-2" style="font-size:28px;font-weight:600;">Where's your home?</h1>
<p class="text-body text-center mb-8" style="color:var(--color-input);">We'll pull up a satellite view of your roof and calculate measurements instantly.</p>
<div class="relative">
<input id="address-input" type="text" placeholder="Enter your home address..." autocomplete="off" role="combobox" aria-label="Home address" aria-expanded="false" aria-controls="address-dropdown" aria-autocomplete="list" class="w-full rounded-xl text-body" style="padding:18px 60px 18px 20px;border:2px solid var(--color-border);font-size:17px;outline:none;transition:border-color 0.2s;" />
<button id="scan-btn" type="button" class="absolute top-1/2 right-3 -translate-y-1/2 bg-primary text-white rounded-lg flex items-center justify-center transition-opacity hover:opacity-90" style="width:44px;height:44px;" aria-label="Scan roof"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
<div id="address-dropdown" role="listbox" aria-label="Address suggestions" class="hidden absolute left-0 right-0 top-full mt-1 bg-white rounded-xl shadow-lg border z-10 overflow-hidden" style="border-color:var(--color-border);"></div>
</div>
<div class="flex items-center justify-center gap-4 mt-6"><a href="/buy" class="text-sm underline" style="color:var(--color-input);">Back to overview</a></div>
</div>
</div>
<div id="step-2" class="scanner-step hidden">
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
<div class="flex items-center justify-between flex-wrap gap-3" style="padding:16px 24px;border-bottom:1px solid var(--color-border);">
<div class="flex items-center gap-3">
<div class="bg-primary/10 rounded-lg flex items-center justify-center" style="width:36px;height:36px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(37,99,70)" stroke-width="2" stroke-linecap="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
<div><p id="display-address" class="font-semibold text-charcoal" style="font-size:15px;line-height:1.3;"></p><p class="text-label-uppercase text-primary" style="font-size:11px;">Roof scan complete</p></div>
</div>
<button id="change-address" type="button" class="text-sm underline" style="color:var(--color-input);">Change address</button>
</div>
<div class="flex flex-col lg:flex-row">
<div class="relative lg:flex-1" style="min-height:400px;background:#1a2332;">
<div id="roof-map" class="w-full h-full absolute inset-0"></div>
<div id="scan-loading" class="absolute inset-0 flex flex-col items-center justify-center z-10" role="alert" aria-busy="true" style="background:rgba(26,35,50,0.92);"><div class="scan-spinner mb-4"></div><p class="text-white font-semibold" style="font-size:15px;">Scanning your roof...</p><p class="text-white/50" style="font-size:13px;" id="scan-status" aria-live="polite" role="status">Locating property</p></div>
<div id="roof-legend" class="hidden absolute bottom-4 left-4 bg-black/70 backdrop-blur rounded-lg text-white z-10" style="padding:10px 14px;font-size:13px;"><div class="flex items-center gap-2"><span class="inline-block rounded" style="width:14px;height:3px;background:rgb(196,112,75);"></span><span>Roof outline</span></div></div>
</div>
<div class="lg:w-[340px] flex-shrink-0" style="padding:28px 24px;border-left:1px solid var(--color-border);">
<h2 class="font-fraunces text-charcoal mb-5" style="font-size:20px;font-weight:600;">Roof Measurements</h2>
<div class="flex flex-col gap-4">
<div class="measurement-row"><span class="meas-label">Total Area</span><span class="meas-value" id="meas-area">—</span></div>
<div class="measurement-row"><span class="meas-label">Predominant Pitch</span><span class="meas-value" id="meas-pitch">—</span></div>
<div class="measurement-row"><span class="meas-label">Facets</span><span class="meas-value" id="meas-facets">—</span></div>
<div class="measurement-row"><span class="meas-label">Ridges & Hips</span><span class="meas-value" id="meas-ridges">—</span></div>
<div class="measurement-row"><span class="meas-label">Valleys</span><span class="meas-value" id="meas-valleys">—</span></div>
<div class="measurement-row"><span class="meas-label">Eaves</span><span class="meas-value" id="meas-eaves">—</span></div>
<div class="measurement-row"><span class="meas-label">Complexity</span><span class="meas-value" id="meas-complexity">—</span></div>
</div>
<hr class="my-5" style="border-color:var(--color-border);" />
<button id="continue-to-options" class="w-full bg-primary text-white text-button rounded-lg transition-opacity hover:opacity-90" style="padding:14px 24px;">Continue to Options & Pricing</button>
</div>
</div>
</div>
</div>
<div id="step-3" class="scanner-step hidden">
<div class="flex flex-col lg:flex-row gap-6">
<div class="lg:flex-1"><div class="bg-white rounded-2xl shadow-sm" style="padding:28px 24px;">
<h2 class="font-fraunces text-charcoal mb-1" style="font-size:22px;font-weight:600;">Choose Your Shingle</h2>
<p class="text-body mb-6" style="color:var(--color-input);font-size:15px;">Select a material tier. All include full tear-off, install & cleanup.</p>
<div class="flex flex-col gap-4" id="material-options" role="radiogroup" aria-label="Shingle material tier">
<label class="material-card selected" data-tier="good"><input type="radio" name="material" value="good" checked class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><span class="text-label-uppercase text-primary" style="font-size:11px;">Good</span><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">3-Tab Shingles</p><p style="font-size:14px;color:var(--color-input);margin-top:4px;">Owens Corning Supreme &middot; 25-year warranty</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="3.50">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">installed</p></div></div><div class="color-swatches mt-3 flex gap-2"><button class="swatch active" type="button" style="background:#2d2d2d;" aria-label="Onyx Black"></button><button class="swatch" type="button" style="background:#5a5a5a;" aria-label="Estate Gray"></button><button class="swatch" type="button" style="background:#6b4c3b;" aria-label="Brownwood"></button><button class="swatch" type="button" style="background:#8b7d6b;" aria-label="Desert Tan"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>
<label class="material-card" data-tier="better"><input type="radio" name="material" value="better" class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><span class="text-label-uppercase text-primary" style="font-size:11px;">Better</span><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Architectural Shingles</p><p style="font-size:14px;color:var(--color-input);margin-top:4px;">GAF Timberline HDZ &middot; 30-year warranty</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="4.75">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">installed</p></div></div><div class="color-swatches mt-3 flex gap-2"><button class="swatch active" type="button" style="background:#1e1e1e;" aria-label="Charcoal"></button><button class="swatch" type="button" style="background:#4a6355;" aria-label="Hunter Green"></button><button class="swatch" type="button" style="background:#8b4513;" aria-label="Hickory"></button><button class="swatch" type="button" style="background:#696969;" aria-label="Pewter Gray"></button><button class="swatch" type="button" style="background:#5c3a21;" aria-label="Barkwood"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>
<label class="material-card" data-tier="best"><input type="radio" name="material" value="best" class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><div class="flex items-center gap-2"><span class="text-label-uppercase text-primary" style="font-size:11px;">Best</span><span class="inline-block bg-terracotta text-white rounded-full" style="font-size:10px;font-weight:700;padding:2px 8px;">POPULAR</span></div><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Designer Shingles</p><p style="font-size:14px;color:var(--color-input);margin-top:4px;">CertainTeed Grand Manor &middot; 50-year warranty</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="6.25">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">installed</p></div></div><div class="color-swatches mt-3 flex gap-2"><button class="swatch active" type="button" style="background:#3d3d3d;" aria-label="Gatehouse Slate"></button><button class="swatch" type="button" style="background:#6b4226;" aria-label="Tudor Brown"></button><button class="swatch" type="button" style="background:#8b0000;" aria-label="Colonial Red"></button><button class="swatch" type="button" style="background:#556b2f;" aria-label="Weathered Evergreen"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>
<label class="material-card" data-tier="premium"><input type="radio" name="material" value="premium" class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><span class="text-label-uppercase text-primary" style="font-size:11px;">Premium</span><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Synthetic Slate</p><p style="font-size:14px;color:var(--color-input);margin-top:4px;">DaVinci Roofscapes Bellaforté &middot; Lifetime warranty</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="9.00">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">installed</p></div></div><div class="color-swatches mt-3 flex gap-2"><button class="swatch active" type="button" style="background:#363636;" aria-label="Slate Black"></button><button class="swatch" type="button" style="background:#708090;" aria-label="Slate Gray"></button><button class="swatch" type="button" style="background:#654321;" aria-label="Castle Brown"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>
</div>
<h3 class="font-fraunces text-charcoal mt-8 mb-4" style="font-size:18px;font-weight:600;">Add-ons</h3>
<div class="flex flex-col gap-3" id="addons">
<label class="addon-row"><input type="checkbox" name="addon" value="gutter-guards" data-addon-price="1200"/><span class="addon-check"></span><span class="addon-label">Gutter Guards</span><span class="addon-price">+$1,200</span></label>
<label class="addon-row"><input type="checkbox" name="addon" value="ice-shield" data-addon-price="800"/><span class="addon-check"></span><span class="addon-label">Full Ice & Water Shield</span><span class="addon-price">+$800</span></label>
<label class="addon-row"><input type="checkbox" name="addon" value="ridge-vent" data-addon-price="600"/><span class="addon-check"></span><span class="addon-label">Ridge Vent Upgrade</span><span class="addon-price">+$600</span></label>
<label class="addon-row"><input type="checkbox" name="addon" value="skylights" data-addon-price="2500"/><span class="addon-check"></span><span class="addon-label">Skylight Install (per unit)</span><span class="addon-price">+$2,500</span></label>
</div>
</div></div>
<div class="lg:w-[380px] flex-shrink-0"><div class="bg-white rounded-2xl shadow-sm lg:sticky lg:top-20" style="padding:28px 24px;">
<h3 class="font-fraunces text-charcoal mb-1" style="font-size:22px;font-weight:600;">Your Price</h3>
<p id="summary-address" class="mb-5" style="font-size:13px;color:var(--color-input);"></p>
<div class="flex flex-col gap-3 mb-5">
<div class="flex justify-between" style="font-size:15px;"><span style="color:var(--color-input);">Materials</span><span class="font-semibold text-charcoal" id="price-materials">$0</span></div>
<div class="flex justify-between" style="font-size:15px;"><span style="color:var(--color-input);">Labor & Install</span><span class="font-semibold text-charcoal" id="price-labor">$0</span></div>
<div class="flex justify-between" style="font-size:15px;"><span style="color:var(--color-input);">Tear-off & Disposal</span><span class="font-semibold text-charcoal" id="price-tearoff">$0</span></div>
<div class="flex justify-between" style="font-size:15px;"><span style="color:var(--color-input);">Permits & Warranty</span><span class="font-semibold text-charcoal" id="price-permits">$0</span></div>
<div id="addons-summary"></div>
<div class="flex justify-between" style="font-size:15px;"><span style="color:var(--color-input);text-decoration:line-through;">Sales Commission</span><span class="font-semibold line-through" style="color:#bbb;">$0</span></div>
<p style="font-size:12px;color:var(--color-primary);font-weight:600;margin-top:-4px;">You save <span id="commission-savings">$0</span> — no salesman, no markup.</p>
</div>
<hr style="border-color:var(--color-border);" />
<div class="flex justify-between items-end my-5">
<div><p style="font-size:13px;color:var(--color-input);">Total Price</p><p class="font-fraunces text-charcoal" style="font-size:36px;font-weight:700;line-height:1;" id="total-price">$0</p></div>
<div class="text-right"><p style="font-size:13px;color:var(--color-input);">or as low as</p><p class="font-fraunces text-primary" style="font-size:22px;font-weight:700;line-height:1;" id="monthly-price">$0/mo</p><p style="font-size:11px;color:var(--color-input);">for 60 months*</p></div>
</div>
<button id="purchase-btn" class="w-full bg-primary text-white text-button rounded-lg transition-opacity hover:opacity-90 mb-3" style="padding:16px 24px;font-size:17px;">Purchase This Roof</button>
<button class="w-full bg-transparent text-charcoal text-button rounded-lg border transition-colors hover:bg-charcoal/5" style="padding:14px 24px;border-color:var(--color-border);">Schedule a Call Instead</button>
<p class="text-center mt-4" style="font-size:12px;color:var(--color-input);">*0% APR financing available with approved credit.</p>
</div></div>
</div>
</div>
</div>
</section>
<div id="mobile-price-bar" class="fixed bottom-0 left-0 right-0 z-50 bg-white shadow-[0_-2px_12px_rgba(0,0,0,0.1)] hidden lg:hidden" style="padding:12px 20px;border-top:1px solid var(--color-border);"><div class="flex items-center justify-between"><div><p style="font-size:11px;color:var(--color-input);line-height:1;">Total Price</p><p class="font-fraunces text-charcoal" style="font-size:24px;font-weight:700;line-height:1.2;" id="mobile-total-price">$0</p></div><a href="#purchase-btn" class="bg-primary text-white text-button rounded-lg" style="padding:12px 28px;font-size:15px;">Purchase</a></div></div>
</Layout>
<style>
.step-dot{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:default}.step-num{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-dm-sans);font-weight:700;font-size:14px;background:var(--color-border);color:var(--color-input);transition:all .3s ease}.step-label{font-family:var(--font-satoshi);font-size:12px;font-weight:500;color:var(--color-input)}.step-dot.active .step-num{background:var(--color-primary);color:#fff}.step-dot.active .step-label{color:var(--color-charcoal);font-weight:700}.step-dot.completed .step-num{background:var(--color-primary);color:#fff}.step-line{width:60px;height:2px;background:var(--color-border);margin-bottom:22px}.step-line.active{background:var(--color-primary)}.scanner-step{animation:fadeUp .4s ease}.scanner-step.hidden{display:none}@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}.scan-spinner{width:48px;height:48px;border:3px solid rgba(255,255,255,.15);border-top-color:var(--color-terracotta);border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.measurement-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(196,191,182,.4)}.meas-label{font-family:var(--font-dm-sans);font-size:14px;color:var(--color-input)}.meas-value{font-family:var(--font-fraunces);font-size:16px;font-weight:600;color:var(--color-charcoal)}.material-card{position:relative;display:block;cursor:pointer;border:2px solid var(--color-border);border-radius:14px;padding:20px;transition:border-color .2s,box-shadow .2s}.material-card:hover{border-color:var(--color-primary)}.material-card.selected{border-color:var(--color-primary);box-shadow:0 0 0 1px var(--color-primary)}.check-indicator{position:absolute;top:12px;right:12px;width:28px;height:28px;border-radius:50%;background:var(--color-border);display:flex;align-items:center;justify-content:center}.check-indicator svg{opacity:0;transition:opacity .2s}.material-card.selected .check-indicator{background:var(--color-primary)}.material-card.selected .check-indicator svg{opacity:1}.swatch{width:32px;height:32px;border-radius:50%;border:2px solid transparent;cursor:pointer;position:relative}.swatch::before{content:'';position:absolute;inset:-6px}.swatch:hover{transform:scale(1.15)}.swatch.active{border-color:var(--color-primary);box-shadow:0 0 0 2px #fff,0 0 0 4px var(--color-primary)}.addon-row{display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 14px;border:1px solid var(--color-border);border-radius:10px}.addon-row:hover{border-color:var(--color-primary)}.addon-row input{display:none}.addon-check{width:20px;height:20px;border-radius:5px;border:2px solid var(--color-border);flex-shrink:0;position:relative}.addon-row input:checked~.addon-check{background:var(--color-primary);border-color:var(--color-primary)}.addon-row input:checked~.addon-check::after{content:'';position:absolute;top:3px;left:6px;width:5px;height:9px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}.addon-label{flex:1;font-family:var(--font-dm-sans);font-size:14px;color:var(--color-charcoal)}.addon-price{font-family:var(--font-dm-sans);font-size:14px;font-weight:600;color:var(--color-input);flex-shrink:0}.price-updating{animation:pricePulse .3s}@keyframes pricePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}.address-suggestion{padding:12px 16px;cursor:pointer;font-family:var(--font-dm-sans);font-size:15px;color:var(--color-charcoal);border-bottom:1px solid rgba(196,191,182,.3)}.address-suggestion:last-child{border-bottom:none}.address-suggestion:hover{background:var(--color-cream)}#address-input:focus{border-color:var(--color-primary)}body.has-mobile-bar{padding-bottom:72px}@media(max-width:1023px){#step-2 .flex-col.lg\:flex-row>div:last-child{border-left:none;border-top:1px solid var(--color-border)}}@media(max-width:480px){.meas-label{font-size:13px}.meas-value{font-size:14px}.measurement-row{padding:6px 0}}
</style>
<script is:inline src="/scan-engine.js"></script>
