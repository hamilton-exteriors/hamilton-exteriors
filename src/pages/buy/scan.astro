t:center}.check-indicator svg{opacity:0;transition:opacity .2s}.material-card.selected .check-indicator{background:var(--color-primary)}.material-card.selected .check-indicator svg{opacity:1}.swatch{width:36px;height:36px;border-radius:50%;border:2px solid transparent;cursor:pointer;position:relative;background-size:cover;background-position:center;background-color:#888}.swatch::before{content:'';position:absolute;inset:-4px}.swatch:hover{transform:scale(1.15)}.swatch.active{border-color:var(--color-primary);box-shadow:0 0 0 2px #fff,0 0 0 4px var(--color-primary)}.addon-row{display:flex;align-items:center;gap:8px;cursor:pointer;padding:8px 10px;border:1px solid var(--color-border);border-radius:8px;font-size:13px}.addon-row:hover{border-color:var(--color-primary)}.addon-row input{display:none}.addon-check{width:16px;height:16px;border-radius:4px;border:2px solid var(--color-border);flex-shrink:0;position:relative}.addon-row input:checked~.addon-check{background:var(--color-primary);border-color:var(--color-primary)}.addon-row input:checked~.addon-check::after{content:'';position:absolute;top:2px;left:5px;width:4px;height:7px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}.addon-label{flex:1;font-family:var(--font-dm-sans);font-size:13px;color:var(--color-charcoal)}.addon-price{font-family:var(--font-dm-sans);font-size:13px;font-weight:600;color:var(--color-input);flex-shrink:0}.price-updating{animation:pricePulse .3s}@keyframes pricePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}.address-suggestion{padding:12px 16px;cursor:pointer;font-family:var(--font-dm-sans);font-size:15px;color:var(--color-charcoal);border-bottom:1px solid rgba(196,191,182,.3)}.address-suggestion:last-child{border-bottom:none}.address-suggestion:hover{background:var(--color-cream)}#address-input:focus{border-color:var(--color-primary)}body.has-mobile-bar{padding-bottom:72px}@media(max-width:1023px){#step-2 .flex-col.lg\:flex-row>div:last-child{border-left:none;border-top:1px solid var(--color-border)}}@media(max-width:480px){.meas-label{font-size:13px}.meas-value{font-size:14px}.measurement-row{padding:6px 0}}
.tier-toggle{cursor:pointer;padding:4px 0;background:none;border:none;}.tier-toggle:hover .tier-arrow{color:var(--color-charcoal)}
