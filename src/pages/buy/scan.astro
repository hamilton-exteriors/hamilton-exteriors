<div class="tier-divider mt-6 mb-3">
  <button type="button" class="tier-toggle flex items-center gap-2 w-full" data-tier-group="upgraded">
    <p class="text-label-uppercase" style="font-size:11px;color:var(--color-input);">Impact-Rated & Upgraded</p>
