---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import IconCheckmark from '../../components/icons/IconCheckmark.astro';
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';
const apiUrl = import.meta.env.PUBLIC_ROOF_SCAN_API || 'http://localhost:3001';
---
<Layout title="Your Roof Scan | Hamilton Exteriors" description="See your roof measurements and get an instant price." noindex>
<Navbar slot="header" />
<script is:inline>
  // Hide step 1 immediately if address is in URL — prevents flash of address input.
  // Uses a removable style tag so goStep(1) can re-show step-1 for errors.
  if (new URLSearchParams(window.location.search).get('address')) {
    var st = document.createElement('style');
    st.id = 'hide-step1';
    st.textContent = '#step-1{display:none}';
    document.head.appendChild(st);
  }
</script>
<section id="scanner" class="min-h-[calc(100vh-80px)] w-full bg-cream px-5 pt-10 pb-20">
<div class="mx-auto max-w-[1100px]">
<nav id="step-indicator" class="mb-10 flex items-center justify-center gap-3" aria-label="Purchase progress">
<div class="step-dot active" data-step="1" aria-current="step"><span class="step-num" aria-hidden="true">1</span><span class="step-label">Enter Address</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="2"><span class="step-num" aria-hidden="true">2</span><span class="step-label">Roof Scan</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="3"><span class="step-num" aria-hidden="true">3</span><span class="step-label">Choose & Buy</span></div>
</nav>
<div id="step-1" class="scanner-step">
<div class="mx-auto max-w-[680px] rounded-[4px] bg-white px-10 py-12 shadow-sm">
<h1 class="mb-2 text-center text-[28px] text-charcoal">Where's your home?</h1>
<p class="mb-8 text-center text-muted">We'll pull up a satellite view of your roof and calculate measurements instantly.</p>
<div class="relative">
<input id="address-input" type="text" placeholder="Enter your home address..." autocomplete="off" role="combobox" aria-label="Home address" aria-expanded="false" aria-controls="address-dropdown" aria-autocomplete="list" class="w-full rounded-[4px] border-2 border-border py-[18px] pr-[60px] pl-5 text-[17px] text-body transition-[border-color] duration-200 outline-none" />
<button id="scan-btn" type="button" class="absolute top-1/2 right-3 flex size-11 -translate-y-1/2 items-center justify-center rounded-[4px] bg-primary text-white transition-opacity hover:opacity-90" aria-label="Scan roof"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
<div id="address-dropdown" role="listbox" aria-label="Address suggestions" class="absolute inset-x-0 top-full z-10 mt-1 hidden overflow-hidden rounded-[4px] border border-border bg-white shadow-lg"></div>
</div>
<p id="service-area-error" class="mt-4 hidden text-center text-[15px] leading-normal text-error"></p>
<div class="mt-6 flex items-center justify-center gap-4"><a href="/buy" class="text-sm text-muted underline">Back to overview</a></div>
</div>
</div>
<div id="step-2" class="scanner-step hidden">
<div class="overflow-hidden rounded-[4px] bg-white shadow-sm">
<div class="flex flex-wrap items-center justify-between gap-3 border-b border-border px-6 py-4">
<div class="flex items-center gap-3">
<div class="flex size-9 items-center justify-center rounded-[4px] bg-primary/10"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(37,99,70)" stroke-width="2" stroke-linecap="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
<div><p id="display-address" class="text-[15px] leading-[1.3] font-semibold text-charcoal"></p><p class="text-label-uppercase text-[11px] text-primary">Roof scan complete</p></div>
</div>
<button id="change-address" type="button" class="text-sm text-muted underline">Change address</button>
</div>
<div class="flex flex-col lg:flex-row">
<div class="relative min-h-[400px] bg-(--color-heading) lg:flex-1">
<div id="roof-map" class="absolute inset-0 size-full"></div>
<div id="scan-loading" class="absolute inset-0 z-10 flex flex-col items-center justify-center bg-[rgba(26,35,50,0.92)]" role="alert" aria-busy="true"><div class="scan-spinner mb-4"></div><p class="text-[15px] font-semibold text-white">Scanning your roof...</p><p class="text-[13px] text-white/50" id="scan-status" aria-live="polite" role="status">Locating property</p></div>
<div id="roof-legend" class="absolute bottom-4 left-4 z-10 hidden rounded-[4px] bg-black/70 px-3.5 py-2.5 text-[13px] text-white backdrop-blur"><div class="flex items-center gap-2"><span class="inline-block h-[3px] w-3.5 rounded bg-[rgb(196,112,75)]"></span><span>Roof outline</span></div></div>
</div>
<div class="shrink-0 border-l border-border px-6 py-7 lg:w-[340px]">
<h2 class="mb-5 text-xl text-charcoal">Roof Measurements</h2>
<div class="flex flex-col gap-4" aria-live="polite" aria-atomic="false">
<div class="measurement-row"><span class="meas-label">Total Area <button type="button" class="meas-info" aria-label="What is total area?" data-tip="The total surface area of your roof, including all slopes. This determines how much material is needed.">?</button></span><span class="meas-value" id="meas-area">—</span></div>
<div class="measurement-row"><span class="meas-label">Predominant Pitch <button type="button" class="meas-info" aria-label="What is roof pitch?" data-tip="How steep your roof is. Steeper roofs need more safety equipment and labor time.">?</button></span><span class="meas-value" id="meas-pitch">—</span></div>
<div class="measurement-row"><span class="meas-label">Facets <button type="button" class="meas-info" aria-label="What are facets?" data-tip="Individual flat sections of your roof. More facets means a more complex (and labor-intensive) installation.">?</button></span><span class="meas-value" id="meas-facets">—</span></div>
<div class="measurement-row"><span class="meas-label">Ridges & Hips <button type="button" class="meas-info" aria-label="What are ridges and hips?" data-tip="The peak lines where two roof slopes meet. These need special ridge cap shingles for weatherproofing.">?</button></span><span class="meas-value" id="meas-ridges">—</span></div>
<div class="measurement-row"><span class="meas-label">Valleys <button type="button" class="meas-info" aria-label="What are valleys?" data-tip="The inward angles where two slopes meet. Valleys channel water, so they need extra waterproofing.">?</button></span><span class="meas-value" id="meas-valleys">—</span></div>
<div class="measurement-row"><span class="meas-label">Eaves <button type="button" class="meas-info" aria-label="What are eaves?" data-tip="The lower edges of your roof that overhang the walls. Eave length affects drip edge and starter strip needs.">?</button></span><span class="meas-value" id="meas-eaves">—</span></div>
<div class="measurement-row"><span class="meas-label">Complexity <button type="button" class="meas-info" aria-label="What is complexity?" data-tip="An overall score based on pitch, facets, and features. Higher complexity means more labor and materials.">?</button></span><span class="meas-value" id="meas-complexity">—</span></div>
</div>
<hr class="my-5 border-border" />
<button id="continue-to-options" class="text-button w-full rounded-[4px] bg-primary px-6 py-3.5 text-white transition-opacity hover:opacity-90">Continue to Options & Pricing</button>
</div>
</div>
</div>
</div>
<div id="step-3" class="scanner-step hidden">
<div class="mb-4 flex flex-wrap items-center justify-between gap-2 px-1">
<p id="step3-address" class="text-sm font-medium text-charcoal"></p>
<button type="button" id="step3-edit-address" class="text-sm text-muted underline">Edit address</button>
</div>
<div class="flex flex-col gap-6 lg:flex-row">
<div class="lg:flex-1"><div class="rounded-[4px] bg-white px-6 py-7 shadow-sm">
<h2 class="mb-1 text-[22px] text-charcoal">Choose Your Shingle</h2>
<p class="mb-5 text-sm text-muted">All prices include tear-off, materials, labor, underlayment, starter, ridge cap, nails & cleanup.</p>
<!-- Swatch preview tooltip -->
<div id="swatch-preview" class="pointer-events-none fixed z-50 hidden size-[140px] overflow-hidden rounded-[4px] border border-border shadow-lg">
  <img id="swatch-preview-img" src="" alt="Shingle color preview" class="size-full object-cover" onerror="this.parentElement.parentElement.classList.add('hidden');" />
  <div id="swatch-preview-name" class="absolute inset-x-0 bottom-0 bg-black/60 p-1 text-center text-[11px] font-semibold text-white"></div>
</div>
<!-- Tier: Recommended -->
<div class="mb-3"><p class="text-label-uppercase mb-2 text-[11px] text-primary">Recommended</p></div>
<div class="flex flex-col gap-3" id="material-options" role="radiogroup" aria-label="Roofing product">

<!-- ── ASPHALT SHINGLES ──────────────────────────────────── -->

<!-- GAF Timberline HDZ — $950/sq (mat $350 + labor 8hr×$75) -->
<label class="material-card selected" data-tier="gaf-hdz"><input type="radio" name="material" value="gaf-hdz" checked class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><div class="flex items-center gap-2"><span class="text-label-uppercase text-[11px] text-brand-gaf">GAF</span><span class="inline-block rounded-full bg-primary px-2 py-[2px] text-[10px] font-bold text-white">POPULAR</span></div><p class="mt-[2px] text-lg font-semibold text-charcoal">Timberline HDZ<sup>&reg;</sup></p><p class="mt-1 text-[13px] text-muted">Lifetime warranty &middot; LayerLock&trade; &middot; StainGuard Plus&trade;</p></div><div class="shrink-0 text-right"><p class="text-[22px] font-bold text-charcoal" data-price-per-sqft="9.50">$<span class="tier-price">0</span></p><p class="text-xs text-muted">total installed</p></div></div><div class="color-swatches mt-3 flex flex-wrap gap-2"><button class="swatch active" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/charcoal.webp);" aria-label="Charcoal"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/pewter-gray.jpg);" aria-label="Pewter Gray"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/barkwood.webp);" aria-label="Barkwood"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/weathered-wood.jpg);" aria-label="Weathered Wood"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/slate.jpg);" aria-label="Slate"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/shakewood.jpg);" aria-label="Shakewood"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/hickory.jpg);" aria-label="Hickory"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/fox-hollow-gray.jpg);" aria-label="Fox Hollow Gray"></button></div></div><div class="check-indicator"><IconCheckmark size={18} /></div></label>

