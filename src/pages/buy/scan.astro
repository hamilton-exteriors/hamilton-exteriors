<button class="swatch" type="button" style="background-image:url(/swatches/certainteed-landmark/driftwood.jpg);" aria-label="Driftwood"></button><button class="swatch" type="button" style="background-image:url(/swatches/certainteed-landmark/colonial-slate.jpg);" aria-label="Colonial Slate"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>

