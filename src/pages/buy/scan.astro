mage:url(/swatches/gaf-timberline-hdz/hickory.jpg);" aria-label="Hickory"></button><button class="swatch" type="button" style="background-image:url(/swatches/gaf-timberline-hdz/fox-hollow-gray.jpg);" aria-label="Fox Hollow Gray"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>

