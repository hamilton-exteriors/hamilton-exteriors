---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---
<Layout title="Your Roof Scan | Hamilton Exteriors" description="See your roof measurements and get an instant price.">
<Navbar />
<section id="scanner" class="w-full" style="background-color:var(--color-cream);padding:40px 20px 80px;min-height:calc(100vh - 80px);">
<div class="mx-auto" style="max-width:1100px;">
<nav id="step-indicator" class="flex items-center justify-center gap-3 mb-10" aria-label="Purchase progress">
<div class="step-dot active" data-step="1" aria-current="step"><span class="step-num" aria-hidden="true">1</span><span class="step-label">Enter Address</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="2"><span class="step-num" aria-hidden="true">2</span><span class="step-label">Roof Scan</span></div>
<div class="step-line" aria-hidden="true"></div>
<div class="step-dot" data-step="3"><span class="step-num" aria-hidden="true">3</span><span class="step-label">Choose & Buy</span></div>
</nav>
<div id="step-1" class="scanner-step">
<div class="bg-white rounded-2xl shadow-sm mx-auto" style="max-width:680px;padding:48px 40px;">
<h1 class="font-fraunces text-charcoal text-center mb-2" style="font-size:28px;font-weight:600;">Where's your home?</h1>
<p class="text-body text-center mb-8" style="color:var(--color-input);">We'll pull up a satellite view of your roof and calculate measurements instantly.</p>
<div class="relative">
<input id="address-input" type="text" placeholder="Enter your home address..." autocomplete="off" role="combobox" aria-label="Home address" aria-expanded="false" aria-controls="address-dropdown" aria-autocomplete="list" class="w-full rounded-xl text-body" style="padding:18px 60px 18px 20px;border:2px solid var(--color-border);font-size:17px;outline:none;transition:border-color 0.2s;" />
<button id="scan-btn" type="button" class="absolute top-1/2 right-3 -translate-y-1/2 bg-primary text-white rounded-lg flex items-center justify-center transition-opacity hover:opacity-90" style="width:44px;height:44px;" aria-label="Scan roof"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
<div id="address-dropdown" role="listbox" aria-label="Address suggestions" class="hidden absolute left-0 right-0 top-full mt-1 bg-white rounded-xl shadow-lg border z-10 overflow-hidden" style="border-color:var(--color-border);"></div>
</div>
<div class="flex items-center justify-center gap-4 mt-6"><a href="/buy" class="text-sm underline" style="color:var(--color-input);">Back to overview</a></div>
</div>
</div>
<div id="step-2" class="scanner-step hidden">
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
<div class="flex items-center justify-between flex-wrap gap-3" style="padding:16px 24px;border-bottom:1px solid var(--color-border);">
<div class="flex items-center gap-3">
<div class="bg-primary/10 rounded-lg flex items-center justify-center" style="width:36px;height:36px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(37,99,70)" stroke-width="2" stroke-linecap="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
<div><p id="display-address" class="font-semibold text-charcoal" style="font-size:15px;line-height:1.3;"></p><p class="text-label-uppercase text-primary" style="font-size:11px;">Roof scan complete</p></div>
</div>
<button id="change-address" type="button" class="text-sm underline" style="color:var(--color-input);">Change address</button>
</div>
<div class="flex flex-col lg:flex-row">
<div class="relative lg:flex-1" style="min-height:400px;background:#1a2332;">
<div id="roof-map" class="w-full h-full absolute inset-0"></div>
<div id="scan-loading" class="absolute inset-0 flex flex-col items-center justify-center z-10" role="alert" aria-busy="true" style="background:rgba(26,35,50,0.92);"><div class="scan-spinner mb-4"></div><p class="text-white font-semibold" style="font-size:15px;">Scanning your roof...</p><p class="text-white/50" style="font-size:13px;" id="scan-status" aria-live="polite" role="status">Locating property</p></div>
<div id="roof-legend" class="hidden absolute bottom-4 left-4 bg-black/70 backdrop-blur rounded-lg text-white z-10" style="padding:10px 14px;font-size:13px;"><div class="flex items-center gap-2"><span class="inline-block rounded" style="width:14px;height:3px;background:rgb(196,112,75);"></span><span>Roof outline</span></div></div>
</div>
<div class="lg:w-[340px] flex-shrink-0" style="padding:28px 24px;border-left:1px solid var(--color-border);">
<h2 class="font-fraunces text-charcoal mb-5" style="font-size:20px;font-weight:600;">Roof Measurements</h2>
<div class="flex flex-col gap-4">
<div class="measurement-row"><span class="meas-label">Total Area</span><span class="meas-value" id="meas-area">—</span></div>
<div class="measurement-row"><span class="meas-label">Predominant Pitch</span><span class="meas-value" id="meas-pitch">—</span></div>
<div class="measurement-row"><span class="meas-label">Facets</span><span class="meas-value" id="meas-facets">—</span></div>
<div class="measurement-row"><span class="meas-label">Ridges & Hips</span><span class="meas-value" id="meas-ridges">—</span></div>
<div class="measurement-row"><span class="meas-label">Valleys</span><span class="meas-value" id="meas-valleys">—</span></div>
<div class="measurement-row"><span class="meas-label">Eaves</span><span class="meas-value" id="meas-eaves">—</span></div>
<div class="measurement-row"><span class="meas-label">Complexity</span><span class="meas-value" id="meas-complexity">—</span></div>
</div>
<hr class="my-5" style="border-color:var(--color-border);" />
<button id="continue-to-options" class="w-full bg-primary text-white text-button rounded-lg transition-opacity hover:opacity-90" style="padding:14px 24px;">Continue to Options & Pricing</button>
</div>
</div>
</div>
</div>
<div id="step-3" class="scanner-step hidden">
<div class="flex flex-col lg:flex-row gap-6">
<div class="lg:flex-1"><div class="bg-white rounded-2xl shadow-sm" style="padding:28px 24px;">
<h2 class="font-fraunces text-charcoal mb-1" style="font-size:22px;font-weight:600;">Choose Your Roof</h2>
<p class="text-body mb-4" style="color:var(--color-input);font-size:15px;">All prices include tear-off, materials, labor, underlayment, starter strip, ridge cap, nails & cleanup.</p>
<!-- Category filter -->
<div class="flex flex-wrap gap-2 mb-6" id="category-filter">
  <button class="cat-btn active" type="button" data-cat="all">All</button>
  <button class="cat-btn" type="button" data-cat="shingle">Asphalt Shingles</button>
  <button class="cat-btn" type="button" data-cat="metal">Metal</button>
  <button class="cat-btn" type="button" data-cat="tile">Tile & Slate</button>
  <button class="cat-btn" type="button" data-cat="flat">Flat / Low-Slope</button>
</div>
<div class="flex flex-col gap-4" id="material-options" role="radiogroup" aria-label="Roofing product">

<!-- ── ASPHALT SHINGLES ──────────────────────────────────── -->

<!-- GAF Timberline HDZ — $950/sq (mat $350 + labor 8hr×$75) -->
<label class="material-card selected" data-tier="gaf-hdz" data-cat="shingle"><input type="radio" name="material" value="gaf-hdz" checked class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><div class="flex items-center gap-2"><span class="text-label-uppercase" style="font-size:11px;color:#003da5;">GAF</span><span class="inline-block bg-terracotta text-white rounded-full" style="font-size:10px;font-weight:700;padding:2px 8px;">POPULAR</span></div><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Timberline HDZ<sup>&reg;</sup></p><p style="font-size:13px;color:var(--color-input);margin-top:4px;">Lifetime warranty &middot; LayerLock&trade; &middot; StainGuard Plus&trade;</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="9.50">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">per sq installed</p></div></div><div class="color-swatches mt-3 flex flex-wrap gap-2"><button class="swatch active" type="button" style="background:#2d2d2d;" aria-label="Charcoal"></button><button class="swatch" type="button" style="background:#6e6e6e;" aria-label="Pewter Gray"></button><button class="swatch" type="button" style="background:#5a4332;" aria-label="Barkwood"></button><button class="swatch" type="button" style="background:#544840;" aria-label="Weathered Wood"></button><button class="swatch" type="button" style="background:#4a4a50;" aria-label="Slate"></button><button class="swatch" type="button" style="background:#6a5a48;" aria-label="Shakewood"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>

<!-- CertainTeed Landmark — $940/sq (mat $340 + labor 8hr×$75) -->
<label class="material-card" data-tier="ct-landmark" data-cat="shingle"><input type="radio" name="material" value="ct-landmark" class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><span class="text-label-uppercase" style="font-size:11px;color:#00543c;">CertainTeed</span><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Landmark<sup>&reg;</sup></p><p style="font-size:13px;color:var(--color-input);margin-top:4px;">Lifetime warranty &middot; Max Def colors &middot; 110 MPH wind</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="9.40">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">per sq installed</p></div></div><div class="color-swatches mt-3 flex flex-wrap gap-2"><button class="swatch active" type="button" style="background:#252525;" aria-label="Moire Black"></button><button class="swatch" type="button" style="background:#6a6a6a;" aria-label="Georgetown Gray"></button><button class="swatch" type="button" style="background:#544840;" aria-label="Weathered Wood"></button><button class="swatch" type="button" style="background:#5e3a2a;" aria-label="Burnt Sienna"></button><button class="swatch" type="button" style="background:#7a6548;" aria-label="Resawn Shake"></button><button class="swatch" type="button" style="background:#8b6d4a;" aria-label="Heather Blend"></button></div></div><div class="check-indicator"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div></label>

