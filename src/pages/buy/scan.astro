<label class="material-card" data-tier="oc-duration"><input type="radio" name="material" value="oc-duration" class="hidden"/><div class="card-inner"><div class="flex items-start justify-between gap-4"><div><span class="text-label-uppercase" style="font-size:11px;color:#d4451a;">Owens Corning</span><p class="font-fraunces text-charcoal" style="font-size:18px;font-weight:600;margin-top:2px;">Duration<sup>&reg;</sup></p><p style="font-size:13px;color:var(--color-input);margin-top:4px;">Lifetime warranty &middot; SureNail&reg; &middot; 130 MPH wind</p></div><div class="text-right flex-shrink-0"><p class="font-fraunces text-charcoal" style="font-size:22px;font-weight:700;" data-price-per-sqft="9.60">$<span class="tier-price">0</span></p><p style="font-size:12px;color:var(--color-input);">total installed</p></div></div><div class="color-swatches mt-3 flex flex-wrap gap-2"><button class="swatch active" type="button" style="background-image:url(/swatches/owens-corning-duration/estate-gray.jpg);" aria-label="Estate Gray"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/brownwood.jpg);" aria-label="Brownwood"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/desert-tan.jpg);" aria-label="Desert Tan"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/driftwood.jpg);" aria-label="Driftwood"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/chateau-green.jpg);" aria-label="Chateau Green"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/harbor-blue.jpg);" aria-label="Harbor Blue"></button><button class="swatch" type="button" style="background-image:url(/swatches/owens-corning-duration/midnight-plum.jpg);" aria-label="Midnight Plum"></button></div></div><div class="check-indicator"><svg width="18" he