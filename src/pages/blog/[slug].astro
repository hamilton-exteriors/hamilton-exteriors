---
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import ContactUs from '../../components/ContactUs.astro';
import Footer from '../../components/Footer.astro';
import { getPost, getPosts, isGhostConfigured, formatDate } from '../../lib/ghost';

const { slug } = Astro.params;

if (!slug || !isGhostConfigured()) {
  return Astro.redirect('/blog');
}

let post;
try {
  post = await getPost(slug);
} catch {
  return Astro.redirect('/blog');
}

if (!post) {
  return Astro.redirect('/blog');
}

const title = post.meta_title || post.title;
const description = post.meta_description || post.custom_excerpt || post.excerpt || '';

// Noindex stub/placeholder posts that shouldn't appear in search results
const NOINDEX_SLUGS = ['untitled', 'coming-soon'];
const NOINDEX_TITLES = ['untitled', 'coming soon'];
const shouldNoindex =
  NOINDEX_SLUGS.includes(slug) ||
  NOINDEX_TITLES.includes((post.title || '').toLowerCase().trim());

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const postImage = post.feature_image || 'https://hamilton-exteriors.com/og-default.jpg';

// Article structured data for SEO
const authorName = post.primary_author?.name || 'Hamilton Exteriors';
const estimatedWordCount = post.reading_time ? post.reading_time * 200 : undefined;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description,
  image: postImage,
  datePublished: post.published_at,
  dateModified: post.updated_at || post.published_at,
  url: canonicalUrl,
  ...(estimatedWordCount && { wordCount: estimatedWordCount }),
  author: authorName === 'Hamilton Exteriors'
    ? { '@type': 'Organization', '@id': 'https://hamilton-exteriors.com/#business', name: 'Hamilton Exteriors' }
    : {
        '@type': 'Person',
        name: authorName,
        jobTitle: 'Owner & Lead Contractor',
        worksFor: {
          '@type': 'Organization',
          '@id': 'https://hamilton-exteriors.com/#business',
          name: 'Hamilton Exteriors',
        },
      },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://hamilton-exteriors.com/#business',
    name: 'Hamilton Exteriors',
    url: 'https://hamilton-exteriors.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hamilton-exteriors.com/logo-schema.png',
      width: 600,
      height: 120,
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  isPartOf: { '@id': 'https://hamilton-exteriors.com/blog#collection' },
  ...(post.tags?.length && { keywords: post.tags.map((t: any) => t.name).join(', ') }),
  ...(post.primary_tag && { articleSection: post.primary_tag.name }),
};

// Fetch related posts (same primary tag, exclude current)
let relatedPosts: any[] = [];
try {
  const primaryTag = post.primary_tag?.slug || post.tags?.[0]?.slug;
  if (primaryTag) {
    const result = await getPosts({ tag: primaryTag, limit: 4 });
    relatedPosts = result.posts.filter((p: any) => p.slug !== slug).slice(0, 3);
  }
} catch { /* no related posts on error */ }
---

<Layout
  title={`${title} | Hamilton Exteriors`}
  description={description}
  image={postImage}
  type="article"
  jsonLd={shouldNoindex ? undefined : articleJsonLd}
  noindex={shouldNoindex}
>
  <meta slot="head" property="article:published_time" content={post.published_at} />
  {post.updated_at && <meta slot="head" property="article:modified_time" content={post.updated_at} />}
  {post.primary_tag && <meta slot="head" property="article:section" content={post.primary_tag.name} />}
  {post.tags?.map((t: any) => <meta slot="head" property="article:tag" content={t.name} />)}
  <AnnouncementBar />
  <Navbar />

  <!-- Reading progress bar (sticks below navbar) -->
  <div id="reading-progress-track" style="position: sticky; top: var(--navbar-height, 56px); z-index: 49; width: 100%; height: 3px; background: rgba(0,0,0,0.06);">
    <div id="reading-progress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Reading progress" style="height: 100%; background: var(--color-primary); width: 0%; transition: width 0.15s linear;"></div>
  </div>

  <article>
    {/* Hero */}
    <section class="blog-hero w-full" style="background-color: var(--color-heading);">
      <div class="mx-auto max-w-[800px] px-5">
        <a href="/blog" style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: var(--color-primary); text-decoration: none;" class="inline-flex items-center gap-2 mb-4 md:mb-6 hover:text-white transition-colors">
          &larr; Back to Blog
        </a>
        {post.tags?.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-3 md:mb-4">
            {post.tags.map((tag: any) => (
              <a href={`/blog?tag=${tag.slug}`} style="font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-primary); background: rgba(36, 99, 69, 0.15); padding: 4px 12px; border-radius: 4px; text-decoration: none;" class="hover:opacity-80 transition-opacity">
                {tag.name}
              </a>
            ))}
          </div>
        )}
        <h1 class="blog-hero-title" style="color: white;">
          {post.title}
        </h1>
        <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: rgba(255,255,255,0.65); margin-bottom: 8px;">
          By Marcus Hamilton, Owner &amp; Licensed Contractor (CSLB #1082377)
        </p>
        <div class="flex items-center gap-4 mb-3 md:mb-0" style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: rgba(255,255,255,0.65);">
          <time datetime={post.published_at}>{formatDate(post.published_at)}</time>
          {post.reading_time > 0 && (
            <>
              <span>&middot;</span>
              <span>{post.reading_time} min read</span>
            </>
          )}
        </div>
        {/* Share buttons */}
        <div class="flex items-center gap-2">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:!bg-white/25"
            aria-label="Share on X"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:!bg-white/25"
            aria-label="Share on Facebook"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:!bg-white/25"
            aria-label="Share on LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <button
            id="copy-link-btn"
            class="blog-share-btn hover:!bg-white/25"
            aria-label="Copy link"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
        </div>
      </div>
    </section>

    {/* Feature Image */}
    {post.feature_image && (
      <div class="w-full" style="background-color: var(--color-cream);">
        <div class="mx-auto max-w-[1000px]">
          <img
            src={post.feature_image}
            alt={post.title}
            class="w-full h-auto"
            style="max-height: 500px; object-fit: cover;"
            loading="eager"
            width="1000"
            height="500"
          />
        </div>
      </div>
    )}

    {/* Content */}
    <section class="w-full bg-white" style="padding: 60px 0 40px;">
      <div class="mx-auto max-w-[800px] px-5">
        <div id="article-content" class="ghost-content" set:html={post.html} />
      </div>
    </section>

    {/* Share bar at bottom of article */}
    <section class="w-full bg-white" style="padding: 0 0 60px;">
      <div class="mx-auto max-w-[800px] px-5">
        <div style="border-top: 1px solid var(--color-border); padding-top: 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
          <p style="font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 600; color: var(--color-charcoal);">Share this article</p>
          <div class="flex items-center gap-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              style="padding: 8px 16px; border-radius: 8px; background: var(--color-cream); font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 600; color: var(--color-charcoal); text-decoration: none; display: flex; align-items: center; gap: 6px;"
              class="hover:opacity-80 transition-opacity"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#333"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Post
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              style="padding: 8px 16px; border-radius: 8px; background: var(--color-cream); font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 600; color: var(--color-charcoal); text-decoration: none; display: flex; align-items: center; gap: 6px;"
              class="hover:opacity-80 transition-opacity"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Share
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              style="padding: 8px 16px; border-radius: 8px; background: var(--color-cream); font-family: var(--font-dm-sans); font-size: 0.8125rem; font-weight: 600; color: var(--color-charcoal); text-decoration: none; display: flex; align-items: center; gap: 6px;"
              class="hover:opacity-80 transition-opacity"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Share
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Related Posts */}
    {relatedPosts.length > 0 && (
      <section class="w-full" style="background: var(--color-cream); padding: 60px 0;">
        <div class="mx-auto max-w-[1200px] px-5">
          <h2 style="color: var(--color-heading); margin-bottom: 32px;">
            Related Articles
          </h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {relatedPosts.map((rp: any) => (
              <a href={`/blog/${rp.slug}`} class="group flex flex-col overflow-hidden rounded-[12px] bg-white transition-all hover:shadow-lg hover:translate-y-[-2px]" style="border: 1px solid var(--color-border);">
                {rp.feature_image ? (
                  <div class="aspect-[16/10] w-full overflow-hidden" style="background-color: var(--color-cream);">
                    <img src={rp.feature_image} alt={rp.title} class="h-full w-full object-cover transition-opacity group-hover:opacity-90" loading="lazy" width="400" height="250" />
                  </div>
                ) : (
                  <div class="aspect-[16/10] w-full bg-gradient-to-br from-footer to-primary flex items-center justify-center">
                    <span style="font-family: var(--font-oswald); font-size: 20px; color: rgba(255,255,255,0.3); text-transform: uppercase;">Hamilton</span>
                  </div>
                )}
                <div class="flex flex-1 flex-col p-4">
                  <h3 style="font-size: 1rem; color: var(--color-heading);" class="group-hover:text-primary transition-colors">
                    {rp.title}
                  </h3>
                  <div class="mt-auto pt-2" style="font-family: var(--font-dm-sans); font-size: 0.75rem; color: var(--color-muted);">
                    <time>{formatDate(rp.published_at)}</time>
                    {rp.reading_time > 0 && <span> &middot; {rp.reading_time} min</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <ContactUs />
  <Footer />
</Layout>

<script is:inline>
  // Set navbar height CSS variable for progress bar positioning
  var navbar = document.querySelector('.navbar');
  if (navbar) {
    var h = navbar.offsetHeight;
    document.documentElement.style.setProperty('--navbar-height', h + 'px');
  }

  // Reading progress bar — fills left to right below navbar
  var bar = document.getElementById('reading-progress');
  var article = document.getElementById('article-content');
  if (bar && article) {
    window.addEventListener('scroll', function() {
      var rect = article.getBoundingClientRect();
      var articleTop = rect.top + window.scrollY;
      var articleHeight = rect.height;
      var scrolled = window.scrollY - articleTop;
      var progress = Math.max(0, Math.min(100, (scrolled / (articleHeight - window.innerHeight)) * 100));
      bar.style.width = progress + '%';
      bar.setAttribute('aria-valuenow', String(Math.round(progress)));
    }, { passive: true });
  }

  // Copy link button
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).catch(function() {}).then(function() {
        copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>';
        setTimeout(function() {
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
        }, 2000);
      });
    });
  }
</script>

<style>
  .blog-hero {
    padding: 32px 0 28px;
  }
  @media (min-width: 768px) {
    .blog-hero {
      padding: 80px 0 60px;
    }
  }
  .blog-hero-title {
    font-size: clamp(26px, 6vw, 48px);
    margin-bottom: 12px;
  }
  @media (min-width: 768px) {
    .blog-hero-title {
      margin-bottom: 16px;
    }
  }
  .blog-share-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
  }
  @media (min-width: 768px) {
    .blog-share-btn {
      width: 44px;
      height: 44px;
    }
  }
</style>

<style is:global>
  .ghost-content {
    font-family: var(--font-dm-sans);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-charcoal);
  }
  .ghost-content h2 {
    font-family: var(--font-oswald);
    font-size: 1.75rem;
    line-height: 1.3;
    font-weight: 400;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 48px 0 16px;
  }
  .ghost-content h3 {
    font-family: var(--font-oswald);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 40px 0 12px;
  }
  .ghost-content h4 {
    font-family: var(--font-oswald);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-heading);
    text-transform: uppercase;
    margin: 32px 0 8px;
  }
  .ghost-content p {
    margin: 0 0 24px;
  }
  .ghost-content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ghost-content a:hover {
    color: var(--color-heading);
  }
  .ghost-content img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 32px 0;
  }
  .ghost-content blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 20px;
    margin: 32px 0;
    font-style: italic;
    color: var(--color-muted);
  }
  .ghost-content ul, .ghost-content ol {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  .ghost-content li {
    margin-bottom: 8px;
  }
  .ghost-content figure {
    margin: 32px 0;
  }
  .ghost-content figcaption {
    font-size: 0.875rem;
    color: var(--color-light);
    text-align: center;
    margin-top: 8px;
  }
  .ghost-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 32px 0;
    display: block;
    overflow-x: auto;
  }
  .ghost-content th, .ghost-content td {
    border: 1px solid var(--color-border);
    padding: 12px 16px;
    text-align: left;
  }
  .ghost-content th {
    background: var(--color-cream);
    font-weight: 600;
    color: var(--color-heading);
  }
  .ghost-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 48px 0;
  }
  .ghost-content pre {
    background: var(--color-cream);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    margin: 32px 0;
    font-size: 0.875rem;
  }
  .ghost-content code {
    background: var(--color-cream);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .ghost-content pre code {
    background: none;
    padding: 0;
  }
</style>
