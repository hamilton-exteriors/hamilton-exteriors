---
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import ContactUs from '../../components/ContactUs.astro';
import Footer from '../../components/Footer.astro';
import { getPost, getPosts, isGhostConfigured, formatDate, GHOST_ORIGIN } from '../../lib/ghost';
import { Image } from 'astro:assets';

const { slug } = Astro.params;

if (!slug || !isGhostConfigured()) {
  return Astro.redirect('/blog');
}

let post;
try {
  post = await getPost(slug);
} catch {
  return Astro.redirect('/blog');
}

if (!post) {
  return Astro.redirect('/blog');
}

// Strip duplicate brand suffix that Ghost CMS sometimes appends (e.g. "Title | Hamilton Exteriors | Hamilton Exteriors")
const rawTitle = post.meta_title || post.title;
const title = rawTitle.replace(/(\s*\|\s*Hamilton Exteriors){2,}/gi, ' | Hamilton Exteriors');
const rawDesc = post.meta_description || post.custom_excerpt || post.excerpt || '';
// Sanitize Unicode replacement characters — em-dashes and en-dashes from Ghost
// sometimes arrive as U+FFFD after encoding round-trips
const description = rawDesc
  .replace(/\ufffd/g, '\u2014')   // replacement char → em-dash (most common source)
  .replace(/\u00e2\u0080\u0093/g, '\u2013')  // mojibake en-dash
  .replace(/\u00e2\u0080\u0094/g, '\u2014'); // mojibake em-dash

// Noindex stub/placeholder posts that shouldn't appear in search results
const NOINDEX_SLUGS = ['untitled', 'coming-soon'];
const NOINDEX_TITLES = ['untitled', 'coming soon'];
const shouldNoindex =
  NOINDEX_SLUGS.some(s => slug.startsWith(s)) ||
  NOINDEX_TITLES.includes((post.title || '').toLowerCase().trim());

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';
const canonicalUrl = `${siteUrl}/blog/${slug}`;

// Ensure og:image is always absolute — social platforms need full URLs
// Rewrite Ghost Railway domain to canonical domain (proxied via middleware)
const rawImage = post.feature_image || '/og-default.jpg';
const postImage = rawImage.startsWith('http')
  ? rawImage.replace(GHOST_ORIGIN, siteUrl)
  : `${siteUrl}${rawImage}`;

// Ghost built-in image resizing: /content/images/size/w{width}/year/month/file.ext
// Returns a resized URL, or the original if it's not a Ghost content image
function ghostResize(url: string, width: number): string {
  return url.replace(/\/content\/images\/(?!size\/)/, `/content/images/size/w${width}/`);
}

// Build srcset string for Ghost images at multiple widths
function ghostSrcset(url: string, widths: number[]): string {
  if (!url.includes('/content/images/')) return '';
  return widths.map(w => `${ghostResize(url, w)} ${w}w`).join(', ');
}

// Article structured data for SEO
// Map Ghost admin user names to the real author for display + schema
const rawAuthorName = post.primary_author?.name || 'Hamilton Exteriors';
const authorName = ['Hamilton Admin', 'Hamilton Exteriors', 'hamilton'].includes(rawAuthorName)
  ? 'Alexander Hamilton Li'
  : rawAuthorName;

// Calculate actual word count from HTML content (not estimate)
const actualWordCount = post.html
  ? post.html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().split(' ').length
  : (post.reading_time ? post.reading_time * 200 : undefined);

// Build real keywords from tag names, filtering out slug-like values
const tagKeywords = post.tags
  ?.map((t: any) => t.name)
  .filter((n: string) => n && !/^[a-z0-9_-]+$/.test(n)) // skip raw slugs like "blog_post"
  .join(', ');

// Build human-readable articleSection from primary tag, with fallback
const rawSection = post.primary_tag?.name;
const articleSection = rawSection && !/^[a-z0-9_-]+$/.test(rawSection) ? rawSection : 'Home Improvement';

const articleJsonLd = {
  '@type': 'BlogPosting',
  '@id': `${canonicalUrl}#article`,
  name: post.title,
  headline: post.title,
  description,
  image: { '@type': 'ImageObject', url: postImage, contentUrl: postImage, width: 1200, height: 630 },
  datePublished: post.published_at || post.updated_at || new Date().toISOString(),
  dateModified: post.updated_at || post.published_at,
  url: canonicalUrl,
  ...(actualWordCount && { wordCount: actualWordCount }),
  inLanguage: 'en-US',
  author: {
    '@type': 'Person',
    '@id': 'https://hamilton-exteriors.com/#founder',
    name: authorName,
    jobTitle: 'Architect & General Contractor (CSLB #1082377)',
    url: 'https://hamilton-exteriors.com/about/alex-hamilton-li',
    sameAs: [
      'https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1082377',
      'https://www.linkedin.com/in/alexanderhamiltonli',
      'https://www.wikidata.org/wiki/Q139044457',
      'https://www.yelp.com/biz/hamilton-exteriors-castro-valley',
    ],
    worksFor: {
      '@type': 'Organization',
      '@id': 'https://hamilton-exteriors.com/#business',
      name: 'Hamilton Exteriors',
    },
    hasCredential: [{
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'California Contractor License #1082377',
      recognizedBy: { '@type': 'Organization', name: 'Contractors State License Board', url: 'https://www.cslb.ca.gov' },
    }],
    knowsAbout: ['Residential roofing', 'Fiber cement siding', 'Energy-efficient windows', 'ADU design and construction', 'Bay Area building codes'],
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://hamilton-exteriors.com/#business',
    name: 'Hamilton Exteriors',
    url: 'https://hamilton-exteriors.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hamilton-exteriors.com/logo-schema.png',
      width: 271,
      height: 112,
    },
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.ghost-content p:first-of-type', '.ghost-content h2', '.ghost-content h2 + p'],
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  isPartOf: { '@id': 'https://hamilton-exteriors.com/blog#collection' },
  ...(tagKeywords && { keywords: tagKeywords }),
  articleSection,
};

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Ground Up', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: post.title, item: canonicalUrl },
  ],
};

// HowTo rich results removed by Google Sept 2023 — schema omitted
let faqJsonLd: Record<string, unknown> | null = null;

// Extract H2 headings for table of contents
const tocHeadings: { id: string; text: string }[] = [];
if (post.html) {
  const h2Regex = /<h2[^>]*>(.*?)<\/h2>/gi;
  let match;
  while ((match = h2Regex.exec(post.html)) !== null) {
    const text = match[1].replace(/<[^>]+>/g, '').trim();
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    tocHeadings.push({ id, text });
  }
}

// Inject IDs into H2 tags in the HTML for jump links
let processedHtml = post.html || '';
if (tocHeadings.length > 0) {
  let tocIndex = 0;
  processedHtml = processedHtml.replace(/<h2([^>]*)>/gi, (_match: string, attrs: string) => {
    const heading = tocHeadings[tocIndex];
    tocIndex++;
    if (heading && !attrs.includes('id=')) {
      return `<h2${attrs} id="${heading.id}">`;
    }
    return `<h2${attrs}>`;
  });
}

// Wrap <table> elements in a scrollable container for mobile
processedHtml = processedHtml.replace(/<table([\s>])/gi, '<div class="table-wrap"><table$1');
processedHtml = processedHtml.replace(/<\/table>/gi, '</table></div>');

// Add decoding="async" and loading="lazy" to Ghost inline images that lack them
processedHtml = processedHtml.replace(/<img(?![^>]*decoding=)([^>]*?)>/gi, '<img decoding="async"$1>');
processedHtml = processedHtml.replace(/<img(?![^>]*loading=)([^>]*?)>/gi, '<img loading="lazy"$1>');

// Auto-wrap common citation patterns in <cite> tags for AI citability
// Matches: (Source: ...), (according to ...), (per ...) — case-insensitive
processedHtml = processedHtml.replace(
  /(?<!<cite[^>]*>)\((?:(Source:\s+|according to\s+|per\s+))([^)]+)\)/gi,
  '<cite>($1$2)</cite>'
);

// Add width/height to Ghost images missing dimensions — prevents CLS
processedHtml = processedHtml.replace(/<img(?![^>]*(?:width|height)=)([^>]*?)>/gi, '<img width="1000" height="563"$1>');

// Add srcset with Ghost built-in resizing for responsive inline images
processedHtml = processedHtml.replace(
  /<img([^>]*?)src="(https?:\/\/[^"]*\/content\/images\/(?!size\/)[^"]*)"([^>]*?)>/gi,
  (_match, before, src, after) => {
    if (before.includes('srcset') || after.includes('srcset')) return _match;
    const srcset = [400, 750, 1000, 1600].map(w => `${ghostResize(src, w)} ${w}w`).join(', ');
    return `<img${before}src="${ghostResize(src, 1000)}" srcset="${srcset}" sizes="(max-width: 600px) 400px, (max-width: 800px) 750px, 1000px"${after}>`;
  }
);

// Build FAQPage schema from question-format H2 headings (AI search engines extract Q&A)
const questionHeadings = tocHeadings.filter(h =>
  /^(what|how|why|when|where|who|which|can|do|does|is|are|should|will|could)\b/i.test(h.text) ||
  h.text.endsWith('?')
);
if (questionHeadings.length >= 2 && processedHtml) {
  const faqEntries = questionHeadings.map((heading, i) => {
    const startTag = `id="${heading.id}"`;
    const startIdx = processedHtml.indexOf(startTag);
    const nextQ = questionHeadings[i + 1];
    const endIdx = nextQ
      ? processedHtml.indexOf(`id="${nextQ.id}"`)
      : processedHtml.length;

    let answerText = '';
    if (startIdx > -1) {
      const section = processedHtml.slice(startIdx, endIdx);
      // Strip the heading itself and any partial tag fragments, then extract plain text
      const rawAnswer = section
        .replace(/^[^<]*>/, '')           // remove leading partial tag (id="..." ...>)
        .replace(/^[\s\S]*?<\/h2>/i, '')  // strip heading text + closing </h2> tag
        .replace(/<h2[^>]*>.*?<\/h2>/gi, '') // strip any remaining H2 tags
        .replace(/<[^>]+>/g, ' ')          // strip all HTML tags
        .replace(/\s+/g, ' ')
        .trim();
      // Truncate at sentence boundary to avoid cut-off answers in FAQ schema
      const truncated = rawAnswer.slice(0, 800);
      const lastSentenceEnd = Math.max(
        truncated.lastIndexOf('. '),
        truncated.lastIndexOf('.\u201D'),
        truncated.lastIndexOf('.)'),
      );
      answerText = lastSentenceEnd > 100 ? truncated.slice(0, lastSentenceEnd + 1) : truncated;
    }

    return {
      '@type': 'Question',
      name: heading.text.replace(/\?$/, '') + '?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: answerText || heading.text,
      },
    };
  }).filter(q => q.acceptedAnswer.text !== q.name && q.acceptedAnswer.text.length > 20);

  if (faqEntries.length >= 2) {
    faqJsonLd = {
      '@type': 'FAQPage',
      mainEntity: faqEntries,
    };
  }
}

// Fetch related posts (same primary tag, exclude current)
let relatedPosts: any[] = [];
try {
  const primaryTag = post.primary_tag?.slug || post.tags?.[0]?.slug;
  if (primaryTag) {
    const result = await getPosts({ tag: primaryTag, limit: 4 });
    relatedPosts = result.posts.filter((p: any) => p.slug !== slug).slice(0, 3);
  }
} catch { /* no related posts on error */ }

// Related Services — internal links based on post tags
const SERVICE_LINKS: Record<string, { href: string; label: string }[]> = {
  'roofing': [
    { href: '/roofing', label: 'Roofing Services' },
    { href: '/service-areas', label: 'Service Areas' },
  ],
  'siding': [
    { href: '/siding', label: 'Siding Services' },
    { href: '/service-areas', label: 'Service Areas' },
  ],
  'windows-doors': [
    { href: '/windows', label: 'Window Services' },
    { href: '/service-areas', label: 'Service Areas' },
  ],
  'adu-additions': [
    { href: '/adu', label: 'ADU Construction' },
    { href: '/additions', label: 'Home Additions' },
    { href: '/service-areas', label: 'Service Areas' },
  ],
};

const DEFAULT_SERVICE_LINKS = [
  { href: '/roofing', label: 'Roofing Services' },
  { href: '/service-areas', label: 'Service Areas' },
];

const tagSlugs = post.tags?.map((t: any) => t.slug) || [];
const matchedLinksMap = new Map<string, { href: string; label: string }>();
for (const tagSlug of tagSlugs) {
  const links = SERVICE_LINKS[tagSlug];
  if (links) {
    for (const link of links) {
      matchedLinksMap.set(link.href, link);
    }
  }
}
const serviceLinks = matchedLinksMap.size > 0
  ? Array.from(matchedLinksMap.values())
  : DEFAULT_SERVICE_LINKS;
---

<Layout
  title={title.replace(/\s*\|\s*Hamilton Exteriors$/i, '') + ' | Hamilton Exteriors'}
  description={description}
  image={postImage}
  type="article"
  jsonLd={shouldNoindex ? undefined : [articleJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])]}
  noindex={shouldNoindex}
>
  {post.feature_image?.includes('/content/images/') ? (
    <link slot="head" rel="preload" as="image" fetchpriority="high"
      href={ghostResize(post.feature_image, 1000)}
      imagesrcset={ghostSrcset(post.feature_image, [400, 750, 1000, 1600])}
      imagesizes="(max-width: 600px) 400px, (max-width: 1000px) 750px, 1000px"
    />
  ) : postImage ? (
    <link slot="head" rel="preload" href={postImage} as="image" fetchpriority="high" />
  ) : null}
  <meta slot="head" property="article:published_time" content={post.published_at} />
  {post.updated_at && <meta slot="head" property="article:modified_time" content={post.updated_at} />}
  {post.primary_tag && <meta slot="head" property="article:section" content={post.primary_tag.name} />}
  {post.tags?.map((t: any) => <meta slot="head" property="article:tag" content={t.name} />)}
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />

  <!-- Reading progress bar (sticks below navbar) -->
  <div id="reading-progress-track" class="sticky z-49 h-[3px] w-full bg-black/6" style="top: var(--navbar-height, 56px);">
    <div id="reading-progress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Reading progress" class="h-full bg-primary transition-[width] duration-150 ease-linear" style="width: 0%;"></div>
  </div>

  <article>
    {/* Hero */}
    <section class="blog-hero w-full bg-heading">
      <div class="mx-auto max-w-[800px] px-5">
        <a href="/blog" class="mb-4 inline-flex items-center gap-2 text-sm font-semibold text-primary no-underline transition-colors hover:text-white md:mb-6">
          &larr; Back to Ground Up
        </a>
        <h1 class="blog-hero-title text-white">
          {post.title}
        </h1>
        {post.tags?.filter((t: any) => !t.slug.startsWith('hash-')).length > 0 && (
          <div class="mt-3 mb-1 flex flex-wrap gap-2">
            {post.tags.filter((t: any) => !t.slug.startsWith('hash-')).map((tag: any) => {
              const displayName = { blog_post: 'Blog', cost_guide: 'Cost Guide', news: 'News', roofing: 'Roofing', siding: 'Siding', windows: 'Windows', adu: 'ADUs', tips: 'Tips' }[tag.slug] || tag.name.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
              return (
                <a href={`/blog?tag=${tag.slug}`} class="rounded-[4px] bg-white/10 px-3 py-1 font-satoshi text-[11px] font-bold tracking-[0.15em] text-white-70 uppercase no-underline transition-opacity hover:opacity-80">
                  {displayName}
                </a>
              );
            })}
          </div>
        )}
        <p class="mb-2 text-sm text-white-65">
          By <a href="/about/alex-hamilton-li" class="text-white-85 underline underline-offset-2">Alexander Hamilton Li</a>, Architect &amp; General Contractor (CSLB #1082377)
        </p>
        <div class="mb-3 flex flex-wrap items-center gap-4 text-sm text-white-65 md:mb-0">
          <time datetime={post.published_at}>{formatDate(post.published_at)}</time>
          {post.updated_at && post.updated_at !== post.published_at && (
            <>
              <span>&middot;</span>
              <span>Updated {formatDate(post.updated_at)}</span>
            </>
          )}
          {post.reading_time > 0 && (
            <>
              <span>&middot;</span>
              <span>{post.reading_time} min read</span>
            </>
          )}
        </div>
        {/* Share buttons */}
        <div class="flex items-center gap-2">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:bg-white/25!"
            aria-label="Share on X"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:bg-white/25!"
            aria-label="Share on Facebook"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share-btn hover:bg-white/25!"
            aria-label="Share on LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <button
            id="copy-link-btn"
            class="blog-share-btn hover:bg-white/25!"
            aria-label="Copy link"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
        </div>
      </div>
    </section>

    {/* Feature Image */}
    {post.feature_image && (() => {
      const filename = post.feature_image.split('/').pop() || '';
      const isUnsplash = filename.includes('unsplash');
      const isPexels = filename.includes('pexels');
      const credit = isUnsplash ? 'Unsplash' : isPexels ? 'Pexels' : '';
      return (
        <div class="w-full bg-cream">
          <div class="mx-auto max-w-[1000px]">
            <img
              src={ghostResize(post.feature_image, 1000)}
              srcset={ghostSrcset(post.feature_image, [400, 750, 1000, 1600])}
              sizes="(max-width: 600px) 400px, (max-width: 1000px) 750px, 1000px"
              alt={post.feature_image_alt || `Featured image for ${post.title}`}
              width="1000"
              height="563"
              class="h-auto max-h-[500px] w-full object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            {credit && (
              <p class="px-4 pt-1.5 text-right text-xs text-muted">
                Photo via {credit}
              </p>
            )}
          </div>
        </div>
      );
    })()}

    {/* Table of Contents */}
    {tocHeadings.length >= 3 && (
      <section class="w-full bg-white pt-10">
        <div class="mx-auto max-w-[800px] px-5">
          <nav aria-label="Table of contents" class="rounded-lg border border-gray-200 bg-cream p-5">
            <p class="mb-3 font-satoshi text-xs font-semibold tracking-wider text-gray-600 uppercase">In this article</p>
            <ol class="space-y-1.5">
              {tocHeadings.map((h) => (
                <li>
                  <a href={`#${h.id}`} class="font-dm-sans text-sm text-(--color-primary) transition-opacity hover:opacity-70">{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
      </section>
    )}

    {/* Content */}
    <section class="w-full bg-white pt-[60px] pb-10">
      <div class="mx-auto max-w-[800px] px-5">
        <div id="article-content" class="ghost-content" set:html={processedHtml} />
      </div>
    </section>

    {/* Share bar at bottom of article */}
    <section class="w-full bg-white pb-[60px]">
      <div class="mx-auto max-w-[800px] px-5">
        <div class="flex flex-wrap items-center justify-between gap-4 border-t border-border pt-6">
          <p class="text-sm font-semibold text-charcoal">Share this article</p>
          <div class="flex items-center gap-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 rounded-[4px] bg-cream px-4 py-2 text-[13px] font-semibold text-charcoal no-underline transition-opacity hover:opacity-80"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#333"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Post
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 rounded-[4px] bg-cream px-4 py-2 text-[13px] font-semibold text-charcoal no-underline transition-opacity hover:opacity-80"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Share
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 rounded-[4px] bg-cream px-4 py-2 text-[13px] font-semibold text-charcoal no-underline transition-opacity hover:opacity-80"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Share
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Related Posts */}
    {relatedPosts.length > 0 && (
      <section class="w-full bg-cream py-[60px]">
        <div class="mx-auto max-w-[1200px] px-5">
          <h2 class="mb-8 text-heading">
            Related Articles
          </h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {relatedPosts.map((rp: any) => (
              <a href={`/blog/${rp.slug}`} class="group flex flex-col overflow-hidden rounded-[4px] border border-border bg-white transition-all hover:opacity-95">
                {rp.feature_image ? (
                  <div class="aspect-16/10 w-full overflow-hidden bg-cream">
                    <img src={ghostResize(rp.feature_image, 400)} srcset={ghostSrcset(rp.feature_image, [300, 400, 600])} sizes="(max-width: 768px) 100vw, 33vw" alt={rp.title} class="size-full object-cover transition-opacity group-hover:opacity-90" loading="lazy" decoding="async" width="400" height="250" />
                  </div>
                ) : (
                  <div class="flex aspect-16/10 w-full items-center justify-center bg-linear-to-br from-footer to-primary">
                    <span class="font-hamilton-display text-xl text-white/30 uppercase">Hamilton</span>
                  </div>
                )}
                <div class="flex flex-1 flex-col p-4">
                  <h3 class="text-base text-heading transition-colors group-hover:text-primary">
                    {rp.title}
                  </h3>
                  <div class="mt-auto pt-2 text-xs text-muted">
                    <time>{formatDate(rp.published_at)}</time>
                    {rp.reading_time > 0 && <span> &middot; {rp.reading_time} min</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  {/* Related Services — internal links to service & city pages */}
  <section class="w-full bg-white py-10">
    <div class="mx-auto max-w-[800px] px-5">
      <p class="mb-4 font-satoshi text-xs font-bold tracking-[0.15em] text-muted uppercase">
        Explore Our Services
      </p>
      <div class="flex flex-wrap gap-2">
        {serviceLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-full border border-border bg-cream px-4 py-2 text-sm font-medium text-primary no-underline transition-opacity hover:opacity-80"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactUs />
  <Footer slot="footer" />
</Layout>

<script is:inline>
  // Set navbar height CSS variable for progress bar positioning
  var navbar = document.querySelector('.navbar');
  if (navbar) {
    var h = navbar.offsetHeight;
    document.documentElement.style.setProperty('--navbar-height', h + 'px');
  }

  // Reading progress bar — fills left to right below navbar
  var bar = document.getElementById('reading-progress');
  var article = document.getElementById('article-content');
  if (bar && article) {
    window.addEventListener('scroll', function() {
      var rect = article.getBoundingClientRect();
      var articleTop = rect.top + window.scrollY;
      var articleHeight = rect.height;
      var scrolled = window.scrollY - articleTop;
      var progress = Math.max(0, Math.min(100, (scrolled / (articleHeight - window.innerHeight)) * 100));
      bar.style.width = progress + '%';
      bar.setAttribute('aria-valuenow', String(Math.round(progress)));
    }, { passive: true });
  }

  // Copy link button
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).catch(function() {}).then(function() {
        copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>';
        setTimeout(function() {
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
        }, 2000);
      });
    });
  }
</script>

