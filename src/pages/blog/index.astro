  @media (min-width: 768px) { .blog-cta { padding: 48px 40px; } }
  .blog-cta__text {
    font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.65;
    color: var(--color-white-60); max-width: 500px;
    margin: 0 auto 24px;
  }
  .blog-cta__buttons {
    display: flex; flex-direction: column; gap: 10px;
    justify-content: center; align-items: center;
  }
  @media (min-width: 640px) { .blog-cta__buttons { flex-direction: row; } }
  .blog-cta__btn {
    display: inline-block; border-radius: 999px;
    padding: 16px 32px; font-family: var(--font-oswald);
    font-size: 0.875rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.04em; text-decoration: none;
    transition: opacity 0.15s;
  }
  .blog-cta__btn:hover { opacity: 0.9; }
  .blog-cta__btn--primary { background: var(--color-yellow); color: var(--color-heading); }
  .blog-cta__btn--secondary { border: 2px solid rgba(255,255,255,0.25); color: #fff; }

  /* ── Pagination ──────────────────────────────────────────────── */
  .blog-pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; margin-top: 48px;
  }
  .blog-pagination__btn {
    font-family: var(--font-dm-sans); font-size: 0.875rem; font-weight: 500;
    padding: 10px 20px; border: 1px solid var(--color-border);
    border-radius: 4px; color: var(--color-heading);
    text-decoration: none; transition: background 0.15s;
  }
  .blog-pagination__btn:hover { background: var(--color-cream); }
  .blog-pagination__label {
    font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted);
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .card, .chip, .search-wrap__input, .filter-panel { transition: none !important; }
  }
</style>

<script>
  // Mobile filter toggle
  const toggle = document.getElementById('filter-toggle');
  const panel = document.getElementById('filter-panel');
  if (toggle && panel) {
    toggle.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    const activeChip = panel.querySelector('.chip--active');
    const isTagFilter = activeChip && !activeChip.getAttribute('href')?.endsWith('/blog');
    if (isTagFilter) {
      panel.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
    }
  }

  // Blog search
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const dropdown = document.getElementById('search-dropdown');
  const cards = document.querySelectorAll('.card');
  const noResults = document.getElementById('search-no-results');
  const posts = (window as any).__blogPosts || [];

  if (searchInput && dropdown) {
    let debounce: ReturnType<typeof setTimeout>;
    let highlightIdx = -1;

    function renderDropdown(query: string) {
      if (!query) {
        dropdown!.classList.remove('open');
        dropdown!.innerHTML = '';
        cards.forEach(c => (c as HTMLElement).classList.remove('search-hidden'));
        noResults?.classList.remove('visible');
        return;
      }
      const q = query.toLowerCase();
      const matches = posts.filter((p: any) =>
        p.title.toLowerCase().includes(q) || (p.excerpt || '').toLowerCase().includes(q) ||
        p.tags.some((t: string) => t.toLowerCase().includes(q))
      ).slice(0, 6);

      dropdown!.innerHTML = matches.length === 0
        ? '<div class="no-match">No results</div>'
        : matches.map((p: any, i: number) => `<a href="/blog/${p.slug}" role="option" data-idx="${i}">${hl(p.title, query)}</a>`).join('');
      dropdown!.classList.add('open');

      let visible = 0;
      cards.forEach(c => {
        const el = c as HTMLElement;
        const t = el.dataset.searchTitle || '';
        const e = el.dataset.searchExcerpt || '';
        if (t.includes(q) || e.includes(q)) { el.classList.remove('search-hidden'); visible++; }
        else { el.classList.add('search-hidden'); }
      });
      noResults?.classList.toggle('visible', visible === 0 && matches.length === 0);
      highlightIdx = -1;
    }

    function hl(text: string, q: string): string {
      const i = text.toLowerCase().indexOf(q.toLowerCase());
      if (i === -1) return text;
      return text.slice(0, i) + '<mark style="background:var(--color-yellow);color:#1A1A1A;padding:0 2px;border-radius:2px">' + text.slice(i, i + q.length) + '</mark>' + text.slice(i + q.length);
    }

    searchInput.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(() => renderDropdown(searchInput.value.trim()), 120);
    });

    searchInput.addEventListener('keydown', (e) => {
      const items = dropdown!.querySelectorAll('a[role="option"]');
      if (!items.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); highlightIdx = Math.min(highlightIdx + 1, items.length - 1); items.forEach((el, i) => el.classList.toggle('highlighted', i === highlightIdx)); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); highlightIdx = Math.max(highlightIdx - 1, 0); items.forEach((el, i) => el.classList.toggle('highlighted', i === highlightIdx)); }
      else if (e.key === 'Enter' && highlightIdx >= 0) { e.preventDefault(); (items[highlightIdx] as HTMLAnchorElement).click(); }
      else if (e.key === 'Escape') { dropdown!.classList.remove('open'); searchInput.blur(); }
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.search-wrap')) dropdown!.classList.remove('open');
    });
  }
</script>
