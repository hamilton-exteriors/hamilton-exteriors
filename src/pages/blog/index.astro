  .inline-cta__link {
    font-family: var(--font-oswald);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-yellow);
    text-decoration: none;
    margin-left: auto;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .inline-cta__link:hover { opacity: 0.85; }

  /* ── Post Grid ───────────────────────────────────────────────── */
  .grid-posts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .grid-posts { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1280px) {
    .grid-posts { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Search hide ─────────────────────────────────────────────── */
  .card.search-hidden { display: none !important; }
  .search-no-results {
    display: none; text-align: center; padding: 48px 20px;
    font-family: var(--font-dm-sans); color: var(--color-muted);
  }
  .search-no-results.visible { display: block; }

  /* ── Empty state ─────────────────────────────────────────────── */
  .blog-empty {
    border: 2px dashed var(--color-border); border-radius: 4px;
