---
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import ContactUs from '../../components/ContactUs.astro';
import Footer from '../../components/Footer.astro';
import { getPosts, getTags, isGhostConfigured, formatDate, type GhostPost, type GhostPagination, type GhostTag } from '../../lib/ghost';
import { PHONE_DISPLAY, PHONE_HREF } from '../../lib/constants';

const tagParam = Astro.url.searchParams.get('tag') || undefined;
const tag = tagParam ? tagParam.replace(/[^a-zA-Z0-9-]/g, '') : undefined;
const page = Math.max(1, Math.floor(Number(Astro.url.searchParams.get('page') || '1')) || 1);

let posts: GhostPost[] = [];
let pagination: GhostPagination = { page: 1, limit: 12, pages: 1, total: 0 };
let tags: GhostTag[] = [];
let error: string | null = null;

if (isGhostConfigured()) {
  try {
    const result = await getPosts({ page, tag, limit: 12 });
    posts = result.posts;
    pagination = result.pagination;
    tags = await getTags();
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : 'Failed to load posts';
  }
} else {
  error = 'Ghost CMS is not configured. Set PUBLIC_GHOST_URL and PUBLIC_GHOST_CONTENT_API_KEY in your .env file.';
}

const featuredPost = !tag && page === 1 && posts.length > 0 ? posts[0] : null;
const gridPosts = featuredPost ? posts.slice(1) : posts;
const activeTag = tags.find((t: any) => t.slug === tag);
const pageTitle = activeTag ? `${activeTag.name} — Roofing & Exteriors Blog | Hamilton Exteriors` : 'Bay Area Roofing & Home Improvement Blog | Hamilton Exteriors';
const pageDesc = activeTag
  ? `Articles about ${activeTag.name.toLowerCase()} from Hamilton Exteriors — Bay Area's trusted contractor.`
  : 'Expert insights on ADU construction, roofing, siding, and home improvement in the Bay Area.';

const siteUrl = Astro.site?.origin || 'https://hamilton-exteriors.com';

// CollectionPage JSON-LD
const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDesc,
  url: `${siteUrl}/blog`,
  publisher: {
    '@type': 'Organization',
    name: 'Hamilton Exteriors',
  },
};
---

<Layout title={pageTitle} description={pageDesc} jsonLd={blogJsonLd}>
  <AnnouncementBar />
  <Navbar />

  <section class="w-full" style="background-color: var(--color-heading); padding: 56px 0 40px;">
    <div class="mx-auto max-w-[1200px] px-5">
      <h1 style="color: white; margin-bottom: 12px;">
        {activeTag ? activeTag.name : 'Roofing & Exteriors Blog'}
      </h1>
      <p style="font-family: var(--font-dm-sans); font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 540px;">
        {activeTag
          ? `${pagination.total} article${pagination.total !== 1 ? 's' : ''} about ${activeTag.name.toLowerCase()}`
          : 'Expert insights on roofing, siding, ADUs, and home improvement across the Bay Area.'}
      </p>
    </div>
  </section>

  {/* Tag Filter */}
  {tags.length > 0 && (
    <nav aria-label="Filter by topic" class="w-full bg-white sticky top-0 z-40" style="border-bottom: 1px solid var(--color-border);">
      <div class="mx-auto max-w-[1200px] px-5 py-3 flex gap-2 overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
        <a
          href="/blog"
          class:list={[
            'px-4 py-2.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap shrink-0',
            !tag ? 'text-white' : 'hover:opacity-80',
          ]}
          style={!tag ? 'background-color: var(--color-heading); font-family: var(--font-dm-sans);' : 'background-color: var(--color-cream); color: var(--color-heading); font-family: var(--font-dm-sans);'}
        >
          All Posts
        </a>
        {tags.map((t: any) => (
          <a
            href={`/blog?tag=${t.slug}`}
            class:list={[
              'px-4 py-2.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap shrink-0',
              tag === t.slug ? 'text-white' : 'hover:opacity-80',
            ]}
            style={tag === t.slug ? 'background-color: var(--color-heading); font-family: var(--font-dm-sans);' : 'background-color: var(--color-cream); color: var(--color-heading); font-family: var(--font-dm-sans);'}
          >
            {t.name} ({t.count})
          </a>
        ))}
      </div>
    </nav>
  )}

  <section class="w-full bg-white" style="padding: 56px 0 80px;">
    <div class="mx-auto max-w-[1200px] px-5">
      {error ? (
        <div class="rounded-[12px] border-2 border-dashed p-12 text-center" style="border-color: var(--color-border);">
          <p style="font-family: var(--font-dm-sans); font-size: 16px; color: var(--color-muted);">{error}</p>
        </div>
      ) : posts.length === 0 ? (
        <div class="rounded-[12px] border-2 border-dashed p-12 text-center" style="border-color: var(--color-border);">
          <p style="font-family: var(--font-dm-sans); font-size: 18px; color: var(--color-heading); font-weight: 600; margin-bottom: 8px;">
            {tag ? `No posts tagged "${activeTag?.name || tag}"` : 'No posts yet'}
          </p>
          <p style="font-family: var(--font-dm-sans); font-size: 16px; color: var(--color-muted); margin-bottom: 20px;">
            {tag ? 'Try a different category or browse all posts.' : 'Check back soon for expert insights on ADU construction and home improvement.'}
          </p>
          {tag && (
            <a href="/blog" style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-primary); text-decoration: underline;">
              View all posts
            </a>
          )}
        </div>
      ) : (
        <>
          {/* Featured Post (first post, full width, only on page 1 without tag filter) */}
          {featuredPost && (
            <a href={`/blog/${featuredPost.slug}`} class="group mb-12 grid grid-cols-1 md:grid-cols-2 gap-0 overflow-hidden rounded-[12px] transition-all hover:shadow-xl" style="border: 1px solid var(--color-border);">
              <div class="aspect-[16/10] md:aspect-auto overflow-hidden bg-gray-100">
                {featuredPost.feature_image ? (
                  <img
                    src={featuredPost.feature_image}
                    alt={featuredPost.title}
                    class="h-full w-full object-cover transition-opacity group-hover:opacity-90"
                    loading="eager"
                    width="600"
                    height="375"
                  />
                ) : (
                  <div class="h-full w-full bg-gradient-to-br from-footer to-primary flex items-center justify-center min-h-[200px]">
                    <span style="font-family: var(--font-oswald); font-size: 32px; color: rgba(255,255,255,0.2); text-transform: uppercase;">Hamilton</span>
                  </div>
                )}
              </div>
              <div class="flex flex-col justify-center p-5 md:p-10">
                <span style="font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 12px;">
                  Latest Article
                </span>
                {(featuredPost.primary_tag ?? featuredPost.tags?.[0]) && (
                  <span style="font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 8px;">
                    {(featuredPost.primary_tag ?? featuredPost.tags[0]).name}
                  </span>
                )}
                <h2 style="font-size: clamp(22px, 3vw, 32px); color: var(--color-heading); margin-bottom: 12px;" class="group-hover:text-primary transition-colors">
                  {featuredPost.title}
                </h2>
                {featuredPost.excerpt && (
                  <p style="font-family: var(--font-dm-sans); font-size: 16px; line-height: 26px; color: var(--color-muted); margin-bottom: 16px;" class="line-clamp-3">
                    {featuredPost.excerpt}
                  </p>
                )}
                <div class="flex items-center gap-3" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted);">
                  <time datetime={featuredPost.published_at}>{formatDate(featuredPost.published_at)}</time>
                  {featuredPost.reading_time > 0 && (
                    <>
                      <span>&middot;</span>
                      <span>{featuredPost.reading_time} min read</span>
                    </>
                  )}
                </div>
                <span style="font-family: var(--font-dm-sans); font-size: 14px; font-weight: 600; color: var(--color-primary); margin-top: 20px; display: inline-flex; align-items: center; gap: 6px;" class="group-hover:gap-3 transition-all">
                  Read Article <span>&rarr;</span>
                </span>
              </div>
            </a>
          )}

          {/* Post Grid */}
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {gridPosts.map((post: any) => (
              <a href={`/blog/${post.slug}`} class="blog-card group flex flex-col overflow-hidden rounded-[12px] transition-all hover:shadow-lg" style="border: 1px solid var(--color-border);">
                {post.feature_image ? (
                  <div class="aspect-[16/10] w-full overflow-hidden bg-gray-100">
                    <img
                      src={post.feature_image}
                      alt={post.title}
                      class="h-full w-full object-cover transition-opacity group-hover:opacity-90"
                      loading="lazy"
                      width="400"
                      height="250"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/10] w-full bg-gradient-to-br from-footer to-primary flex items-center justify-center">
                    <span style="font-family: var(--font-oswald); font-size: 24px; color: rgba(255,255,255,0.3); text-transform: uppercase;">Hamilton</span>
                  </div>
                )}
                <div class="flex flex-1 flex-col p-5">
                  {(post.primary_tag ?? post.tags?.[0]) && (
                    <span style="font-family: var(--font-satoshi); font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 8px;">
                      {(post.primary_tag ?? post.tags[0]).name}
                    </span>
                  )}
                  <h3 style="font-size: 1.125rem; margin-bottom: 8px;" class="group-hover:text-primary transition-colors">
                    {post.title}
                  </h3>
                  {post.excerpt && (
                    <p style="font-family: var(--font-dm-sans); font-size: 15px; line-height: 24px; color: var(--color-muted); margin-bottom: 12px;" class="line-clamp-3">
                      {post.excerpt}
                    </p>
                  )}
                  <div class="mt-auto flex items-center gap-3" style="font-family: var(--font-dm-sans); font-size: 0.8125rem; color: var(--color-muted);">
                    <time datetime={post.published_at}>{formatDate(post.published_at)}</time>
                    {post.reading_time > 0 && (
                      <>
                        <span>&middot;</span>
                        <span>{post.reading_time} min read</span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>

          {/* Newsletter CTA — between content and pagination */}
          {page === 1 && (
            <div class="mt-16 rounded-[12px] overflow-hidden" style="background-color: var(--color-heading);">
              <div class="px-8 py-12 md:px-12 md:py-14 text-center">
                <h3 style="color: white; margin-bottom: 8px;">
                  Get a Free Roof Inspection
                </h3>
                <p style="font-family: var(--font-dm-sans); font-size: 1rem; line-height: 1.7; color: rgba(255,255,255,0.65); margin-bottom: 24px; max-width: 500px; margin-left: auto; margin-right: auto;">
                  Bay Area homeowners — find out the true condition of your roof with a no-obligation inspection from our certified team.
                </p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                  <a
                    href="/buy"
                    class="inline-block rounded-full px-8 py-3.5 font-bold uppercase text-sm tracking-wide"
                    style="background-color: var(--color-yellow); color: var(--color-footer); font-family: var(--font-oswald);"
                  >
                    Scan Your Roof Online
                  </a>
                  <a
                    href={PHONE_HREF}
                    class="inline-block rounded-full px-8 py-3.5 font-bold uppercase text-sm tracking-wide border-2 border-white/30 text-white hover:bg-white/10 transition-colors"
                    style="font-family: var(--font-oswald);"
                  >
                    Call {PHONE_DISPLAY}
                  </a>
                </div>
              </div>
            </div>
          )}

          {/* Pagination */}
          {pagination.pages > 1 && (
            <div class="mt-12 flex items-center justify-center gap-3">
              {pagination.page > 1 && (
                <a
                  href={`/blog?page=${pagination.page - 1}${tag ? `&tag=${tag}` : ''}`}
                  rel="prev"
                  class="rounded-[8px] px-5 py-2.5 text-sm font-medium inline-flex items-center gap-2 transition-colors hover:bg-cream"
                  style="font-family: var(--font-dm-sans); border: 1px solid var(--color-border); color: var(--color-heading);"
                >
                  &larr; Previous
                </a>
              )}
              <span style="font-family: var(--font-dm-sans); font-size: 0.875rem; color: var(--color-muted);">
                Page {pagination.page} of {pagination.pages}
              </span>
              {pagination.page < pagination.pages && (
                <a
                  href={`/blog?page=${pagination.page + 1}${tag ? `&tag=${tag}` : ''}`}
                  rel="next"
                  class="rounded-[8px] px-5 py-2.5 text-sm font-medium inline-flex items-center gap-2 transition-colors hover:bg-cream"
                  style="font-family: var(--font-dm-sans); border: 1px solid var(--color-border); color: var(--color-heading);"
                >
                  Next &rarr;
                </a>
              )}
            </div>
          )}
        </>
      )}
    </div>
  </section>

  <ContactUs />
  <Footer />
</Layout>

<style>
  /* Hide scrollbar on tag filter strip */
  section::-webkit-scrollbar { display: none; }

  /* Blog card hover — lift + border shift */
  .blog-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .blog-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary) !important;
  }
</style>
