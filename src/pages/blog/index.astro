  .card__cta {
    font-family: var(--font-dm-sans); font-size: 0.875rem;
    font-weight: 600; color: var(--color-primary);
    margin-top: 16px;
    text-decoration: underline; text-underline-offset: 3px;
  }

  /* ── Inline CTA ───────────────────────────────────────────────── */
  .inline-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    padding: 14px 20px;
