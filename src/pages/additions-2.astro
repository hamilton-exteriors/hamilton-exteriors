---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoSlider from '../components/LogoSlider.astro';
import Reviews from '../components/Reviews.astro';
import ReviewLogos from '../components/ReviewLogos.astro';
import Difference from '../components/Difference.astro';
import Projects from '../components/Projects.astro';
import CTA from '../components/CTA.astro';
import Financing from '../components/Financing.astro';
import FAQ from '../components/FAQ.astro';
import ContactUs from '../components/ContactUs.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Room Additions',
    description: 'Add bedrooms, bathrooms, or living areas that integrate seamlessly with your existing floor plan',
  },
  {
    title: 'Second Story Additions',
    description: 'Expand upward to maximize your lot space without sacrificing your yard',
  },
  {
    title: 'Kitchen Extensions',
    description: 'Create the open, spacious kitchen you have always wanted with a bump-out or full addition',
  },
  {
    title: 'Sunrooms & Enclosed Patios',
    description: 'Enjoy natural light year-round with a beautiful enclosed living space',
  },
];
---

<Layout
  title="Home Additions Across the San Francisco Bay Area | Design & Construction Experts | Hamilton Exteriors"
  description="Hamilton Exteriors builds quality home extensions in Castro Valley, CA."
  includeMapbox
>
  <AnnouncementBar />
  <Navbar />
  <Hero
    formTitle="Get a FREE Consultaion"
    headline="Quality Home Extensions in Castro Valley"
    badges={[
      'Licensed Bonded & Insured',
      'Start with $0 Down',
      '50 year Warranty',
      'Increase Property Value',
    ]}
    ctaText="Get A FREE Estimate Now!"
    ctaHref="/quote-calculator"
  />
  <LogoSlider />
  <Reviews />

  <!-- ─── Extensions Section ────────────────────────────────────────── -->
  <section class="w-full bg-cream py-20">
    <div class="mx-auto max-w-[1294px] px-5">
      <div class="mb-12 text-center">
        <h2>Home Extension Services</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {services.map((service) => (
          <div class="rounded-2xl border border-border/40 bg-white p-8 transition-shadow hover:shadow-lg">
            <h3 class="mb-3 font-fraunces text-[24px] font-600 text-charcoal">{service.title}</h3>
            <p class="font-dm-sans text-[17px] leading-relaxed text-input">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
  <ReviewLogos />
  <Difference />
  <Projects showFilters={false} />
  <Financing scheduleHref="/quote-calculator" />
  <FAQ />
  <ContactUs />
  <Footer />
</Layout>
