---
import Layout from '../../layouts/Layout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactUs from '../../components/ContactUs.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../../lib/constants';

const siteUrl = 'https://hamilton-exteriors.com';
const pageUrl = `${siteUrl}/about/alex-hamilton-li`;

const personSchema = {
  '@type': 'ProfilePage',
  '@id': `${pageUrl}#profilepage`,
  url: pageUrl,
  name: 'Alex Hamilton Li — Architect & General Contractor',
  isPartOf: { '@id': `${siteUrl}/#website` },
  mainEntity: {
    '@type': 'Person',
    '@id': `${siteUrl}/#founder`,
    name: 'Alexander Hamilton Li',
    jobTitle: 'Architect & General Contractor',
    url: pageUrl,
    image: `${siteUrl}/images/alex-hamilton-li.jpg`,
    description: 'Founder and owner of Hamilton Exteriors, a licensed Bay Area design-build contractor specializing in roofing, siding, windows, ADUs, and custom homes.',
    sameAs: [
      'https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1078806',
      'https://www.linkedin.com/in/alexanderhamiltonli',
    ],
    worksFor: {
      '@type': 'Organization',
      '@id': `${siteUrl}/#business`,
      name: 'Hamilton Exteriors',
    },
    hasCredential: [
      {
        '@type': 'EducationalOccupationalCredential',
        credentialCategory: 'license',
        name: 'California Contractor License #1078806',
        recognizedBy: { '@type': 'Organization', name: 'Contractors State License Board', url: 'https://www.cslb.ca.gov' },
      },
      { '@type': 'EducationalOccupationalCredential', credentialCategory: 'certification', name: 'GAF Master Elite Contractor' },
      { '@type': 'EducationalOccupationalCredential', credentialCategory: 'certification', name: 'Owens Corning Preferred Contractor' },
      { '@type': 'EducationalOccupationalCredential', credentialCategory: 'certification', name: 'CertainTeed ShingleMaster' },
      { '@type': 'EducationalOccupationalCredential', credentialCategory: 'certification', name: 'James Hardie Elite Preferred Installer' },
    ],
    knowsAbout: [
      { '@type': 'Thing', name: 'Residential roofing', sameAs: 'https://en.wikipedia.org/wiki/Domestic_roof_construction' },
      { '@type': 'Thing', name: 'Commercial roofing' },
      { '@type': 'Thing', name: 'Fiber cement siding', sameAs: 'https://en.wikipedia.org/wiki/Fibre_cement' },
      { '@type': 'Thing', name: 'James Hardie siding installation' },
      { '@type': 'Thing', name: 'Energy-efficient window replacement', sameAs: 'https://en.wikipedia.org/wiki/Energy-efficient_window' },
      { '@type': 'Thing', name: 'ADU design and construction', sameAs: 'https://en.wikipedia.org/wiki/Accessory_dwelling_unit' },
      { '@type': 'Thing', name: 'Custom home building', sameAs: 'https://en.wikipedia.org/wiki/Custom_home' },
      { '@type': 'Thing', name: 'Bay Area building codes' },
      { '@type': 'Thing', name: 'California Title 24 compliance' },
      { '@type': 'Thing', name: 'WUI fire zone requirements' },
    ],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Castro Valley',
      addressRegion: 'CA',
      postalCode: '94546',
      addressCountry: 'US',
    },
  },
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Alex Hamilton Li', item: pageUrl },
  ],
};
---

<Layout
  title="Alex Hamilton Li — Architect & GC | Hamilton Exteriors"
  description="Founder of Hamilton Exteriors. Licensed architect & general contractor (CSLB #1078806) serving the Bay Area since 2018. 500+ projects."
  jsonLd={[breadcrumbSchema, personSchema]}
>
  <AnnouncementBar slot="header" />
  <Navbar slot="header" />

  <main>
    <!-- Hero section -->
    <section class="bg-primary-dark py-16 pb-[60px]">
      <div class="mx-auto max-w-4xl px-5">
        <div class="flex flex-col items-center gap-8 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0">
            <img
              src="/images/alex-hamilton-li.jpg"
              alt="Alex Hamilton Li with a Hamilton Exteriors customer in front of a completed Bay Area project"
              width="280"
              height="280"
              class="h-[220px] w-[220px] rounded-lg object-cover shadow-lg md:h-[280px] md:w-[280px]"
              style="object-position: center top;"
              loading="eager"
            />
          </div>
          <div class="text-center md:text-left">
            <p class="mb-3 text-[13px] tracking-widest text-white-60 uppercase">
              About the Founder
            </p>
            <h1 class="mb-4 text-[clamp(2rem,6vw,3rem)] leading-[1.2] text-white">
              Alexander Hamilton Li
            </h1>
            <p class="mb-0 text-lg leading-[1.6] text-white-85">
              Architect &amp; General Contractor &bull; CSLB #1078806 &bull; Castro Valley, CA
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Background + Stats -->
    <section class="py-[60px]">
      <div class="mx-auto max-w-3xl px-5 text-base leading-[1.85] text-charcoal">

        <h2 class="mb-4 text-2xl">Background</h2>
        <p class="mb-6">
          I founded Hamilton Exteriors in 2018 in Castro Valley, California, with a simple idea: Bay Area homeowners deserve a contractor who brings an architect's eye to every project. Before starting the company, I worked in architecture and construction management, which gave me a deep understanding of both the design and execution sides of building.
        </p>
        <p class="mb-8">
          Today, Hamilton Exteriors is a full-service design-build contractor serving homeowners across Alameda, Contra Costa, Marin, Napa, San Mateo, and Santa Clara counties. We have completed more than 500 projects — from single-day roof repairs in Oakland to ground-up custom homes in Palo Alto.
        </p>

        <!-- Stats grid — moved up to break the text wall early -->
        <div class="mb-6 grid grid-cols-2 gap-5 sm:grid-cols-4">
          <div class="rounded-lg bg-cream p-5 text-center">
            <div class="font-hamilton-display text-[2rem] text-primary-dark">500+</div>
            <div class="font-satoshi text-[13px] text-muted">Projects Completed</div>
          </div>
          <div class="rounded-lg bg-cream p-5 text-center">
            <div class="font-hamilton-display text-[2rem] text-primary-dark">4.8</div>
            <div class="font-satoshi text-[13px] text-muted">Google Rating</div>
          </div>
          <div class="rounded-lg bg-cream p-5 text-center">
            <div class="font-hamilton-display text-[2rem] text-primary-dark">2018</div>
            <div class="font-satoshi text-[13px] text-muted">Founded</div>
          </div>
          <div class="rounded-lg bg-cream p-5 text-center">
            <div class="font-hamilton-display text-[2rem] text-primary-dark">6</div>
            <div class="font-satoshi text-[13px] text-muted">Counties Served</div>
          </div>
        </div>

      </div>
    </section>

    <!-- Credentials — cream background for visual contrast -->
    <section class="bg-cream py-[60px]">
      <div class="mx-auto max-w-3xl px-5 text-base leading-[1.85] text-charcoal">

        <h2 class="mb-4 text-2xl">Credentials &amp; Certifications</h2>
        <div class="rounded-lg border border-charcoal/10 bg-white p-6 shadow-sm">
          <ul class="mb-0 space-y-3 pl-6">
            <li>
              <strong>CSLB License #1078806</strong> — California Contractors State License Board.
              <a href="https://www.cslb.ca.gov/onlineservices/checklicenseII/LicenseDetail.aspx?LicNum=1078806" target="_blank" rel="noopener noreferrer" class="text-primary">Verify on CSLB.ca.gov</a>
            </li>
            <li><strong>GAF Master Elite Contractor</strong> — Only 2% of roofers in the country qualify. Factory-certified installer with enhanced manufacturer warranty eligibility.</li>
            <li><strong>Owens Corning Preferred Contractor</strong> — Platinum-level certification for roofing excellence.</li>
            <li><strong>CertainTeed ShingleMaster</strong> — Advanced certification in shingle roofing systems.</li>
            <li><strong>James Hardie Elite Preferred Contractor</strong> — Certified installer of James Hardie fiber cement siding.</li>
            <li><strong>Licensed, Bonded &amp; Insured</strong> — General liability and workers' compensation coverage on every project.</li>
          </ul>
        </div>

      </div>
    </section>

    <!-- What I Do -->
    <section class="py-[60px]">
      <div class="mx-auto max-w-3xl px-5 text-base leading-[1.85] text-charcoal">

        <h2 class="mb-4 text-2xl">What I Do at Hamilton Exteriors</h2>
        <p class="mb-6">
          I oversee every project from the initial inspection through final walkthrough. My background in architecture means I think about how materials, design, and craftsmanship come together — not just whether the shingles are nailed straight. Every estimate I write is fully itemized line by line, and every project gets a dedicated project manager who reports to me directly.
        </p>
        <p class="mb-6">
          Our services include roofing (asphalt, metal, tile, and flat), James Hardie fiber cement siding, energy-efficient window replacements, ADU construction, home additions, and custom homes. We handle all Bay Area building permits and know the codes for every jurisdiction we serve.
        </p>

      </div>
    </section>

    <!-- Bay Area Expertise — cream background -->
    <section class="bg-cream py-[60px]">
      <div class="mx-auto max-w-3xl px-5 text-base leading-[1.85] text-charcoal">

        <h2 class="mb-4 text-2xl">What Makes Bay Area Roofing and Exteriors Different?</h2>
        <p class="mb-6">
          The Bay Area has unique building challenges that national contractors often miss. Wildland-Urban Interface fire zones in the Oakland Hills, Berkeley Hills, and Marin require specific Class A fire-rated materials and installation methods that comply with California Chapter 7A standards. Coastal fog in San Francisco and Pacifica accelerates roof wear differently than the inland heat of Walnut Creek and San Ramon — salt-laden marine air corrodes exposed flashing and can halve the life of untreated metal components. Older housing stock in Oakland — roughly 60% built before 1960, according to the U.S. Census Bureau American Community Survey — often needs structural reinforcement before new materials go on. Every Bay Area jurisdiction also has its own permitting requirements, from San Francisco's historic district overlays to Marin County's defensible space inspections. I have worked in all six counties we serve, and our crews know how to handle every condition.
        </p>

      </div>
    </section>

    <!-- Get in Touch -->
    <section class="py-[60px]">
      <div class="mx-auto max-w-3xl px-5 text-base leading-[1.85] text-charcoal">

        <h2 class="mb-4 text-2xl">Get in Touch</h2>
        <p class="mb-2">
          Have a question about your home exterior project? I am happy to talk through it.
        </p>
        <p class="mb-0">
          <strong>Phone:</strong> <a href={PHONE_HREF} class="text-primary">{PHONE_DISPLAY}</a><br />
          <strong>Email:</strong> <a href="mailto:support@hamilton-exteriors.com" class="text-primary">support@hamilton-exteriors.com</a><br />
          <strong>Office:</strong> 21634 Redwood Rd Unit F, Castro Valley, CA 94546
        </p>

      </div>
    </section>
  </main>

  <ContactUs />
  <Footer slot="footer" />
</Layout>
