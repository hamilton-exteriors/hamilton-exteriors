---
import Layout from '../layouts/Layout.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../lib/constants';
---

<Layout title="Page Not Found | Hamilton Exteriors" description="The page you're looking for doesn't exist." noindex>
  <main class="flex min-h-[70vh] items-center justify-center px-6">
    <div class="max-w-lg text-center">
      <p class="font-oswald text-[8rem] leading-none font-black text-primary">
        404
      </p>
      <h1 class="mt-4 mb-3 text-2xl font-bold text-charcoal">
        Page Not Found
      </h1>
      <p class="mb-8 text-base text-muted">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-block rounded-full bg-primary px-8 py-3.5 text-sm font-bold tracking-wide text-white uppercase"
        >
          Back to Home
        </a>
        <a
          href="/buy"
          class="inline-block rounded-full border-2 border-primary px-8 py-3.5 text-sm font-bold tracking-wide text-primary uppercase"
        >
          Get Your Free Quote
        </a>
      </div>
      <p class="mt-12 text-sm text-light">
        Need help? Call us at <a href={PHONE_HREF} class="text-primary underline">{PHONE_DISPLAY}</a>
      </p>
    </div>
  </main>
</Layout>
