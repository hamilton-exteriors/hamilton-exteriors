---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Hamilton Exteriors" description="The page you're looking for doesn't exist.">
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <p class="text-[8rem] leading-none font-black" style="font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif; color: var(--color-primary);">
        404
      </p>
      <h1 class="text-2xl font-bold mt-4 mb-3" style="font-family: 'DM Sans', sans-serif; color: var(--color-charcoal);">
        Page Not Found
      </h1>
      <p class="text-base mb-8" style="font-family: 'DM Sans', sans-serif; color: rgb(120,120,120);">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-block rounded-full px-8 py-3.5 font-bold uppercase text-white text-sm tracking-wide"
          style="background-color: var(--color-primary); font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif;"
        >
          Back to Home
        </a>
        <a
          href="/buy"
          class="inline-block rounded-full px-8 py-3.5 font-bold uppercase text-sm tracking-wide border-2"
          style="border-color: var(--color-primary); color: var(--color-primary); font-family: 'THE BOLD FONT (FREE VERSION)', 'Oswald', sans-serif;"
        >
          Get a Roof Quote
        </a>
      </div>
      <p class="mt-12 text-sm" style="font-family: 'DM Sans', sans-serif; color: rgb(150,150,150);">
        Need help? Call us at <a href="tel:6509773351" class="underline" style="color: var(--color-primary);">(650) 977-3351</a>
      </p>
    </div>
  </main>
</Layout>
