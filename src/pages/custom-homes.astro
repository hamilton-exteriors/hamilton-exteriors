---
import Layout from '../layouts/Layout.astro';
import ServicePage from '../components/ServicePage.astro';
import { data } from '../data/services/custom-homes';

const siteUrl = 'https://hamilton-exteriors.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Custom Homes', item: `${siteUrl}/custom-homes` },
  ],
};
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/custom-homes#service`,
  name: 'Custom Homes',
  description: 'Full-service custom home builder in the Bay Area. Ground-up construction, design, architecture, engineering, permitting, and construction under one roof.',
  url: `${siteUrl}/custom-homes`,
  serviceType: ['Custom Home Construction', 'Ground-Up Construction', 'Architectural Design'],
  provider: { '@type': 'GeneralContractor', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'County', name: 'Alameda County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Contra Costa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Marin County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Napa County', containedInPlace: { '@type': 'State', name: 'California' } },
    { '@type': 'County', name: 'Santa Clara County', containedInPlace: { '@type': 'State', name: 'California' } },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '350',
    highPrice: '800',
    unitText: 'per square foot',
    description: 'Custom home cost depends on finishes, complexity, and lot conditions',
  },
};
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/custom-homes#webpage`,
  url: `${siteUrl}/custom-homes`,
  name: data.title,
  description: data.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/custom-homes#service` },
  inLanguage: 'en-US',
};
---

<Layout title={data.title} description={data.description} includeMapbox preloadHero heroImage={data.hero.heroImage} jsonLd={[breadcrumbJsonLd, webPageJsonLd, serviceJsonLd]}>
  <ServicePage data={data} />
</Layout>
